0 PIN_FLD_NEXT_BILL_T  TSTAMP [0] (0) <null>
0 PIN_FLD_PENDING_RECV DECIMAL [0] 0.000000
0 PIN_FLD_PAYINFO_OBJ    POID [0] $PIN_CONF_DB_NO /payinfo 1 0
0 PIN_FLD_PAY_TYPE      ENUM [0] 0
</PCM_OP> 

# item object for the top level account
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /item/usage 1 0
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_BILL_OBJ       POID [0] $PIN_CONF_DB_NO /bill 1 0
0 PIN_FLD_BILLINFO_OBJ	 POID [0] $PIN_CONF_DB_NO /billinfo 1 0
0 PIN_FLD_BAL_GRP_OBJ    POID [0] $PIN_CONF_DB_NO /balance_group 1 0
0 PIN_FLD_NAME            STR [0] "top item obj"
0 PIN_FLD_GL_SEGMENT      STR [0] "ROOT"
0 PIN_FLD_STATUS         ENUM [0] 0
</PCM_OP> 

#=============================================================================#

# create top /service/pcm_client object
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /service/pcm_client 1 0
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_BAL_GRP_OBJ    POID [0] $PIN_CONF_DB_NO /balance_group 1 0
0 PIN_FLD_LOGIN           STR [0] "root.$PIN_CONF_DB_NO"
0 PIN_FLD_NAME            STR [0] "top /service/pcm_client obj"
0 PIN_FLD_PASSWD          STR [0] "md5|5f4dcc3b5aa765d61d8327deb882cf99"
</PCM_OP> 

# Prohibited args for /service/pcm_client using WFLDS.
<PCM_OP $PIN_OPNAME=PCM_OP_WRITE_FLDS; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /service/pcm_client 1 0
0 PIN_FLD_STATUS         ENUM [0] 10100
0 PIN_FLD_CLOSE_WHEN_T TSTAMP [0] (0) <null>
0 PIN_FLD_STATUS_FLAGS    INT [0] 0
</PCM_OP> 


#=============================================================================#

