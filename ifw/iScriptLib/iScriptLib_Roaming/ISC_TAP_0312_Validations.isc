  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TrackingCustomerIdentification", "362", "31", "Mandatory item Customer Identifier missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","", "Mandatory item Customer Identifier missing within group");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateTrackingCustomerIdentification for each element of Tracking CustomerId List.
 ******************************************************************************************************************************/
 
function validateTrackingCustomerIdList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",299";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "TrackingCustomerIdentification";
  Long TrackingCustomerIdListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < TrackingCustomerIdListEntries; i = i + 1 )
  {
    validateTrackingCustomerIdentification ( myContext, nMyIndices, "TrackingCustomerIdentification", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate TrackingCustomerInformation. It will raise error code 30 for TrackingCustomerInformation.
 ******************************************************************************************************************************/
 
function validateTrackingCustomerInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",298";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "trackingCustomerIdList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackingCustomerIdList ( myContext, nMyIndices, "trackingCustomerIdList", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TrackingCustomerInformation", "298", "30", "Mandatory group Tracking Customer Identification missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group Tracking Customer Identification missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "trackingCustomerHomeIdList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackingCustomerHomeIdList ( myContext, nMyIndices, "trackingCustomerHomeIdList", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingCustomerLocList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackingCustomerLocList ( myContext, nMyIndices, "trackingCustomerLocList", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingCustomerEquipment";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackingCustomerEquipment ( myContext, nMyIndices, "trackingCustomerEquipment", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}
 
function validateCallReference ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",45";

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate RecEntityCode, GprsNetworkLocation, CauseForTermination. It will raise error code 20, 100, 101,
 * 102, 103, 104, 105 for RecEntityCode, error code 31 for GprsNetworkLocation and error code 20 for CauseForTermination.
 ******************************************************************************************************************************/
 
function validateRecEntityCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",184";
  Long i;
 

  if( strStartsWith(parentContext, "HEADER.networkInfo") == true and 
         validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"10000" , "0", "INTEGER_TYPE") == true )
  {
    rollbackReason = "NetworkInfo," + errorContext + ",20" + ":" + NetworkInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "RecEntityCode", "184", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "184", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
    edrLongEx( myContext, indices, nParentIndices ) = -1;
    return;
  }
  lastCode = edrLongEx( myContext, indices, nParentIndices );

  if ( strStartsWith(parentContext, "HEADER") == true )
  { 
    if( recEntityCode[ lastCode ] == lastCode )
    {
      recEntityCodeIsDuplicate = true;
    }
    else
    {    
      recEntityCode[ lastCode ] = lastCode;
    }    
  }
  else
  {
    if(validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"10000" , "0", "INTEGER_TYPE") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RecEntityCode", "184", "11", "Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", "184", "0", "-1", "-1", "","Syntax Error");
      edrSetIsValidDetail(false);
      return;
   }
      
    if( recEntityCode[ lastCode ] != lastCode )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RecEntityCode", "184", "100", "Specified recording entity code not defined in the Recording Entity Information");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1", "","Specified recording entity code not defined in the Recording Entity Information");
      edrSetIsValidDetail(false);
    }

    if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
      lastRecEntityType = recEntityType[edrLongEx(myContext, indices, nParentIndices)];
      recEntityTypeArray[recEntityTypeIndx] = lastRecEntityType;
      recEntityTypeIndx = recEntityTypeIndx + 1;
      
      if( recEntityTypeIndx > 1 )
      {
        for( i = 0; i < recEntityTypeIndx; i = i + 1 )
        {
          if( lastRecEntityType == 3 and lastRecEntityType == recEntityTypeArray[i] )
          {
	    objTag = "1,3,14,117,118";
            // FieldName, AppId, ErrorCode,ErrorDescription
            edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Network Location", "118", "31",
                                                      "More than one Recording Entity Code is of type GGSN present within group");
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", objTag, "0", "-1", "-1", "",
                                                      "More than one Recording Entity Code is of type GGSN present within group");
            edrSetIsValidDetail(false);
            i = recEntityTypeIndx;    // Once Error is logged , need to come out from for loop
          }
        }
      }
      if( lastRecEntityType == 6 and causeForTermIsPresent == true )
      {
        if( lastCauseForTerm != 4 and lastCauseForTerm != 20 )
        {
          if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
          {
            objTag = "1,3,9,147,58";
          }
          else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
          {
            objTag = "1,3,10,153,58";
          }
          else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
          {
            objTag = "1,3,14,114,58";
          }

          // FieldName, AppId, ErrorCode,ErrorDescription
          edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Cause For Termination", "58", "20", "Value Out Of Range");
          edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", objTag, "0", "-1", "-1", "","Value Out Of Range");
          edrSetIsValidDetail(false);
        }
      }
    }  

    if ( ( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true or 
             strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or
               strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true ) and     
                 validateMsisdnSE(recEntityId[ lastCode ]) == true and 
                  (strSearchRegExpr(recEntityId[lastCode], "[^A-Za-z0-9\.]") >= 0 ) and
                     recEntityType[ lastCode ] == 1 ) 
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Recording Entity Code", "184", "101", "Entity Code refers to MSC (Recording Entity Type 1) and syntax of the referenced Recording Entity Identification does not conform to MSISDN (3GPP TS 23.003) or Signalling Point Code (ITU-T Q.701)");
    }    

      
    if ( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true and     
          validateMsisdnSE(recEntityId[ lastCode ]) == true  and
              recEntityType[ lastCode ] == 2 )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "102", "Entity Code refers to SMSC (Recording Entity Type 2) and syntax of the referenced Recording Entity Identification does not conform to MSISDN (3GPP TS 23.003)");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "102", errorContext, "0", "-1", "-1","", "Entity Code refers to SMSC (Recording Entity Type 2) and syntax of the referenced Recording Entity Identification does not conform to MSISDN (3GPP TS 23.003)");
      edrSetIsValidDetail(false);
    }    

    if ( strStartsWith(parentContext, "DETAIL.locationService") == true and     
          ( validateMsisdnSE(recEntityId[ lastCode ]) != false and 
                validateIpV4(recEntityId[ lastCode ]) != true and
                validateIpV6(recEntityId[ lastCode ]) != true ) and
                    recEntityType[ lastCode ] == 5 )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "105", "ERecording Entity Code refers to GMLC (Recording Entity Type 5) and syntax of the referenced Recording Entity Identification does not conform to MSISDN (3GPP TS 23.003) or to section 5.2");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "105", errorContext, "0", "-1", "-1", "","ERecording Entity Code refers to GMLC (Recording Entity Type 5) and syntax of the referenced Recording Entity Identification does not conform to MSISDN (3GPP TS 23.003) or to section 5.2");
      edrSetIsValidDetail(false);
    }    
      
    if ( ( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true or 
             strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or
               strStartsWith(parentContext, "DETAIL.gprsCall") == true ) and     
                 ( validateIpV4(recEntityId[ lastCode ]) != true and
                     validateIpV6(recEntityId[ lastCode ]) != true ) )
    {
        if ( recEntityType[ lastCode ] == 3 )
        {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "103", "Entity Code refers to GGSN (Recording Entity Type 3) and syntax of the referenced Recording Entity Identification does not conform to section 5.2");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "103", errorContext, "0", "-1", "-1", "","Entity Code refers to GGSN (Recording Entity Type 3) and syntax of the referenced Recording Entity Identification does not conform to section 5.2");
        edrSetIsValidDetail(false);
      }
      else if ( recEntityType[ lastCode ] == 4 )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "104", "Entity Code refers to SGSN (Recording Entity Type 4) and syntax of the referenced Recording Entity Identification does not conform to section 5.2");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "104", errorContext, "0", "-1", "-1", "","Entity Code refers to SGSN (Recording Entity Type 4) and syntax of the referenced Recording Entity Identification does not conform to section 5.2");
        edrSetIsValidDetail(false);
      }        
    }          

    if (( strStartsWith(parentContext, "DETAIL.gprsCall") == true  or 
             strStartsWith(parentContext, "DETAIL.mobileSession") == true or
               strStartsWith(parentContext, "DETAIL.messagingEvent") == true ) and     
                 ( validateIpV4(recEntityId[ lastCode ]) != true and
                     validateIpV6(recEntityId[ lastCode ]) != true ))
    {
       if ( recEntityType[ lastCode ] == 7 )
       {
         edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "106", "Entity Code refers to P-GW (Recording Entity Type 7) and syntax of the referenced Recording Entity Identification does not conform to Section 5.2.");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "106", errorContext, "0", "-1", "-1","", "Entity Code refers to P-GW (Recording Entity Type 7) and syntax of the referenced Recording Entity Identification does not conform to Section 5.2.");
        edrSetIsValidDetail(false);
      }
      else if ( recEntityType[ lastCode ] == 8 )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "107", "Entity Code refers to S-GW (Recording Entity Type 8) and syntax of the referenced Recording Entity Identification does not conform to Section 5.2.");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "107", errorContext, "0", "-1", "-1","", "Entity Code refers to S-GW (Recording Entity Type 8) and syntax of the referenced Recording Entity Identification does not conform to Section 5.2.");
        edrSetIsValidDetail(false);
      }
    }

    if (( strStartsWith(parentContext, "DETAIL.mobileSession") == true or
               strStartsWith(parentContext, "DETAIL.messagingEvent") == true ) and     
                 ( validateIpV4(recEntityId[ lastCode ]) != true and
                     validateIpV6(recEntityId[ lastCode ]) != true ))
    {
       if ( recEntityType[ lastCode ] == 9 )
       {
         edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "106", "Entity Code refers to P-CSCF (Recording Entity Type 9) and syntax of the referenced Recording Entity Identification does not conform to Section 5.2.");
         edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "108", errorContext, "0", "-1", "-1","", "Entity Code refers to P-CSCF (Recording Entity Type 9) and syntax of the referenced Recording Entity Identification does not conform to Section 5.2.");
         edrSetIsValidDetail(false);
      } 
      else if ( recEntityType[ lastCode ] == 4 )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Recording Entity Code", "184", "104", "Entity Code refers to SGSN (Recording Entity Type 4) and syntax of the referenced Recording Entity Identification does not conform to section 5.2");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "104", errorContext, "0", "-1", "-1", "","Entity Code refers to GGSN (Recording Entity Type 3) and syntax of the referenced Recording Entity Identification does not conform to section 5.2");
        edrSetIsValidDetail(false);
      }	  
    }

    if ( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
        String objTag = "1,3,14,117,118";
	if (recEntityType[ lastCode ] == 7 )
	{ 
	 	if (PGWRecEntityCode == true)
		{
		  edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Network Location", "118", "39", 
			"More than one Recording Entity Code is of type P-GW present within group.");
		  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "39", objTag, "0", "-1", "-1", "",
			"More than one Recording Entity Code is of type P-GW present within group.");
	          edrSetIsValidDetail(false);
		}
		else 
		{
			PGWRecEntityCode = true;
		}

	} 
	else if (recEntityType[ lastCode ] == 8 )
	{ 
		SGWRecEntityCode = true;
	}
	else if (recEntityType[ lastCode ] == 3 )
	{ 
 	 	GGSNRecEntityCode = true;
	}
	if (PGWRecEntityCode == true and GGSNRecEntityCode == true)
	{
		  edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Network Location", "118", "40", 
			"Recording Entity Codes of type GGSN and P-GW present within group");
		  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "40", objTag, "0", "-1", "-1","", 
			"Recording Entity Codes of type GGSN and P-GW present within group");
	          edrSetIsValidDetail(false);
	}
	if (SGWRecEntityCode == true and GGSNRecEntityCode == true)
	{
		  edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Network Location", "118", "41", 
			"Recording Entity Codes of type GGSN and S-GW present within group");
		  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "41", objTag, "0", "-1", "-1", "",
			"Recording Entity Codes of type GGSN and S-GW present within group");
	          edrSetIsValidDetail(false);
	 }
     }  
  } 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate LocationService. It will raise error code 30, 31 for LocationService.
 ******************************************************************************************************************************/
 
function validateLocationService ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",297";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  Bool trackingCustomerInformationIsMissing = false;
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "recEntityCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecEntityCode ( myContext, nMyIndices, "recEntityCode", 0, errorContext );
  }
 
  childContext = myContext + "." + "callReference";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallReference ( myContext, nMyIndices, "callReference", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingCustomerInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackingCustomerInformation ( myContext, nMyIndices, "trackingCustomerInformation", 0, errorContext );
  }
  else
  {
    trackingCustomerInformationIsMissing = true;
  }
 
  childContext = myContext + "." + "lCSSPInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLCSSPInformation ( myContext, nMyIndices, "lCSSPInformation", 0, errorContext );
  }
  else
  {
    if ( trackingCustomerInformationIsMissing == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LocationService", "297", "30", "Neither of groups Tracking Customer Information or LCS SP Information present within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Neither of groups Tracking Customer Information or LCS SP Information present within group");
      edrSetIsValidDetail(false);
    }    
  }
  
  trackingCustomerInformationIsMissing = false;  
 
  childContext = myContext + "." + "trackedCustomerInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackedCustomerInformation ( myContext, nMyIndices, "trackedCustomerInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "locationServiceUsage";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLocationServiceUsage ( myContext, nMyIndices, "locationServiceUsage", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LocationService", "297", "31", "Mandatory group Location Service Usage missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory group Location Service Usage missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate Commission. It will raise error code 20 for Commission.
 ******************************************************************************************************************************/
 
function validateCommission ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",350";
  Long commissionValue = edrLongEx(myContext, indices, nParentIndices);

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Commission", "350", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }

  if( hasChargeRefund == false )
  {
     totalCalcCommission_Arr[advCurrencyIndex] = totalCalcCommission_Arr[advCurrencyIndex] + commissionValue;
  }
  else
  {
     totalCalcCommissionRefund_Arr[advCurrencyRefundIndex] = totalCalcCommissionRefund_Arr[advCurrencyRefundIndex] + commissionValue;
  }  
    
    
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate AdvisedCharge. It will raise error code 20 for AdvisedCharge.
 ******************************************************************************************************************************/
 
function validateAdvisedCharge ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",349";
  Long advisedChargeValue = edrLongEx(myContext, indices, nParentIndices);

  if( edrLongEx(myContext, indices, nParentIndices) < 0 ) 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Advised Charge", "349", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range");
    edrSetIsValidDetail(false);
  }

  if( hasChargeRefund == false )
  {
    totalCalcAdvisdchrg_Arr[advCurrencyIndex] = totalCalcAdvisdchrg_Arr[advCurrencyIndex] + advisedChargeValue;
  }
  else
  {
    totalCalcAdvisdchrgRefund_Arr[advCurrencyRefundIndex] = totalCalcAdvisdchrgRefund_Arr[advCurrencyRefundIndex] + advisedChargeValue;
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate PaymentMethod. It will raise error code 20 for PaymentMethod.
 ******************************************************************************************************************************/
 
function validatePaymentMethod ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
