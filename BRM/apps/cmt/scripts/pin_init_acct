0 PIN_FLD_LOGIN           STR [0] "root.$PIN_CONF_DB_NO"
0 PIN_FLD_STATUS         ENUM [0] 2
0 PIN_FLD_SERVICE_OBJ    POID [0] $PIN_CONF_DB_NO /service/pcm_client 1 0
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
