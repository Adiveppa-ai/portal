//-----------------------------------------------------------------------------
// validateHasBSBlock
//
// This function will be used to validate if this MOC or MTC block has any
// BS blocks.
//-----------------------------------------------------------------------------
function validateHasBSBlock
{
  if (debug)
  {
    logStdout("validateHasBSBlock()\n");
  }

  if (((edrString(DETAIL.RECORD_TYPE) == type_MOC) or
       (edrString(DETAIL.RECORD_TYPE) == type_MTC)) and
      (edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0) == 0))
  {
    const String ruleID     = "Missing BS Block";
    const String severe     = "severe";
    const String arrayIndex = "-1";
    const String depth      = "3";
    const String offset     = "-1";
    String tag;

    // offset = longToStr(edrFieldTokenBytePos(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0));
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    if (edrString(DETAIL.RECORD_TYPE) == type_MOC)
    {
      tag = "9";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "32", tag, depth,
		offset, arrayIndex, ruleID);
      setAssociatedTapErr("ERR_TAP3_SERVICE_USED_LIST_TRANSACTION_DESCRIPTION_SUPP", LOG_MAJOR ,"32" ,tag ,depth);	
    }
    else if (edrString(DETAIL.RECORD_TYPE) == type_MTC)
    {
      tag = "10";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "32", tag, depth,
		offset, arrayIndex, ruleID);
      setAssociatedTapErr("ERR_TAP3_SERVICE_USED_LIST_TRANSACTION_DESCRIPTION_SUPP", LOG_MAJOR ,"32" ,tag ,depth);	
    }
  }
}


