</PCM_OP> 

# item object for the top level account
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /item/usage 1 0
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_BILL_OBJ       POID [0] $PIN_CONF_DB_NO /bill 1 0
