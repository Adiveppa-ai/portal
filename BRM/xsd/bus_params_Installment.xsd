		</xs:documentation>
	</xs:annotation>

	<xs:complexType name="BusParamsInstallmentType">
		<xs:sequence>
			
			<xs:element name="DueDateReminderNotification">
				<xs:annotation>
					<xs:documentation xml:lang="en">
						This parameter is used to send installment due date notification before X days of installment due date.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:nonNegativeInteger">
						<xs:whiteSpace value="collapse"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			
			<xs:element name="EndDateReminderNotification">
				<xs:annotation>
					<xs:documentation xml:lang="en">
						This parameter is used to send installment schedule end date notification before X days of installment due date.
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:nonNegativeInteger">
						<xs:whiteSpace value="collapse"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>

		</xs:sequence>
	</xs:complexType>


</xs:schema>
