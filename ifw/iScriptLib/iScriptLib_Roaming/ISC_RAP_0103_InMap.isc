    mapRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapFileCreationTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapRapFileCreationTimeStamp ( myContext, nMyIndices, "rapFileCreationTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapFileAvailableTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapRapFileAvailableTimeStamp ( myContext, nMyIndices, "rapFileAvailableTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "specificationVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSpecificationVersionNumber ( myContext, nMyIndices, "specificationVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "releaseVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapReleaseVersionNumber ( myContext, nMyIndices, "releaseVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapSpecificationVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRapSpecificationVersionNumber ( myContext, nMyIndices, "rapSpecificationVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapReleaseVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRapReleaseVersionNumber ( myContext, nMyIndices, "rapReleaseVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileTypeIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFileTypeIndicator ( myContext, nMyIndices, "fileTypeIndicator", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "roamingPartner";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRoamingPartner ( myContext, nMyIndices, "roamingPartner", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecList ( myContext, nMyIndices, "operatorSpecList", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
