/******************************************************************************************************************************
 * This function will validate TotalTaxRefund. It will raise error code 20, 100 for TotalTaxRefund.
 ******************************************************************************************************************************/ 

function validateTotalTaxRefund ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",353";

  String totalTaxRefundStr = longToStr(edrLongEx( myContext, indices, nParentIndices ));

  if( edrLongEx(myContext, indices, nParentIndices) <= 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    
    rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Total Tax Refund", "353", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "353", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else  
  {
    if ( totalCalcTaxRefund != strToLong(totalTaxRefundStr) )
    {
      
      rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Total Tax Refund", "353", "100", "Value does not match the calculated sum of refund taxes from Call Event Details");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "353", "0", "-1", "-1","", "Value does not match the calculated sum of refund taxes from Call Event Details");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TotalChargeRefund. It will raise error code 20, 21, 100 for TotalChargeRefund.
 ******************************************************************************************************************************/ 
 
function validateTotalChargeRefund ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",355";
  String totalChargeRefundStr = longToStr(edrLongEx( myContext, indices, nParentIndices ));

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalChargeRefund", "355", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "355", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( edrLongEx(myContext, indices, nParentIndices) == 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",21" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalChargeRefund", "355", "21", "Item Total Charge Refund has a value of zero");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "21", "355", "0", "-1", "-1","", "Item Total Charge Refund has a value of zero");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if ( totalCalcChargeRefund != strToLong(totalChargeRefundStr) )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalChargeRefund", "355", "100", "Value does not match the calculated sum of refund charges associated with the same Charge Type");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "355", "0", "-1", "-1", "","Value does not match the calculated sum of refund charges associated with the same Charge Type");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TotalCharge. It will raise error code 20, 100 for TotalCharge.
 ******************************************************************************************************************************/ 
 
function validateTotalCharge ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",415";
  String totalChargeStr = longToStr(edrLongEx( myContext, indices, nParentIndices ));

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalCharge", "415", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "415", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if ( totalCalcCharge != strToLong(totalChargeStr) )
  {     
    
    rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalCharge", "415", "100", "Value does not match the calculated sum of non refund charges which includes sum of CAMEL Invocation Fee for all CAMEL calls in the Transfer Batch");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "415", "0", "-1", "-1", "","Value does not match the calculated sum of non refund charges which includes sum of CAMEL Invocation Fee for all CAMEL calls in the Transfer Batch");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate LatestCallTimeStamp. It will raise error code 30 for LatestCallTimeStamp.
 ******************************************************************************************************************************/ 
 
function validateLatestCallTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",133";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffset";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "LatestCallTimestamp", "133", "30", "Mandatory associated item UTC Time Offset missing");  
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate EarliestCallTimeStamp. It will raise error code 30 for EarliestCallTimeStamp.
 ******************************************************************************************************************************/ 
 
function validateEarliestCallTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",101";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffset";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "EarliestCallTimeStamp", "101", "30", "Mandatory associated item UTC Time Offset missing");
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate AuditControlInfo. It will raise error code 30, 31, 32, 33, 39, 40 for AuditControlInfo.
 ******************************************************************************************************************************/
 
function validateAuditControlInfo ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",15";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "earliestCallTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateEarliestCallTimeStamp ( myContext, nMyIndices, "earliestCallTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "latestCallTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLatestCallTimeStamp ( myContext, nMyIndices, "latestCallTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "totalCharge";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalCharge ( myContext, nMyIndices, "totalCharge", 0, errorContext );
  }
  else      
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",30" + ":" + AuditControlInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "30", "Missing Total Charge"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "15", "0", "-1", "-1","", "Missing Total Charge");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "totalChargeRefund";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalChargeRefund ( myContext, nMyIndices, "totalChargeRefund", 0, errorContext );
  }
  else
  {
    if( hasChargeRefund == true )
    {
      rollbackReason = "AuditControlInfo," + errorContext + ",40" + ":" + AuditControlInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "40",
                  "Item Total Charge Refund expected with value greater than 0 and not present");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "40", "15", "0", "-1", "-1","",
                  "Item Total Charge Refund expected with value greater than 0 and not present");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "totalTaxRefund";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalTaxRefund ( myContext, nMyIndices, "totalTaxRefund", 0, errorContext );
  }
 
  childContext = myContext + "." + "totalTaxValue";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalTaxValue ( myContext, nMyIndices, "totalTaxValue", 0, errorContext );
  }
  else      
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",31" + ":" + AuditControlInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "31", "Missing Total Tax Value"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "15", "0", "-1", "-1", "","Missing Total Tax Value");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  } 

  childContext = myContext + "." + "totalDiscountValue";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalDiscountValue ( myContext, nMyIndices, "totalDiscountValue", 0, errorContext );
  }
  else      
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",32" + ":" + AuditControlInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "32", "Missing Total Discount Value"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "15", "0", "-1", "-1","", "Missing Total Discount Value");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);

  }
 
  childContext = myContext + "." + "totalDiscountRefund";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalDiscountRefund ( myContext, nMyIndices, "totalDiscountRefund", 0, errorContext );
  }
  childContext = myContext + "." + "totalAdvisedChargeValueList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTotalAdvisedChargeValueList ( myContext, nMyIndices, "totalAdvisedChargeValueList", 0, errorContext );
  }
  else
  {
    if( advisedChargeInfoCount >= 1 )
    {
      rollbackReason = "AuditControlInfo," + errorContext + ",39" + ":" + AuditControlInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "39",
      "TotalAdvisedChargeValue missing and one or more occurrences of ContentTransaction present containing Advised Charge Info");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "39", "15", "0", "-1", "-1","", 
      "TotalAdvisedChargeValue missing and one or more occurrences of ContentTransaction present containing Advised Charge Info");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }    
  }
 
  childContext = myContext + "." + "callEventDetailsCount";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallEventDetailsCount ( myContext, nMyIndices, "callEventDetailsCount", 0, errorContext );
  }
  else      
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",33" + ":" + AuditControlInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "33", "Missing Call Event Details Count"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "15", "0", "-1", "-1", "","Missing Call Event Details Count");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate Discountable Amount. It will raise error code 20 for Discountable Amount.
 ******************************************************************************************************************************/
 
function validateDiscountableAmount ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",423";
  
  if( edrLongEx(myContext, indices, nParentIndices) <= 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discountable Amount", "423", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate Discount value. It will raise error code 20 for Discount value.
 ******************************************************************************************************************************/
 
function validateDiscount ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",412";
  Long lastDiscount = edrLongEx( myContext, indices, nParentIndices );

  if( edrLongEx(myContext, indices, nParentIndices) <= 0 ) 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discount Value", "412", "20", " Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
     
  if ( hasChargeRefund == false )
  {
    totalCalcDiscount = totalCalcDiscount + lastDiscount;
  }
  else
  {
    totalCalcDiscountRefund = totalCalcDiscountRefund + lastDiscount;
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate Discount code. It will raise error code 20, 102 for Discount code.
 ******************************************************************************************************************************/

function validateDiscountCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",91";
  if( strStartsWith(parentContext, "HEADER") == true )
  {
    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "99", "0", "INTEGER_TYPE") == true) 
    {
      rollbackReason   = "AccountingInfo," +  errorContext + ",20" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discount Code", "91", "20", "Out Of Range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "91", "0", "-1", "-1", "","Out Of Range");
      edrSetIsValidDetail(false);
      edrLongEx( myContext, indices, nParentIndices ) = -1; 
      return;
    }
    hasDupDiscountingEntries = false;
    lastCode             = edrLongEx(myContext, indices, nParentIndices);
    Long tmpDiscountCode = edrLongEx(myContext, indices, nParentIndices);
    if ( discountCode[lastCode] == tmpDiscountCode )
    {
      hasDupDiscountingEntries = true;
    }
    if (hasDupDiscountingEntries == false)
    {
      discountCode[lastCode] = lastCode;
    }
  }
  else
  {
    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "99", "0", "INTEGER_TYPE") == true)
    {

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discount Code", "91", "10", "Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", "91", "0", "-1", "-1", "","Syntax Error");
      edrSetIsValidDetail(false);
      return;
    }
    lastDiscountCodeValue = edrLongEx(myContext, indices, nParentIndices);
    lastDiscountRate = discountApplied[lastDiscountCodeValue]; 
    if( lastDiscountCodeValue != discountCode[lastDiscountCodeValue] )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discount Code", "91", "102",
                                                "Specified discount code was not defined in group Discount Applied");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "102", errorContext, "0", "-1", "-1","",
                                                "Specified discount code was not defined in group Discount Applied");
      edrSetIsValidDetail(false);
    }
  }
      
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate DiscountInformation and AccountingInfo. It will raise error code 30, 31, 32 for DiscountInformation
 * and error code 31 for AccountingInfo.
 ******************************************************************************************************************************/
 
function validateDiscountInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{

  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",96";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  if ( discountListIsMissing == true )      
  {
    rollbackReason   = "AccountingInfo," +  "1 ,5 " + ",31" + ":" + AccountingInfoStr;
 
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AccountingInfo", "5", "31", "No Discounting group present and batch contains discounts"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "5", "0", "-1", "-1", "","No Discounting group present and batch contains discounts");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

 
  childContext = myContext + "." + "discountCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDiscountCode ( myContext, nMyIndices, "discountCode", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discount Information", "96", "30",
                                              "Mandatory item Discount Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                              "Mandatory item Discount Code missing within group");
    edrSetIsValidDetail(false);
  }
   
  childContext = myContext + "." + "discount";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDiscount ( myContext, nMyIndices, "discount", 0, errorContext );
  }
  else
  {
    if( discountApplied_Type[lastDiscountCodeValue] == discountApplied_discountRate )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discount Information", "96", "31",
                                     "Item Discount Value missing within group and Discount Code refers to a Discount Rate");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","",
                                     "Item Discount Value missing within group and Discount Code refers to a Discount Rate");
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "discountableAmount";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDiscountableAmount ( myContext, nMyIndices, "discountableAmount", 0, errorContext );
  }
  else
  {
    if( discountApplied_Type[lastDiscountCodeValue] == discountApplied_discountRate )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Discount Information", "96", "32",
                                     "Item Discountable Amount missing within group and Discount Code refers to a Discount Rate");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","",
                                     "Item Discountable Amount missing within group and Discount Code refers to a Discount Rate");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nMyIndices );
}

