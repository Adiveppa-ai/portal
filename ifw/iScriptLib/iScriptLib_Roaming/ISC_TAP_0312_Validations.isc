/******************************************************************************************************************************
 * This function calls the validation function validateRecEntityCode for each element of Rec Entity Code List.
 ******************************************************************************************************************************/
 
function validateRecEntityCodeList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",185";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "RecEntityCode_Elem";
  Long RecEntityCodeListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < RecEntityCodeListEntries; i = i + 1 )
  {
    indices[nMyIndices] = i;
    Long nChildIndices  = nMyIndices + 1;
    validateRecEntityCode ( childContext, nChildIndices, "RecEntityCode", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation functions validateRecEntityCodeList, validateLocationArea and validateCellId.
 ******************************************************************************************************************************/
 
function validateGprsNetworkLocation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",118";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  locationAreaIsPresent   = false;
  cellIdIsPresent         = false;
  Long   i;
 
  childContext = myContext + "." + "recEntity";
  recEntityTypeIndx = 0;
  arrayClear(recEntityTypeArray);
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateRecEntityCodeList ( myContext, nMyIndices, "recEntity", 0, errorContext );
  }
 
  childContext = myContext + "." + "locationArea";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    locationAreaIsPresent = true;
    validateLocationArea ( myContext, nMyIndices, "locationArea", 0, errorContext );
  }
 
  childContext = myContext + "." + "cellId";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    cellIdIsPresent = true;
    validateCellId ( myContext, nMyIndices, "cellId", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate GprsLocationInformation. It will raise error code 30 for GprsLocationInformation. 
 ******************************************************************************************************************************/
 
function validateGprsLocationInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",117";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  geographicalLocationIsMissing = false;
 
  childContext = myContext + "." + "gprsNetworkLocation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsNetworkLocation ( myContext, nMyIndices, "gprsNetworkLocation", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Location Information", "117", "30", 
                                              "Mandatory group GPRS Network Location missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                              "Mandatory group GPRS Network Location missing within group");
    edrSetIsValidDetail(false);
  }
    
 
  childContext = myContext + "." + "homeLocationInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateHomeLocationInformation ( myContext, nMyIndices, "homeLocationInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "geographicalLocation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGeographicalLocation ( myContext, nMyIndices, "geographicalLocation", 0, errorContext );
  }
  else
  {
    geographicalLocationIsMissing = true;
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
