function mapMissingReturn ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  createNewRapDetail(MISSING);
  edrString(DETAIL.ASS_ROAMING_EXT.RAP_RECORD_TYPE, 0) = MISSING;
  startSeqNum = 0;
  endSeqNum   = 0;
  
  childContext = myContext + "." + "startMissingSeqNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapStartMissingSeqNumber ( myContext, nMyIndices, "startMissingSeqNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "endMissingSeqNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapEndMissingSeqNumber ( myContext, nMyIndices, "endMissingSeqNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecList ( myContext, nMyIndices, "operatorSpecList", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
