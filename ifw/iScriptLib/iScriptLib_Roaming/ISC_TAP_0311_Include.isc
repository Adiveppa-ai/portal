function mapCamelServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  service_Type = service_Camel;
  if ( edrAddDatablock( DETAIL.ASS_CAMEL_EXT ) == false )
  {
  }
  records = records + 1;
  edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) = edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) + 1;
  edrString(DETAIL.ASS_CAMEL_EXT.RECORD_TYPE, 0) = extension_CAMEL;
  edrLong(DETAIL.ASS_CAMEL_EXT.RECORD_NUMBER, 0) = records;
  related_record = records;
                                                                                                             
  childContext = myContext + "." + "camelServiceLevel";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapCamelServiceLevel ( myContext, nMyIndices, "camelServiceLevel", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "camelServiceKey";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapCamelServiceKey ( myContext, nMyIndices, "camelServiceKey", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "defaultCallHandling";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapDefaultCallHandlingIndicator ( myContext, nMyIndices, "defaultCallHandling", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "exchangeRateCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapExchangeRateCode ( myContext, nMyIndices, "exchangeRateCode", 0 );                               
  }                                                                                                          
  else
  {
    lastExchangeRateFactorValue = 1.0;
    lastExchangeRateFactor = lastExchangeRateFactorValue;
  }
                                                                                                             
  childContext = myContext + "." + "taxInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTaxInformationList ( myContext, nMyIndices, "taxInformation", 0 );                               
  }                                                                                                          

  updateBasicDetailWithCamelCharge();
                                                                                                             
  childContext = myContext + "." + "discountInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapDiscountInformation ( myContext, nMyIndices, "discountInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "camelInvocationFee";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
