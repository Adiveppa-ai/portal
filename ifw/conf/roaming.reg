            {
                 FilePath   = ./log/edrLog
                 FileName   = edrTraceLog
                 FilePrefix = log_
                 FileSuffix = .log
            }

            TraceStartPoint =  Input
            TraceEndPoint   = Output

        } # END EdrTrace

      } # END of Output    
