/******************************************************************************************************************************
 * This function will validate GprsServiceUsed. It will raise error code 32, 33, 34 for GprsServiceUsed.
 ******************************************************************************************************************************/
 
function validateGprsServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",121";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "iMSSignallingContext";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateIMSSignallingContext ( myContext, nMyIndices, "iMSSignallingContext", 0, errorContext );
  }
 
  childContext = myContext + "." + "dataVolumeIncoming";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDataVolumeIncoming ( myContext, nMyIndices, "dataVolumeIncoming", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Service Used", "121", "33", "Data Volume Incoming is missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1", "","Data Volume Incoming is missing");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "dataVolumeOutgoing";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDataVolumeOutgoing ( myContext, nMyIndices, "dataVolumeOutgoing", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Service Used", "121", "34", "Data Volume Outgoing is missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", errorContext, "0", "-1", "-1", "","Data Volume Outgoing is missing");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargeInformationList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Service Used", "121", "32", "Charge Information is missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Charge Information is missing");
    edrSetIsValidDetail(false);
  }

 
  //logContext( myContext, nMyIndices );
}
 
