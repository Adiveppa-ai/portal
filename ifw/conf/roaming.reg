          } # end of DevNull

         
          #--------------------------------------------------------------------
          # The Home related records
          #--------------------------------------------------------------------
          HomeOutput
          {
            ModuleName = OUT_GenericStream
            ProcessType = SPLITTER_PIPELINE
            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/SOL42_V670_REL_OutGrammar.dsc
              DeleteEmptyStream = True
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/edr
                  OutputPrefix          = test_
                  OutputSuffix          = .edr
                  TempPrefix            = tmptest_
                  TempDataPath          = ./data/edr
                  TempDataPrefix        = test.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of HomeOutput

          #--------------------------------------------------------------------
          # The Roam related records
          #--------------------------------------------------------------------
          RoamOutput
          {
            ModuleName = OUT_GenericStream
            ProcessType = SPLITTER_PIPELINE
            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/SOL42_V670_REL_OutGrammar.dsc
              DeleteEmptyStream = True
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/in
                  OutputPrefix          = test_
                  OutputSuffix          = .edr
                  TempPrefix            = tmptest_
                  TempDataPath          = ./data/outcollect/in
                  TempDataPrefix        = test.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of RoamOutput
        } # end of OutputCollection

        #-------------------------------
        OutputLog
        {
          FilePath        = ./log/stream
          FileName        = SplitterPipeline
          FilePrefix      = Stream_
          FileSuffix      = .log
          SuppressErrors
          {
            ERR_SPEC_VERSION_INVALID
            ERR_RELEASE_VERSION_INVALID
          }
        } # end of OutputLog

        EdrTraceEnabled = False
        EdrTrace
        {
            TraceLog
            {
                 FilePath   = ./log/edrLog
                 FileName   = edrTraceLog
                 FilePrefix = log_
                 FileSuffix = .log
            }

            TraceStartPoint =  Input
            TraceEndPoint   = Output

        } # END EdrTrace

      } # END Output
    } # END SplitterPipeline

    TAPOutCollectPipeline
    {
      Active                      = True
      
      CountryCode                 = 49
      MobileCountryCode           = 262
      NationalAccessCode          = 0
      InternationalAccessCode     = 00
      InternationalAccessCodeSign = +
      NetworkDestinationCode      = 172
      ChargedCurrencyType         = H
      RejectStream                = SuspenseCreateOutput
      
      TransactionManager
      {
        RedoEnabled       = True
        SingleTransaction = False
        WriteToLogEnabled = True
        BinaryLogFileName = ./tam/binaryLogFileTAPOutCollectPipeline.dat
      }
      
      EdrFactory 
      {
        DataConnection = ifw.DataPool.Login
        Description = ./formatDesc/Formats/TAP3-NG/containerDesc.dsc
        UsageStatistic = ./log/statistic/edrStatisticTAPOutCollectPipeline.txt
        EdrVersionDataConnection = ifw.DataPool.LoginInfranet
      }

      DataDescription
      {
        Standard
        {
          ModuleName = Standard
          Module
          {
            StreamFormats
            {
              SOL42                   = ./formatDesc/Formats/Solution42/SOL42_V670_REL_FORINPUT.dsc
              Generic                 = ./formatDesc/Formats/TAP3-NG/GenericBlocks.dsc
              TAP3                    = ./formatDesc/Formats/TAP3-NG/TAP_0312_Blocks.dsc
              NRTRDE2                 = ./formatDesc/Formats/TAP3/NRTRDE2_v01_Blocks.dsc
              SUSPENSE_CREATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreation.dsc
              SUSPENSE_UPDATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdate.dsc
            }

            InputMapping
            {
              SOL42                   = ./formatDesc/Formats/Solution42/SOL42_V670_REL_InMap.dsc
            }

            OutputMapping
            {
              SUSPENSE_CREATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreationMapping.dsc
              SUSPENSE_UPDATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdateMapping.dsc
            }
          }
        }
      }

      PipelineLog 
      { 
        ModuleName = LOG
        Module 
        { 
          ITO 
          { 
            WriteMessageKey = True
            FilePath        = ./log/pipeline
            FileName        = pipeline_TAPOutCollectPipeline.log
            ProcessName     = ifw
            MessageGroup    = IFW
            ShowOriginator  = True
          }

          Buffer 
          { 
            Size = 500
          } 
        } 
      }

      InputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }

      OutputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }
      
      #------------------------------------------------------------------------
      # Input section
      #------------------------------------------------------------------------
      Input
      {
        UnitsPerTransaction = 1

        InputModule
        {
          ModuleName  = INP_GenericStream
          Module
          {
            DefaultOutput = SuspenseCreateOutput
            Grammar       = ./formatDesc/Formats/Solution42/SOL42_V670_REL_InGrammar.dsc

            InputStream
            {
              ModuleName = EXT_InFileManager
              Module
              {
                InputPath   = ./data/outcollect/in
                InputPrefix = test_
                InputSuffix = .edr
 
                DonePath    = ./data/outcollect/done
                DonePrefix  = test_TAPOutCollectPipeline_
                DoneSuffix  = .done
           
                ErrorPath   = ./data/outcollect/error
                ErrorPrefix = test_TAPOutCollectPipeline_
                ErrorSuffix = .err

                TempPrefix  = temp_TAPOutCollectPipeline_
                Replace     = True
                InputDirEmptyTimeout = 10
              }
            }
          }
        }
      }

      #------------------------------------------------------------------------
      # Function section
      #------------------------------------------------------------------------
      Functions 
      {
        Processing
        {
          FunctionPool
          {
            #---------------------------------------------------
            # PreSuspense FCT
            #---------------------------------------------------
            PreSuspense
            {
              ModuleName = FCT_PreSuspense
              Module
              {
                Active = True
                QueryableFields
                {
                  SUSP_USAGE_TELCO_INFO_T
                  {
                    START_TIME = DETAIL.CHARGING_START_TIMESTAMP
                    CALL_DURATION = DETAIL.DURATION
                    CALLING_FROM = DETAIL.A_NUMBER
                    CALLED_TO = DETAIL.B_NUMBER
                  }
                }
              }
            }

            #--------------------------------------------------------------
            # This IScript will remove ASS_CBD from reprocessed RAP records
            #--------------------------------------------------------------
            RemoveASSCBD
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  RemoveASSCBDIScript
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_RemoveASSCBD.isc                    
                  }
                }
              }
            }

            #--------------------------------------------------------------
            # This will map external service to internal service
            #--------------------------------------------------------------
            ServiceCodeMap 
            { 
              ModuleName = FCT_ServiceCodeMap
              Module 
              { 
                Active             = TRUE
                DataConnection     = ifw.DataPool.Login
                MapGroup           = ALL_RATE
              } 
            } 
            #--------------------------------------------------
            # Usage Class Mapping
            #--------------------------------------------------
            UsageClassMap
            {
              ModuleName = FCT_UsageClassMap 
              Module 
              { 
                Active              = TRUE
                DataConnection      = ifw.DataPool.Login
                OverwriteUsageClass = False 
                MapGroup            = ALL_RATE
                #OptimizeFor        = Memory
              } 
            }            

            #--------------------------------------------------
            # This iScript will put logic based on CamelFlag value
            #--------------------------------------------------
            GetCamelFlag
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  CamelFlagIScript
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_GetCamelFlag.isc
                  }
                }
              }
            }

            #--------------------------------------------------
            # Access Point Name Mapping (before zoning)
            #--------------------------------------------------
            APNMap
            {
              ModuleName = FCT_APN_Map
              Module
              {
                Active         = TRUE
                DataConnection = ifw.DataPool.Login
                APNGroup  = ALL_RATE
              }
            }

            #--------------------------------------------------------------
            # This will populate the prefix description
            #--------------------------------------------------------------
            PrefixDesc
            {
              ModuleName = FCT_PrefixDesc
              Module
              {
                Active = True
                PrefixDataModule = ifw.DataPool.PrefixDescDataModule
              }
            }            

            #--------------------------------------------------
            # Carrier Rating
            #--------------------------------------------------
            CarrierICRating
            {
              ModuleName = FCT_CarrierIcRating
              Module 
              { 
                Active = TRUE 
                InterConnectDataModule = ifw.DataPool.ICDataModule
                EdrNetworkModel = Standard 
                UseRateplan = Standard
                Mode = ROAMING
                IcProductGroup = Standard                        
               } 
            }
 
            #--------------------------------------------------
            # Pre-Rating (Zoning)
            #--------------------------------------------------
            PreRatingZone
            {
              ModuleName = FCT_PreRating
              Module
              {
                Active = TRUE
                RateplanDataModule = ifw.DataPool.RateplanDataModule
                ZoneDataModule = ifw.DataPool.ZoneDataModule
              }
            }

            #--------------------------------------------------
            # Access Point Name Mapping (after zoning)
            #--------------------------------------------------              
            APNMap
            {
              ModuleName = FCT_APN_Map 
              Module 
              { 
                Active         = TRUE
                DataConnection = ifw.DataPool.Login
                APNGroup {} 
              }
            } 

            #--------------------------------------------------
            # Usage Scenario Mapping
            #--------------------------------------------------
            UsageScenarioMap
            {
              ModuleName = FCT_USC_Map
              Module
              {
                Active = TRUE
                DataModule = ifw.DataPool.USCDataModule
                DefaultUSCGroup = ALL_RATE
              }
            }

            #--------------------------------------------------
            # Rate Service Class Mapping
            #--------------------------------------------------              
            RateServiceClassMap 
            { 
              ModuleName = FCT_RSC_Map 
              Module 
              {
                Active          = FALSE 
                DataConnection  = ifw.DataPool.Login
                DefaultRscGroup = ALL_RATE
              } 
            }

            #--------------------------------------------------
            # Main Rating (Pricing)
            #--------------------------------------------------
            MainRating
            {
              ModuleName = FCT_MainRating
              Module
              {
                Active                  = TRUE
                RateplanDataModule      = ifw.DataPool.RateplanDataModule
                CalendarDataModule      = ifw.DataPool.CalendarDataModule
                TimeDataModule          = ifw.DataPool.TimeDataModule
                PriceDataModule         = ifw.DataPool.PriceDataModule
                CurrencyDataModule      = ifw.DataPool.CurrencyDataModule
                ModelSelectorDataModule = ifw.DataPool.ModelSelectorDataModule
              }
            }
            
            #--------------------------------------------------
            # Special Dayrates
            #--------------------------------------------------
            SpecialDayRate
            {
              ModuleName = FCT_Dayrate
              Module
              {
                Active = TRUE
                DayrateDataModule = ifw.DataPool.DayRateDataModule
              }
            }

            #--------------------------------------------------
            # Rate Adjustment
            #--------------------------------------------------
            RateAdjustment
            {
              ModuleName = FCT_RateAdjust
              Module
              {
                Active         = TRUE
                Source         = Database
                DataConnection = ifw.DataPool.Login
              }
            }

            #--------------------------------------------------
            # Rounding (Rating)
            #--------------------------------------------------
            Round_Rating
            {
              ModuleName = FCT_Rounding
              Module
              {
                Active             = TRUE
                CurrencyDataModule = ifw.DataPool.CurrencyDataModule
                Mode               = RATING
              }
            }
            
            #--------------------------------------------------
            # Exchange Rate Calculation
            #--------------------------------------------------              
            ExchangeRate
            {
              ModuleName  = FCT_ExchangeRate
              Module
              {
                Active                 = TRUE
                ExchangeRateDataModule = ifw.DataPool.ExchangeRateDataModule
                RatingDateHome         = CDR
                HomeCurrency           = SDR
                ErrorMessages          = TRUE
              }
            }
            
            #--------------------------------------------------
            # Rounding (Rating)
            #--------------------------------------------------
            Round_Rating
            {
              ModuleName = FCT_Rounding
              Module
              {
                Active             = TRUE
                CurrencyDataModule = ifw.DataPool.CurrencyDataModule
                Mode               = RATING
              }
            }

            #-------------------------------------------------------------------
            # This IScript will create BS, SS block
            #--------------------------------------------------------------------
            MiscAddInfo
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  MiscAddInfoIScript
                  {        
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_MiscOutCollect.isc                    
                  }
                }
              }
            }

            #--------------------------------------------------
            # Splitting based on source network
            #--------------------------------------------------  
            RoamPartner_EventSplitting
            {
              ModuleName = FCT_EnhancedSplitting
              Module
              {
                Active = True 
                DataConnection = ifw.DataPool.Login 
                DefaultOutput = SuspenseCreateOutput 
                SystemBrands 
                {  
                  XXX = TAPOutput_XXX 
                  SUSP = SuspenseCreateOutput
                }
              }
            }

            #--------------------------------------------------
            # Duplication based on NRTRDE setting of the operator
            #--------------------------------------------------
            NRTRDESplit
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = File
                Scripts
                {
                  NRTRDESplit
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_NRTRDE_EventSplit.isc
                    NRTRDE_STREAM_PATTERN = NRTRDEOutput_ 
                  }
                }
              }
            }

            #--------------------------------------------------
            # This will take care of the reject part
            #--------------------------------------------------  
            Rejection
            {
              ModuleName = FCT_Reject
              Module
              {
                Active          = True 
                NotifyOnReject  = True 
                UseRejectStream = True 
                StreamMap {}
              }
            }


##----------------------------------------------------------------------
##         Deprecated because of the introduction of EDR Trace
##----------------------------------------------------------------------
##          PostPipelineTAPOutCollectDump
##          {
##            ModuleName = FCT_EdrDump
##            Module
##            {
##              Active     = False
##              FilePath   = ./data/dump
##		FileName   = PostPipelineTAPOutCollect
##              FileSuffix = .txt
##            }
##          }
##----------------------------------------------------------------------

            #---------------------------
            # Suspense FCT
            #---------------------------
            Suspense
            {
              ModuleName = FCT_Suspense
              Module
              {
                Active                   = True
                SuspenseCreateStream     = SuspenseCreateOutput
                SuspenseUpdateStream     = SuspenseUpdateOutput
                DataConnection           = ifw.DataPool.LoginInfranet
                LogTestResults           = True
                PipelineCategory         = RoamingPipelines

                RecycleLog
                {
                   MessageFilePath   = ./etc
                   MessageFilePrefix = Framework
                   MessageFileSuffix = msg
                   FilePath          = ./data/log
                   FilePrefix        = TAPOutCollect_Reject_
                   FileSuffix        = .log
                }
              }
            }

          } # END of FunctionPool
        } # END of Processing
      } # END of Functions

      #--------------------------------------------------
      # Output Section
      #--------------------------------------------------
      Output
      {
        SequenceGeneration = Unit
        WriteDefaultEdr    = False
        DeleteEmptyFile    = True

        MaxErrorRates
        {
        }

        #-------------------------------------------
        # Multithreaded writing. This is recommended
        # when EDRs are associated with multiple
        # output streams.
        #------------------------------------------
        MultiThreading
        {
           Active = False      # Defaults to False
           NumberOfThreads = 1 # Number of threads spawned. Defaults to 1
           BatchSize = 0       # The number of EDRs cached before sent for writing. Defaults to 0
        }

        OutputCollection
        {
          #--------------------------------------------------------------------
          # The operator related output stream
          #--------------------------------------------------------------------
          TAPOutput_XXX 
          {
            ModuleName  = OUT_GenericStream
            ProcessType = TAPOUTCOLLECT_PIPELINE
            EventType   = /event/delayed/session/telco/gsm

            Module
            {
              Grammar = ./formatDesc/Formats/TAP3-NG/TAP_0312_OutGrammar.dsc
              DeleteEmptyStream = False
              Sequencer = SEQ_GEN_TAPOUT_XXX 

              Sender = EUR01
              Recipient = XXX 
              CountryCode = XXX
              DecimalPlaces = XXX 
	

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/tapout/XXX
                  OutputPrefix          = CDEUR01XXX
                  TempPrefix            = tmptest_XXX_
                  TempDataPath          = ./data/outcollect/tapout/XXX
                  TempDataPrefix        = test.XXX.tmp.
                  TempDataSuffix        = .data
                  UseInputStreamName    = [0,0]
                  SequencerPrefix       = "" 
                  AppendSequenceNumber  = True
                }
              }
            }
          }

          NRTRDEOutput_XXX
          {
            ModuleName  = XXX 
            ProcessType = TAPOUTCOLLECT_PIPELINE
            EventType   = /event/delayed/session/telco/gsm

            Module
            {
              Grammar = ./formatDesc/Formats/TAP3/NRTRDE2_v01_OutGrammar.dsc
              DeleteEmptyStream = True
              Sequencer = SEQ_GEN_NRTRDEOUT_XXX

              Sender = EUR01
              Recipient = XXX

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/nrtrdeout/XXX
                  OutputPrefix          = NREUR01XXX
                  TempPrefix            = tmptest_XXX_
                  TempDataPath          = ./data/outcollect/nrtrdeout/XXX
                  TempDataPrefix        = test.XXX.tmp.
                  TempDataSuffix        = .data
                  UseInputStreamName    = [0,0]
                  SequencerPrefix       = ""
                  AppendSequenceNumber  = True
                }
              }
            }
          }

          #--------------------------------------------------------------------
          # SuspenseCreateOutput stream
          #--------------------------------------------------------------------
          SuspenseCreateOutput
          {
            ModuleName  = OUT_GenericStream
            ProcessType = RATING_PIPELINE
            EventType   = /suspended_usage/telco

            Module
            {
              Grammar = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreationGrammar.dsc
              DeleteEmptyStream = True

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/reject
                  OutputPrefix          = suspense_create_
                  OutputSuffix          = .out
                  TempPrefix            = tmpsuspense_create_
                  TempDataPath          = ./data/outcollect/reject
                  TempDataPrefix        = susp.create.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          }

          #--------------------------------------------------------------------
          # SuspenseUpdateOutput stream
          #--------------------------------------------------------------------
          SuspenseUpdateOutput
          {
            ModuleName  = OUT_GenericStream
            ProcessType = RATING_PIPELINE
            EventType   = /tmp_suspended_usage

            Module
            {
              Grammar = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdateGrammar.dsc
              DeleteEmptyStream = True

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/reject
                  OutputPrefix          = suspense_update_
                  OutputSuffix          = .out
                  TempPrefix            = tmpsuspense_update_
                  TempDataPath          = ./data/outcollect/reject
                  TempDataPrefix        = susp.update.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          }
        }

        OutputLog
        {
          FilePath        = ./log/stream
          FileName        = TAPOutCollectPipeline
          FilePrefix      = Stream_
          FileSuffix      = .log

          SuppressErrors
          {
            ERR_SPEC_VERSION_INVALID
            ERR_RELEASE_VERSION_INVALID
          }
        }

        EdrTraceEnabled = False
        EdrTrace
        {
            TraceLog
            {
                 FilePath   = ./log/edrLog
                 FileName   = edrTraceLog
                 FilePrefix = log_
                 FileSuffix = .log
            }

            TraceStartPoint =  Input
            TraceEndPoint   = Output

        } # END EdrTrace

      } # END of Output    
    } # END TAPOutCollectPipeline

    TAPOutSettlementPipeline
    {
      Active                      = True
      
      CountryCode                 = 49
      MobileCountryCode           = 262
      #NationalAccessCode          = 0
      #InternationalAccessCode     = 00
      InternationalAccessCodeSign = +
      NetworkDestinationCode      = 172
      RejectStream                = DevNull
      
      TransactionManager
      {
        RedoEnabled = True #False
        SingleTransaction = False
        WriteToLogEnabled = True
        BinaryLogFileName = ./tam/binaryLogFileTAPOutSettlementPipeline.dat
      }
      
      EdrFactory 
      { 
        DataConnection = ifw.DataPool.Login 
        Description = ./formatDesc/Formats/TAP3-NG/containerDesc.dsc
        UsageStatistic = ./log/statistic/edrStatisticTAPOutSettlementPipeline.txt
        EdrVersionDataConnection = ifw.DataPool.LoginInfranet
      }

      DataDescription
      {
        Standard
        {
          ModuleName = Standard
          Module
          {
            StreamFormats
            {
              Generic       = ./formatDesc/Formats/TAP3-NG/GenericBlocks.dsc
              TAP3          = ./formatDesc/Formats/TAP3-NG/TAP_0312_Blocks.dsc
              RAP           = ./formatDesc/Formats/TAP3-NG/RAP_0105_Blocks.dsc
              EVENT_LOADER  = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER.dsc
              TapHeaderInfo    = ./formatDesc/Formats/TapHeaderInfo/TapHeaderInfo.dsc
            }

            InputMapping
            {
            }
    
            OutputMapping
            {
              EVENT_LOADER  = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutMap.dsc          
              TapHeaderInfo    = ./formatDesc/Formats/TapHeaderInfo/TapHeaderInfo_OutMap.dsc
            }
          }
        }
      }

      PipelineLog 
      { 
        ModuleName = LOG
        Module 
        { 
          ITO 
          { 
            WriteMessageKey = True
            FilePath        = ./log/pipeline
            FileName        = pipeline_TAPOutSettlementPipeline.log
            ProcessName     = ifw
            MessageGroup    = IFW
            ShowOriginator  = TRUE
          }

          Buffer 
          { 
            Size = 500
          } 
        } 
      }


      InputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }

      OutputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }

      #------------------------------------------------------------------------
      # Input section
      #------------------------------------------------------------------------
      Input
      {
        UnitsPerTransaction = 1

        #TAP3 Input stream
        InputModule
        {
          ModuleName = INP_GenericStream
          Module
          {
            DefaultOutput = GSMOutput
            Grammar       = ./formatDesc/Formats/TAP3-NG/TAP_0312_InGrammar.dsc
            
            InputStream
            {
              ModuleName = EXT_InFileManager
              Module
              {
                InputPath   = ./data/outcollect/settlement/in
                InputPrefix = CD

                DonePath    = ./data/outcollect/settlement/done
                DonePrefix  = test_TAPOutSettlementPipeline_
                DoneSuffix  = .done

                ErrorPath   = ./data/outcollect/settlement/error
                ErrorPrefix = test_TAPOutSettlementPipeline_
                ErrorSuffix = .err

                TempPrefix  = temp_TAPOutSettlementPipeline_
                Replace     = True
                InputDirEmptyTimeout = 10
                SynchronizeWithOutput = False
              }
            }
          }
        }
      }

      
      #------------------------------------------------------------------------
      # Function section
      #------------------------------------------------------------------------
      Functions 
      {
        Processing
        {
          FunctionPool
          {
            #---------------------------
            # Batch Suspense
            #---------------------------
            BatchSuspense
            {
              ModuleName = FCT_BatchSuspense
              Module
              {
                Active = True
                DataConnection = ifw.DataPool.LoginInfranet
                ResubmitDataModule = ifw.DataPool.ResubmitBatch
                PipelineCategory = RoamingPipelines
                StorableClass = /suspended_batch/cdr

                SuspenseFile
                {
                  Path = ./data/outcollect/settlement/suspended_batch
                  Prefix = suspended_batch_
                  Suffix = .out
                  TempDataPrefix = batch.suspense.tmp.
                }
              }
            }

            #------------------------------------------------------------------
            # Business Mapping
            #------------------------------------------------------------------
            BusinessMapping
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  BusinessMapping
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_TAP_0312_InMap.isc 
                  }
                }
              }
            }

            #-------------------------------------------------------------------
            # This IScript will keep CP of the consolidated one
            #--------------------------------------------------------------------
            ConsolidatedCP
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  ConsolidatedCPIScript
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_ConsolidatedCP.isc
                    GL_CODE = 1514
                  }
                }
              }
            }
      
            #--------------------------------------------------
            # Service Code Mapping
            #--------------------------------------------------
            ServiceCodeMap 
            { 
              ModuleName = FCT_ServiceCodeMap
              Module 
              { 
                Active             = TRUE
                DataConnection     = ifw.DataPool.Login
                MapGroup           = OUTCOLLECT
              } 
            } 

            #--------------------------------------------------
            # Usage Class Set Mapping
            #--------------------------------------------------
            UsageClassMap
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  UsageClassSettingIScript
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_UsageClassSetting.isc                    
                  }
                }
              }
            }
      
            #--------------------------------------------------
            # Infranet Customer
            #--------------------------------------------------
            CustomerSearch 
            { 
              ModuleName = FCT_Account
              Module 
              { 
                Active         = TRUE
                DataModule     = ifw.DataPool.CustomerData
                #DisableRatingProductCheck  = False
              }
            }
      
            #--------------------------------------------------
            # Exchange Rate Calculation
            #--------------------------------------------------
            ExchangeRateRoaming
            {
              ModuleName  = FCT_ExchangeRate
              Module
              {
                Active                 = TRUE
                ExchangeRateDataModule = ifw.DataPool.ExchangeRateDataModule
                CurrencyDataModule     = ifw.DataPool.CurrencyDataModule
                RatingDateBilling      = CDR
                ErrorMessages          = TRUE
              }
            }

            #--------------------------------------------------
            # ItemAssign PlugIn
            #--------------------------------------------------
            FlexibleItemAssignment
            {
              ModuleName = FCT_ItemAssign
              Module
              {
                 Active     = TRUE
                 DataModule     = ifw.DataPool.ItemAssignDataModule
              }
            }

            #----------------------------------------------------------------
            # Add Infranet Billing Record (plugin version)
            #----------------------------------------------------------------
            AddInfranetBillingRecord
            {
              ModuleName = FCT_BillingRecord
              Module
              {
                Active = TRUE
                CurrencyType = B
                CurrencyDataModule = ifw.DataPool.CurrencyDataModule
                ItemAssignDataModule     = ifw.DataPool.ItemAssignDataModule
                BalanceDataModule        = ifw.DataPool.BalanceDataModule
                AccountDataModule  = ifw.DataPool.CustomerData
                PortalConfigDataModule   = ifw.DataPool.PortalConfigDataModule
                RatePlanType = W
                ChargeBreakDownRecordType = 980
              }
            }            

            #--------------------------------------------------------------
            # Override RateTag field with NRTRDE Flag value of the operator
            #--------------------------------------------------------------
            OverrideRateTag 
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  OverrideRateTagIScript
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_OverrideRateTag.isc
                  }
                }
              }
            }


            #--------------------------------------------------
            # Split Output based on extrenal service
            #--------------------------------------------------              
            ServiceOutputSplit
            {
              ModuleName = FCT_EnhancedSplitting
              Module
              {
                Active = True 
                DataConnection = ifw.DataPool.Login 
                DefaultOutput = GSMOutput
                SystemBrands 
                {  
                  GSMR = GSMOutput
                  GPRSR = GPRSOutput                
                }
              }
            }

            #--------------------------------------------------
            # Reject Module
            #--------------------------------------------------
            Rejection
            {
              ModuleName = FCT_Reject
              Module
              {
                Active           = True
                NotifyOnReject   = True
                UseRejectStream  = True
                MinErrorSeverity = 1
                StreamMap
                {
                  garbage      = DevNull
                }
              }
            }

            #--------------------------------------------------
            # Rollback Module
            #--------------------------------------------------
            RollbackSettlement
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  RollbackIScript
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_RollbackSettlement.isc
                  }
                }
              }
            }    

            #--------------------------------------------------
            # Set Service Type Accordingly for HUR Report
            #--------------------------------------------------
            HUR_ServiceSetting
            {
               ModuleName = FCT_IRules
               Module
               {
                 Active = True
                 Source = File
                 Descriptions
                 {
                   FileName= ./iScriptLib/iScriptLib_Roaming/IRL_HUR_ServiceSetting.irl
                 }
               }
            }

##----------------------------------------------------------------------
##         Deprecated because of the introduction of EDR Trace
##----------------------------------------------------------------------
##	    PostPipelineTAPOutSettlementDump
##          {
##            ModuleName = FCT_EdrDump
##            Module
##            {
##              Active     = False
##              FilePath   = ./data/dump
##              FileName   = PostPipelineTAPOutSettlement
##              FileSuffix = .txt
##            }
##          }            
##----------------------------------------------------------------------

          } #END FunctionPool
        }
      } # END Functions

      #--------------------------------------------------
      # Output Section
      #--------------------------------------------------
      Output
      {
        WriteDefaultEdr            = False

        MaxErrorRates
        {
          INF_EDR_REJECTED = 90
        }

        OutputCollection
        {
          #--------------------------------------------------------------------
          # The DevNull stream
          #--------------------------------------------------------------------
          DevNull
          {
            ModuleName = OUT_DevNull
            Module
            { 
            } 
          } # end of DevNull          
 
          #--------------------------------------------------------------------
          # The /event/delayed/session/telco/gsm/roaming output stream
          #--------------------------------------------------------------------
          GSMOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gsm/roaming

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
               
              DeleteEmptyStream = False # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/out/gsm
                  OutputPrefix          = test_gsm_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_gsm_
                  TempDataPath          = ./data/outcollect/settlement/out/gsm
                  TempDataPrefix        = test.gsm.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of TELOutput

          #--------------------------------------------------------------------
          # The /event/delayed/session/telco/gprs/roaming output stream
          #--------------------------------------------------------------------
          GPRSOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gprs/roaming

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/out/gprs
                  OutputPrefix          = test_gprs_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_gprs_
                  TempDataPath          = ./data/outcollect/settlement/out/gprs
                  TempDataPrefix        = test.gprs.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of GPRSOutput   
	  
          #--------------------------------------------------------------------
          # The TAPHeaderInfo Output stream
          #--------------------------------------------------------------------
          TapHeaderInfoOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gsm/roaming

            Module
            {
              Grammar = ./formatDesc/Formats/TapHeaderInfo/TapHeaderInfo_OutGrammar.dsc
               
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/out/tapheaderinfo
                  OutputPrefix          = test_
                  OutputSuffix          = .thi
                  TempPrefix            = tmptest_
                  TempDataPath          = ./data/outcollect/settlement/out/tapheaderinfo
                  TempDataPrefix        = test.thi.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of TELOutput
        
        } # end of OutputCollection

        OutputLog
        {
          FilePath        = ./log/stream
          FileName        = TAPOutSettlementPipeline_
          FilePrefix      = Stream_
          FileSuffix      = .log

          SuppressErrors
          {
            ERR_SPEC_VERSION_INVALID
            ERR_RELEASE_VERSION_INVALID
          }
        }
        
        SequenceGeneration = Unit

        EdrTraceEnabled = False
        EdrTrace
        {
            TraceLog
            {
                 FilePath   = ./log/edrLog
                 FileName   = edrTraceLog
                 FilePrefix = log_
                 FileSuffix = .log
            }

            TraceStartPoint =  Input
            TraceEndPoint   = Output

        } # END EdrTrace

        
      } # end of Output    
      
    } # END TAPOutSettlementPipeline
    
    #--------------------------------------------------------------------------
    # BackOut pipeline.
    #--------------------------------------------------------------------------
    TAPSettlementBkOutPipeline
    {
      Active                      = True
      
      CountryCode                 = 49
      MobileCountryCode           = 262
      NationalAccessCode          = 0
      InternationalAccessCode     = 00
      InternationalAccessCodeSign = +
      NetworkDestinationCode      = 172

      RejectStream                = SuspenseCreateOutput 
      
      TransactionManager
      {
        RedoEnabled = True #False
        SingleTransaction = False
        WriteToLogEnabled = True
        BinaryLogFileName = ./tam/binaryLogFileTAPSettlementBkOutPipeline.dat
      }
      
      EdrFactory 
      { 
        DataConnection = ifw.DataPool.Login 
        Description = ./formatDesc/Formats/TAP3-NG/containerDesc.dsc
        UsageStatistic = ./log/statistic/edrStatisticTAPSettlementBkOutPipeline.txt 
        EdrVersionDataConnection = ifw.DataPool.LoginInfranet
      }

      DataDescription
      {
        Standard
        {
          ModuleName = Standard
          Module
          {
            StreamFormats
            {
              SOL42_FORINPUT          = ./formatDesc/Formats/Solution42/SOL42_V670_REL_FORINPUT.dsc
              EVENT_LOADER            = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER.dsc
              SUSPENSE_CREATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreation.dsc
              SUSPENSE_UPDATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdate.dsc
            }

            InputMapping
            {
              SOL42_FORINPUT          = ./formatDesc/Formats/Solution42/SOL42_V670_REL_InMap.dsc
            }

            OutputMapping
            {
              EVENT_LOADER            = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutMap.dsc
              SUSPENSE_CREATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreationMapping.dsc
              SUSPENSE_UPDATE_OUTPUT  = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdateMapping.dsc
            }
          }
        }
      }
    
      PipelineLog 
      { 
        ModuleName = LOG
        Module 
        { 
          ITO 
          { 
            WriteMessageKey = True
            FilePath        = ./log/pipeline
            FileName        = pipeline_TAPSettlementBkOutPipeline.log
            ProcessName     = ifw
            MessageGroup    = IFW
            ShowOriginator  = TRUE
          }

          Buffer 
          { 
            Size = 500
          } 
        } 
      }

      InputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }

      OutputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }
      
      #------------------------------------------------------------------------
      # Input section
      #------------------------------------------------------------------------
      Input
      {
        UnitsPerTransaction = 1

        InputModule
        {
          ModuleName  = INP_GenericStream
          Module
          {
            DefaultOutput = GSMOutput

            Grammar = ./formatDesc/Formats/Solution42/SOL42_V670_REL_InGrammar_BACKOUT.dsc
            InputStream
            {
              ModuleName = EXT_InFileManager
              Module
              {
                InputPath   = ./data/outcollect/settlement/backout/in
                InputPrefix = test_
                InputSuffix = .edr
 
                DonePath    = ./data/outcollect/settlement/backout/done
                DonePrefix  = test_TAPSettlementBkOutPipeline_
                DoneSuffix  = .done
           
                ErrorPath   = ./data/outcollect/settlement/backout/error
                ErrorPrefix = test_TAPSettlementBkOutPipeline_
                ErrorSuffix = .err

                TempPrefix  = temp_TAPSettlementBkOutPipeline_
                Replace     = TRUE
                InputDirEmptyTimeout = 10
              }
            } # end of InputStream
          }
        } # end of InputModule
      } # end of Input

      #------------------------------------------------------------------------
      # Function section
      #------------------------------------------------------------------------
      Functions 
      {
        BackOut
        {
          FunctionPool
          {            
            #---------------------------------------------------
            # PreSuspense FCT
            #---------------------------------------------------
            PreSuspense
            {
              ModuleName = FCT_PreSuspense
              Module
              {
                Active = True
              }
            }
            
            #--------------------------------------------------
            # Split Output per ServiceCode
            #--------------------------------------------------              
            ServiceOutputSplit
            {
              ModuleName = FCT_EnhancedSplitting
              Module
              {
                Active = True 
                DataConnection = ifw.DataPool.Login 
                DefaultOutput = GSMOutput 
                SystemBrands 
                {  
                    GSMR = GSMOutput
                    GPRSR = GPRSOutput      
                }
              }
            }
             
            #--------------------------------------------------
            # Rejection
            #--------------------------------------------------
            Rejection
            {
              ModuleName = FCT_Reject
              Module
              {
                Active          = True 
                NotifyOnReject  = True 
                UseRejectStream = True
                StreamMap {}
              }
            }

            #---------------------------
            # Suspense FCT
            #---------------------------
            Suspense
            {
              ModuleName  = FCT_Suspense
              Module
              {
                Active = True
                SuspenseCreateStream     = SuspenseCreateOutput
                SuspenseUpdateStream     = SuspenseUpdateOutput
                DataConnection           = ifw.DataPool.LoginInfranet
                LogTestResults           = False
                PipelineCategory         = RoamingPipelines

                RecycleLog
                {
                }
              }
            }
	    
