/******************************************************************************************************************************
 * This function will validate LCSRequestTimestamp. It will raise error code 30 for LCSRequestTimestamp.
 ******************************************************************************************************************************/
 
function validateLCSRequestTimestamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",384";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCSRequestTimestamp", "384", "30", 
		"Mandatory associated item UTC Time Offset Code missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "",
		"Mandatory associated item UTC Time Offset Code missing");  
    edrSetIsValidDetail(false);
  }
  endLocalTimeStamp = addUTCToLocalTimestamp( endLocalTimeStamp, endUTCTimeOffset);
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate LCSQosRequested. It will raise error code 30 for LCSQosRequested.
 ******************************************************************************************************************************/
 
function validateLCSQosRequested ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",383";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "lCSRequestTimestamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLCSRequestTimestamp ( myContext, nMyIndices, "lCSRequestTimestamp", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCS Qos Requested", "383", "30",
                                              "LCS Request Timestamp not present within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                              "LCS Request Timestamp not present within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "horizontalAccuracyRequested";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateHorizontalAccuracyRequested ( myContext, nMyIndices, "horizontalAccuracyRequested", 0, errorContext );
  }
 
  childContext = myContext + "." + "verticalAccuracyRequested";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateVerticalAccuracyRequested ( myContext, nMyIndices, "verticalAccuracyRequested", 0, errorContext );
  }
 
  childContext = myContext + "." + "responseTimeCategory";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateResponseTimeCategory ( myContext, nMyIndices, "responseTimeCategory", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingPeriod";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTrackingPeriod ( myContext, nMyIndices, "trackingPeriod", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingFrequency";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTrackingFrequency ( myContext, nMyIndices, "trackingFrequency", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate LocationServiceUsage. It will raise error code 30, 31 for LocationServiceUsage.
 ******************************************************************************************************************************/
 
function validateLocationServiceUsage ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",382";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "lCSQosRequested";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLCSQosRequested ( myContext, nMyIndices, "lCSQosRequested", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LocationServiceUsage", "382", "30", "Mandatory group LCS QoS Requested missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group LCS QoS Requested missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "lCSQosDelivered";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLCSQosDelivered ( myContext, nMyIndices, "lCSQosDelivered", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargingTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargingTimeStamp ( myContext, nMyIndices, "chargingTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargeInformationList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LocationServiceUsage", "382", "31", "Mandatory group Charging Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory group Charging Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}
 
