/******************************************************************************************************************************
 * This function will validate HomeIdentifier. It will raise error code 100 for HomeIdentifier.
 ******************************************************************************************************************************/
 
function validateHomeIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  Bool   checkType         = true;  
  Long   ret               = -1;
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",288";
  String homeIdentifier = edrStringEx(myContext, indices, nParentIndices); 
  switch( lastHomeIdType )
  {
     case 1:
     {
       ret = strSearchRegExpr(homeIdentifier, "[^A-Za-z ]");
       Long checkSpace = strSearchRegExpr(homeIdentifier, "[A-Za-z]");
       if ( checkSpace < 0  and ret < 0 )
       {
          ret = 0;
       }
     }
     break;
     case 2:
     {
       ret = strSearchRegExpr(homeIdentifier, "[^0-9A-Z]");
       if ( strLength(homeIdentifier) != 5 and ret < 0 )
       {
         ret = 0;
       }
     }
     break;
     case 3:
     {
       ret = strSearchRegExpr(homeIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       ret = strSearchRegExpr(homeIdentifier, "!(.+)");
     }
     break;
  }
  if (ret >= 0)
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Home Identifier", "288", "100", "Item content does not match Home Id Type");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1", "","Item content does not match Home Id Type");
    edrSetIsValidDetail(false);
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

