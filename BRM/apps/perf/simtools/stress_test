###############################################################################
# find_next_date ()
#       input:
#               time from time()         
#       output:
#               string in format mmddhhssyyyy  one month later
###############################################################################
sub find_next_date {
        local ($mytime) = @_;

        $next_date = $mytime + 40 * 24 *3600; # +32days in sec
        ($sec,$min,$hour,$day,$month,$year)=localtime($next_date);
        if ( $year < 1000 ) {
		if ( $year > 70 ) {     # HP algorithm
		    $year = $year + 1900;
		}
		else {
		    $year = $year + 2000;
		}
	}
	$outstr=sprintf ("%02d%02d%02d%02d%04d",$month+1,$day,$hour,$min,$year);
        return ($outstr);
}

###############################################################################
# get_date ()
#       output:
#               string in format MM/DD/YYYY HH:MM:SS
###############################################################################
sub get_date {
	$mytime = time();
                
	($sec,$min,$hour,$day,$month,$year)=localtime($mytime);
        if ( $year < 1000 ) {
		if ( $year > 70 ) {     # HP algorithm
		    $year = $year + 1900;
		}
		else {
		    $year = $year + 2000;
		}
	}
	$outstr=sprintf ("%02d/%02d/%04d %02d:%02d:%02d",$month+1,$day,$year,$hour,$min,$sec);
	return ($outstr);
}

