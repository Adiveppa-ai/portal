            edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalAdvisedChargeRefund", "357", "100", "Value does not match the calculated sum of refund advised charges associated with the same currency");
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "357", "0", "-1", "-1", "","Value does not match the calculated sum of refund advised charges associated with the same currency");
