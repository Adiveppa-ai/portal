 AND("GDTLS_RSTRM_STYPE_T"."USAGE_START_T" >= bipext.infStrToTimet(''' || pTransStartDate || ''', 2)
 AND "GDTLS_RSTRM_STYPE_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
