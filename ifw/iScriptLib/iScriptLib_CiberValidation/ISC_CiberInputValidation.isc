//------------------------------------------------------------------------------
// validateOCCCharge(Long recordType); 
// Cross Validation between 
//    OCC Charge
//    OCC Start Date
//    OCC End Date
//    OCC Interval Indicator
//    OCC Record Use Indicator
//------------------------------------------------------------------------------
function validateOCCCharge(Long recordType) 
{
  if (debug)
    logStdout("validateOCCCharge()\n");

  if ((edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) == 0.00 and
      dateToStr(edrDate(DETAIL.ASS_CIBER_EXT.OCC_START_DATE, 0),"%y%m%d") != "000000" )) {

      if (recordType == 52){
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
        //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
        edrAddError("ERR_CIBER_RET",3,"4","07","051","CIBER25.ASS_CIBER_EXT.OCC_START_DATE");
      }

      if (recordType == 50){
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
        //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
        edrAddError("ERR_CIBER_RET",3,"4","07","007","CIBER25.ASS_CIBER_EXT.OCC_START_DATE");
      }
  }

  if ((edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) == 0.00 and
      dateToStr(edrDate(DETAIL.ASS_CIBER_EXT.OCC_END_DATE, 0),"%y%m%d") != "000000" )) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","207","CIBER25.ASS_CIBER_EXT.OCC_END_DATE");
  }

  if (edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) == 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.OCC_INTERVAL_INDICATOR, 0) != "0" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","210",
		"CIBER25.ASS_CIBER_EXT.OCC_INTERVAL_INDICATOR");
  }

  if (edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) == 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.RECORD_USE_INDICATOR, 0) != "0" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","056",
		"CIBER25.ASS_CIBER_EXT.RECORD_USE_INDICATOR");
  }
// TODO LOOK INTO THIS AGAIN
//  if ((edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) == 0.00 and
//      strToLong(edrString(DETAIL.ASS_CIBER_EXT.OCC_DESCRIPTION, 0) != 0 )) or
//      (edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) != 0.00 and 
//      strToLong(edrString(DETAIL.ASS_CIBER_EXT.OCC_DESCRIPTION, 0) == 0 )))
//      {
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
//      edrAddError("ERR_CIBER_RET",3,"4","07","041","CIBER25.ASS_CIBER_EXT.OCC_DESCRIPTION");
//  }

  return;

}


//------------------------------------------------------------------------------
// validateMobileIdNumber(); 
// Cross validation between 
//     MIN/ESN APP Indicator
//     Mobile Id No length
//     Mobile Id No
//------------------------------------------------------------------------------
function validateMobileIdNumber
{
  if (debug)
    logStdout("validateMobileIdNumber()\n");

  if (edrLong(DETAIL.ASS_CIBER_EXT.MOBILE_ID_NO_LENGTH, 0) == 0 and
      edrString(DETAIL.ASS_CIBER_EXT.MIN_ESN_APP_INDICATOR, 0) == "3" and
      edrString(DETAIL.ASS_CIBER_EXT.MOBILE_ID_NO, 0) != "0000000000" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","005","CIBER25.ASS_CIBER_EXT.MOBILE_ID_NUMBER");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.MIN_ESN_APP_INDICATOR, 0) == "1" or 
      edrString(DETAIL.ASS_CIBER_EXT.MIN_ESN_APP_INDICATOR, 0) == "2" ) and
      edrString(DETAIL.ASS_CIBER_EXT.MOBILE_ID_NO, 0) == "0000000000" ){
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","005","CIBER25.ASS_CIBER_EXT.MOBILE_ID_NUMBER");
  }

  return;
}

//------------------------------------------------------------------------------
// validateESNNumber(); 
// Cross validation between ESN and MIN/ESN APP Indicator
//------------------------------------------------------------------------------
function validateESNNumber
{
  if (debug)
    logStdout("validateESNNumber()\n");

  if (edrString(DETAIL.ASS_CIBER_EXT.MIN_ESN_APP_INDICATOR, 0) == "1" and
      edrString(DETAIL.ASS_CIBER_EXT.ELECTRONIC_SERIAL_NO, 0) == "00000000000" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","006","CIBER25.ASS_CIBER_EXT.ELECTRONIC_SERIAL_NO");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.MIN_ESN_APP_INDICATOR, 0) == "2" or 
      edrString(DETAIL.ASS_CIBER_EXT.MIN_ESN_APP_INDICATOR, 0) == "3" ) and
      edrString(DETAIL.ASS_CIBER_EXT.ELECTRONIC_SERIAL_NO, 0) != "00000000000" ){
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","006","CIBER25.ASS_CIBER_EXT.ELECTRONIC_SERIAL_NO");
  }

  return;
}

//------------------------------------------------------------------------------
// validateMiscSurcharge(); 
// Perform cross field validations between Misc surcharge desc. and
// Misc. surcharge.
//------------------------------------------------------------------------------
function validateMiscSurcharge
{
  if (debug)
    logStdout("validateMiscSurcharge()\n");


  if ((edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) == "0" and
      edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) != 0.00 ) or
      (edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) != "0" and
      edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) == 0.00))
      {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","059","CIBER25.ASS_CIBER_EXT.MISC_SURCHARGE");
  }

  return;
}

//------------------------------------------------------------------------------
// validateMiscSurchargeDesc(); 
// Cross field validations between Special Features Used and Misc Surcharge Desc.
//------------------------------------------------------------------------------
function validateMiscSurchargeDesc
{
  if (debug)
    logStdout("validateMiscSurchargeDesc()\n");


    if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "F") >= 0) and
       (edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) != "A" or 
       edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) != "B" or 
       edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) != "D" or 
       edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) != "E" or 
       edrString(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE_DESC, 0) != "F" )) 
      {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","062","CIBER25.ASS_CIBER_EXT.MISC_SURCHARGE_DESCR");
  }

  return;
}


//------------------------------------------------------------------------------
// validateSSUCharge(); 
// Cross field validation between Special Features Used and SSU charge.
// 
//------------------------------------------------------------------------------
function validateSSUCharge
{

  if (debug)
    logStdout("validateSSUCharge()\n");

  // Get the special features used 
  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "F") >= 0) and 
       edrDecimal(DETAIL.ASS_CIBER_EXT.SSU_CHARGE, 0) != 0.00) {
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","07","026","CIBER25.ASS_CIBER_EXT.SSU_CHARGE");
  }

  return;
}

//------------------------------------------------------------------------------
// validateSpecialFeaturesUsed(); 
// Cross field validations between
//     Special Features Used
//     SSU Charge
//     Toll Charge
//------------------------------------------------------------------------------
function validateSpecialFeaturesUsed
{

  if (debug)
    logStdout("validateSpecialFeaturesUsed()\n");

  
  if (edrDecimal(DETAIL.ASS_CIBER_EXT.SSU_CHARGE, 0) == 0.00 and
      edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) == 0.00 and 
      ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED, 0), "TU") >= 0) or
      (strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED, 0), "UT") >= 0))) {
   
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";   
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","06","018",
		"CIBER25.ASS_CIBER_EXT.SPECIAL_FEATURES_USED");
  }

  return;
}

