my $installlog="Log/pin_setup.log";
if($ENV{'OS_TYPE'} ne "Windows") {
  functions::teelog($installlog,$dotee);
  $ENV{"CFGpipeline_didteelog"}=1; 
}
else {
  open (STDOUT,">".$installlog);
}

#force stuff to go to logfile, even for kiddies
open(STDERR,">&STDOUT") or functions::fulldie "ERROR: STDERR redirect failed";
select(STDERR); $|=1;
select(STDOUT); $|=1;


################################################################################################
# choice #2: we're trying to recover a previous install which broke someplace
my %donesteps=();
my $lastone;
if( $recover_last==1 && open(AIST,"<Log/steptracker.log") ){
  #basically, run updateifw, but skip steps you've already done, then restart the failed one 
  functions::fulldie "None of the steps have been executed!. Please run the pin_setup from the beginning.....\n" if (-z "./Log/steptracker.log");
  %donesteps=map{ chomp; $lastone=$_; ($_,0) } <AIST>;
  delete $donesteps{$lastone};
  close(AIST);
  }


################################################################################################
# choice #3: if we got this far, we must be doing some sort of  pipeline setup
open(AIST,">Log/steptracker.log") || functions::fulldie "ERROR: could not open(Log/steptracker.log)";
select(AIST); $|=1; select(STDOUT); #make sure it's tracked well

# do it... for the children.
$ENV{"perl"}='/home/pin/opt/portal/Thirdparty/perl-5.38.2/bin/perl'unless exists $ENV{"perl"};

if( $runone==1){
   $cmd = "\"$ENV{'perl'}\" \"$RunStep\"";
   $res = system ($cmd);
   if( $res == -1 || $res&128){ $res=255; }
   else{ $res >>= 8; }
   print "\n<-><-><-><-> $zeroprog CALLED $RunStep RETURN $res <-><-><-><->\n";
   functions::fulldie "ERROR: install step failed" if $res;
  }
else{
my $nSteps=functions::RetLength();
print "No of Steps: " ,$nSteps ,"\n";
my $currentStepNo=0;
my $laststep=0;
while ($currentStepNo<$nSteps){
  my $Step=functions::GetStep($currentStepNo);
  $currentStepNo++;

#check if it is in the recover_last mode,and dont execute steps which have been completed earlier  
if(($recover_last == 1) && ($Step eq $lastone))
  {$laststep=1;} 
elsif(($recover_last==1) &&($laststep==0))
  {next;} 
  print "<><><><> $zeroprog CALLING $Step <><><><>\n";
  $cmd = "\"$ENV{'perl'}\" \"$Step\"";
  $es = system ($cmd);
  print AIST "$Step","\n";
  if( $es == -1 || $es&128){ $es=255; }
  else{ $es >>= 8; }
  print "\n<-><-><-><-> $zeroprog CALLED $Step RETURN $es <-><-><-><->\n";
  functions::fulldie "ERROR: install step failed" if $es;
  }
}
#if we got this far, it must be good.
#closedir(IND);
print "\n$zeroprog: pin_setup FINISHED ";
print "\n$zeroprog: exiting pin_setup...\n" if $topinstmode eq $instmode;
print "$zeroprog: returning to caller...\n" if $topinstmode ne $instmode;
functions::stopbgproc();
exit 0;

