}



//------------------------------------------------------------------------------
// validateChargeInformation()
//
// This function will be used to validate the charge Information
//------------------------------------------------------------------------------
function validateChargeInformation
{
  if (debug)
  {
    logStdout("validateChargeInformation()\n");
  }


  Long blockIndex;
  Long packetIndex;
  Long blockEntries;
  Long packetEntries;
  Long service_Index;
  Long chargeTypeIndex;
  String chargeType;
  String service_Type;
  String chargeItem;

  String offset = "-1";

  blockEntries = edrNumDatablocks(DETAIL.ASS_CBD);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long      vals{};
    hashClear (vals);

    packetEntries = edrNumDatablocks(DETAIL.ASS_CBD.CP, blockIndex);
    for (packetIndex = 0; packetIndex < packetEntries; packetIndex = (packetIndex + 1))
    {
      service_Type = edrString(DETAIL.ASS_CBD.CP.RELATED_SERVICE_TYPE,  blockIndex, packetIndex);
      service_Index =  edrLong(DETAIL.ASS_CBD.CP.RELATED_SERVICE_INDEX, blockIndex, packetIndex);
      chargeType =   edrString(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY,       blockIndex, packetIndex);
      chargeItem =   edrString(DETAIL.ASS_CBD.CP.RUM,                   blockIndex, packetIndex);

      if (chargeType == "00" or chargeType == "01" or chargeType == "03" or chargeType == "04" or
           chargeType == "05" or chargeType == "14" or chargeType == "15" or chargeType == "21")
      {
        String tmp = service_Type + longToStr(service_Index) + chargeType + chargeItem;
        if (hashContains(vals, tmp) == true)
        {
               edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
               edrSetIsValidDetail(false);
               edrAddError("ERR_TAP3_RET", 3, "severe",  "37",  "69",  "6",
                         offset, "-1", "More than one occurrence of charge detail");
               setAssociatedTapErr("ERR_TAP3_CHARGE_INFORMATION", 3, "37" ,"69" ,"6");
               return;
        }
        else
        {
          vals{tmp} = 1;
        }
      }
    }
  }
}




//------------------------------------------------------------------------------
// validatePDPContextStartTimeStamp()
//
// This function will be used to validate the gprs PDP context start timestamp
//------------------------------------------------------------------------------
function validatePDPContextStartTimeStamp
{
  if (debug)
  {
    logStdout("validatePDPContextStartTimeStamp()\n");
  }

  String offset;
  offset = "-1";

    Date pdpStartTimeStamp = edrDate(
                         DETAIL.ASS_GPRS_EXT.PDP_CONTEXT_START_TIMESTAMP, 0);
    if (dateIsValid(pdpStartTimeStamp))
    {
      if (dateDiff( edrDate(DETAIL.CHARGING_START_TIMESTAMP), pdpStartTimeStamp) < 0)
      {
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "100", "260", "5",
                offset, "-1", "PDP Context Start Timestamp is later than Call Event Start Timestamp.");
        setAssociatedTapErr("ERR_TAP3_PDP_START_TIME_LATER_THAN_CALL_EVENT_START", LOG_WARNING ,"100" ,"260" ,"5");     
      }

      Date chargeDate = edrDate(
          DETAIL.ASS_GPRS_EXT.SERVICE_USED_CHARGING_START_TIMESTAMP, 0);

      // validate the following only if charging timestamp is available as charging timestamp too is 
      // conditional.
      if (dateIsValid(chargeDate))
      {
        if (dateDiff( chargeDate, pdpStartTimeStamp) < 0)
        {
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "101", "260", "5",
                offset, "-1", "PDP Context Start Timestamp is later than Charging Timestamp.");
          setAssociatedTapErr("ERR_TAP3_PDP_START_TIME_LATER_THAN_CHARGING_START_TIMESTAMP", LOG_WARNING ,"100" ,"260" ,"5");   
        }
      }

      // Raise warning if the partial indicator is the first one or not present
      if ((edrString(DETAIL.LONG_DURATION_INDICATOR) == "F") or (edrString(DETAIL.LONG_DURATION_INDICATOR) == ""))
      {
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET"; 
          edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "31", "260", "5",
                offset, "-1", "PDP Context Start Timestamp and partial type indicator is not present or first one");
          setAssociatedTapErr("ERR_TAP3_PARTIAL_IND_FIRST_OR_NOT_PRESENT", LOG_WARNING ,"31" ,"260" ,"5");
      }

    }
}

//------------------------------------------------------------------------------
// validateCauseForTermination()
//
// This function will be used to validate the cause of termination
//------------------------------------------------------------------------------
function validateCauseForTermination
{
  if (debug)
  {
    logStdout("validateCauseForTermination\n");
  }

  String offset;

  if (edrInternalState(DETAIL.CALL_COMPLETION_INDICATOR) != STATE_CLEARED and edrInputState(DETAIL.CALL_COMPLETION_INDICATOR) != MISSING)
  {
    if (edrString(DETAIL.LONG_DURATION_INDICATOR) == "F" or
		edrString(DETAIL.LONG_DURATION_INDICATOR) == "I")
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.CALL_COMPLETION_INDICATOR));
      offset = "-1";
      edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "100", "58", "5",
		offset, "-1", "Cause for termination present for partial call ");
      setAssociatedTapErr("ERR_TAP3_CAUSE_FOR_TERMINATION_PRESENT_FOR_PARTIAL_CALL", LOG_WARNING ,"100" ,"58" ,"5");	
     }
  }
}

//------------------------------------------------------------------------------
// validateTypeOfControllingNode()
//
// This function will be used to validate Type of Controlling Node for GPRS
//------------------------------------------------------------------------------
function validateTypeOfControllingNode
{
  if (debug)
  {
    logStdout("validateTypeOfControllingNode\n");
  }

  if (edrInternalState(DETAIL.ASS_GPRS_EXT.TYPE_OF_CONTROLLING_NODE,0) != STATE_CLEARED and edrInputState(DETAIL.ASS_GPRS_EXT.TYPE_OF_CONTROLLING_NODE,0) != MISSING)
  {
    Long tmpTypeOfControllingNode = edrLong(DETAIL.ASS_GPRS_EXT.TYPE_OF_CONTROLLING_NODE,0);

    if ( (tmpTypeOfControllingNode < 0) or (tmpTypeOfControllingNode > 3) )
    {
        String offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "229", "4",
                offset, "0", "Type of Controlling Node for GPRS call is out of range");
        setAssociatedTapErr("ERR_TAP3_TYPE_OF_CTRL_NODE_OOR", LOG_MAJOR ,"20" ,"229" ,"4");     
     }
  }
}

//------------------------------------------------------------------------------
// valUMTSQoSReqAndUsedHelper()
//
// Helper function for validating UMTS Qos Requested and Used blocks as both
// these blocks have the same fields.
//------------------------------------------------------------------------------
function valUMTSQoSReqAndUsedHelper ( String UMTSQosReqOrUsed)
{
      String tmpUMTSQosReqOrUsedArray[];
      Long nbElem = strSplit(tmpUMTSQosReqOrUsedArray, UMTSQosReqOrUsed, ",");
      Long i;

      String offset = "-1";
      

      for (i = 0; i < nbElem; i = i+2) //Every even index will contain key, so we jump 2 (i = i+2)
      {
          switch(strToLong(tmpUMTSQosReqOrUsedArray[i]))
          {
             //These case values are defined as follwos in the input grammar
             //  const String QosTrafficClassKey                     = "1";
             //  const String QosMaxBitRateUpLnKey                   = "2";
             //  const String QosMaxBitRateDownLnKey                 = "3";
             //  const String QosGuaranteedBitRateDownLnKey          = "4";
             //  const String QosGuaranteedBitRateUpLnKey            = "5";
             //  const String QosAllocRetenPriorityKey               = "6";

             case 1: // This is QosTrafficClassKey
             {
                  Long tmpQoSTrafficClass = strToLong(tmpUMTSQosReqOrUsedArray[i+1]);
                  if ( (tmpQoSTrafficClass < 0) or (tmpQoSTrafficClass > 4) )
                  {
                      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
                      edrSetIsValidDetail(false);
                      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "268", "6",
                        offset, "0", "Qos Traffic Class value is out of range");
                      setAssociatedTapErr("ERR_TAP3_QOS_TRAFFIC_CLASS_OOR", LOG_MAJOR ,"20" ,"268" ,"6");       
                  }
             }
             break;
             case 2: // This is QosMaxBitRateUpLnKey
             {
                  Long tmpQoSMaxBitRateUpLink = strToLong(strHexStrToStr(tmpUMTSQosReqOrUsedArray[i+1]));
                  if ( (tmpQoSMaxBitRateUpLink < 0) or (tmpQoSMaxBitRateUpLink > 254) )
                  {
                      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
                      edrSetIsValidDetail(false);
                      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "264", "6",
                        offset, "0", "Qos Max Bit Rate Uplink value is out of range");
                      setAssociatedTapErr("ERR_TAP3_QOS_MAX_BIT_RATE_UPLINK_OOR", LOG_MAJOR ,"20" ,"264" ,"6"); 
                  }
             }
             break;
             case 3: // This is QosMaxBitRateDownLnKey
             {
                  Long tmpQoSMaxBitRateDownLink = strToLong(strHexStrToStr(tmpUMTSQosReqOrUsedArray[i+1]));
                  if ( (tmpQoSMaxBitRateDownLink < 0) or (tmpQoSMaxBitRateDownLink > 254) )
                  {
                      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
                      edrSetIsValidDetail(false);
                      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "274", "6",
                        offset, "0", "Qos Max Bit Rate Downlink is out of range");
                      setAssociatedTapErr("ERR_TAP3_QOS_MAX_BIT_RATE_DOWNLINK_OOR", LOG_MAJOR ,"20" ,"274" ,"6");       
                  }
             }
             break;
             case 4: // This is QosGuaranteedBitRateDownLnKey
             {
                  Long tmpQoSGuaranteedBitRateDownLink = strToLong(strHexStrToStr(tmpUMTSQosReqOrUsedArray[i+1]));
                  if ( (tmpQoSGuaranteedBitRateDownLink < 0) or (tmpQoSGuaranteedBitRateDownLink > 254) )
                  {
                      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
                      edrSetIsValidDetail(false);
                      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "283", "6",
                        offset, "0", "Qos Guaranteed Bit Rate Downlink is out of range");
                      setAssociatedTapErr("ERR_TAP3_QOS_GUA_BIT_RATE_DOWNLINK_OOR", LOG_MAJOR ,"20" ,"283" ,"6");       
                  }
             }
             break;
             case 5: // This is QosGuaranteedBitRateUpLnKey
             {
                  Long tmpQoSGuaranteedBitRateUpLink = strToLong(strHexStrToStr(tmpUMTSQosReqOrUsedArray[i+1]));
                  if ( (tmpQoSGuaranteedBitRateUpLink < 0) or (tmpQoSGuaranteedBitRateUpLink > 254) )
                  {
                      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
                      edrSetIsValidDetail(false);
                      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "284", "6",
                        offset, "0", "Qos Guaranteed Bit Rate Uplink is out of range");
                      setAssociatedTapErr("ERR_TAP3_QOS_GUA_BIT_RATE_UPLINK_OOR", LOG_MAJOR ,"20" ,"284" ,"6"); 
                  }
             }
             break;
             case 6: // This is QosAllocRetenPriorityKey
             {
                  Long tmpQoSAllocRetenPriority = strToLong(tmpUMTSQosReqOrUsedArray[i+1]);
                  if ( (tmpQoSAllocRetenPriority < 1) or (tmpQoSAllocRetenPriority > 3) )
                  {
                      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
                      edrSetIsValidDetail(false);
                      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "275", "6",
                        offset, "0", "Qos Allocation Retention Priority value is out of range");
                      setAssociatedTapErr("ERR_TAP3_QOS_ALLOC_RETEN_PRIORITY_OOR", LOG_MAJOR ,"20" ,"275" ,"6");        
                  }
             }
             break;
         }
          
     }
}

//------------------------------------------------------------------------------
// validateUMTSQoSRequestedAndUsed()
//
// This function will be used to validate UMTS Qos Requeseted and Used blocks
//------------------------------------------------------------------------------
function validateUMTSQoSRequestedAndUsed
{
  if (debug)
  {
    logStdout("validateTSQoSRequestedAndUsed\n");
  }

    Long count = 0;
    Long idx = 0;

    count = edrNumDatablocks( DETAIL.ASS_GPRS_EXT.GS_PACKET, 0 );

    for (idx = 0; count > idx; idx = idx + 1)
    {
        if( edrString(DETAIL.ASS_GPRS_EXT.GS_PACKET.UMTS_QOS_REQUESTED, 0, idx) != "")
        {
           valUMTSQoSReqAndUsedHelper(edrString(DETAIL.ASS_GPRS_EXT.GS_PACKET.UMTS_QOS_REQUESTED, 0, idx));
        }

        if( edrString(DETAIL.ASS_GPRS_EXT.GS_PACKET.UMTS_QOS_USED, 0, idx) != "")
        {
           valUMTSQoSReqAndUsedHelper(edrString(DETAIL.ASS_GPRS_EXT.GS_PACKET.UMTS_QOS_USED, 0, idx));
        }
    }
}

//------------------------------------------------------------------------------
// validateGprsCallEventDuration()
//
// This function will be used to validate the gprs call event duration
//------------------------------------------------------------------------------
function validateGprsCallEventDuration
{
  if (debug)
  {
    logStdout("validateGprsCallEventDuration\n");
  }

  String offset;
  Long totalDuration = 24 * 3600;

  if (edrLong(DETAIL.TOTAL_CALL_EVENT_DURATION) >  totalDuration)
  {
    // offset = longToStr(edrFieldTokenBytePos(
    //			DETAIL.TOTAL_CALL_EVENT_DURATION));
    offset = "-1";
    edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "200", "223", "5",
		offset, "-1", "Call Duration is more than 24 hours");
    setAssociatedTapErr("ERR_TAP3_CALL_DUR_GT_24_HOURS", LOG_WARNING ,"200" ,"223" ,"5");	
  }
}


