  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapCharge ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, ACBidx, CPidx) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
  lastCharge = (longToDecimal(edrLongEx( myContext, indices, nParentIndices )) / theAbsoluteAmountDivider);
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapChargeType ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "HEADER" ) == true )
  {
    chargeType[lastCode] = edrStringEx( myContext, indices, nParentIndices );
  }
  else
  {
    edrString(DETAIL.ASS_CBD.TP.CHARGE_TYPE, ACBidx, TPidx) = edrStringEx( myContext, indices, nParentIndices );
    edrString(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, ACBidx, CPidx) = edrStringEx( myContext, indices, nParentIndices );
    lastChargeType = edrStringEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapChargeDetail ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  successiveChargeDetail = successiveChargeDetail + 1;
  initializeChargeDetailTempFields();

  if ( edrAddDatablock( DETAIL.ASS_CBD.CP ) == false )
  {
  }
  CPidx                    = successiveChargePacket;
  successiveChargePacket   = successiveChargePacket   + 1;
  successiveChargePacketCI = successiveChargePacketCI + 1;

  records = records+1;
  edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) = edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) + 1;
  edrString(DETAIL.ASS_CBD.CP.RECORD_TYPE, ACBidx, CPidx) = extension_CP;
  edrLong(DETAIL.ASS_CBD.CP.RECORD_NUMBER, ACBidx, CPidx) = records;
  edrLong(DETAIL.ASS_CBD.CP.RELATED_RECORD_NUMBER, ACBidx, CPidx) = related_record;
  edrLong(DETAIL.ASS_CBD.CP.RELATED_CHARGE_INFO_ID, ACBidx, CPidx) = related_info_id;

  //defaults
  edrString(DETAIL.ASS_CBD.CP.SERVICE_CLASS_USED, ACBidx, CPidx)     = "*";
  edrString(DETAIL.ASS_CBD.CP.PRICEMODEL_TYPE, ACBidx, CPidx)        = "S";
  edrString(DETAIL.ASS_CBD.CP.CHARGE_TYPE, ACBidx, CPidx)            = "N";
  edrString(DETAIL.ASS_CBD.CP.CHARGED_CURRENCY_TYPE, ACBidx, CPidx)  = "R";
  edrString(DETAIL.ASS_CBD.CP.CHARGED_TAX_TREATMENT, ACBidx, CPidx)  = "N";
  edrString(DETAIL.ASS_CBD.CP.RATEPLAN_TYPE, ACBidx, CPidx)          = "W";
                                                                                                             
  childContext = myContext + "." + "chargeType";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapChargeType ( myContext, nMyIndices, "chargeType", 0 );                               
  }                                                                                                          
  else
  {
    lastChargeType = "";
  }
                                                                                                             
  childContext = myContext + "." + "charge";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapCharge ( myContext, nMyIndices, "charge", 0 );                               
  }                                                                                                          
  else
  {
    lastCharge = 0.0;
  }
                                                                                                             
  childContext = myContext + "." + "chargeableUnits";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapChargeableUnits ( myContext, nMyIndices, "chargeableUnits", 0 );                               
  }                                                                                                          
  else
  {
    lastChargeableUnits = 0;
  }
                                                                                                             
  childContext = myContext + "." + "chargedUnits";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapChargedUnits ( myContext, nMyIndices, "chargedUnits", 0 );                               
  }                                                                                                          
  else
  {
    lastChargedUnits = 0;
  }
                                                                                                             
  childContext = myContext + "." + "chargeDetailTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargeDetailTimeStamp ( myContext, nMyIndices, "chargeDetailTimeStamp", 0 );                               
  }                                                                                                          
  else
  {
    lastChargeDetailTimeStamp = lastValidLocalTimeStamp;
  }

  Decimal ChargedAmountValue = (lastCharge * lastExchangeRateFactor);
  edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, ACBidx, CPidx) = ChargedAmountValue;
  edrString(DETAIL.ASS_CBD.CP.RUM, ACBidx, CPidx) = lastChargedItem;

  if ( lastChargeType == "00" )
  {
    lastCPidx_00 = CPidx;
    lastChargedAmountValue_00 = ChargedAmountValue;
    lastChargeableUnits_00 = lastChargeableUnits;
    lastChargedUnits_00 = lastChargedUnits;
  }

  if (bUseLocalCurrency)
  {
    edrString(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_CURRENCY, ACBidx, CPidx) = theLocalCurrency;
    edrDecimal(DETAIL.ASS_CBD.CP.EXCHANGE_RATE, ACBidx, CPidx) = (1.0 / lastExchangeRateFactorValue);
    edrString(DETAIL.ASS_CBD.CP.EXCHANGE_CURRENCY, ACBidx, CPidx) = theTapCurrency;
  }
  else
  {
    edrString(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_CURRENCY, ACBidx, CPidx) = theTapCurrency;
    edrDecimal(DETAIL.ASS_CBD.CP.EXCHANGE_RATE, ACBidx, CPidx) = lastExchangeRateFactorValue;
    edrString(DETAIL.ASS_CBD.CP.EXCHANGE_CURRENCY, ACBidx, CPidx) = theLocalCurrency;
  }

  edrDate(DETAIL.ASS_CBD.CP.CHARGING_START_TIMESTAMP, ACBidx, CPidx) = strToDate(lastChargeDetailTimeStamp);

  if ( service_Type == service_Vas )
  {
    edrString(DETAIL.ASS_CBD.CP.PRODUCTCODE_USED, ACBidx, CPidx) = getVasShortDesc(lastVasCode);
  }
  else if ( service_Type == service_Camel )
  {
    edrString(DETAIL.ASS_CBD.CP.PRODUCTCODE_USED, ACBidx, CPidx) = "CAMEL";
  }

  sumChargedAmountValueCI = sumChargedAmountValueCI + ChargedAmountValue;
  sumChargeableUnitsCI = sumChargeableUnitsCI + lastChargeableUnits;
  sumChargedUnitsCI = sumChargedUnitsCI + lastChargedUnits;

  if (lastChargedItem == "D")
  {
    edrString(DETAIL.ASS_CBD.CP.ROUNDED_QUANTITY_UOM, ACBidx, CPidx) = "SEC";
  }
  else if ((lastChargedItem == "V") or (lastChargedItem == "X"))
  {
    edrString(DETAIL.ASS_CBD.CP.ROUNDED_QUANTITY_UOM, ACBidx, CPidx) = "BYT";
  }
  else if (lastChargedItem == "W")
  {
    edrString(DETAIL.ASS_CBD.CP.ROUNDED_QUANTITY_UOM, ACBidx, CPidx) = "BYT";
  }
  else if (lastChargedItem == "E")
  {
    edrString(DETAIL.ASS_CBD.CP.ROUNDED_QUANTITY_UOM, ACBidx, CPidx) = "CLK";
  }
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapChargeDetailList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "ChargeDetail";                                            
  Long ChargeDetailListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < ChargeDetailListEntries; i = i + 1 )                                                      
  {                                                                                                          
    mapChargeDetail ( myContext, nMyIndices, "ChargeDetail", i );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
