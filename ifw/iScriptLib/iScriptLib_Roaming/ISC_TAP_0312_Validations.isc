/******************************************************************************************************************************
 * This function will validate LCSTransactionStatus. It will raise error code 20 for LCSTransactionStatus.
 ******************************************************************************************************************************/
 
function validateLCSTransactionStatus ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",391";

  lastLCSTransactionStatus = edrLongEx( myContext, indices, nParentIndices );

  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"3" , "1", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCSTransactionStatus", "391", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function calls the validation functions validateLCSTransactionStatus, validateHorizontalAccuracyDelivered, 
 * validateVerticalAccuracyDelivered , validateResponseTime, validatePositioningMethod, validateTrackingPeriod, 
 * validateTrackingFrequency and validateAgeOfLocation. This function also validate LCSQosDelivered. It will raise
 * error code 30, 31 for LCSQosDelivered.
 ******************************************************************************************************************************/
 
function validateLCSQosDelivered ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",390";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "lCSTransactionStatus";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLCSTransactionStatus ( myContext, nMyIndices, "lCSTransactionStatus", 0, errorContext );
  }
 
  childContext = myContext + "." + "horizontalAccuracyDelivered";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateHorizontalAccuracyDelivered ( myContext, nMyIndices, "horizontalAccuracyDelivered", 0, errorContext );
  }
 
  childContext = myContext + "." + "verticalAccuracyDelivered";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateVerticalAccuracyDelivered ( myContext, nMyIndices, "verticalAccuracyDelivered", 0, errorContext );
  }
 
  childContext = myContext + "." + "responseTime";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateResponseTime ( myContext, nMyIndices, "responseTime", 0, errorContext );
  }
 
  childContext = myContext + "." + "positioningMethod";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validatePositioningMethod ( myContext, nMyIndices, "positioningMethod", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingPeriod";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTrackingPeriod ( myContext, nMyIndices, "trackingPeriod", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackingFrequency";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTrackingFrequency ( myContext, nMyIndices, "trackingFrequency", 0, errorContext );
  }
 
  childContext = myContext + "." + "ageOfLocation";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateAgeOfLocation ( myContext, nMyIndices, "ageOfLocation", 0, errorContext );
  }
  else if( lastLCSTransactionStatus == 1 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCSQosDelivered", "390", "31",
                "Item Age Of Location missing from group and LCS Transaction Status contains 'last known location'");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","",
                "Item Age Of Location missing from group and LCS Transaction Status contains 'last known location'");
    edrSetIsValidDetail(false);
  }

  if ( (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.lCSTransactionStatus", indices, nMyIndices) != STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.horizontalAccuracyDelivered", indices, nMyIndices) == STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.verticalAccuracyDelivered", indices, nMyIndices) == STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.responseTime", indices, nMyIndices) == STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.positioningMethod", indices, nMyIndices) == STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.trackingPeriod", indices, nMyIndices) == STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.trackingFrequency", indices, nMyIndices) == STATE_CLEARED) and (edrInternalStateEx("DETAIL.locationService.locationServiceUsage.lCSQosDelivered.ageOfLocation", indices, nMyIndices) == STATE_CLEARED) )
  {
   // FieldName, AppId, ErrorCode,ErrorDescription
   edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCSQosDelivered", "390", "30", 
                                             "Item LCS Transaction Status present and no other items present within group.");
   edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                             "Item LCS Transaction Status present and no other items present within group.");
   edrSetIsValidDetail(false);
  }

 
  //logContext( myContext, nMyIndices );
}

