/******************************************************************************************************************************
 * This function will validate GsmChargeableSubscriber. It will raise error code 30 for GsmChargeableSubscriber.
 ******************************************************************************************************************************/
 
function validateGsmChargeableSubscriber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",286";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  imsiIsMissing      = false;
 
  childContext = myContext + "." + "imsi";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateImsi ( myContext, nMyIndices, "imsi", 0, errorContext );
  }
  else
  {
    imsiIsMissing = true;
  }
 
  childContext = myContext + "." + "msisdn";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMsisdn ( myContext, nMyIndices, "msisdn", 0, errorContext );
  }
  else
  {
    if( imsiIsMissing == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gsm Chargeable Subscriber", "286", "30", 
                                                "Neither IMSI or MSISDN present within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                                "Neither IMSI or MSISDN present within group");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ScuChargeableSubscriber. It will raise error code 30, 31 for ScuChargeableSubscriber. 
 ******************************************************************************************************************************/
 
function validateScuChargeableSubscriber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",430";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  Bool gsmChargeableSubscriberIsMissing;
 
  childContext = myContext + "." + "gsmChargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGsmChargeableSubscriber ( myContext, nMyIndices, "gsmChargeableSubscriber", 0, errorContext );
  }
  else
  {
    gsmChargeableSubscriberIsMissing = true;
  }
 
  childContext = myContext + "." + "minChargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMinChargeableSubscriber ( myContext, nMyIndices, "minChargeableSubscriber", 0, errorContext );
    if ( gsmChargeableSubscriberIsMissing == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuChargeableSubscriber", "430", "31", "Both MIN and GSM Chargeable Subscriber present within group");      
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Both MIN and GSM Chargeable Subscriber present within group");      
      edrSetIsValidDetail(false);
    }    
  }
  else
  {
    if ( gsmChargeableSubscriberIsMissing == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuChargeableSubscriber", "430", "30", "Group empty i.e. no MIN and no GSM Chargeable Subscriber present within group");      
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Group empty i.e. no MIN and no GSM Chargeable Subscriber present within group");      
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ScuBasicInformation. It will raise error code 30, 31, 32, 33, 34 for ScuBasicInformation.
 ******************************************************************************************************************************/

function validateScuBasicInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",191";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "chargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateScuChargeableSubscriber ( myContext, nMyIndices, "chargeableSubscriber", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuBasicInformation", "191", "30", "Mandatory group SCU Chargeable Subscriber missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group SCU Chargeable Subscriber missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargedPartyStatus";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargedPartyStatus ( myContext, nMyIndices, "chargedPartyStatus", 0, errorContext );
  }
  else
  {
    lastChargedPartyStatus = -1;
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuBasicInformation", "191", "31", "Mandatory item Charged Party Status missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory item Charged Party Status missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "nonChargedNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateNonChargedNumber ( myContext, nMyIndices, "nonChargedNumber", 0, errorContext );
  }
  else
  {
    if ( lastChargedPartyStatus == 0  )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuBasicInformation", "191", "32", "Mandatory item Non Charged Number missing within group and Charged Party Status is originating");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Mandatory item Non Charged Number missing within group and Charged Party Status is originating");
      edrSetIsValidDetail(false);
    }
    if ( lastChargedPartyStatus == 1  )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ScuBasicInformation", "191", "33", "Mandatory item Non Charged Number missing within group and Charged Party Status is terminating");
    }
  }
 
  childContext = myContext + "." + "clirIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateClirIndicator ( myContext, nMyIndices, "clirIndicator", 0, errorContext );
  }
  else if ( lastChargedPartyStatus == 1  )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ScuBasicInformation", "191", "34", "Item CLIR Status Indicator missing within group and Charged Party Status is terminating");
  }
 
  childContext = myContext + "." + "originatingNetwork";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateOriginatingNetwork ( myContext, nMyIndices, "originatingNetwork", 0, errorContext );
  }
 
  childContext = myContext + "." + "destinationNetwork";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDestinationNetwork ( myContext, nMyIndices, "destinationNetwork", 0, errorContext );
  }
 
  lastChargedPartyStatus = -1;
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ServiceCentreUsage. It will raise error code 30, 33, 34, 35, 36 for ServiceCentreUsage.
 ******************************************************************************************************************************/
 
function validateServiceCentreUsage ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",12";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "basicInformation";
