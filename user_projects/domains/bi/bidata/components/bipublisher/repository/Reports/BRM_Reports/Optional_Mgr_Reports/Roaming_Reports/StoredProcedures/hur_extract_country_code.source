29401, 30201, 31020, 33078, 40001, 40410, 40411, 41001, 41301, 41302, 41501, 41503, 41601,
41902, 42001, 42203, 42401, 42402, 42501, 42601, 42701, 43405, 45400, 45404, 45406, 45410,
45412, 45416, 45422, 45501, 45601, 46000, 46001, 46601, 46606, 46688, 46692, 46693, 46697,
46699, 50212, 50216, 50217, 50219, 50501, 50502, 50503, 51001, 51010, 51011, 51501, 51502,
52001, 52018, 52501, 52502, 52503, 52811, 53001, 54201, 60201, 60401, 60502, 60801, 61203,
61205, 61701, 63301, 63310, 64001, 64301, 64710, 64801, 64901, 65501, 65510, 73010, 90103,
99009, 99292, 310150, 310160, 310170, 310240, 310270, 781285) 
                THEN
                    v_CountryCode := '+' || SUBSTR(TO_CHAR(TO_NUMBER(CALLED_TO)),1, v_Len);
                    EXIT;
                END IF;
                v_Len := v_Len - 1;
            END LOOP;
      END IF;
    END IF;
    return v_CountryCode;
END extractCountryCode;
/
 
