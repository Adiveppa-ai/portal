<Configuration>
  <Appenders>
    <RollingFile name="RELM" fileName="${sys:RELM_LOG_BASE}.log" filePattern="${sys:RELM_LOG_BASE}.log.%i">
      <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%-5p] [%t] %m%n"/>
      <Policies>
        <SizeBasedTriggeringPolicy size="100MB"/>
      </Policies>
      <DefaultRolloverStrategy max="99"/>
    </RollingFile>
  </Appenders>
  <Loggers>
    <!-- JDBC Pool is in Rated-event-manager -->
    <Logger name="com.oracle.brm.rated_event_manager" level="INFO"/>
    <Logger name="com.oracle.brm.rel_manager" level="INFO"/>
    <Logger name="com.oracle.brm.table_formatter" level="INFO"/>
    <Root level="INFO">
      <AppenderRef ref="RELM"/>
    </Root>
  </Loggers>
</Configuration>
