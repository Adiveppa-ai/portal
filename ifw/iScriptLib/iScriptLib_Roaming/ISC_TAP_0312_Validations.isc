/***********************************************************************
 * function onRollBack
 ***********************************************************************/
function Bool onRollback
{
  
  /* rollback-related actions are defined here. */
  resetGlobalVariables();
  rollbackReason = edrRollbackReason();
  logPipeline( "Rollback invoked - reason: " + rollbackReason + "\n",1);
  return true;	
  
} 
 
 
  
      
