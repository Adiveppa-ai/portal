      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "06" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "08" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "09" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "11" )
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","085","CIBER25.ASS_CIBER_EXT.CHARGE_NO_3_IND");
  }


  return ;
}

//------------------------------------------------------------------------------
// validateChargeNo1SurgInd()
// Cross field validation between
//     Surcharge Indicator
//     Total State Tax
//     Total Local Tax
//     Misc. Surcharge
//------------------------------------------------------------------------------
function validateChargeNo1SurgInd
{
  if (debug)
    logStdout("validateChargeNo1SurgInd()\n");

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "1" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "3" or
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "5" or
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "7" ) and 
      edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) == 0.00)
      {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","095",
		"CIBER25.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "2" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "3" or
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "6" or
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "7" ) and 
      edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0) == 0.00)
      {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","095",
		"CIBER25.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "4" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "5" or
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "6" or
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND, 0) == "7" ) and 
      edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) == 0.00)
      {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","095",
		"CIBER25.ASS_CIBER_EXT.CHARGE_NO_1_SURCHARGE_IND");
  }

  return ;
}

