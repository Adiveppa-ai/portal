/***************************************************************************
 * function validateIpV4
 ***************************************************************************/
function Bool validateIpV4(String ipAddress)
{
  String ListArray[];
  Long nbElem = strSplit( ListArray, ipAddress, "." );
  Long i;
  if(nbElem != 4)
  {
    return false;
  }
  for (i=0 ; i<nbElem ; i=i+1)
  {
    Long found = strSearchRegExpr(ListArray[i], "[^0-9]");
    if(found >= 0)
    {
      return false;
    }
    else
    {
      Long num = strToLong(ListArray[i]);
      if(num < 0 or num >255)
      {
        return false;
      }
    }
  }
  return true;
}


/***************************************************************************
 * function validateIpV6
 ***************************************************************************/
function Bool validateIpV6(String ipAddress)
{
  String ListArray[];
  Long nbElem = strSplit( ListArray, ipAddress, ":" );
  Long i;
  if(nbElem != 8)
  {
    return false;
  }
  for (i=0 ; i<nbElem ; i=i+1)
  {
    if(strLength(ListArray[i]) > 4)
    {
      return false;
    }
    Long found = strSearchRegExpr(ListArray[i], "[^0-9A-Fa-f]");
    if(found >= 0)
    {
      return false;
    }
  }
  return true;
}

/***************************************************************************
 * function validateEmail
 ***************************************************************************/
function Bool validateEmail(String emailAddress)
{
  String ListArray[];
  Long nbElem = strSplit( ListArray, emailAddress, "@" );
  Long i;
  if(nbElem != 2)
  {
    return false;
  }
  for (i=0 ; i<nbElem ; i=i+1)
  {
    Long found = strSearchRegExpr(ListArray[i], "!.+");
    if(found >= 0)
    {
      return false;
    }
  }
  return true;
}

/***************************************************************************
 * function validateMsisdnSE
 ***************************************************************************/
function Bool validateMsisdnSE(String msisdnStr)
{
  if( strSearchRegExpr(msisdnStr, "[^0-9]") >= 0 or strLength(msisdnStr) < 2 or strLength(msisdnStr) > 16)
  {
    return true;
  }
  return false;
}

/***************************************************************************
 * function validateHexValue
 ***************************************************************************/
function Bool validateHexValue(String hexValue)
{
  if( strSearchRegExpr(hexValue, "[^0-9A-F]") >= 0 )
  {
    return true;
  }
  return false;
}


 
function logContext ( String context, Long nIndices )
{
  String msgStr = "Field: " + context + ".";
  Long i;
  for( i = 0; i < nIndices; i = i + 1)
  {
    msgStr = msgStr + longToStr(indices[i]) + ".";
  }
   logStdout( msgStr + "\n");
}
 
function validateOperatorSpecInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",163";
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function calls the validation function validateOperatorSpecInformation for each element of Operator Spec Info List.
 ******************************************************************************************************************************/
 
function validateOperatorSpecInfoList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",162";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "OperatorSpecInformation_Elem";
  Long OperatorSpecInfoListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < OperatorSpecInfoListEntries; i = i + 1 )
  {
    indices[nMyIndices] = i;
    Long nChildIndices  = nMyIndices + 1;
    validateOperatorSpecInformation ( childContext, nChildIndices, "OperatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/*********************************************************************************************************
 * This function will validate File Type Indicator and Batch Control Info. It will raise error code 10, 20
 * for File Type Indicator and error code 38 for Batch Control Info.
 ********************************************************************************************************/

function validateFileTypeIndicator ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",110";
  
  theFileTypeIndicator = edrStringEx( myContext, indices, nParentIndices );
  String fileName = strSubstr(tapFileName, 0, 1);
  Long StrtoAscii_1 = strByteValue(fileName);
  Long StrtoAscii_2 = strByteValue(theFileTypeIndicator);
  Long StrtoAscii_3 = strByteValue("T");

  if( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
  {
    if((StrtoAscii_2 == StrtoAscii_3) and (StrtoAscii_1 != StrtoAscii_3)) 
    {
      rollbackReason = "BatchControlInfo," + "1,4" + ",38" + ":" + BatchControlInfoStr;  

      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "38", "FileTypeIndicator Mismatch");      
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "38", "4", "0", "-1", "-1", "","FileTypeIndicator Mismatch");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }

  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHA_UPPER") == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 1) )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",10" + ":" + BatchControlInfoStr;  
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",10" + ":" + NotificationStr;  
    }

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "File Type Indicator", "110", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "110", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if(  edrStringEx(myContext, indices, nParentIndices) != "T" )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;  
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;  
    }
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "File Type Indicator", "110", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "110", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/***********************************************************************************************************
 * This function will validate Release Version Number. It will raise error code 20 for ReleaseVersionNumber.
 **********************************************************************************************************/
 
function validateReleaseVersionNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",189";
  
  if( edrLongEx(myContext, indices, nParentIndices) != 12 )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;  
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;  
    }      
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "ReleaseVersionNumber", "189", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "189", "0", "-1", "-1", "","Value out of range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/***********************************************************************************************************************
 * This function will validate Specification Version Number. It will raise error code 20 for SpecificationVersionNumber.
 **********************************************************************************************************************/

function validateSpecificationVersionNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",201";
  
  if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;  
  }
  else
  {
    rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;  
  }  

  if( edrLongEx(myContext, indices, nParentIndices) != 3 )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;  
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;  
    }   
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "SpecificationVersionNumber", "201", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "201", "0", "-1", "-1", "","Value out of range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/***********************************************************************************************************************
 * This function will validate UtcTimeOffsetInfo and UtcTimeOffset . It will raise error code 32 and 33 for UtcTimeOffsetInfo
 * and error code 10, 11, 12, 13, 14, 15, 16, 20, 21, 22, 23, 24, 25, 26 for UtcTimeOffset.
 **********************************************************************************************************************/
 
function validateUtcTimeOffset ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{

  String errorDescription1 = "";
  String errorDescription2 = "";
  Long applicationTag = 0;
  String severity = "";
  String errorCode1 = "";
  String errorCode2 = "";
  Long logType    = 0;
  applicationTag = 231; // Will be taken from the built in fn tag hierarchy
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",231";
  String utcTimeOffsetStr = edrStringEx( myContext, indices, nParentIndices );

 
  if( strStartsWith(parentContext, "HEADER.networkInfo") == true )
  {
    if ( utcTimeOffsetIsDuplicate == false )
    {
      utcTimeOffset[ lastCode ] = edrStringEx( myContext, indices, nParentIndices );
    }
    else
    {
      if( utcTimeOffset[ lastCode ] != utcTimeOffsetStr )
      {
        rollbackReason = "NetworkInfo" + "1 ,6 ,234 ,233" + ",32" + ":" + NetworkInfoStr;

        edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "UtcTimeOffsetInfo", "233", "32", "More than one occurrence of group with same UTC Time Offset Code where UTC Time Offset is not the same");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "233", "0", "-1", "-1","", "More than one occurrence of group with same UTC Time Offset Code where UTC Time Offset is not the same");
        edrDemandRollback(rollbackReason);
        edrSetIsValidDetail(false);
      }
      else
      {
        rollbackReason = "NetworkInfo" + "1 ,6 ,234 ,233" + ",33" + ":" + NetworkInfoStr;

        edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "UtcTimeOffsetInfo", "233", "33", "More than one occurrence of group with same UTC Time Offset Code where UTC Time Offset is the same");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "233", "0", "-1", "-1", "","More than one occurrence of group with same UTC Time Offset Code where UTC Time Offset is the same");
        edrDemandRollback(rollbackReason);
        edrSetIsValidDetail(false);
      }
    }
  }

  if ( strStartsWith(parentContext, "HEADER.notification") == true )
  {
    errorDescription1 = "Syntax error";
    errorDescription2 = "Value out of range";
    errorCode1 = "10"; 
    errorCode2 = "20";
    severity = "ERR_TAP3_WARNING";
    logType = 3;
  }
  else if ( strStartsWith(parentContext, "HEADER.networkInfo") == true )
  {
    errorDescription1 = "Syntax error";
    errorDescription2 = "Value out of range";
    errorCode1 = "11"; 
    errorCode2 = "21";
    severity = "ERR_TAP3_FATAL";
    logType = 4;
  }
  else if( strStartsWith(parentContext, "HEADER.batchControlInfo.fileCreationTimeStamp") == true )
  {
    errorDescription1 = "Syntax error and associated item is File Creation Timestamp";
    errorDescription2 = "Value out of range and associated item is File Creation Timestamp";
    errorCode1 = "12"; 
    errorCode2 = "22";
    severity = "ERR_TAP3_WARNING";
    logType = 3;
  }
  else if( strStartsWith(parentContext, "HEADER.batchControlInfo.transferCutOffTimeStamp") == true )
  {
    errorDescription1 = "Syntax error and associated item is Transfer Cut Off Timestamp";
    errorDescription2 = "Value out of range and associated item is Transfer Cut Off Timestamp";
    errorCode1 = "13"; 
    errorCode2 = "23";
    severity = "ERR_TAP3_WARNING";
    logType = 3;
  }
  else if( strStartsWith(parentContext, "HEADER.batchControlInfo.fileAvailableTimeStamp") == true )
  {
    errorDescription1 = "Syntax error and associated item is File Available Timestamp";
    errorDescription2 = "Value out of range and associated item is File Available Timestamp";
    errorCode1 = "14"; 
    errorCode2 = "24";
    severity = "ERR_TAP3_FATAL";
    logType = 4;
  }
  
  else if( strStartsWith(parentContext, "TRAILER.auditControlInfo.earliestCallTimeStamp") == true )
  {
    errorDescription1 = "Syntax error and associated item is Earliest Call Timestamp";
    errorDescription2 = "Value out of range and associated item is Earliest Call Timestamp";
    errorCode1 = "15"; 
    errorCode2 = "25";
    severity = "ERR_TAP3_WARNING";
    logType = 3;
  }
  else if( strStartsWith(parentContext, "TRAILER.auditControlInfo.latestCallTimeStamp") == true )
  {
    errorDescription1 = "Syntax error and associated item is Latest Call Timestamp";
    errorDescription2 = "Value out of range and associated item is Latest Call Timestamp";
    errorCode1 = "16"; 
    errorCode2 = "26";
    severity = "ERR_TAP3_WARNING";
    logType = 3;
  }
  
  
  Long utcTimeOffsetVal   = strToLong(utcTimeOffsetStr);
  String mmUtcTimeOffset        = strSubstr(utcTimeOffsetStr,3,2);
  String First_char = strSubstr(utcTimeOffsetStr,0,1);
  String Rest_chars = strSubstr(utcTimeOffsetStr,1,4);
  
  if ( ( strLength(utcTimeOffsetStr) != 5 ) 
    or ( ( First_char != "+" ) and ( First_char != "-" ) ) 
    or ( strSearchRegExpr(Rest_chars, "[^0-9]") >= 0 ) )
  {
    edrAddError(severity, logType, "UtcTimeOffset", "231", errorCode1, errorDescription1);
    if ( severity == "ERR_TAP3_FATAL" )
    {
      rollbackReason = "NetworkInfo," + errorContext + errorCode1 + ":" + NetworkInfoStr;
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", errorCode1, "231", "0", "-1", "-1", "",errorDescription1);
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
  else if( ( utcTimeOffsetVal  > 1300 ) 
        or ( utcTimeOffsetVal  < -1300 )
        or (strToLong(mmUtcTimeOffset) % 15 != 0 ) )
  {
    edrAddError(severity, logType, "UtcTimeOffset", "231", errorCode2, errorDescription2);
    if ( severity == "ERR_TAP3_FATAL" )
    {
      rollbackReason = "NetworkInfo," + errorContext + errorCode2 + ":" + NetworkInfoStr;
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", errorCode2, "231", "0", "-1", "-1", "",errorDescription2);
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
  else
  {
    if( strStartsWith(parentContext, "HEADER") == true )
    {
      if( strEndsWith(parentContext, "fileCreationTimeStamp") == true )
      {
        creationDateUTC = edrStringEx( myContext, indices, nParentIndices );
      }
      if( strEndsWith(parentContext, "transferCutOffTimeStamp") == true )
      {
        cutOffDateUTC = edrStringEx( myContext, indices, nParentIndices );
      }  
      if( strEndsWith(parentContext, "fileAvailableTimeStamp") == true )
      { 
        availableDateUTC = edrStringEx( myContext, indices, nParentIndices ); 
      }
    }
	
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/***********************************************************************************************************************
 * This function will validate timeStamp. It will raise error code 10 for TransferCutOffTimeStamp, error code 10, 100 for
 * PDPContextStartTimestamp, error code 10, 100 for LatestCallTimestamp , error code 10, 100 for EarliestCallTimeStamp, 
 * error code 10, 100 for FileCreationTimeStamp, error code 10, 11, 100, 101, 102, 103, 104, 105 for FileAvailableTimestamp,
 * error code 10 for ChargingTimeStamp, error code 10 for ChargeDetailTimeStamp, error code 10 for CallEventStartTimeStamp, 
 * error code 20 for LCSRequestTimestamp, error code 100, 101 for ActualDeliveryTimeStamp, error code 100, 101 for 
 * RequestedDeliveryTimeStamp, error code 100, 101 for OrderPlacedTimeStamp.
 **********************************************************************************************************************/
 
function validateLocalTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  //errorContext = errorContext + ",16";
  String localTimeStampStr = edrStringEx( myContext, indices, nParentIndices );


  if( dateIsValid(strToDate(localTimeStampStr)) == false or strLength(localTimeStampStr) != 14 )
  {
    if( strStartsWith(parentContext, "HEADER.batchControlInfo.transferCutOffTimeStamp") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",10" + ":" + BatchControlInfoStr; 

      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferCutOffTimeStamp", "227", "10", "Syntax error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "227", "0", "-1", "-1", "","Syntax error");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else if( strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation.pDPContextStartTimestamp") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "PDPContextStartTimestamp", "260", "10", "Syntax error");
    }
    else if( strStartsWith(parentContext, "TRAILER.auditControlInfo.latestCallTimeStamp") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "LatestCallTimestamp", "133", "10", "Syntax error");  
    }
    else if( strEndsWith(parentContext, "fileCreationTimeStamp") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileCreationTimeStamp", "108", "10", "Syntax error");
    }
    else if( strStartsWith(parentContext, "HEADER.batchControlInfo.fileAvailableTimeStamp") == true )
    {
    rollbackReason = "BatchControlInfo," + errorContext + ",10" + ":" + BatchControlInfoStr; 

    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "FileAvailableTimestamp", "107", "10", "Syntax error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "107", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
    }
    else if( strStartsWith(parentContext, "HEADER.notification") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileAvailableTimestamp", "107", "11", "Syntax error");
    }
    else if( strStartsWith(parentContext, "TRAILER.auditControlInfo.earliestCallTimeStamp") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "EarliestCallTimeStamp", "101", "10", "Syntax error");      
    }
    else if( strEndsWith(parentContext, "chargingTimeStamp") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargingTimeStamp", "74", "10", "Syntax error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error"); 
      edrSetIsValidDetail(false);
    }
    else if( strEndsWith(parentContext, "chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetailTimeStamp", "410", "10", "Syntax error"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error"); 
      edrSetIsValidDetail(false);
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicCallInformation.callEventStartTimeStamp") == true or 
             strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicCallInformation.callEventStartTimeStamp") == true or
             strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation.callEventStartTimeStamp") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallEventStartTimeStamp", "44", "10", "Syntax error"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error"); 
      edrSetIsValidDetail(false);
    }
    else if ( strStartsWith(parentContext, "DETAIL.locationService.locationServiceUsage.lCSQosRequested.lCSRequestTimestamp") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCSRequestTimestamp", "384", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
	else if ( strStartsWith(parentContext, "DETAIL.messagingEvent.serviceStartTimestamp") == true  or
	          strStartsWith(parentContext, "DETAIL.mobileSession.serviceStartTimestamp") == true)
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Service Start Timestamp", "447", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  else
  {
    if( strStartsWith(parentContext, "HEADER") == true )
    {
      if( strEndsWith(parentContext, "fileCreationTimeStamp") == true )
      {
        creationDate = strToDate(edrStringEx( myContext, indices, nParentIndices ));
      }
      if( strEndsWith(parentContext, "transferCutOffTimeStamp") == true )
      {
        cutOffDate = strToDate(edrStringEx( myContext, indices, nParentIndices ));
      }  
      if( strEndsWith(parentContext, "fileAvailableTimeStamp") == true )
      { 
        availableDate = strToDate(edrStringEx( myContext, indices, nParentIndices )); 
      }
    }

    if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicCallInformation.callEventStartTimeStamp") == true or
        strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicCallInformation.callEventStartTimeStamp") == true or
        strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation.callEventStartTimeStamp") == true )
    {
      lastCallEventStartTimeStamp = edrStringEx(myContext, indices, nParentIndices);
    }
    
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or strStartsWith(parentContext, "DETAIL.gprsCall.gprsServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or strStartsWith(parentContext, "DETAIL.locationService.locationServiceUsage.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed.chargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true )
    {
      lastChargeDetailTimeStamp = edrStringEx(myContext, indices, nParentIndices);
    }
  
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicServiceUsedList.BasicServiceUsed.chargingTimeStamp") == true
        or strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicServiceUsedList.BasicServiceUsed.chargingTimeStamp")
        == true or strStartsWith(parentContext, "DETAIL.locationService.locationServiceUsage.chargingTimeStamp") == true or
        strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed.chargingTimeStamp") == true ) 
    {
      lastChargingTimeStamp = edrStringEx(myContext, indices, nParentIndices);
    }

    if( strStartsWith(parentContext, "DETAIL.locationService.locationServiceUsage.lCSQosRequested.lCSRequestTimestamp") == true )
    {
      lastLcsRequestTimestamp = edrStringEx(myContext, indices, nParentIndices);
    } 

    if ( strStartsWith(parentContext, "DETAIL.contentTransaction.contentServiceUsed.ContentServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true )  
    {
      lastChargeDetailTimeStamp = edrStringEx( myContext, indices, nParentIndices );
      if( (dateDiff(strToDate(lastChargeDetailTimeStamp), strToDate(lastActualDeliveryTimeStamp)) < 0) and 
          (contentChargingPoint == 3) and (lastChargeDetailTimeStamp != "") and (lastActualDeliveryTimeStamp != "") )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
	objTag = "1,3,17,304,302";
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ActualDeliveryTimeStamp", "302", "100", "Actual Delivery Timestamp after associated Charge Detail timestamp");  
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", objTag, "0", "-1", "-1", "","Actual Delivery Timestamp after associated Charge Detail timestamp");
        edrSetIsValidDetail(false);
      }
      else if( (dateDiff(strToDate(lastChargeDetailTimeStamp), strToDate(lastActualDeliveryTimeStamp)) < 0) and 
               (contentChargingPoint != 3) and (lastChargeDetailTimeStamp != "") and (lastActualDeliveryTimeStamp != "") )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ActualDeliveryTimeStamp", "302", "101", "Actual Delivery Timestamp after associated Charge Detail timestamp and timestamp not referenced as Charging Point");  
      }
      if ( (dateDiff(strToDate(lastChargeDetailTimeStamp), strToDate(lastRequestedDeliveryTimeStamp)) < 0) and 
           (contentChargingPoint == 2) and (lastChargeDetailTimeStamp != "") and (lastRequestedDeliveryTimeStamp != "") )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        objTag = "1,3,17,304,301";
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RequestedDeliveryTimeStamp", "301", "100", "Requested Delivery Timestamp after associated Charge Detail timestamp and timestamp referenced as Charging Point");  
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", objTag, "0", "-1", "-1", "","Requested Delivery Timestamp after associated Charge Detail timestamp and timestamp referenced as Charging Point");  
        edrSetIsValidDetail(false);
      }
      else if ( (dateDiff(strToDate(lastChargeDetailTimeStamp), strToDate(lastRequestedDeliveryTimeStamp)) < 0) and 
                (contentChargingPoint != 2) and (lastChargeDetailTimeStamp != "") and (lastRequestedDeliveryTimeStamp != "") )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "RequestedDeliveryTimeStamp", "301", "101", "Requested Delivery Timestamp after associated Charge Detail timestamp and timestamp not referenced as Charging Point");  
      }
      if ( (dateDiff(strToDate(lastChargeDetailTimeStamp), strToDate(lastOrderPlacedTimeStamp)) < 0) and 
           (contentChargingPoint == 1) and (lastChargeDetailTimeStamp != "") and (lastOrderPlacedTimeStamp != "") )
      {
        objTag = "1,3,17,304,300";
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "OrderPlacedTimeStamp", "300", "100", "Order Placed Timestamp after associated Charge Detail timestamp and timestamp referenced as Charging Point");  
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", objTag, "0", "-1", "-1", "","Order Placed Timestamp after associated Charge Detail timestamp and timestamp referenced as Charging Point");  
        edrSetIsValidDetail(false);
      }
      else if ( (dateDiff(strToDate(lastChargeDetailTimeStamp), strToDate(lastOrderPlacedTimeStamp)) < 0) and 
                (contentChargingPoint != 1) and (lastChargeDetailTimeStamp != "") and (lastOrderPlacedTimeStamp != "") )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "OrderPlacedTimeStamp", "300", "101", "Order Placed Timestamp after associated Charge Detail timestamp and timestamp not referenced as Charging Point");  
      }      
    }
    
    if ( strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation.callEventStartTimeStamp") == true ) 
    {
      lastGprsCallEventStartTimeStamp = localTimeStampStr;
    }    
    else if ( strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation.pDPContextStartTimestamp") == true ) 
    {
      if ( dateIsValid( strToDate(lastGprsCallEventStartTimeStamp)) == true and 
              dateDiff( strToDate(lastGprsCallEventStartTimeStamp), strToDate(localTimeStampStr)) < 0  )
      {
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "PDP Context Start Timestamp", "260", "100", "PDP Context Start Timestamp is later than Call Event Start Timestamp");
      }
    }

  }
  
    if( strStartsWith(parentContext, "DETAIL") == true )
    {
      if( ( strEndsWith(parentContext, "callEventStartTimeStamp") == true ) or 
	      ( strEndsWith(parentContext, "completionTimeStamp") == true ) or
	      ( strEndsWith(parentContext, "lCSRequestTimestamp") == true ) or
	      ( strEndsWith(parentContext, "actualDeliveryTimeStamp") == true ) or
	      ( strEndsWith(parentContext, "supplServiceEvent.supplServiceUsed.chargingTimeStamp") == true  ) )
      {
        endLocalTimeStamp = edrStringEx( myContext, indices, nParentIndices );
      }
    }

  if ( strStartsWith(parentContext, "DETAIL.contentTransaction.contentTransactionBasicInfo.requestedDeliveryTimeStamp") == true )
  {
    lastRequestedDeliveryTimeStamp = edrStringEx( myContext, indices, nParentIndices );
  }
  if ( strStartsWith(parentContext, "DETAIL.contentTransaction.contentTransactionBasicInfo.actualDeliveryTimeStamp") == true )
  {
    lastActualDeliveryTimeStamp = edrStringEx( myContext, indices, nParentIndices );
  }
  if ( strStartsWith(parentContext, "DETAIL.contentTransaction.contentTransactionBasicInfo.orderPlacedTimeStamp") == true )
  {
    lastOrderPlacedTimeStamp = edrStringEx( myContext, indices, nParentIndices );
  }
  if( strStartsWith(parentContext,"DETAIL.serviceCentreUsage.scuTimeStamps.completionTimeStamp") == true )
  {
    lastCompletionTimeStamp = edrStringEx(myContext, indices, nParentIndices);
  }
  if( strStartsWith(parentContext, "DETAIL.serviceCentreUsage.scuTimeStamps.depositTimeStamp") == true )
  {
    lastDepositTimeStamp = edrStringEx(myContext, indices, nParentIndices);
  }

  if( strStartsWith(parentContext, "DETAIL") == true )
  {
    timeStampArray[detailTimeStampEntries] = edrStringEx(myContext, indices, nParentIndices);
    detailTimeStampEntries = detailTimeStampEntries + 1;
  }
  if( strStartsWith(parentContext, "TRAILER.auditControlInfo.earliestCallTimeStamp") == true )
  {
    Long i;
    String minDate;
    minDate = timeStampArray[0];
    for ( i = 1; i < detailTimeStampEntries; i = i + 1 )
    {
      if( dateDiff( strToDate(minDate), strToDate(timeStampArray[i]) ) > 0 )
      {
        minDate = timeStampArray[i];
      }
    }

    if( dateDiff ( strToDate(minDate), strToDate(edrStringEx(myContext, indices, nParentIndices)) ) != 0 )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Earliest Call Timestamp", "101", "100",
                                     "The timestamp does not match the timestamp of the earliest Call Event Detail Timestamp");
    }
  }
  if( strStartsWith(parentContext, "TRAILER.auditControlInfo.latestCallTimeStamp") == true )
  {
    Long i;
    String maxDate;
    maxDate = timeStampArray[0];
    for ( i = 1; i < detailTimeStampEntries; i = i + 1 )
    {
      if( dateDiff( strToDate(maxDate), strToDate(timeStampArray[i]) ) < 0 )
      {
        maxDate = timeStampArray[i];
      }
    }

    if( dateDiff ( strToDate(maxDate), strToDate(edrStringEx(myContext, indices, nParentIndices)) ) != 0 )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Latest Call Timestamp", "133", "100",
                                     "The timestamp does not match the timestamp of the latest Call Event Detail Timestamp");
    }
  }


  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/***********************************************************************************************************************
 * This function will validate TransferCutOffTimeStamp . It will raise error code 30 for TransferCutOffTimeStamp
 **********************************************************************************************************************/
 
function validateTransferCutOffTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",227";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffset";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0, errorContext );
  }
  else
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",30" + ":" + BatchControlInfoStr;

    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferCutOffTimeStamp", "227", "30", 
                                             "Mandatory associated item UTC Time Offset missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "227", "0", "-1", "-1","",
                                             "Mandatory associated item UTC Time Offset missing");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/***********************************************************************************************************************
 * This function will validate FileAvailableTimestamp. It will raise error code 30, 31 for FileAvailableTimestamp
 **********************************************************************************************************************/ 

function validateFileAvailableTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",107";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffset";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0, errorContext );
  }
  else
  {
    if( strStartsWith(parentContext, "HEADER.notification") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileAvailableTimestamp", "107", "31", "Mandatory associated item UTC Time Offset missing");
    }
    else
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",30" + ":" + BatchControlInfoStr; 
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "FileAvailableTimestamp", "107", "30", "Mandatory associated item UTC Time Offset missing");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "107", "0", "-1", "-1", "","Mandatory associated item UTC Time Offset missing");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }

  }
  
  Date currentProcessingTime = sysdate();
  if ( (dateToStr(availableDate) != "") or (availableDateUTC == "") )
  {
    availableDate = strToDate(addUTCToLocalTimestamp(dateToStr(availableDate),availableDateUTC));
  }
  if ( (dateToStr(cutOffDate) != "") or (cutOffDateUTC == "") )
  {
    cutOffDate = strToDate(addUTCToLocalTimestamp(dateToStr(cutOffDate),cutOffDateUTC));
  }
  if ( (dateToStr(creationDate) != "") or (creationDateUTC == "") )
  {
    creationDate = strToDate(addUTCToLocalTimestamp(dateToStr(creationDate),creationDateUTC));
  }
  
  if( (dateToStr(availableDate) != "") or (dateToStr(cutOffDate) != "") )
  {
    if ( (dateDiff(availableDate,cutOffDate) < 0) and (strStartsWith(parentContext, "HEADER.notification") == true) )
    { 
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileAvailableTimestamp", "107", "102", 
                                      "Timestamp is earlier than the Transfer Cut Off Timestamp");
    }
  
    if ( (dateDiff(availableDate,cutOffDate) < 0) and (strStartsWith(parentContext, "HEADER.batchControlInfo") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      rollbackReason = "BatchControlInfo," + "1 ,4 ,107" + ",100" + ":" + BatchControlInfoStr;
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "FileAvailableTimestamp", "107", "100",                 
                                    "Timestamp is earlier than the Transfer Cut Off Timestamp");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "107", "0", "-1", "-1","",
                                    "Timestamp is earlier than the Transfer Cut Off Timestamp");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
  
  if( (dateToStr(availableDate) != "") or (dateToStr(creationDate) != "") )
  {
    if (dateDiff(availableDate,creationDate) < 0) 
    {
      if( strStartsWith(parentContext, "HEADER.notification") == true )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileAvailableTimestamp", "107", "103",
                                        "Timestamp is earlier than the File Creation Timestamp");
      }
      else if( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileAvailableTimestamp", "107", "101",
                                        "Timestamp is earlier than the File Creation Timestamp");
      }
    }
  }
  
  if (dateDiff(availableDate,currentProcessingTime) > 0 and (dateToStr(availableDate) != "")) 
  {
    if( strStartsWith(parentContext, "HEADER.notification") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileAvailableTimestamp", "107", "105",
                                      "Timestamp is after the file received time at the HPMN");
    }
    else if( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + "1 ,4 ,107" + ",104" + ":" + BatchControlInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "FileAvailableTimestamp", "107", "104",
                                      "Timestamp is after the file received time at the HPMN");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "104", "107", "0", "-1", "-1","",
                                      "Timestamp is after the file received time at the HPMN");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
  
  if( (dateToStr(creationDate) != "") or (dateToStr(cutOffDate) != "") )
  {
    if ( dateDiff(creationDate,cutOffDate) < 0 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileCreationTimestamp", "108", "100",  
                                     "Timestamp is earlier than the Transfer Cut Off Timestamp");
    }
  }

  creationDateUTC = "";
  cutOffDateUTC = "";
  availableDateUTC = "";
  
  //logContext( myContext, nMyIndices );
}

/***********************************************************************************************************************
 * This function will validate FileCreationTimeStamp. It will raise error code 30 for FileCreationTimeStamp
 **********************************************************************************************************************/ 

function validateFileCreationTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",108";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffset";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "FileCreationTimeStamp", "108", "30", "Mandatory associated item UTC Time Offset missing");
  }
 
  //logContext( myContext, nMyIndices );
}

/***********************************************************************************************************************
 * This function will validate RapFileSequenceNumber. It will raise error code 10, 11, 20, 21 for RapFileSequenceNumber
 **********************************************************************************************************************/
 
function validateRapFileSequenceNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",181";
  
  if( ( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true ) or 
        ( strLength(edrStringEx(myContext, indices, nParentIndices)) != 5 ) )
  {  
    if (  strStartsWith(parentContext, "DETAIL") == true )  
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RapFileSequenceNumber", "181", "11", "Syntax error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", errorContext, "0", "-1", "-1", "","Syntax error"); 
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "RapFileSequenceNumber", "181", "10", "Syntax error");
    }   
  }
  else if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"99999" , "1", "INTEGER_TYPE") == true )
  {
    if (  strStartsWith(parentContext, "DETAIL") == true )  
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RapFileSequenceNumber", "181", "21", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "RapFileSequenceNumber", "181", "20", "Value out of range");
    }  
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/***********************************************************************************************************************
 * This function will validate FileSequenceNumber. It will raise error code 10, 20, 100 for FileSequenceNumber
 **********************************************************************************************************************/
 
function validateFileSequenceNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",109";
  Long fileSequenceNumber = strToLong(edrStringEx(myContext, indices, nParentIndices));
  Long sequenceNumberOnFile = strToLong(strSubstr(tapFileName, 12, 5));
  

  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 5 ) )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    { 
      rollbackReason = "BatchControlInfo," + errorContext + ",10" + ":" + BatchControlInfoStr;    
    } 
    else
    { 
      rollbackReason = "Notification," + errorContext + ",10" + ":" + NotificationStr;    
    }

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "File Sequence Number", "109", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "109", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason); 
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "99999", "1", "INTEGER_TYPE") == true)
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {  
      rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;    
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;
    }

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "File Sequence Number", "109", "20", "Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "109", "0", "-1", "-1", "","Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
 
  }
  else if( fileSequenceNumber != sequenceNumberOnFile )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {  
      rollbackReason = "BatchControlInfo," + errorContext + ",100" + ":" + BatchControlInfoStr;    
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",100" + ":" + NotificationStr;
    }

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "File Sequence Number", "109", "100",
                                             "The item does not match the File Sequence Number on the filename");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "109", "0", "-1", "-1","",
                                             "The item does not match the File Sequence Number on the filename");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/***********************************************************************************************************************
 * This function will validate Recipient. It will raise error code 10, 20, 100 for Recipient.
 **********************************************************************************************************************/
 
function validateRecipient ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",182";
  String recipientFileName = strSubstr(tapFileName, 7, 5);
  Long i;  
  Bool recipientPresent = false;
  
  if ( (strLength(edrStringEx(myContext, indices, nParentIndices)) != 5) or 
         (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHANUMERIC_UPPER") == true) )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",10" + ":" + BatchControlInfoStr;  
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",10" + ":" + NotificationStr;  
    }  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Recipient", "182", "10", "Syntax error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "182", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else
  {
    for( i = 0; i < numOfPlmnoCode and recipientPresent == false; i = i + 1 )
    {
      if( PLMNOCode[i] == edrStringEx(myContext, indices, nParentIndices) )
      {
        recipientPresent = true;
      }
    }

    if ( recipientPresent == false )
    {
      if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
      {
        rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;  
      }
      else
      {
        rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;  
      }  
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Recipient", "182", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "182", "0", "-1", "-1","", "Value out of range");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    if ( edrStringEx(myContext, indices, nParentIndices) != recipientFileName )
    {
      if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
      {
        rollbackReason = "BatchControlInfo," + errorContext + ",100" + ":" + BatchControlInfoStr;  
      }
      else
      {
        rollbackReason = "Notification," + errorContext + ",100" + ":" + NotificationStr;  
      }  
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Recipient", "182", "100", "The item does not match the Recipient on the filename.");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "182", "0", "-1", "-1", "","The item does not match the Recipient on the filename.");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/***********************************************************************************************************************
 * This function will validate Sender. It will raise error code 10, 20, 100 for Sender.
 **********************************************************************************************************************/
 
function validateSender ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",196";
  String senderFileName = strSubstr(tapFileName, 2, 5); 
  Long i;  
  Bool senderPresent = false;

  if ( (strLength(edrStringEx(myContext, indices, nParentIndices)) != 5) or 
         (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHANUMERIC_UPPER") == true) )
  {
    if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",10" + ":" + BatchControlInfoStr;  
    }
    else
    {
      rollbackReason = "Notification," + errorContext + ",10" + ":" + NotificationStr;  
    }  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Sender", "196", "10", "Syntax error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "196", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else
  {
    for( i = 0; i < numOfPlmnoCode and senderPresent == false; i = i + 1 )
    {
      if( PLMNOCode[i] == edrStringEx(myContext, indices, nParentIndices) )
      {
        senderPresent = true;
      }
    }

    if ( senderPresent == false )
    {
      if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
      {
        rollbackReason = "BatchControlInfo," + errorContext + ",20" + ":" + BatchControlInfoStr;  
      }
      else
      {
        rollbackReason = "Notification," + errorContext + ",20" + ":" + NotificationStr;  
      }      
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Sender", "196", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "196", "0", "-1", "-1", "","Value out of range");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    if ( edrStringEx(myContext, indices, nParentIndices) != senderFileName )
    {
      if ( strStartsWith(parentContext, "HEADER.batchControlInfo") == true )
      {
        rollbackReason = "BatchControlInfo," + errorContext + ",100" + ":" + BatchControlInfoStr;  
      }
      else
      {
        rollbackReason = "Notification," + errorContext + ",100" + ":" + NotificationStr;  
      } 
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Sender", "196", "100", "The item does not match the Sender on the filename.");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "196", "0", "-1", "-1", "","The item does not match the Sender on the filename.");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }  
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/**************************************************************************************************************************
 * This function will validate Notification and SpecificationVersionNumber. It will raise error code 30, 31, 32, 33, 35, 36 
 * for Notification and error code 30 for SpecificationVersionNumber.
 **************************************************************************************************************************/
 
function validateNotification ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  Long startIndex;
  Long endIndex;
  Long i;
  String childContext;
  String originalBlock;
  childContext = myContext + "." + "sender";


  startIndex = edrLong(HEADER.NOTIFICATION_START_INDEX);
  endIndex   = edrLong(TRAILER.NOTIFICATION_END_INDEX);
  originalBlock = "";
  for( i = startIndex; i <= endIndex; i = i + 1 )
  {
    originalBlock = originalBlock + edrTokenString(i);
  }
  NotificationStr = strStrToHexStr(originalBlock);


  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSender ( myContext, nMyIndices, "sender", 0, errorContext );
  }
  else
  {
    rollbackReason = "Notification," + errorContext + ",30" + ":" + NotificationStr;  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Notification", "2", "30", "Mandatory item Sender missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "2", "0", "-1", "-1", "","Mandatory item Sender missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "recipient";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecipient ( myContext, nMyIndices, "recipient", 0, errorContext );
  }
  else
  {
    rollbackReason = "Notification," + errorContext + ",31" + ":" + NotificationStr;  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Notification", "2", "31", "Mandatory item Recipient missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "2", "0", "-1", "-1", "","Mandatory item Recipient missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "fileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateFileSequenceNumber ( myContext, nMyIndices, "fileSequenceNumber", 0, errorContext );
  }
  else
  {
    rollbackReason = "Notification," + errorContext + ",32" + ":" + NotificationStr;  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Notification", "2", "32", "Mandatory item File Sequence Number missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "2", "0", "-1", "-1", "","Mandatory item File Sequence Number missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "fileCreationTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateFileCreationTimeStamp ( myContext, nMyIndices, "fileCreationTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "fileAvailableTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateFileAvailableTimeStamp ( myContext, nMyIndices, "fileAvailableTimeStamp", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Notification", "2", "35", "Mandatory item File Available Timestamp missing within group"); 
  }
 
  childContext = myContext + "." + "transferCutOffTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTransferCutOffTimeStamp ( myContext, nMyIndices, "transferCutOffTimeStamp", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Notification", "2", "36", "Mandatory item Transfer Cut Off Timestamp missing within group");
  }
 
  childContext = myContext + "." + "specificationVersionNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSpecificationVersionNumber ( myContext, nMyIndices, "specificationVersionNumber", 0, errorContext );
  }
  else
  {
    rollbackReason = "Notification," + errorContext + ",33" + ":" + NotificationStr;  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Notification", "2", "33", "Mandatory item Specification Version Number missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "2", "0", "-1", "-1", "","Mandatory item Specification Version Number missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "releaseVersionNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateReleaseVersionNumber ( myContext, nMyIndices, "releaseVersionNumber", 0, errorContext );
  }
  else
  {
    rollbackReason = "Notification," + "2,196,30" + ":" + NotificationStr;  
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "SpecificationVersionNumber", "201", "30", "Mandatory associated item Release Version Number missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "201", "0", "-1", "-1","", "Mandatory associated item Release Version Number missing");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "fileTypeIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateFileTypeIndicator ( myContext, nMyIndices, "fileTypeIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/**************************************************************************************************************************
 * This function will validate CallEventDetailsCount. It will raise error code 20, 100 for CallEventDetailsCount.
 **************************************************************************************************************************/
 
function validateCallEventDetailsCount ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",43";

  if ( edrLongEx( myContext, indices, nParentIndices ) <= 0 )
  {
     rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;

     // FieldName, AppId, ErrorCode,ErrorDescription
     edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CallEventDetailsCount", "43", "20", "Call Event Details Count Out Of Range");    
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "43", "0", "-1", "-1", "","Call Event Details Count Out Of Range");
     edrDemandRollback(rollbackReason);
     edrSetIsValidDetail(false);
  }
  if ( edrLongEx(myContext, indices, nParentIndices) != callEventDetailCount )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CallEventDetailsCount", "43", "100", 
                                             "Value does not match the count of Call Event Details");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "43", "0", "-1", "-1","",
                                             "Value does not match the count of Call Event Details");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/**************************************************************************************************************************
 * This function will validate Total Commission Refund. It will raise error code 20, 100 for Total Commission Refund.
 **************************************************************************************************************************/
 
function validateTotalCommissionRefund ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",359";
  Long i;

  String totalCommissionRefundStr = longToStr(edrLongEx( myContext, indices, nParentIndices ));

  if( edrLongEx(myContext, indices, nParentIndices) <= 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Total Commission Refund", "359", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "359", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else  
  { 
    if( advCurrencyEntriesRefund == 0 )
    {
      for ( i = 0 ; i < advCurrencyEntries; i = i + 1 )
      {
        if ( lastAdvisedChargeCurrency == advChargeCurrency_Arr[i] )
        {
          if ( totalCalcCommissionRefund_Arr[i] != strToLong(totalCommissionRefundStr) )
          {    
            rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
            edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Total Commission Refund", "359", "100", "Value does not match the calculated sum of refund commision associated with the same currency");
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "359", "0", "-1", "-1","", "Value does not match the calculated sum of refund commision associated with the same currency");
            edrDemandRollback(rollbackReason);
            edrSetIsValidDetail(false);
          }
        }
      }
    }
    else
    {
      for ( i = 0 ; i < advCurrencyEntriesRefund; i = i + 1 )
      {
        if ( lastAdvisedChargeCurrency == advChargeCurrencyRefund_Arr[i] )
        {
          if ( totalCalcCommissionRefund_Arr[i] != strToLong(totalCommissionRefundStr) )
          {     
            rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
            edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Total Commission Refund", "359", "100", "Value does not match the calculated sum of refund commision associated with the same currency");
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "359", "0", "-1", "-1", "","Value does not match the calculated sum of refund commision associated with the same currency");
            edrDemandRollback(rollbackReason);
            edrSetIsValidDetail(false);
          }
        }
      }
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/**************************************************************************************************************************
 * This function will validate Total Commission. It will raise error code 20, 100 for Total Commission. 
 **************************************************************************************************************************/
 
function validateTotalCommission ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",358";
  Long i;
  String totalCommissionStr = longToStr(edrLongEx( myContext, indices, nParentIndices ));

  if( edrLongEx(myContext, indices, nParentIndices) <= 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalCommission", "358", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "358", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else  
  {
    for ( i = 0 ; i <= advCurrencyEntries; i = i + 1 )
    {
      if ( lastAdvisedChargeCurrency == advChargeCurrency_Arr[i] )
      {
        if ( totalCalcCommission_Arr[i] != strToLong(totalCommissionStr) )
        {
          rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
          edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalCommission", "358", "100", "Value does not match the calculated sum of non refund commision associated with the same currency");
          edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "358", "0", "-1", "-1", "","Value does not match the calculated sum of non refund commision associated with the same currency");
          edrDemandRollback(rollbackReason);
          edrSetIsValidDetail(false);
        }
      }
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

