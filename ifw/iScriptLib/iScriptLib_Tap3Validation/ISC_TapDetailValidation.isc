      }
      else
      {
        typeID = edrLong(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.NETWORK_LIST.TYPE, 0, 0, blockIndex); 
	if ((typeID < 1) or (typeID > 5))
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.NETWORK_LIST.TYPE,
	  //	0, 0, blockIndex));
	  offset = "-1";
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", "331", "6",
		offset, longToStr(blockIndex), "Out Of Range Location Network Type");
          setAssociatedTapErr("ERR_TAP3_OOR_LOCATION_NETWORK_TYPE", LOG_MAJOR ,"21" ,"331" ,"6");	
	}
      }

      if ((edrInputState(
		DETAIL.ASS_LOCN_EXT.LCSSP_INFO.NETWORK_LIST.IDENTIFIER,
		0, 0, blockIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_LOCN_EXT.LCSSP_INFO.NETWORK_LIST.IDENTIFIER,
	//	0, 0, blockIndex));
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "332", "5",
		offset, longToStr(blockIndex), "Missing Location Network Identifier");
        setAssociatedTapErr("ERR_TAP3_MISSING_LOCATION_NETWORK_ID", LOG_MAJOR ,"33" ,"332" ,"5");	
      }
    }
  }
}


