###############################################################################
# find_param_value()
#       input:
#               file
#               prefix (dm, cm etc.)
#               parameter                      
###############################################################################
sub find_param_value {
        local ($file, $prefix, $param) = @_;

        if ($DEBUG) {
                printout("$ME: prefix $prefix; parameter: $param\n");
        }

        #
        # Open file for input
        #
        open (FILE, "$file") ||
            die "$ME: Unable to open file '$file': $!\n";
       $value = "";

       while (<FILE>) {
                $line = $_;
                if ($line =~ m/^\s*-*\s*$prefix\s+/) {
                   @words=split(/[\t ]+/,$line);
                   $count = 1;
                   while ( $count <= @words ) {
                         if ( $words[$count-1] eq $param ) {
                           $value = $words[$count];
			   if ( $value =~m/\n/) {
                           	chop($value);
		           }
                           if ($DEBUG) {
                                  printout("$ME:    Found parameter $param; value = $value\n");
                           }
                           last;
                         }
                         $count++;
                   }
                 }
        } # end while
        #
        # Close filehandles
        #
        close(FILE);
        if ($DEBUG) {
                printout("$ME:    Return value: $value\n");
        }

        return $value;
}
###############################################################################
# fix_pinconf()
#	input:
#		pinconf_file
#		prefix (dm, cm etc.)
#		assoc array of pinconf entries      
###############################################################################
sub fix_pinconf { 
	local ($file, $prefix, %PINCONF) = @_;
	local ($tmpoutfile) = "$file.xxx";
	local %MATCHES = ();

	if ($DEBUG) {
		printout("$ME: prefix $prefix\n");
	}


        #
        # Open pin.conf for output
        # Open pin.conf.xxx for input
        #
        open (FILE, "$file") ||
            die "$ME: Unable to open file '$file': $!\n";
        open (OUTFILE, ">$tmpoutfile") ||
            die "$ME: Unable to create file '$tmpoutfile': $!\n";
 
	
	# Read entries from pin.conf
	# If line matches key to be substituted, transform
	# Write line to pin.conf.xxx
	# 

	while (<FILE>) {
		$line = $_;
		$matched = 0;

		foreach $pinkey (keys(%PINCONF)) {
			if ($line =~ m/^\s*-\s+$prefix\s+$pinkey\s+/) {
				$matched = 1;
				$MATCHES{$pinkey} = 1;
				if ($DEBUG) {
					printout("$ME:    Replacing key $pinkey\n");
				}
				print OUTFILE "- $prefix $pinkey $PINCONF{$pinkey}\n";
			}
		} # end foreach

		if ($matched == 0) {
			print OUTFILE "$line";
		}

	} # end while

	#
	# Walk through all the non-matched pinconf entries in PINCONF
	# and output them.
	#
	foreach $pinkey (keys(%PINCONF)) {
		if (! exists $MATCHES{$pinkey}) {
			if ($DEBUG) {
				printout("$ME:    Adding key $pinkey\n");
			}
			print OUTFILE "- $prefix $pinkey $PINCONF{$pinkey}\n";
		}
	}

	#
	# Close filehandles
	# 
	close(FILE); 
	close(OUTFILE); 

	if ($DEBUG) {
		printout("$ME:    Renaming $tmpoutfile to $file\n");
	}
	
	#
	# Moving pin.conf.xxx to pin.conf
	#
        unlink "$file";
        (rename "$tmpoutfile", "$file") ||
            die "$ME: Cannot rename $tmpoutfile to $file: $!\n";

}

###############################################################################
# fix_pin_setup()
#	input:
#		pin_setup.values_file
#		flag: 0 - initial non scoping, 1- scoping
###############################################################################
sub fix_pin_setup { 
	local ($file, $flag) = @_;
	local ($tmpoutfile) = "$file.xxx";
	local %MATCHES = ();


        #
        # Open pin.setup.values for output
        # Open pin.setup.values.xxx for input
        #
        open (FILE, "$file") ||
            die "$ME: Unable to open file '$file': $!\n";
        open (OUTFILE, ">$tmpoutfile") ||
            die "$ME: Unable to create file '$tmpoutfile': $!\n";
 
	# Read entries from pinsetup.values
	# If line matches key to be substituted, transform
	# Write line to pin.setup.values.xxx
	# 

	while (<FILE>) {
		$line = $_;

		if ($line =~ m/SETUP_DROP_ALL_TABLES/) {
			if ($DEBUG) {
				printout("$ME:    Replacing SETUP_DROP_ALL_TABLES\n");
			}
			print OUTFILE "\$SETUP_DROP_ALL_TABLES = \"Yes\";\n";
			next;
		}

		if ($line =~ m/COMPONENT_LIST/) {
		  if ($line !~ m/cmmp/) {  #full component list?
			if ($DEBUG) {
				printout("$ME:    Replacing COMPONENT_LIST\n");
			}
			print OUTFILE "\@COMPONENT_LIST  = ( \"radius\" ,\"archiving\", \"dm_email\", \"answer_fusa\", \"dm_fusa\", \"dm_taxware\", \"infmgr\", \"infmgr_cli\", \"nmgr\", \"pin_inv\", \"pin_billd\", \"testnap\", \"dm_$DBSERVER\", \"js\", \"cmmp\", \"cm\" );\n";
			next;
		  }
		}

		if ($line =~ m/enforce_scoping/) {
			if ($DEBUG) {
				printout("$ME:    Replacing enforce_scoping\n");
			}
			print OUTFILE "\$MAIN_CM{'enforce_scoping'} = \"$flag\";\n";
			next;
		}

		print OUTFILE "$line";

	} # end while

	#
	# Close filehandles
	# 
	close(FILE); 
	close(OUTFILE); 

	if ($DEBUG) {
		printout("$ME:    Renaming $tmpoutfile to $file\n");
	}
	
	#
	# Moving pin.setup.values.xxx to pin.setup.values
	#
        unlink "$file";
        (rename "$tmpoutfile", "$file") ||
            die "$ME: Cannot rename $tmpoutfile to $file: $!\n";

}
