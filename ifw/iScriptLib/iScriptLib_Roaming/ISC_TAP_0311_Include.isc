  {                                                                                                          
    mapBatchControlInfo ( myContext, nMyIndices, "batchControlInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "accountingInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapAccountingInfo ( myContext, nMyIndices, "accountingInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "networkInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapNetworkInfo ( myContext, nMyIndices, "networkInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "messageDescriptionInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMessageDescriptionInfoList ( myContext, nMyIndices, "messageDescriptionInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "callEventDetails";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapCallEventDetailList ( myContext, nMyIndices, "callEventDetails", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "auditControlInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapAuditControlInfo ( myContext, nMyIndices, "auditControlInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
