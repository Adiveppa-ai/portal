   NULL                                     EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   NULL                                     OUTPUT_STREAM,
   NULL                                     REVENUE_STREAM,
   NULL                                     SERVICE_TYPE,
   SUSPENSE_CODE                            SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   NULL                                     UOUTPUT_STREAM,
   NULL                                     UREVENUE_STREAM,
   NULL                                     USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   13                                       POID_VAL
FROM((("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0")
INNER JOIN "GDTLS_SUSPENSE_T" "GDTLS_SUSPENSE_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_SUSPENSE_T"."OBJ_ID0";
	  end if;	 

    RETURN l_cursor;
  EXCEPTION
      WHEN INVALID_FLOW_TYPE       THEN
          RAISE_APPLICATION_ERROR (-20001, 'Flow Type Cannot be NULL');
      WHEN INVALID_CONTROL_POINT   THEN
          RAISE_APPLICATION_ERROR (-20002, 'Control Type Cannot be NULL');
	WHEN INVALID_RANGE           THEN
          RAISE_APPLICATION_ERROR (-20003, 'Invalid Range for Batch Type');
     return l_cursor;
  END RARatingSummary;

FUNCTION RARatingDetail(
              	pStartDate 		IN VARCHAR2,
			pEndDate 		IN VARCHAR2,
			pTransStartDate 	IN VARCHAR2,
			pTransEndDate 	IN VARCHAR2,
              	pFlowType 		IN VARCHAR2,
              	pControlPoint 	IN VARCHAR2,
              	pServiceType 	IN VARCHAR2,
              	pBatchID 		IN VARCHAR2,
                	pReportType     	IN VARCHAR2,
              	pSuccess 		IN VARCHAR2,
              	pSuspense 		IN VARCHAR2,
              	pWrittenOff 	IN VARCHAR2,
                  pRaScope           IN VARCHAR2       )RETURN RARating.refcursor IS
                      l_cursor RARating.refcursor;
      MyQuery                       QUERY_TYPE;
      INVALID_ARGUMENT              EXCEPTION;
      INVALID_BATCH_ID              EXCEPTION;
      INVALID_FLOW_TYPE             EXCEPTION;
      INVALID_CONTROL_POINT         EXCEPTION;

      EDR_STATUS              VARCHAR2(256):=NULL;
      TOTAL_COUNT             VARCHAR2(256):=NULL;
      TOTAL_DURATION          VARCHAR2(256):=NULL;
      OLD_RETAIL_AMOUNT       VARCHAR2(256):=NULL;
      TOTAL_RETAIL_AMOUNT     VARCHAR2(256):=NULL;
      TOTAL_DISCOUNT_VALUE    VARCHAR2(256):=NULL;
      OLD_DISCOUNT_VALUE      VARCHAR2(256):=NULL;
      BATCH_TYPE              VARCHAR2(256):=NULL;
      PROCESS_NAME            VARCHAR2(256):=NULL;
      BATCH_ID                VARCHAR2(256):=NULL;
      original_batch_id       VARCHAR2(256):=NULL;
      suspended_from_batch_id VARCHAR2(256):=NULL;
      -- Variable declaration for RA02 Dynamic data
      success_recycle_count_ra02    NUMBER(10, 2) := 0;
      success_static_count_ra02     NUMBER(10, 2) := 0;
      failed_static_count_ra02      NUMBER(10, 2) := 0;
      writtenoff_count_ra02         NUMBER(10, 2) := 0;
      flag_rerate_recycle_ra02      NUMBER(10, 2) := 0;
      flag_writtenoff_ra02          NUMBER(10, 2) := 0;

      success_recycle_duration_ra02 NUMBER(10, 2) := 0;
      success_static_duration_ra02  NUMBER(10, 2) := 0;
      failed_static_duration_ra02   NUMBER(10, 2) := 0;
      writtenoff_duration_ra02      NUMBER(10, 2) := 0;

      success_recycle_amount_ra02   NUMBER(10, 2) := 0;
      success_static_amount_ra02    NUMBER(10, 2) := 0;
      failed_static_amount_ra02     NUMBER(10, 2) := 0;
      success_rerating_amount_ra02  NUMBER(10, 2) := 0;
      failed_rerating_amount_ra02   NUMBER(10, 2) := 0;
      CurrentAmount_ra02            NUMBER(10, 2) := 0;

      -- Variable declaration for RA10 Dynamic data
      success_recycle_count_ra10    NUMBER(10, 2) := 0;
      success_static_count_ra10     NUMBER(10, 2) := 0;
      failed_static_count_ra10      NUMBER(10, 2) := 0;
      writtenoff_count_ra10         NUMBER(10, 2) := 0;
      flag_rerate_recycle_ra10      NUMBER(10, 2) := 0;
      flag_writtenoff_ra10          NUMBER(10, 2) := 0;

      success_recycle_duration_ra10 NUMBER(10, 2) := 0;
      success_static_duration_ra10  NUMBER(10, 2) := 0;
      failed_static_duration_ra10   NUMBER(10, 2) := 0;
      writtenoff_duration_ra10      NUMBER(10, 2) := 0;

      success_recycle_amount_ra10   NUMBER(10, 2) := 0;
      success_static_amount_ra10    NUMBER(10, 2) := 0;
      failed_static_amount_ra10     NUMBER(10, 2) := 0;
      success_rerating_amount_ra10  NUMBER(10, 2) := 0;
      failed_rerating_amount_ra10   NUMBER(10, 2) := 0;
      CurrentAmount_ra10            NUMBER(10, 2) := 0;

      -- Variable declaration for RA04 Dynamic data
      success_recycle_count_ra04    NUMBER(10, 2) := 0;
      success_static_count_ra04     NUMBER(10, 2) := 0;
      failed_static_count_ra04      NUMBER(10, 2) := 0;
      writtenoff_count_ra04         NUMBER(10, 2) := 0;
      flag_rerate_recycle_ra04      NUMBER(10, 2) := 0;
      flag_writtenoff_ra04          NUMBER(10, 2) := 0;

      success_recycle_duration_ra04 NUMBER(10, 2) := 0;
      success_static_duration_ra04  NUMBER(10, 2) := 0;
      failed_static_duration_ra04   NUMBER(10, 2) := 0;
      writtenoff_duration_ra04      NUMBER(10, 2) := 0;

      success_recycle_amount_ra04   NUMBER(10, 2) := 0;
      success_static_amount_ra04    NUMBER(10, 2) := 0;
      failed_static_amount_ra04     NUMBER(10, 2) := 0;
      success_rerating_amount_ra04  NUMBER(10, 2) := 0;
      failed_rerating_amount_ra04   NUMBER(10, 2) := 0;
      CurrentAmount_ra04            NUMBER(10, 2) := 0;

      -- Variable declaration for RA08 Dynamic data
      success_recycle_count_ra08    NUMBER(10, 2) := 0;
      success_static_count_ra08     NUMBER(10, 2) := 0;
      failed_static_count_ra08      NUMBER(10, 2) := 0;
      writtenoff_count_ra08         NUMBER(10, 2) := 0;
      flag_rerate_recycle_ra08      NUMBER(10, 2) := 0;
      flag_writtenoff_ra08          NUMBER(10, 2) := 0;

      success_recycle_duration_ra08 NUMBER(10, 2) := 0;
      success_static_duration_ra08  NUMBER(10, 2) := 0;
      failed_static_duration_ra08   NUMBER(10, 2) := 0;
      writtenoff_duration_ra08      NUMBER(10, 2) := 0;

      success_recycle_amount_ra08   NUMBER(10, 2) := 0;
      success_static_amount_ra08    NUMBER(10, 2) := 0;
      failed_static_amount_ra08     NUMBER(10, 2) := 0;
      success_rerating_amount_ra08  NUMBER(10, 2) := 0;
      failed_rerating_amount_ra08   NUMBER(10, 2) := 0;
      CurrentAmount_ra08            NUMBER(10, 2) := 0;

      -- Variable declaration for RA14 Dynamic data
      success_recycle_count_ra14    NUMBER(10, 2) := 0;
      success_static_count_ra14     NUMBER(10, 2) := 0;
      failed_static_count_ra14      NUMBER(10, 2) := 0;
      writtenoff_count_ra14         NUMBER(10, 2) := 0;
      flag_rerate_recycle_ra14      NUMBER(10, 2) := 0;
      flag_writtenoff_ra14          NUMBER(10, 2) := 0;

      success_recycle_duration_ra14 NUMBER(10, 2) := 0;
      success_static_duration_ra14  NUMBER(10, 2) := 0;
      failed_static_duration_ra14   NUMBER(10, 2) := 0;
      writtenoff_duration_ra14      NUMBER(10, 2) := 0;

      success_recycle_amount_ra14   NUMBER(10, 2) := 0;
      success_static_amount_ra14    NUMBER(10, 2) := 0;
      failed_static_amount_ra14     NUMBER(10, 2) := 0;
      success_rerating_amount_ra14  NUMBER(10, 2) := 0;
      failed_rerating_amount_ra14   NUMBER(10, 2) := 0;
      CurrentAmount_ra14            NUMBER(10, 2) := 0;

      -- Variable declaration for RA06 Dynamic data
      success_recycle_count_ra06    NUMBER(10, 2) := 0;
      success_static_count_ra06     NUMBER(10, 2) := 0;
      failed_static_count_ra06      NUMBER(10, 2) := 0;
      writtenoff_count_ra06         NUMBER(10, 2) := 0;
      flag_rerate_recycle_ra06      NUMBER(10, 2) := 0;
      flag_writtenoff_ra06          NUMBER(10, 2) := 0;

      success_recycle_duration_ra06 NUMBER(10, 2) := 0;
      success_static_duration_ra06  NUMBER(10, 2) := 0;
      failed_static_duration_ra06   NUMBER(10, 2) := 0;
      writtenoff_duration_ra06      NUMBER(10, 2) := 0;

      success_recycle_amount_ra06   NUMBER(10, 2) := 0;
      success_static_amount_ra06    NUMBER(10, 2) := 0;
      failed_static_amount_ra06     NUMBER(10, 2) := 0;
      success_rerating_amount_ra06  NUMBER(10, 2) := 0;
      failed_rerating_amount_ra06   NUMBER(10, 2) := 0;
      CurrentAmount_ra06            NUMBER(10, 2) := 0;

      BEGIN

      IF ( pBatchID is NULL ) THEN
         RAISE INVALID_BATCH_ID;
      END IF;
      IF (pFlowType is NULL) THEN
         RAISE INVALID_FLOW_TYPE;
      END IF;
      IF (pControlPoint is NULL) THEN
         RAISE INVALID_CONTROL_POINT;
      END IF;

     IF pReportType = 'NO' THEN

-- This query corresponds to RA_11 scenario where the grouping is based on
-- outputstream and object type is /process_audit/batchstat/outputstream
MyQuery(1) := 'SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   NULL                                     EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   OUTPUT_STREAM                            OUTPUT_STREAM,
   NULL                                     REVENUE_STREAM,
   NULL                                     SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   UPPER(OUTPUT_STREAM)                     UOUTPUT_STREAM,
   NULL                                     UREVENUE_STREAM,
   NULL                                     USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   1                                        POID_VAL
FROM(("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "GDTLS_OSTRM_T" "GDTLS_OSTRM_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_OSTRM_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"= ''' || pFlowType  || '''
 AND "PROC_AUD_T"."PROCESS_NAME"= ''' || pControlPoint || '''
 AND "GDTLS_OSTRM_T"."ORIGINAL_BATCH_ID" = ''' || pBatchID || '''
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet(''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND("GDTLS_OSTRM_T"."USAGE_START_T" >= bipext.infStrToTimet(''' || pTransStartDate || ''', 2)
 AND "GDTLS_OSTRM_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)))
 AND bipext.infCheckDates(''' || pStartDate || ''', ''' || pEndDate || ''') = 1
 AND bipext.infCheckDates(''' || pTransStartDate || ''', ''' || pTransEndDate || ''') = 1
 AND "PROC_AUD_T"."VERSION_ID" = 4';


-- This query corresponds to RA_03 scenario where the grouping is based on
-- Service Type and object type is /process_audit/batchstat/svctype
MyQuery(2) := ' SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		        OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
