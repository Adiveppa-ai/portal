 ******************************************************************************************************************************/
 
function validateTrackedCustomerInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",367";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
