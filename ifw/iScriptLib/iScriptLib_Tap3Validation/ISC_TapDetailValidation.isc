//------------------------------------------------------------------------------
// validateContentServiceUsed()
//
// This function will be used to validate the content service used
//------------------------------------------------------------------------------
function validateContentServiceUsed
{
  if (debug)
  {
    logStdout("validateContentServiceUsed\n");
  }

  Long typeID;
  Long blockIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if ((edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE,
		0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE,
      //	0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "352", "4",
		offset, longToStr(blockIndex), "Missing Content Transaction Code");
      setAssociatedTapErr("ERR_TAP3_MISSING_CONTENT_TRANS_CODE", LOG_MAJOR ,"30" ,"352" ,"4");	
    }
    else
    {
      typeID = edrLong(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE,
		0, blockIndex);
      if ((typeID < 0) or (typeID > 7))
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE,
	//	0, blockIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "336", "5",
		offset, longToStr(blockIndex), "Out Of Range Content Transaction Code");
        setAssociatedTapErr("ERR_TAP3_OOR_CONTENT_TRANS_CODE", LOG_MAJOR ,"20" ,"336" ,"5");	
      }
    }

    if ((edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE,
		0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE,
      //	0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "352", "4",
		offset, longToStr(blockIndex), "Missing Content Transaction Type");
      setAssociatedTapErr("ERR_TAP3_MISSING_CONTENT_TRANS_TYPE", LOG_MAJOR ,"31" ,"352" ,"4");	
    }
    else
    {
      typeID = edrLong(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE,
		0, blockIndex);
      if ((typeID < 0) or (typeID > 17))
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE,
	//	0, blockIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "337", "5",
		offset, longToStr(blockIndex), "Out Of Range Content Transaction Type");
        setAssociatedTapErr("ERR_TAP3_OOR_CONTENT_TRANS_TYPE", LOG_MAJOR ,"20" ,"337" ,"5");	
      }
    }

    if ((edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TRANSACTION_SHORT_DESCRIPTION,
		0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TRANSACTION_SHORT_DESCRIPTION,
      //	0, blockIndex));
      offset = "-1";
      edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "32", "352", "4",
		offset, longToStr(blockIndex), "Missing Content Transaction Short Description");
      setAssociatedTapErr("ERR_TAP3_MISSING_CONTENT_TRANS_SHORT_DESC", LOG_WARNING ,"32" ,"352" ,"4");	
    }
    else
    {
      if (strLength(edrString(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TRANSACTION_SHORT_DESCRIPTION,
		0, blockIndex)) > 24)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TRANSACTION_SHORT_DESCRIPTION,
	//	0, blockIndex));
	offset = "-1";
	edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "100", "340", "5",
		offset, longToStr(blockIndex), "Too Long Content Transaction Short Desc");
        setAssociatedTapErr("ERR_TAP3_LONG_CONTENT_TRANS_SHORT_DESC", LOG_WARNING ,"100" ,"340" ,"5");	
      }
    }

    if ((edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TRANSACTION_IDENTIFIER,
		0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TRANSACTION_IDENTIFIER,
      //	0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "352", "4",
		offset, longToStr(blockIndex), "Missing Content Transaction Identifier");
      setAssociatedTapErr("ERR_TAP3_MISSING_CONTENT_TRANS_ID", LOG_MAJOR ,"33" ,"352" ,"4");	
    }
    if ((edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE, 0, blockIndex) == MISSING)
         and (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE, 0, blockIndex) == 3)
         and (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE, 0, blockIndex) == 11))
    {
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", "352", "4",
                offset, longToStr(blockIndex), "Missing Object Type");
      setAssociatedTapErr("ERR_TAP3_MISSING_OBJECT_TYPE", LOG_MAJOR ,"34" ,"352" ,"4");
    }
    if ((edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE, 0, blockIndex) == MISSING)
         and (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE, 0, blockIndex) == 3)
         and (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE, 0, blockIndex) == 12))
    {
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", "352", "4",
                offset, longToStr(blockIndex), "Missing Object Type");
      setAssociatedTapErr("ERR_TAP3_MISSING_OBJECT_TYPE", LOG_MAJOR ,"35" ,"352" ,"4");
    }
    Long dataVolumeIncoming = edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_INCOMING, 0, blockIndex);
    Long dataVolumeOutgoing = edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_OUTGOING, 0, blockIndex);
    Long totalDataVolume    = edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME, 0, blockIndex);
    if ( (edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_INCOMING, 0, blockIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_INCOMING, 0, blockIndex) != MISSING)
          and (edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_OUTGOING, 0, blockIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_OUTGOING, 0, blockIndex) != MISSING)
          and (edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME, 0, blockIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME, 0, blockIndex) != MISSING)
          and (totalDataVolume != (dataVolumeIncoming + dataVolumeOutgoing)) ) 
    {
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "352", "4", offset,
                  longToStr(blockIndex), "Total Data Volume value does not equal the sum of Incoming and Outgoing Data Volume");
      setAssociatedTapErr("ERR_TAP3_DATA_VOLUME_VALUE", LOG_MAJOR ,"100" ,"352" ,"4");
    }
  }
}


//------------------------------------------------------------------------------
// validateGprsServiceUsage()
//
// This function will be used to validate the gprs service usage
//------------------------------------------------------------------------------
function validateGprsServiceUsage
{
  if (debug)
  {
    logStdout("validateGprsServiceUsage\n");
  }

  Long typeID;
  Long blockIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_GPRS_EXT.GS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if ((edrInputState(DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_RECEIVED,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_RECEIVED, 0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", "119", "5",
		offset, longToStr(blockIndex), "Missing Data Volume Incoming");
      setAssociatedTapErr("ERR_TAP3_MISSING_DATA_VOL_INCOMMING", LOG_MAJOR ,"32" ,"119" ,"5");	
    }
    else
    {
      if (edrDecimal(
		DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_RECEIVED, 0, blockIndex) < 0.0)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_RECEIVED, 0, blockIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "250", "6",
		offset, longToStr(blockIndex), "Out Of Range Data Volume Incoming");
        setAssociatedTapErr("ERR_TAP3_OOR_DATA_VOL_INCOMMING", LOG_MAJOR ,"20" ,"250" ,"6");	
      }
    }

    if ((edrInputState(DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_SENT,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_SENT, 0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "119", "5",
		offset, longToStr(blockIndex), "Missing Data Volume Outgoing");
      setAssociatedTapErr("ERR_TAP3_MISSING_DATA_VOL_OUTGOING", LOG_MAJOR ,"31" ,"119" ,"5");	
    }
    else
    {
      if (edrDecimal(DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_SENT, 0, blockIndex) < 0.0)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GPRS_EXT.GS_PACKET.VOLUME_SENT, 0, blockIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "251", "6",
		offset, longToStr(blockIndex), "Out Of Range Data Volume Outgoing");
        setAssociatedTapErr("ERR_TAP3_OOR_DATA_VOL_OUTGOING", LOG_MAJOR ,"20" ,"251" ,"6");	
      }
    }

    if ((edrInputState(DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_REQUESTED_DELAY,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_REQUESTED_DELAY,
      //	0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "272", "7",
		offset, longToStr(blockIndex), "Missing QoS Requested Delay");
      setAssociatedTapErr("ERR_TAP3_MISSING_QOS_REQUESTED_DELAY", LOG_MAJOR ,"30" ,"272" ,"7");	
    }
    else
    {
      typeID = strToLong(edrString(DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_REQUESTED_DELAY,
						0, blockIndex));
      if ((typeID < 0) or (typeID > 3))
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_REQUESTED_DELAY,
	//	0, blockIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "171", "8",
		offset, longToStr(blockIndex), "Out Of Range QoS Requested Delay");
        setAssociatedTapErr("ERR_TAP3_OOR_QOS_REQUESTED_DELAY", LOG_MAJOR ,"20" ,"171" ,"8");	
      }
    }

    if ((edrInputState(
		DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_USED_DELAY,
		0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_USED_DELAY,
      //	0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
