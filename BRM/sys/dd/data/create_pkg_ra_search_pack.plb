DECLARE
   v_ddl_stmt VARCHAR2(100);
   v_count NUMBER;
BEGIN
   SELECT COUNT(table_name) INTO v_count FROM user_tables WHERE table_name = 'BATCH_IDS';
   IF v_count <>0 THEN
   v_ddl_stmt :=  'drop table BATCH_IDS';
   EXECUTE IMMEDIATE v_ddl_stmt;
   END IF;
END;
/
CREATE  global temporary TABLE BATCH_IDS
(
  BATCH_ID  VARCHAR2(80 BYTE)
) on commit delete rows ;
CREATE UNIQUE INDEX BATCH_IDS_I ON BATCH_IDS
(BATCH_ID);	
