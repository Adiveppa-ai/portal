function onDetailEdr
{
  String myContext = "DETAIL";
  Long  nMyIndices = 0;
  String childContext;

  childContext = myContext + "." + "missingReturn";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMissingReturn ( myContext, nMyIndices, "missingReturn", 0 );                               
    return;
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fatalReturn";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapFatalReturn ( myContext, nMyIndices, "fatalReturn", 0 );                               
    return;
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "severeReturn";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapSevereReturn ( myContext, nMyIndices, "severeReturn", 0 );                               
  }                                                                                                          
  
  childContext = myContext + "." + "mobileOriginatedCall";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMobileOriginatedCall ( myContext, nMyIndices, "mobileOriginatedCall", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "mobileTerminatedCall";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMobileTerminatedCall ( myContext, nMyIndices, "mobileTerminatedCall", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "supplServiceEvent";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapSupplServiceEvent ( myContext, nMyIndices, "supplServiceEvent", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "serviceCentreUsage";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapServiceCentreUsage ( myContext, nMyIndices, "serviceCentreUsage", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "gprsCall";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapGprsCall ( myContext, nMyIndices, "gprsCall", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "contentTransaction";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapContentTransaction ( myContext, nMyIndices, "contentTransaction", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "locationService";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLocationService ( myContext, nMyIndices, "locationService", 0 );                               
  }                                                                                                          

  edrDate(DETAIL.CREATED_TIMESTAMP) = edrDate(DETAIL.CHARGING_START_TIMESTAMP);
  edrDate(DETAIL.NE_CHARGING_START_TIMESTAMP) = edrDate(DETAIL.CHARGING_START_TIMESTAMP);
  edrDate(DETAIL.NE_CHARGING_END_TIMESTAMP) = edrDate(DETAIL.CHARGING_END_TIMESTAMP);
}

function onHeaderEdr
{
  String myContext = "HEADER";
  Long  nMyIndices = 0;
  String childContext;

  initializeForNewHeader();

  childContext = myContext + "." + "acknowledgement";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    mapAcknowledgement ( myContext, nMyIndices, "acknowledgement", 0 );

    edrString(HEADER.RECORD_TYPE) = "000";
    edrLong(HEADER.RECORD_NUMBER) = 1;
  }

  childContext = myContext + "." + "rapBatchControlInfoRap";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    mapRapBatchControlInfo ( myContext, nMyIndices, "rapBatchControlInfoRap", 0 );

    edrString(HEADER.RECORD_TYPE) = type_HEADER;
    edrLong(HEADER.RECORD_NUMBER) = 1;
  }
}

function onTrailerEdr
{
  String myContext = "TRAILER";
  Long  nMyIndices = 0;
  String childContext;

  childContext = myContext + "." + "rapAuditControlInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapRapAuditControlInfo ( myContext, nMyIndices, "rapAuditControlInfo", 0 );                               
  }                                                                                                          

  else
  {
    // if the trailer EDR does not contain rapAuditControlInfo block
    // it means that it was a acknowledgement RAP file
  }
}

function onStartEdr
{
  processingRAPIN();
}
