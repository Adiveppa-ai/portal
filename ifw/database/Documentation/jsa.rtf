SA_USER.USR_AUTHID IS 'the password which should be used in the login-dialog'\line ;\line COMMENT ON COLUMN JSA_USER.ENTRYDATE IS 'ENTRYDATE'\line ;\line COMMENT ON COLUMN JSA_USER.ENTRYBY IS 'ENTRYBY'\line ;\line COMMENT ON COLUMN JSA_USER.MODIFDATE IS 'MODIFDATE'\line ;\line COMMENT ON COLUMN JSA_USER.MODIFBY IS 'MODIFBY'\line ;\line COMMENT ON COLUMN JSA_USER.MODIFIED IS 'MODIFIED'\line ;\line COMMENT ON COLUMN JSA_USER.RECVER IS 'RECVER'\line ;\line }\cell }\pard \keepn\intbl \row
