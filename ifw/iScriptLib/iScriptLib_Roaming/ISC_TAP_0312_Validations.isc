 ******************************************************************************************************************************/
 
function validateNetworkList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",333";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "Network";
  Long NetworkListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < NetworkListEntries; i = i + 1 )
  {
    validateNetwork ( myContext, nMyIndices, "Network", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate IspIdentifier. It will raise error code 100, 101 for IspIdentifier.
 ******************************************************************************************************************************/
 
function validateIspIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  Bool   checkType         = true;
  Bool   codeFound         = false;
  Long   ret               = -1;
  Long   i;
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",294";
  String ispIdentifier = edrStringEx(myContext, indices, nParentIndices);
  switch( lastIspIdType )
  {
    case 1:
    {
      ret = strSearchRegExpr(ispIdentifier, "[^A-Za-z ]");
      Long checkSpace = strSearchRegExpr(ispIdentifier, "[A-Za-z]");
      if ( checkSpace < 0  and ret < 0 )
      {
         ret = 0;
      }
    }
    break;
    case 2:
    {
      for( i = 0; i < numOfPlmnoCode and codeFound == false; i = i + 1 )
      {
        if( ispIdentifier == PLMNOCode[i] )
        {
          codeFound = true;
        }
      }
      if ( codeFound == false )
      {
        ret = 0;
      }
    }
    break;
    case 3:
    {
      ret = strSearchRegExpr(ispIdentifier, "!(.+)");
    }
    break;
    case 4:
    {
      checkType = validateIpV4(ispIdentifier);
    }
    break;
    case 5:
    {
      checkType = validateIpV6(ispIdentifier);
    }
    break;
  }
  if (ret >= 0 or checkType == false)
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ISP Identifier", "294", "100", "Item content does not match ISP Id Type");
    }
    else
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ISP Identifier", "294", "101", "Item content does not match ISP Id Type");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1", "","Item content does not match ISP Id Type");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate IspIdType. It will raise error code 20, 21 for IspIdType.
 ******************************************************************************************************************************/
 
function validateIspIdType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",293";

  lastIspIdType = edrLongEx(myContext, indices, nParentIndices);

  if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
  {
    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "1", "INTEGER_TYPE") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Isp Id Type", "293", "20", "Out Of Range");
    }
  }
  else
  {
    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "1", "INTEGER_TYPE") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Isp Id Type", "293", "21", "Value Out Of Range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", errorContext, "0", "-1", "-1", "","Value Out Of Range");
      edrSetIsValidDetail(false);
    }
  }

 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate InternetServiceProvider. It will raise error code 30, 31, 32, 33 for InternetServiceProvider.
 ******************************************************************************************************************************/
 
function validateInternetServiceProvider ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",329";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "ispIdType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateIspIdType ( myContext, nMyIndices, "ispIdType", 0, errorContext );
  }
  else
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Internet Service Provider", "329", "30",
                                                   "Mandatory item ISP Id Type missing within group"); 
    }
    else
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Internet Service Provider", "329", "32",
                                                   "Mandatory item ISP Id Type missing within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","",
                                                   "Mandatory item ISP Id Type missing within group");
      edrSetIsValidDetail(false);
    }
  } 
 
  childContext = myContext + "." + "ispIdentifier";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateIspIdentifier ( myContext, nMyIndices, "ispIdentifier", 0, errorContext );
  }
  else
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Internet Service Provider", "329", "31",
                                                   "Mandatory item ISP Identifier missing within group");
    }
    else
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Internet Service Provider", "329", "33",
                                                   "Mandatory item ISP Identifier missing within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1","",
                                                   "Mandatory item ISP Identifier missing within group");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nMyIndices );
}

