      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "09" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "11" )
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","071","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_IND");
  }
  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED, 0), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "03" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "04" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "05" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "06" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "08" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "09" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "11" )
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","078","CIBER25.ASS_CIBER_EXT.CHARGE_NO_3_IND");
  }
  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED, 0), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "03" or 
