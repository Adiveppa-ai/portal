/******************************************************************************************************************************
 * This function will validate DialledDigits. It will raise error code 10 for DialledDigits.
 ******************************************************************************************************************************/
 
function validateDialledDigits ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",279";

  String dialledDigits = edrStringEx(myContext, indices, nParentIndices);

  if( (strSearchRegExpr(dialledDigits, "[^0-9#\*\+]") >= 0) or (strLength(dialledDigits) == 0) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Dialled Digits", "279", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CalledNumber. It will raise error code 20 for CalledNumber.
 ******************************************************************************************************************************/
 
function validateCalledNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",407";
  Bool   countryCodeFound = false;
  Long   i;

  onlyCountryCodeFound = false;

  lastCalledNumber = edrStringEx( myContext, indices, nParentIndices );
  for( i = 0 ; i < numOfCountryCode and countryCodeFound == false ; i = i + 1 )
  {
    if (strStartsWith(lastCalledNumber, countryCodeArray[i]))
    {
      countryCodeFound = true;
    }
    if( lastCalledNumber == countryCodeArray[i] )
    {
      onlyCountryCodeFound = true;
    }
  }
  if( countryCodeFound == false and validateSyntax(lastCalledNumber, "CHECK_NUM") == false ) 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Called Number", "407", "20",
                                                 "Value out of range or number does not start with a valid country code");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "",
                                                 "Value out of range or number does not start with a valid country code");
    edrSetIsValidDetail(false);
    
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate Destination. It will raise error code 40 for Destination.
 ******************************************************************************************************************************/
 
function validateDestination ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",89";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  calledNumberIsMissing   = false;
  dialledDigitsIsMissing  = false;
 
  childContext = myContext + "." + "calledNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCalledNumber ( myContext, nMyIndices, "calledNumber", 0, errorContext );
  }
  else
  {
    calledNumberIsMissing = true;
  }
 
  childContext = myContext + "." + "dialledDigits";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDialledDigits ( myContext, nMyIndices, "dialledDigits", 0, errorContext );
  }
  else
  {
    dialledDigitsIsMissing = true;
    if( onlyCountryCodeFound  == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Destination", "89", "40",
                                    "Called Number contains only country code and item Dialled Digits not presen");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "40", errorContext, "0", "-1", "-1","",
                                    "Called Number contains only country code and item Dialled Digits not presen");
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "calledPlace";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCalledPlace ( myContext, nMyIndices, "calledPlace", 0, errorContext );
  }
 
  childContext = myContext + "." + "calledRegion";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCalledRegion ( myContext, nMyIndices, "calledRegion", 0, errorContext );
  }
 
  childContext = myContext + "." + "sMSDestinationNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSMSDestinationNumber ( myContext, nMyIndices, "sMSDestinationNumber", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MoBasicCallInformation. It will raise error code 30, 31, 32 for MoBasicCallInformation.
 ******************************************************************************************************************************/
 
function validateMoBasicCallInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",147";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "chargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeableSubscriber ( myContext, nMyIndices, "chargeableSubscriber", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MoBasicCallInformation", "147", "30", "Mandatory group Chargeable Subscriber missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group Chargeable Subscriber missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "destination";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateDestination ( myContext, nMyIndices, "destination", 0, errorContext );
  }
  else
  {
    destinationIsMissing = true;
  }
 
  childContext = myContext + "." + "destinationNetwork";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDestinationNetwork ( myContext, nMyIndices, "destinationNetwork", 0, errorContext );
  }
 
  childContext = myContext + "." + "callEventStartTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCallEventStartTimeStamp ( myContext, nMyIndices, "callEventStartTimeStamp", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MoBasicCallInformation", "147", "31", "Mandatory item Call Event Start Timestamp missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory item Call Event Start Timestamp missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "totalCallEventDuration";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalCallEventDuration ( myContext, nMyIndices, "totalCallEventDuration", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MoBasicCallInformation", "147", "32", "Mandatory item Total Call Event Duration missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Mandatory item Total Call Event Duration missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "simToolkitIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSimToolkitIndicator ( myContext, nMyIndices, "simToolkitIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "causeForTerm";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCauseForTerm ( myContext, nMyIndices, "causeForTerm", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MobileOriginatedCall. It will raise error code 30, 31, 32 for MobileOriginatedCall.
 ******************************************************************************************************************************/
 
function validateMobileOriginatedCall ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",9";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  
  destinationIsMissing = false;
 
  childContext = myContext + "." + "basicCallInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMoBasicCallInformation ( myContext, nMyIndices, "basicCallInformation", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileOriginatedCall", "9", "30", "Mandatory group MO Basic Call Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group MO Basic Call Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "locationInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLocationInformation ( myContext, nMyIndices, "locationInformation", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileOriginatedCall", "9", "31", "Mandatory group Location Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory group Location Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "equipmentIdentifier";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateImeiOrEsn ( myContext, nMyIndices, "equipmentIdentifier", 0, errorContext );
  }
 
  childContext = myContext + "." + "basicServiceUsedList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateBasicServiceUsedList ( myContext, nMyIndices, "basicServiceUsedList", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileOriginatedCall", "9", "32", "Mandatory group Basic Service Used missing within group.");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Mandatory group Basic Service Used missing within group.");
    edrSetIsValidDetail(false);
  }
  
  childContext = myContext + "." + "supplServiceCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSupplServiceCode ( myContext, nMyIndices, "supplServiceCode", 0, errorContext );
  }
 
  childContext = myContext + "." + "thirdPartyInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateThirdPartyInformation ( myContext, nMyIndices, "thirdPartyInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "camelServiceUsed";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCamelServiceUsed ( myContext, nMyIndices, "camelServiceUsed", 0, errorContext );
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation functions validateMobileOriginatedCall, validateMobileTerminatedCall,
 * validateSupplServiceEvent, validateServiceCentreUsage, validateGprsCall, validateContentTransaction, validateLocationService.
 ******************************************************************************************************************************/
 
function validateCallEventDetail ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",0";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "mobileOriginatedCall";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMobileOriginatedCall ( myContext, nMyIndices, "mobileOriginatedCall", 0, errorContext );
  }
 
  childContext = myContext + "." + "mobileTerminatedCall";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMobileTerminatedCall ( myContext, nMyIndices, "mobileTerminatedCall", 0, errorContext );
  }
 
  childContext = myContext + "." + "supplServiceEvent";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateSupplServiceEvent ( myContext, nMyIndices, "supplServiceEvent", 0, errorContext );
  }
 
  childContext = myContext + "." + "serviceCentreUsage";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateServiceCentreUsage ( myContext, nMyIndices, "serviceCentreUsage", 0, errorContext );
  }
 
  childContext = myContext + "." + "gprsCall";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsCall ( myContext, nMyIndices, "gprsCall", 0, errorContext );
  }
 
  childContext = myContext + "." + "contentTransaction";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateContentTransaction ( myContext, nMyIndices, "contentTransaction", 0, errorContext );
  }
 
  childContext = myContext + "." + "locationService";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLocationService ( myContext, nMyIndices, "locationService", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateCallEventDetail for each element of Call Event Detail List.
 ******************************************************************************************************************************/
 
function validateCallEventDetailList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",3";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "CallEventDetail";
  Long CallEventDetailListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < CallEventDetailListEntries; i = i + 1 )
  {
    validateCallEventDetail ( myContext, nMyIndices, "CallEventDetail", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MessageDescriptionInformation. It will raise error code 32, 33 for MessageDescriptionInformation.
 ******************************************************************************************************************************/
 
function validateMessageDescription ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",142";
  if ( messageDescriptionCodeIsDuplicate == true )
  {
    if ( messageDescription[ lastCode ] != edrStringEx( myContext, indices, nParentIndices ) )
    {
      rollbackReason = "TransferBatch," + errorContext + ",32";
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Message Description Information", "143", "32", "More than one occurrence of group with same Message Description Code where Message Description  is not the same");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "143", "0", "-1", "-1", "","More than one occurrence of group with same Message Description Code where Message Description  is not the same");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Message Description Information", "143", "33", "More than one occurrence of group with same Message Description Code where Message Description is the same");
    }
  }
  else
  {
    messageDescription[ lastCode ] = edrStringEx( myContext, indices, nParentIndices );
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate MessageDescriptionInformation. It will raise error code 30, 31 for MessageDescriptionInformation. 
 ******************************************************************************************************************************/
 
function validateMessageDescriptionInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",143";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "messageDescriptionCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMessageDescriptionCode ( myContext, nMyIndices, "messageDescriptionCode", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "MessageDescriptionInformation", "143", "30", "Mandatory item Message Description Code missing within group");
  }
 
  childContext = myContext + "." + "messageDescription";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMessageDescription ( myContext, nMyIndices, "messageDescription", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "MessageDescriptionInformation", "143", "31", "Mandatory item Message Description missing within group");
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateMessageDescriptionInformation for each element of Message Description Info
 * List.
 ******************************************************************************************************************************/
 
function validateMessageDescriptionInfoList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",8";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "MessageDescriptionInformation";
  Long MessageDescriptionInfoListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;

  for( i = 0; i < MessageDescriptionInfoListEntries; i = i + 1 )
  {
    messageDescriptionCodeIsDuplicate = false;
    validateMessageDescriptionInformation ( myContext, nMyIndices, "MessageDescriptionInformation", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate RecordingEntityInformation. It will raise error code 33, 34 for RecordingEntityInformation.
 ******************************************************************************************************************************/
 
function validateRecEntityId ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",400";
  if ( recEntityCodeIsDuplicate == true )
  {
    if ( recEntityTypeIsDuplicate == true and recEntityId[ lastCode ] == edrStringEx( myContext, indices, nParentIndices ) )
    {
      rollbackReason = "NetworkInfo," + "1,6,188,183" + ",34" + ":" + NetworkInfoStr; 
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Recording Entity Information", "183", "34", "More than one occurrence of group with same Recording Entity Code where Recording Entity Type and Recording Entity Identification are the same ");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "34", "183", "0", "-1", "-1", "","More than one occurrence of group with same Recording Entity Code where Recording Entity Type and Recording Entity Identification are the same ");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else
    {
      rollbackReason = "NetworkInfo," + "1,6,188,183" + ",33" + ":" + NetworkInfoStr; 
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Recording Entity Information", "183", "33", "More than one occurrence of group with same Recording Entity Code where Recording Entity Type and /or Recording Entity Identification are not the same.");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "183", "0", "-1", "-1", "","More than one occurrence of group with same Recording Entity Code where Recording Entity Type and /or Recording Entity Identification are not the same.");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }    
  else
  {
    recEntityId[ lastCode ] = edrStringEx( myContext, indices, nParentIndices );
  } 
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate RecEntityType. It will raise error code 10, 20 for RecEntityType.
 ******************************************************************************************************************************/
 
function validateRecEntityType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",186";
  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 1) )
  {
    rollbackReason = "NetworkInfo," + errorContext + ",10" + ":" + NetworkInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "RecEntityType", "186", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "186", "0", "-1", "-1", "","Syntax Error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"9" , "1", "INTEGER_TYPE") == true )
  {
    rollbackReason = "NetworkInfo," + errorContext + ",20" + ":" + NetworkInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "RecEntityType", "186", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "186", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else
  {
    if ( recEntityCodeIsDuplicate == true )
    {
      if ( recEntityType[ lastCode ] == edrLongEx( myContext, indices, nParentIndices ) )
      {
        recEntityTypeIsDuplicate = true;
      }
    }
    else
    {
      recEntityType[ lastCode ] = edrLongEx( myContext, indices, nParentIndices );
    }    
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate RecEntityInformation. It will raise error code 30, 31, 32 for RecEntityInformation.
 ******************************************************************************************************************************/
 
function validateRecEntityInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",183";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "recEntityCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecEntityCode ( myContext, nMyIndices, "recEntityCode", 0, errorContext );
  }
  else
  {
    rollbackReason = "NetworkInfo," + errorContext + ",30" + ":" + NetworkInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "RecEntityInformation", "183", "30", "Mandatory item Recording Entity Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "183", "0", "-1", "-1", "","Mandatory item Recording Entity Code missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "recEntityType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecEntityType ( myContext, nMyIndices, "recEntityType", 0, errorContext );
  }
  else
  {
    rollbackReason = "NetworkInfo," + errorContext + ",31" + ":" + NetworkInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "RecEntityInformation", "183", "31", "Mandatory item Recording Entity Type missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "183", "0", "-1", "-1","","Mandatory item Recording Entity Type missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "recEntityId";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecEntityId ( myContext, nMyIndices, "recEntityId", 0, errorContext );
  }
  else
  {
    rollbackReason = "NetworkInfo," + errorContext + ",32" + ":" + NetworkInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "RecEntityInformation", "183", "32", "Mandatory item Recording Entity Identification missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "183", "0", "-1", "-1", "","Mandatory item Recording Entity Identification missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateRecEntityInformation for each element of Rec Entity Info List.
 ******************************************************************************************************************************/
 
function validateRecEntityInfoList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",188";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "RecEntityInformation";
  Long RecEntityInfoListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < RecEntityInfoListEntries; i = i + 1 )
  {
    lastCode = -1;
    recEntityCodeIsDuplicate = false;
    recEntityTypeIsDuplicate = false;
    validateRecEntityInformation ( myContext, nMyIndices, "RecEntityInformation", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

