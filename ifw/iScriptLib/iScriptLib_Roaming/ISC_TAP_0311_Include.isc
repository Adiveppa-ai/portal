function mapBearerServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
                                                                                                             
  if ( strEndsWith ( parentContext, "basicServiceCodeList.BasicServiceCode" ) == true )
  {
    // Adding suffix "1" to identify it as BearerServiceCode
    lastbasicServiceCodeSS = lastbasicServiceCodeSS + "1" + edrStringEx( myContext, indices, nParentIndices ) + ",";
  }
  else
  {
    edrString(DETAIL.BASIC_SERVICE) = "1" + edrStringEx( myContext, indices, nParentIndices );
    edrString(DETAIL.ASS_GSMW_EXT.BS_PACKET.BASIC_SERVICE, 0, bsPacketIdx) = edrString(DETAIL.BASIC_SERVICE);
  }

  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
