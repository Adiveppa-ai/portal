      typeID = strToLong(edrString(
		DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_REQUESTED_RELIABILITY,
		0, blockIndex));
      if ((typeID < 0) or (typeID > 5))
      {
	// offset = longToStr(edrFieldTokenBytePos(
