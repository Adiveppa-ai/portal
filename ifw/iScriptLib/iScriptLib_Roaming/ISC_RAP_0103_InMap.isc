function mapSevereReturn ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  createNewRapDetail(SEVERE);
  edrString(DETAIL.ASS_ROAMING_EXT.RAP_RECORD_TYPE, 0) = SEVERE;

  childContext = myContext + "." + "fileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFileSequenceNumber ( myContext, nMyIndices, "fileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  //childContext = myContext + "." + "callEventDetail";                                                       
  //if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  //{                                                                                                          
  //  mapCallEventDetail ( myContext, nMyIndices, "callEventDetail", 0 );                               
  //}                                                                                                          
                                                                                                             
  childContext = myContext + "." + "errorDetail";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapErrorDetailList ( myContext, nMyIndices, "errorDetail", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecList ( myContext, nMyIndices, "operatorSpecList", 0 );                               
  }                                                                                                          
                                                                                                             
  edrLong(DETAIL.ASS_ROAMING_EXT.TAP_FILE_SEQ_NO, 0) = theFileSeqNum;
  if ( edrString(DETAIL.SOURCE_NETWORK) == "" )
  {
    edrString(DETAIL.SOURCE_NETWORK) = headerSender;
  }

  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapAuditControlInfoError ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
  
  return; // just return, there is no need to map this block to any business fields, it is just for information and the staging fields solve that purpose
                                                                                                             
  childContext = myContext + "." + "auditControlInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapAuditControlInfo ( myContext, nMyIndices, "auditControlInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "errorDetail";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapErrorDetailList ( myContext, nMyIndices, "errorDetail", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
