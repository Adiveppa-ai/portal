	select count(*) into tcount from user_tab_columns where table_name like
		'DD_OBJECTS_FIELDS_T';	
	if tcount = 2 then
		cid := DBMS_SQL.OPEN_CURSOR;
		DBMS_SQL.PARSE (cid,
			'DROP TABLE DD_OBJECTS_FIELDS_T ',
			dbms_sql.v7);
		DBMS_SQL.CLOSE_CURSOR(cid);
	end if;
END;
