/******************************************************************************************************************************
 * This function will validate ChargeableSubscriber. It will raise error code 31 for ChargeableSubscriber.
 ******************************************************************************************************************************/
 
function validateMinChargeableSubscriber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",254";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "min";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    if( (strStartsWith(parentContext, "DETAIL.serviceCentreUsage") != true) and
        (imsiIsMissing == false) )
    {
      if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
      {
        objTag = "1,3,9,147,427";
      }
      else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
      {
        objTag = "1,3,10,153,427";
      }
      else if( strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true )
      {
        objTag = "1,3,11,427";
      }
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Subscriber", "427", "31",
                                                "Both of mandatory items IMSI and MIN present within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", objTag, "0", "-1", "-1","",
                                                "Both of mandatory items IMSI and MIN present within group");
      edrSetIsValidDetail(false);
    }
    validateMin ( myContext, nMyIndices, "min", 0, errorContext );
  }
  else
  {
    minIsMissing = true;
  }
 
 
  childContext = myContext + "." + "mdn";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMdn ( myContext, nMyIndices, "mdn", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate Msisdn. It will raise error code 11, 12, 13, 21, 22, 23 for Msisdn.
 ******************************************************************************************************************************/
 
function validateMsisdn ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",152";
  Long j;
  Bool countryCodeFound = false;  
  if( validateMsisdnSE(edrStringEx(myContext, indices, nParentIndices)) == true )
  {

    if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true or 
          strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or
            strStartsWith(parentContext, "DETAIL.gprsCall") == true or 
              strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Msisdn", "152", "13", "Syntax error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "13", errorContext, "0", "-1", "-1", "","Syntax error");
      edrSetIsValidDetail(false);
    }
    if ( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true and imsiIsMissing == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Msisdn", "152", "11", "Syntax error and IMSI not present");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", errorContext, "0", "-1", "-1", "","Syntax error and IMSI not present");
      edrSetIsValidDetail(false);
    }
    else if ( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true and imsiIsMissing == false )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Msisdn", "152", "12", "Syntax error and IMSI present");
    }    
  }
  else 
  {  
    for( j = 0 ; j < numOfCountryCode and countryCodeFound == false ; j = j + 1 )
    {
      if ( strStartsWith(edrStringEx(myContext, indices, nParentIndices), countryCodeArray[j]) == true )
      {
        countryCodeFound = true;
      }
    }
    if ( countryCodeFound == false )
    {    
      if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true or 
          strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or
            strStartsWith(parentContext, "DETAIL.gprsCall") == true or 
              strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Msisdn", "152", "23", "Number not represented in international format");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "23", errorContext, "0", "-1", "-1", "","Number not represented in international format");
        edrSetIsValidDetail(false);
      }
      else if ( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true and imsiIsMissing == true )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Msisdn", "152", "21", "Number not represented in international format and IMSI not present ");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", errorContext, "0", "-1", "-1", "","Number not represented in international format and IMSI not present ");
        edrSetIsValidDetail(false);
      }
      else if ( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true and imsiIsMissing == false )
      {
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Msisdn", "152", "22", "Number not represented in international format and IMSI present");
      }
    }
  }   
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}
 
function validateImsi ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",129";
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function calls the validation functions validateImsi and validateMsisdn. 
 ******************************************************************************************************************************/

function validateSimChargeableSubscriber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",199";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "imsi";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateImsi ( myContext, nMyIndices, "imsi", 0, errorContext );
  }
  else
  {
    imsiIsMissing = true;
  }
 
  childContext = myContext + "." + "msisdn";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMsisdn ( myContext, nMyIndices, "msisdn", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ChargeableSubscriber. It will raise error code 30 for ChargeableSubscriber.
 ******************************************************************************************************************************/
 
function validateChargeableSubscriber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",427";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  imsiIsMissing           = false;
  minIsMissing            = false;
 
  childContext = myContext + "." + "simChargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateSimChargeableSubscriber ( myContext, nMyIndices, "simChargeableSubscriber", 0, errorContext );
  }
  else
  {
    imsiIsMissing = true;
  }
 
  childContext = myContext + "." + "minChargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMinChargeableSubscriber ( myContext, nMyIndices, "minChargeableSubscriber", 0, errorContext );
  }
  else
  {
    minIsMissing = true;
  }

  if( (imsiIsMissing == true) and (minIsMissing == true) )
  {
     // FieldName, AppId, ErrorCode,ErrorDescription
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Subscriber", "427", "30",
                                               "Neither of mandatory items IMSI or MIN present");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                              "Neither of mandatory items IMSI or MIN present");
     edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate GprsChargeableSubscriber. It will raise error code 34 for GprsChargeableSubscriber.
 ******************************************************************************************************************************/
 
function validateGprsChargeableSubscriber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",115";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  networkAccessIdentifierIsPresent = false;
  chargeableSubscriberIsMissing = false;
  pdpAddressIsMissing           = false;
 
  childContext = myContext + "." + "chargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeableSubscriber ( myContext, nMyIndices, "chargeableSubscriber", 0, errorContext );
  }
  else
  {
   chargeableSubscriberIsMissing = true;
  }
 
  childContext = myContext + "." + "pdpAddress";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validatePdpAddress ( myContext, nMyIndices, "pdpAddress", 0, errorContext );
  }
  else
  {
    pdpAddressIsMissing = true;
  }
 
  childContext = myContext + "." + "networkAccessIdentifier";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  { 
    networkAccessIdentifierIsPresent = true;
    validateNetworkAccessIdentifier ( myContext, nMyIndices, "networkAccessIdentifier", 0, errorContext );
  }
  else
  {
    if( chargeableSubscriberIsMissing == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Chargeable Subscriber", "115", "34",
                                     "Neither item Network Access Identifier nor group Chargeable Subscriber present within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", errorContext, "0", "-1", "-1","",
                                     "Neither item Network Access Identifier nor group Chargeable Subscriber present within group");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate GprsBasicCallInformation and PDPContextStartTimestamp. It will raise error code 30, 32, 33, 34, 35
 * for GprsBasicCallInformation and error code 31 for PDPContextStartTimestamp.
 ******************************************************************************************************************************/
 
function validateGprsBasicCallInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",114";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  partialTypeIndicatorIsMissing = false;
  
  lastGprsCallEventStartTimeStamp = "";
  lastPartialTypeIndicator = "";
  

  causeForTermIsPresent = false;
  networkInitPDPContextIsPresent = false;
 
  childContext = myContext + "." + "gprsChargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsChargeableSubscriber ( myContext, nMyIndices, "gprsChargeableSubscriber", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Basic Call Information", "114", "30", 
                                              "GPRS Chargeable Subscriber missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                              "GPRS Chargeable Subscriber missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "gprsDestination";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsDestination ( myContext, nMyIndices, "gprsDestination", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Basic Call Information", "114", "32", "GPRS Destination missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","", "GPRS Destination missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "callEventStartTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCallEventStartTimeStamp ( myContext, nMyIndices, "callEventStartTimeStamp", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Basic Call Information", "114", "33",
                                              "Call Event Start Timestamp missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1","",
                                              "Call Event Start Timestamp missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "totalCallEventDuration";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalCallEventDuration ( myContext, nMyIndices, "totalCallEventDuration", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Basic Call Information", "114", "34", 
                                              "Total Call Event Duration missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", errorContext, "0", "-1", "-1","",
                                              "Total Call Event Duration missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "causeForTerm";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCauseForTerm ( myContext, nMyIndices, "causeForTerm", 0, errorContext );
    causeForTermIsPresent = true;
  }
 
  childContext = myContext + "." + "partialTypeIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validatePartialTypeIndicator ( myContext, nMyIndices, "partialTypeIndicator", 0, errorContext );
  }
  else
  {
    partialTypeIndicatorIsMissing = true;
  }
 
  childContext = myContext + "." + "pDPContextStartTimestamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  { 
    if ( ( (partialTypeIndicatorIsMissing == false and lastPartialTypeIndicator == "F") or
            partialTypeIndicatorIsMissing == true )
           and strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "PDPContextStartTimestamp", "260", "31", "PDP Context Start Timestamp present but Partial Type Indicator is either not present or identifies GPRS Call as the 'first' partial");
    }
    validatePDPContextStartTimestamp ( myContext, nMyIndices, "pDPContextStartTimestamp", 0, errorContext );
  }
  
  lastGprsCallEventStartTimeStamp = "";
  lastPartialTypeIndicator = "";
 
  childContext = myContext + "." + "networkInitPDPContext";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    networkInitPDPContextIsPresent = true;
    validateNetworkInitPDPContext ( myContext, nMyIndices, "networkInitPDPContext", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargingId";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargingId ( myContext, nMyIndices, "chargingId", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Basic Call Information", "114", "35", "Charging Id missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", errorContext, "0", "-1", "-1","", "Charging Id missing within group");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate GprsCall. It will raise error code 31, 32, 34 for GprsCall.
 ******************************************************************************************************************************/
 
function validateGprsCall ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",14";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "gprsBasicCallInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsBasicCallInformation ( myContext, nMyIndices, "gprsBasicCallInformation", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Call", "14", "31",
                                              "GPRS Basic Call Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","",
                                              "GPRS Basic Call Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "gprsLocationInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsLocationInformation ( myContext, nMyIndices, "gprsLocationInformation", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Call", "14", "32",
                                              "GPRS Location Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","",
                                              "GPRS Location Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "equipmentIdentifier";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateImeiOrEsn ( myContext, nMyIndices, "equipmentIdentifier", 0, errorContext );
  }
 
  childContext = myContext + "." + "gprsServiceUsed";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsServiceUsed ( myContext, nMyIndices, "gprsServiceUsed", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Call", "14", "34",
                                              "GPRS Service Used missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", errorContext, "0", "-1", "-1","",
                                              "GPRS Service Used missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "camelServiceUsed";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCamelServiceUsed ( myContext, nMyIndices, "camelServiceUsed", 0, errorContext );
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ChargingPoint, CompletionTimeStamp, DepositTimestamp. It will raise error code 10, 20 for
 * ChargingPoint, error code 10, 11, 30, 31 for CompletionTimeStamp, error code 10, 11, 30, 31 for DepositTimestamp.
 ******************************************************************************************************************************/
 
function validateChargingPoint ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",73";


  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHA_UPPER") == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 1) )  
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charging Point", "73", "10", "Charging Point Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Charging Point Syntax Error");
    edrSetIsValidDetail(false);
  }
  else if( edrStringEx(myContext, indices, nParentIndices) != "C" and edrStringEx(myContext, indices, nParentIndices) != "D" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charging Point", "73", "20", "Charging Point Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Charging Point Out Of Range");
    edrSetIsValidDetail(false);
  }

  if( (dateIsValid(strToDate(lastCompletionTimeStamp)) == false or strLength(lastCompletionTimeStamp) != 14) and 
      (edrStringEx(myContext, indices, nParentIndices) == "D") and (lastCompletionTimeStamp != "") )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Completion TimeStamp", "76", "10", "Completion TimeStamp Syntax Error");
  }
  else if( (dateIsValid(strToDate(lastCompletionTimeStamp)) == false or strLength(lastCompletionTimeStamp) != 14) and 
           (edrStringEx(myContext, indices, nParentIndices) == "C") and (lastCompletionTimeStamp != "") )
  {
    objTag = "1,3,12,193,76";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Completion TimeStamp", "76", "11", "Completion TimeStamp Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", objTag, "0", "-1", "-1","", "Completion TimeStamp Syntax Error");
    edrSetIsValidDetail(false);
  }
  if( (dateIsValid(strToDate(lastDepositTimeStamp)) == false or strLength(lastDepositTimeStamp) != 14) and
      (edrStringEx(myContext, indices, nParentIndices) == "C") and (lastDepositTimeStamp != "") )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Deposit Timestamp", "88", "10", "Syntax error and charging point is 'C' ");
  }
  else if( (dateIsValid(strToDate(lastDepositTimeStamp)) == false or strLength(lastDepositTimeStamp) != 14) and
           (edrStringEx(myContext, indices, nParentIndices) == "D") and (lastDepositTimeStamp != "") )
  {
    objTag = "1,3,12,193,88"; 

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Deposit Timestamp", "88", "11", "Syntax error and charging point is 'D' ");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", objTag, "0", "-1", "-1", "","Syntax error and charging point is 'D' ");
    edrSetIsValidDetail(false);
  }
  if( completionUtcTimeOffsetCodeIsMissing == true and edrStringEx(myContext, indices, nParentIndices) == "D" )
  { 
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Completion TimeStamp", "76", "30",
                                                 "UTC Time Offset Code missing and charging point is 'D'");
  }
  else if( completionUtcTimeOffsetCodeIsMissing == true and edrStringEx(myContext, indices, nParentIndices) == "C" )
  {
    objTag = "1,3,12,193,76";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Completion TimeStamp", "76", "31", 
                                              "UTC Time Offset Code missing and charging point is 'D'");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", objTag, "0", "-1", "-1","",
                                              "UTC Time Offset Code missing and charging point is 'D'");
    edrSetIsValidDetail(false);
  }
 
  if( depositUtcTimeOffsetCodeIsMissing == true and edrStringEx(myContext, indices, nParentIndices) == "C" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Deposit Timestamp", "88", "30",
                                                 "UTC Time Offset Code missing and charging point is 'C'");
  }
  else if( depositUtcTimeOffsetCodeIsMissing == true and edrStringEx(myContext, indices, nParentIndices) == "D" )
  {
    objTag = "1,3,12,193,88";

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Deposit Timestamp", "88", "31",
                                              " UTC Time Offset Code missing and charging point is 'D'");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", objTag, "0", "-1", "-1","",
                                              " UTC Time Offset Code missing and charging point is 'D'");
    edrSetIsValidDetail(false);
  }

 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function calls the validation functions validateLocalTimeStamp and validateUtcTimeOffsetCode.
 ******************************************************************************************************************************/

function validateCompletionTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",76";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else
  {
    completionUtcTimeOffsetCodeIsMissing = true;
  }
  endLocalTimeStamp = addUTCToLocalTimestamp( endLocalTimeStamp, endUTCTimeOffset);
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation functions validateLocalTimeStamp and validateUtcTimeOffsetCode.
 ******************************************************************************************************************************/
 
function validateDepositTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",88";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else
  {
    depositUtcTimeOffsetCodeIsMissing = true;
  }
    
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ScuTimeStamps. It will raise error code 30, 31, 32 for ScuTimeStamps.
 ******************************************************************************************************************************/
 
function validateScuTimeStamps ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",193";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "depositTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateDepositTimeStamp ( myContext, nMyIndices, "depositTimeStamp", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuTimeStamps", "193", "30", "Mandatory item Deposit Timestamp missing within group");  
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory item Deposit Timestamp missing within group"); 
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "completionTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCompletionTimeStamp ( myContext, nMyIndices, "completionTimeStamp", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuTimeStamps", "193", "31", "Mandatory item Completion Timestamp missing within group");  
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory item Completion Timestamp missing within group"); 
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargingPoint";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargingPoint ( myContext, nMyIndices, "chargingPoint", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuTimeStamps", "193", "32", "Mandatory item Charging Point missing within group");  
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","", "Mandatory item Charging Point missing within group");  
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MessageDescriptionCode. It will raise error code 100 for MessageDescriptionCode.
 ******************************************************************************************************************************/
 
function validateMessageDescriptionCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",141";
  Long i;  

  // Since there is no range is specified for MessageDescriptionCode in TD57 Standard Doc, Checking the range 0 to 100. 
  // Customer can always specify their range according to requirement. 

  if( strStartsWith(parentContext, "HEADER") and
      validateOOR(edrStringEx(myContext, indices, nParentIndices), "100", "0", "INTEGER_TYPE") == true ) 
  {

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "MessageDescriptionCode", "141", "10", "Syntax Error");
    edrLongEx( myContext, indices, nParentIndices ) = -1; 
    return;
  }

  lastCode = edrLongEx( myContext, indices, nParentIndices );  

  if ( strStartsWith(parentContext, "HEADER") == true )
  { 
    if( messageDescriptionCode[ lastCode ] == edrLongEx( myContext, indices, nParentIndices) )
    {
      messageDescriptionCodeIsDuplicate = true;
    }
    else
    {
      messageDescriptionCode[ lastCode ] = lastCode;
    }    
  }
  else
  { 
    // Since there is no range is specified for MessageDescriptionCode in TD57 Standard Doc, Checking the range 0 to 100.
    // Customer can always specify their range according to requirement.      

    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "100", "0", "INTEGER_TYPE") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "MessageDescriptionCode", "141", "10", "Syntax Error");
      edrLongEx(myContext, indices, nParentIndices) = -1;
      return;
    } 

    if( messageDescriptionCode[ lastCode ] != lastCode )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "MessageDescriptionCode", "141", "100", "Specified message description code not defined in Message Description Information");
    }
  }  
    
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate MessageType. It will raise error code 20 for MessageType.
 ******************************************************************************************************************************/
 
function validateMessageType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",145";

