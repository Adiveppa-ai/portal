<xs:schema
  targetNamespace="http://www.oracle.com/schemas/BusinessConfig"
  xmlns="http://www.oracle.com/schemas/BusinessConfig"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  attributeFormDefault="unqualified"
  elementFormDefault="qualified">

  <xs:include schemaLocation="PinTypes.xsd" />

  <xs:element name="ObjectList">
    <xs:complexType>
      <xs:sequence>

        <xs:element name="ConfigObject" minOccurs="1" maxOccurs="1">
          <xs:complexType>
            <xs:sequence>

              <xs:element name="DESCR" type="xs:string" minOccurs="0" />
              <xs:element name="NAME" type="xs:string" minOccurs="1" />

              <xs:element name="STATES"  minOccurs="1" maxOccurs="unbounded">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="DEFAULT_FLAG" type="xs:int" />
                    <xs:element name="LIFECYCLE_STATE" type="xs:int" />
                    <xs:element name="STATUS" type="ServiceStatus" />
                    <xs:element name="STATUS_FLAGS" type="xs:int" />
                  </xs:sequence>
                  <xs:attribute name="elem" type="xs:int" />
                </xs:complexType>
              </xs:element>

            </xs:sequence>
          </xs:complexType>
        </xs:element>

      </xs:sequence>
      <xs:attribute name="configName" type="xs:string" default="/config/service_state_map" />
    </xs:complexType>
  </xs:element>

</xs:schema>

