function mapBasicServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "teleServiceCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTeleServiceCode ( myContext, nMyIndices, "teleServiceCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "bearerServiceCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapBearerServiceCode ( myContext, nMyIndices, "bearerServiceCode", 0 );                               
  }                                                                                                          

  if ( strEndsWith ( parentContext, "basicServiceCodeList" ) == true )
  {
    SsBasicServicesAffected[SsBasicServicesAffectedNb] = lastBasicService;
    SsBasicServicesAffectedNb = SsBasicServicesAffectedNb + 1;
  }
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapBasicServiceCodeList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
