###############################################################################
# save_pinconf_file()
#       input:
#               pinconf_file
#               prefix (dm, cm etc.)
#               assoc array of pinconf entries
###############################################################################
sub save_pinconf_file {
        local ($FILE) = @_;

        #
        # Move pin.conf to pin.conf.xxxx
        #
        if (! -e "$FILE.$currtime1") {
                printout("$ME: Saving $FILE as $FILE.$currtime1\n");
                open (OUTFILE, ">$FILE.$currtime1") ||
                        die "$ME: Unable to create file '$FILE.$currtime1': $!\n";
                open (FILE, "<$FILE") ||
                        die "$ME: Unable to open file '$FILE': $!\n";
                while (<FILE>) {
                        print OUTFILE $_;
                }
                close(OUTFILE);
                close(FILE);
        }
}


###############################################################################
# comment some line in pin.conf
# comment_conf()
#       input:
#               file
#               prefix (dm, cm etc.)
#               parameter
###############################################################################
sub comment_conf {
        local ($file, $prefix, $param) = @_;
        local ($tmpoutfile) = "$file.xxx";

        if ($DEBUG) {
                printout("$ME: prefix $prefix; parameter: $param\n");
        }

        #
        # Open file for input
        #
        open (FILE, "$file") ||
            die "$ME: Unable to open file '$file': $!\n";
       open (OUTFILE, ">$tmpoutfile") ||
            die "$ME: Unable to create file '$tmpoutfile': $!\n";


       while (<FILE>) {
               $line = $_;
               $matched = 0;
                if ($line =~ m/^\s*-\s+$prefix\s+$param\s+/) {
                 # comment out this line
                       if ($DEBUG) {
                          printout("$ME: comment out line: $line");
                       }
                    print OUTFILE "#$line";
                 } else {
                    print OUTFILE "$line";
                }

        } # end while
        #
        # Close filehandles
        #
        close(FILE);
        close(OUTFILE);
        #
        # Moving pin.conf.xxx to pin.conf
        #
        unlink "$file";
        (rename "$tmpoutfile", "$file") ||
            die "$ME: Cannot rename $tmpoutfile to $file: $!\n";

}

###############################################################################
# uncomment some line in pin.conf
# uncomment_conf()
#       input:
#               file
#               prefix (dm, cm etc.)
