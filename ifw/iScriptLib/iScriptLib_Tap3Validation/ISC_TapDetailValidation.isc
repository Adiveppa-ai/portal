  {
    if (edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CHARGE_REFUND_INDICATOR,
		0, blockIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CHARGE_REFUND_INDICATOR,
