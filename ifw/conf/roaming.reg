      #------------------------------------------------------------------------
      # Input section
      #------------------------------------------------------------------------
      Input
      {
        UnitsPerTransaction = 1

        InputModule
        {
          ModuleName  = INP_GenericStream
          NotificationFilePath    = ./data/rapin/notification
          NotificationFilePrefix  = CD
          TapHeaderInfoFilePrefix = test_
          TapHeaderInfoFileSuffix = .thi
          TapHeaderInfoFieldSep   = ;
          TapHeaderInfoFilePath   = ./data/outcollect/settlement/out/tapheaderinfo

          Module
          {
            DefaultOutput = EETOutput
            Grammar       = ./formatDesc/Formats/TAP3-NG/RAP_0105_InGrammar.dsc

            InputStream
            {
              ModuleName = EXT_InFileManager
              Module
              {
                InputPath   = ./data/rapin/in
                InputPrefix = RC
 
                DonePath    = ./data/rapin/done
                DonePrefix  = test_RAPInProcessingPipeline_
                DoneSuffix  = .done
           
                ErrorPath   = ./data/rapin/error
                ErrorPrefix = test_RAPInProcessingPipeline_
                ErrorSuffix = .err

                TempPrefix  = temp_RAPInProcessingPipeline_ 
                Replace     = True
                InputDirEmptyTimeout = 10
              }
            }
          }
        }
      }

      #------------------------------------------------------------------------
      # Function section
      #------------------------------------------------------------------------
      Functions 
      {
        Processing
        {
          FunctionPool
          {
            #---------------------------------------------------
            # Business Mapping
            #---------------------------------------------------
            BusinessMapping
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  BusinessMapping
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_RAP_0105_InMap.isc
                  }
                }
              }
            }

            #---------------------------------------------------
            # PreSuspense FCT
            #---------------------------------------------------
            PreSuspense
            {
              ModuleName = FCT_PreSuspense
              Module
              {
                Active = True
                QueryableFields
                {
                  SUSP_USAGE_RAP_INFO_T
                  {
                    TAP_FILE_SEQ_NO = DETAIL.ASS_ROAMING_EXT.TAP_FILE_SEQ_NO
                    RAP_FILE_SEQ_NO = DETAIL.ASS_ROAMING_EXT.RAP_FILE_SEQ_NO
                    SENDER = DETAIL.ASS_ROAMING_EXT.SENDER
                  }
                }
              }
            }
           
	    #---------------------------------------------------
            # Duplicate RAP Records
            #---------------------------------------------------
            DupRAPRecords
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  DupRAPRecords
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_DupRAPRecords.isc
                    NULLStream = DevNull
                  }
                }
              }
            }
	    
            #--------------------------------------------------
            # Rejection
            #--------------------------------------------------
            Rejection
            {
              ModuleName = FCT_Reject
              Module
              {
                Active          = True 
                NotifyOnReject  = True 
                UseRejectStream = True 
                StreamMap {}
              }
            }

            #---------------------------
            # Suspense FCT
            #---------------------------
            Suspense
            {
              ModuleName = FCT_Suspense
              Module
              {
                Active                   = True
                SuspenseCreateStream     = SuspenseCreateOutput
                SuspenseUpdateStream     = SuspenseUpdateOutput
                DataConnection           = ifw.DataPool.LoginInfranet
                LogTestResults           = True
                PipelineCategory         = RoamingPipelines

                RecycleLog
                {
                   MessageFilePath   = ./etc
                   MessageFilePrefix = Framework
                   MessageFileSuffix = msg
                   FilePath          = ./data/log
                   FilePrefix        = RAPInProcessing_Reject_
                   FileSuffix        = .log
                }
              }
            }

            #------------------------------------------
            # Override Suspense Parameters
            #------------------------------------------
            OverrideSuspenseParams
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  OverrideSuspenseParams
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_OverrideSuspenseParams.isc
                    TAPFilePrefix = CD
                    TAPOutCollectPipeline = TAPOutCollectPipeline
                    TAPCorrectionPipeline = TAPCorrectionPipeline

                    #the following path must be absolute
                    TAPSentArchivePath = ./data/outcollect/tapout/sent
                    SBRStream = SBROutput
                  }
                }
              }
            }

