VERSION=15.0
PATH=/usr/bin:/bin

PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/dm_fusa

LD_LIBRARY_PATH=${PINDIR}/lib
export LD_LIBRARY_PATH

ANSBIN=${PINDIR}/bin
ANSDIR=${PINDIR}/apps/fusa_server
S_PID=${LOGDIR}/answer_s.pid
B_PID=${LOGDIR}/answer_b.pid
JSLOG=${LOGDIR}/dm_fusa.log

if [ -r ${S_PID} -o -r ${B_PID} ]; then
  /bin/ps -f -p `cat ${S_PID}` -p `cat ${B_PID}` | grep answer > /dev/null
  if [ $? -eq 0 ]; then
        echo "ERROR: answer is already running"
        exit 1
  fi
fi

( cd ${ANSDIR} ;
  ${ANSBIN}/answer_s >> ${JSLOG} 2>&1&
  echo $! > ${S_PID} ;
  chmod 640 ${S_PID}
  ${ANSBIN}/answer_b >> ${JSLOG} 2>&1&
  echo $! > ${B_PID} ;
  chmod 640 ${B_PID}
)

# get rc from cm startup
exit $?
