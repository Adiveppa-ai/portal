<Opcode xmlns:h="http://www.w3.org/1999/xhtml" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.portal.com/schemas/BusinessOpcodes" name="PCM_OP_COLLECTIONS_INVOKE_PROMISE_TO_PAY" visibility="public" transaction="required" component="fm_collections" xsi:schemaLocation="http://www.portal.com/schemas/BusinessOpcodes opspec.xsd">
  <Doc>Invokes promise to pay for a billinfo which is already in collections.When the opcode is called in calc-only mode, it returns the break
        up of payment schedule along with milestone amount </Doc>
  <Input>
    <Fields>
      <Poid name="PIN_FLD_POID" use="required" mode="complete">
        <Doc>The account poid</Doc>
        <ClassRef>obj://account</ClassRef>
      </Poid>
      <String name="PIN_FLD_PROGRAM_NAME" use="required">
        <Doc>Name of the program calling this opcode</Doc>
      </String>
      <String name="PIN_FLD_SPEC_NAME" use="optional">
        <Doc>Name of the /config/collections/promise_to_pay_spec object</Doc>
      </String>
      <Poid name="PIN_FLD_SCENARIO_OBJ" use="required" mode="complete">
        <Doc> The collections scenario poid for which promise to pay is invoked </Doc>
        <ClassRef>obj://collections_scenario</ClassRef>
      </Poid>
      <Poid name="PIN_FLD_BILLINFO_OBJ" use="required" mode="complete">
        <Doc> The billinfo poid</Doc>
        <ClassRef>obj://billinfo</ClassRef>
      </Poid>
      <Substruct name="PIN_FLD_PROMISE_TO_PAY_INFO" use="required" isRecursive="false">
        <Doc> Promise to pay info substructure </Doc>
        <Fields>
          <Decimal name="PIN_FLD_AMOUNT" use="optional">
            <Doc> Total Promise Amount </Doc>
          </Decimal>
          <Int name="PIN_FLD_NUM_MILESTONES" use="optional">
            <Doc> Number of payment milestones </Doc>
          </Int>
          <Decimal name="PIN_FLD_MILESTONE_AMOUNT" use="optional">
            <Doc> Amount per milestone </Doc>
          </Decimal>
          <Int name="PIN_FLD_DAYS" use="optional">
            <Doc> Number of days within which outstanding amount will be paid off </Doc>
          </Int>
          <Int name="PIN_FLD_MILESTONE_INTERVAL" use="optional">
            <Doc> Interval between each payment milestone </Doc>
          </Int>
          <Timestamp name="PIN_FLD_INVOKE_T" use="required">
            <Doc> Date from which promise to pay is effective (first installment date) </Doc>
          </Timestamp>
          <Poid name="PIN_FLD_PAYINFO_OBJ" use="optional" mode="complete">
            <Doc> The payinfo poid. </Doc>
            <ClassRef>obj://payinfo</ClassRef>
          </Poid>
          <Array name="PIN_FLD_PAYINFO" use="optional" elemIdMode="ignored" iterationOrder="undefined" minElements="0" maxElements="1" minElemId="0" isElemIdAssignAllowed="false" isElemIdAnyAllowed="false" isRecursive="false">
            <Doc> Payinfo object - information for immediate payment </Doc>
            <Fields>
              <Array name="PIN_FLD_CC_INFO" use="optional" elemIdMode="ignored" iterationOrder="undefined" minElements="0" maxElements="1" minElemId="0" isElemIdAssignAllowed="false" isElemIdAnyAllowed="false" isRecursive="false">
                <Doc> Credit Card info - Refer to the /payinfo/cc object spec for details.
                                        			      Only the cc subtype is returned [e.g. PIN_FLD_CC_INFO and all its fields].
                                        			      Note - only 1 element used.</Doc>
                <Fields> </Fields>
              </Array>
              <Array name="PIN_FLD_DD_INFO" use="optional" elemIdMode="ignored" iterationOrder="undefined" minElements="0" maxElements="1" minElemId="0" isElemIdAssignAllowed="false" isElemIdAnyAllowed="false" isRecursive="false">
                <Doc> Direct debit info - Refer to the /payinfo/dd object spec for details. 
								      Only the dd subtype is returned (e.g. PIN_FLD_DD_INFO and all its fields). 
								      Note - only 1 element used. </Doc>
                <Fields> </Fields>
              </Array>
            </Fields>
          </Array>
      	  <Array name="PIN_FLD_MILESTONES" use="optional" elemIdMode="ignored" iterationOrder="undefined">
                <Doc> Milestone elements holds the unequal installments and unequal intervals information</Doc>
                <Fields>
                   <Decimal name="PIN_FLD_MILESTONE_AMOUNT" use="optional">
                       <Doc>Milestone amount</Doc>
                   </Decimal>
                   <Decimal name="PIN_FLD_MILESTONE_PERCENTAGE" use="optional">
	               <Doc>Milestone percentage</Doc>
	           </Decimal>
                   <Int name="PIN_FLD_MILESTONE_INTERVAL" use="optional">
	               <Doc>Milestone interval between each promise to pay action</Doc>
	           </Int>
	        </Fields>
          </Array>
        </Fields>
      </Substruct>
      <Substruct name="PIN_FLD_CONTEXT_INFO" use="optional">
        <Doc>Substruct to pass information from external clients.</Doc>
        <Fields>
          <String name="PIN_FLD_CORRELATION_ID" use="optional" maxlen="128">
            <Doc>Correlation id passed by an external system to BRM.</Doc>
          </String>
          <String name="PIN_FLD_EXTERNAL_USER" use="optional" maxlen="128">
            <Doc>User of an external system connecting to BRM.</Doc>
          </String>
        </Fields>
      </Substruct>
    </Fields>
  </Input>
  <Output>
    <Fields>
      <Poid name="PIN_FLD_POID" use="required" mode="complete">
        <Doc>The new activity event poid that holds promise to pay information </Doc>
        <ClassRef>obj://event.activity.collections.promise_to_pay</ClassRef>
      </Poid>
      <Int name="PIN_FLD_FLAGS" use="optional">
        <Doc>0 - Indicates account/billinfo is not under promise to pay 
             1 - Indicates account/billinfo is already under promise to pay</Doc>
      </Int>
      <Substruct name="PIN_FLD_PROMISE_TO_PAY_INFO" use="optional" isRecursive="false">
        <Doc> Promise to pay information </Doc>
        <Fields>
          <Decimal name="PIN_FLD_AMOUNT" use="optional">
            <Doc> Total Promise Amount </Doc>
          </Decimal>
          <Decimal name="PIN_FLD_NUM_MILESTONES" use="optional">
            <Doc> Number of payment milestones </Doc>
          </Decimal>
          <Decimal name="PIN_FLD_MILESTONE_INTERVAL" use="optional">
            <Doc> Interval between each payment milestone </Doc>
          </Decimal>
          <Decimal name="PIN_FLD_MILESTONE_AMOUNT" use="required">
            <Doc> Amount per milestone </Doc>
          </Decimal>
          <Timestamp name="PIN_FLD_INVOKE_T" use="required">
            <Doc> First milestone date </Doc>
          </Timestamp>
          <Timestamp name="PIN_FLD_END_T" use="required">
            <Doc> Last milestone date </Doc>
          </Timestamp>
      	  <Array name="PIN_FLD_MILESTONES" use="optional" elemIdMode="ignored" iterationOrder="undefined">
                <Doc> Milestone elements holds the unequal installments and unequal intervals information </Doc>
                <Fields>
                   <Decimal name="PIN_FLD_MILESTONE_AMOUNT" use="optional">
                       <Doc>Milestone amount</Doc>
                   </Decimal>
                   <Decimal name="PIN_FLD_MILESTONE_PERCENTAGE" use="optional">
	               <Doc>Milestone percentage</Doc>
	           </Decimal>
                   <Int name="PIN_FLD_MILESTONE_INTERVAL" use="optional">
	               <Doc>Milestone interval between each promise to pay action</Doc>
	           </Int>
	        </Fields>
          </Array>
        </Fields>
      </Substruct>
      <Substruct name="PIN_FLD_CONTEXT_INFO" use="optional">
        <Doc>Substruct to pass information from external clients.</Doc>
        <Fields>
          <String name="PIN_FLD_CORRELATION_ID" use="optional" maxlen="128">
            <Doc>Correlation id passed by an external system to BRM.</Doc>
          </String>
          <String name="PIN_FLD_EXTERNAL_USER" use="optional" maxlen="128">
            <Doc>User of an external system connecting to BRM.</Doc>
          </String>
        </Fields>
      </Substruct>
      <Array name="PIN_FLD_PROMISE_TO_PAY" use="optional" elemIdMode="ignored" iterationOrder="undefined" minElements="1" maxElements="256" minElemId="0" isElemIdAssignAllowed="false" isElemIdAnyAllowed="false" isRecursive="false">
        <Doc> When the opcode is called in calc-only mode, the array element holds the milestone amount and due-date information </Doc>
          <Fields>
            <Timestamp name="PIN_FLD_DUE_T" use="optional">
              <Doc>Milestone due date</Doc>
            </Timestamp>
            <Decimal name="PIN_FLD_AMOUNT" use="optional">
	      <Doc>Milestone amount</Doc>
	    </Decimal>
	  </Fields>
      </Array>
    </Fields>
  </Output>
</Opcode>
