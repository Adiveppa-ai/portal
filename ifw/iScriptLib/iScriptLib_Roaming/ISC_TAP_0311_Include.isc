function mapContentServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  service_Type = service_Content;
  contentSvcUsedIdx = contentSvcUsedIdx + 1;
  if ( edrAddDatablock( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST ) == false )
  {
  }
                                                                                                             
  childContext = myContext + "." + "contentTransactionCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapContentTransactionCode ( myContext, nMyIndices, "contentTransactionCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "contentTransactionType";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapContentTransactionType ( myContext, nMyIndices, "contentTransactionType", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "objectType";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapObjectType ( myContext, nMyIndices, "objectType", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transactionDescriptionSupp";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTransactionDescriptionSupp ( myContext, nMyIndices, "transactionDescriptionSupp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transactionShortDescription";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTransactionShortDescription ( myContext, nMyIndices, "transactionShortDescription", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transactionDetailDescription";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTransactionDetailDescription ( myContext, nMyIndices, "transactionDetailDescription", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transactionIdentifier";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTransactionIdentifier ( myContext, nMyIndices, "transactionIdentifier", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transactionAuthCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTransactionAuthCode ( myContext, nMyIndices, "transactionAuthCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "dataVolumeIncoming";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapDataVolumeIncoming ( myContext, nMyIndices, "dataVolumeIncoming", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "dataVolumeOutgoing";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapDataVolumeOutgoing ( myContext, nMyIndices, "dataVolumeOutgoing", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalDataVolume";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalDataVolume ( myContext, nMyIndices, "totalDataVolume", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "chargeRefundIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapChargeRefundIndicator ( myContext, nMyIndices, "chargeRefundIndicator", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "contentChargingPoint";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapContentChargingPoint ( myContext, nMyIndices, "contentChargingPoint", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "chargeInformationList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0 );                               
  }                                                                                                          

  storeChargeInfoTempFields();
                                                                                                             
  childContext = myContext + "." + "advisedChargeInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapAdvisedChargeInformation ( myContext, nMyIndices, "advisedChargeInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapContentServiceUsedList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "ContentServiceUsed";                                            
  Long ContentServiceUsedListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < ContentServiceUsedListEntries; i = i + 1 )                                                      
  {                                                                                                          
    mapContentServiceUsed ( myContext, nMyIndices, "ContentServiceUsed", i );                               
  }                                                                                                          
                                                                                                             
