  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate AdvisedChargeInformation. It will raise error code 30 for AdvisedChargeInformation.
 ******************************************************************************************************************************/
 
function validateAdvisedChargeInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",351";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "paidIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validatePaidIndicator ( myContext, nMyIndices, "paidIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "paymentMethod";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validatePaymentMethod ( myContext, nMyIndices, "paymentMethod", 0, errorContext );
  }
 
  childContext = myContext + "." + "advisedChargeCurrency";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateAdvisedChargeCurrency ( myContext, nMyIndices, "advisedChargeCurrency", 0, errorContext );
  }
  else 
  {
    Bool advCurrencyPresent = false;
    Long i;
    if ( hasChargeRefund == false )
    {
      for( i = 0; i < advCurrencyEntries and advCurrencyPresent == false; i = i + 1 )
      {
        if( advChargeCurrency_Arr[i] == "NO_CURRENCY" )
        {
          advCurrencyIndex = i;
          advCurrencyPresent = true;
        }
      }
      if ( advCurrencyPresent == false )
      {
        advChargeCurrency_Arr[advCurrencyEntries] = "NO_CURRENCY";
        advCurrencyIndex = advCurrencyEntries;
        advCurrencyEntries = advCurrencyEntries + 1;
      }
    }
    else
    {
      for( i = 0; i < advCurrencyEntriesRefund and advCurrencyPresent == false; i = i + 1 )
      {
        if( advChargeCurrencyRefund_Arr[i] == "NO_CURRENCY" )
        {
          advCurrencyRefundIndex = i;
          advCurrencyPresent = true;
        }
      }
      if ( advCurrencyPresent == false )
      {
        advChargeCurrencyRefund_Arr[advCurrencyEntriesRefund] = "NO_CURRENCY";
        advCurrencyRefundIndex = advCurrencyEntriesRefund;
        advCurrencyEntriesRefund = advCurrencyEntriesRefund + 1;
      }
    }
  }
 
  childContext = myContext + "." + "advisedCharge";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateAdvisedCharge ( myContext, nMyIndices, "advisedCharge", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "AdvisedChargeInformation", "351", "30", "Missing Advised Charge");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Missing Advised Charge");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "commission";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCommission ( myContext, nMyIndices, "commission", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ContentChargingPoint, ActualDeliveryTimeStamp, RequestedDeliveryTimeStamp, OrderPlacedTimeStamp.
 * It will raise error code 20, 21, 100 for ContentChargingPoint, error code 10, 11, 30, 31 for ActualDeliveryTimeStamp,
 * error code 10, 11, 30, 31 for RequestedDeliveryTimeStamp and error code 10, 11, 30, 31 for OrderPlacedTimeStamp.
 ******************************************************************************************************************************/
 
function validateContentChargingPoint ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",345";
  contentChargingPoint = edrLongEx( myContext, indices, nParentIndices );   

  if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "3", "1", "INTEGER_TYPE") == true) and 
            (timeStampEntries > 1) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Content Charging Point", "345", "20",
                                    "Value out of range and more than one timestamp present within Content Transaction Basic Info");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","",
                                    "Value out of range and more than one timestamp present within Content Transaction Basic Info");
    edrSetIsValidDetail(false);
  }
  else if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "3", "1", "INTEGER_TYPE") == true) and
            (timeStampEntries == 1) ) 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Content Charging Point", "345", "21",
            "Value out of range and only one timestamp present within Content Transaction Basic Info");
  }

  if( (contentChargingPoint ==1 and referencedTimeStamp[1] != 1) or (contentChargingPoint == 2 and referencedTimeStamp[2] != 2)
                                                                 or (contentChargingPoint == 3 and referencedTimeStamp[3] != 3) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Content Charging Point", "345", "100",
                                 "Referenced timestamp not present within associated group Content Transaction Basic Info");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1","",
                                 "Referenced timestamp not present within associated group Content Transaction Basic Info");
    edrSetIsValidDetail(false);
  }
                        
  if ( (dateIsValid(strToDate(lastActualDeliveryTimeStamp)) == false or strLength(lastActualDeliveryTimeStamp) != 14) and 
       (contentChargingPoint == 3) and (referencedTimeStamp[3] == 3) and (lastActualDeliveryTimeStamp != "") )
  {
    objTag = "1,3,17,304,302";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ActualDeliveryTimeStamp", "302", "10", 
                                              "Syntax Error and timestamp referenced as Charging Point");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", objTag, "0", "-1", "-1", "",
                                              "Syntax Error and timestamp referenced as Charging Point");
    edrSetIsValidDetail(false);
    
  }
  else if ( (dateIsValid(strToDate(lastActualDeliveryTimeStamp)) == false or strLength(lastActualDeliveryTimeStamp) != 14) and 
            (contentChargingPoint != 3) and (referencedTimeStamp[3] == 3) and (lastActualDeliveryTimeStamp != "") )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ActualDeliveryTimeStamp", "302", "11", 
                                                 "Syntax Error and timestamp not referenced as Charging Point"); 
  }
  if( (actualDeliveryUtcTimeOffsetCodeIsMissing == true) and (contentChargingPoint == 3) )
  {
    objTag = "1,3,17,304,302";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ActualDeliveryTimeStamp", "302", "30", "Missing UTC time offset in group Actual Delivery TimeStamp");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", objTag, "0", "-1", "-1", "","Missing UTC time offset in group Actual Delivery TimeStamp");
    edrSetIsValidDetail(false);
  }
  else if( (actualDeliveryUtcTimeOffsetCodeIsMissing == true) and (contentChargingPoint != 3) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ActualDeliveryTimeStamp", "302", "31", "Missing UTC time offset in group Actual Delivery TimeStamp"); 
  }

  if ( (dateIsValid(strToDate(lastRequestedDeliveryTimeStamp)) == false or strLength(lastRequestedDeliveryTimeStamp) != 14) and 
       (lastRequestedDeliveryTimeStamp != "") and (contentChargingPoint == 2) )
  {
    objTag = "1,3,17,304,301";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RequestedDeliveryTimeStamp", "301", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", objTag, "0", "-1", "-1", "","Syntax error");
    edrSetIsValidDetail(false);
  }
  if ( (dateIsValid(strToDate(lastRequestedDeliveryTimeStamp)) == false or strLength(lastRequestedDeliveryTimeStamp) != 14) and 
       (lastRequestedDeliveryTimeStamp != "") and (contentChargingPoint != 2) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "RequestedDeliveryTimeStamp", "301", "11", "Syntax Error"); 
  }
  if( (requestedDeliveryUtcTimeOffsetCodeIsMissing == true) and (contentChargingPoint == 2) )
  {
    objTag = "1,3,17,304,301";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RequestedDeliveryTimeStamp", "301", "30", "Mandatory associated UTC Time Offset Code missing and timestamp referenced as Charging Point");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", objTag, "0", "-1", "-1", "","Mandatory associated UTC Time Offset Code missing and timestamp referenced as Charging Point");
    edrSetIsValidDetail(false);
  }
  else if( (requestedDeliveryUtcTimeOffsetCodeIsMissing == true) and (contentChargingPoint != 2) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "RequestedDeliveryTimeStamp", "301", "31", "Mandatory associated UTC Time Offset Code missing and timestamp not referenced as Charging Point"); 
  }
  
  if ( (dateIsValid(strToDate(lastOrderPlacedTimeStamp)) == false or strLength(lastOrderPlacedTimeStamp) != 14) and 
       (lastOrderPlacedTimeStamp != "") and (contentChargingPoint == 1) )
  {
    objTag = "1,3,17,304,300";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "OrderPlacedTimeStamp", "300", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", objTag, "0", "-1", "-1", "","Syntax error");
    edrSetIsValidDetail(false);
  }
  else if ( (dateIsValid(strToDate(lastOrderPlacedTimeStamp)) == false or strLength(lastOrderPlacedTimeStamp) != 14) and
            (lastOrderPlacedTimeStamp != "") and (contentChargingPoint != 1) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "OrderPlacedTimeStamp", "300", "11", "Syntax Error"); 
  }
  if( (orderPlacedUtcTimeOffsetCodeIsMissing == true) and (contentChargingPoint == 1) )
  {
    objTag = "1,3,17,304,300";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "OrderPlacedTimeStamp", "300", "30", "Mandatory associated UTC Time Offset Code missing and timestamp referenced as Charging Point");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", objTag, "0", "-1", "-1", "","Mandatory associated UTC Time Offset Code missing and timestamp referenced as Charging Point");
    edrSetIsValidDetail(false);
  }
  else if( (orderPlacedUtcTimeOffsetCodeIsMissing == true) and (contentChargingPoint != 1) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "OrderPlacedTimeStamp", "300", "31", "Mandatory associated UTC Time Offset Code missing and timestamp not referenced as Charging Point"); 
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

