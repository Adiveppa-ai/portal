# root account object
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_ACCOUNT_TYPE	 ENUM [0] 1
0 PIN_FLD_BRAND_OBJ	 POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_ACCOUNT_TYPE   ENUM [0] 2
0 PIN_FLD_INTERNAL_NOTES    BUF [0] flag/size/offset 0x0 0 0 NULL data ptr
0 PIN_FLD_LINEAGE	  STR [0] "/"
0 PIN_FLD_NAME            STR [0] "Brand Host"
0 PIN_FLD_NAMEINFO      ARRAY [1] allocated 18, used 18
1     PIN_FLD_FIRST_CANON     STR [0] "system"
1     PIN_FLD_FIRST_NAME      STR [0] "System"
1     PIN_FLD_LAST_CANON      STR [0] "administrator"
1     PIN_FLD_LAST_NAME       STR [0] "Administrator"
</PCM_OP> 



# Prohibited fields in the account object are created separately using
# a WFLDS opcode.
<PCM_OP $PIN_OPNAME=PCM_OP_WRITE_FLDS; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_ACCOUNT_NO      STR [0] "ROOT"
0 PIN_FLD_CURRENCY        INT [0] $PIN_CONF_SYS_CURRENCY
0 PIN_FLD_ITEM_POID_LIST STR [0] "$PIN_CONF_DB_NO|/item/misc 1 0"
0 PIN_FLD_LASTSTAT_CMNT   STR [0] ""
0 PIN_FLD_CLOSE_WHEN_T   TSTAMP [0] (0) <null>
0 PIN_FLD_STATUS         ENUM [0] 10100
0 PIN_FLD_STATUS_FLAGS    INT [0] 0
0 PIN_FLD_BAL_GRP_OBJ    POID [0] $PIN_CONF_DB_NO /balance_group 1 0
</PCM_OP>

#
#=============================================================================#

# default bill object for the top level account
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /bill 1 0
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_NAME            STR [0] "top bill obj"
0 PIN_FLD_BILLINFO_OBJ	POID [0] $PIN_CONF_DB_NO /billinfo 1 0
0 PIN_FLD_START_T      TSTAMP [0] ($PIN_CONF_DATE_NOW)
0 PIN_FLD_END_T        TSTAMP [0] (0) <null>
</PCM_OP> 

#=============================================================================#

# default payinfo object for the top level account
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /payinfo 1 0
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_INVOICE_OBJ    POID [0] $PIN_CONF_DB_NO /invoice 1 0
0 PIN_FLD_NAME            STR [0] "top payinfo obj"
</PCM_OP> 

#=============================================================================#

# balance_group object for the top level account
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
