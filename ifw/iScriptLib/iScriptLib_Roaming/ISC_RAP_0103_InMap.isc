function mapNotificationError ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
  
  return; // just return, there is no need to map this block to any business fields, it is just for information and the staging fields solve that purpose
                                                                                                             
  childContext = myContext + "." + "notification";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapNotification ( myContext, nMyIndices, "notification", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "errorDetail";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
