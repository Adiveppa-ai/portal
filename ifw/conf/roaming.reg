##              FilePath   = ./data/dump
##              FileName   = PostPipelineTAPInRePrice4
##              FileSuffix = .txt
##            }
##          }
##----------------------------------------------------------------------

          } #END FunctionPool
        }
      } # END Functions

      #--------------------------------------------------
      # Output Section
      #--------------------------------------------------
      Output
      {
        WriteDefaultEdr            = False

        MaxErrorRates
        {
          INF_EDR_REJECTED = 90
        }

        #-------------------------------------------
        # Multithreaded writing. This is recommended
        # when EDRs are associated with multiple
        # output streams.
        #------------------------------------------
        MultiThreading
        {
           Active = False      # Defaults to False
           NumberOfThreads = 1 # Number of threads spawned. Defaults to 1
           BatchSize = 0       # The number of EDRs cached before sent for writing. Defaults to 0
        }

        OutputCollection
        {
          #--------------------------------------------------------------------
          # The DevNull stream
          #--------------------------------------------------------------------
          DevNull
          {
            ModuleName = OUT_DevNull
            Module
            { 
            } 
          } # end of DevNull

          #--------------------------------------------------------------------
          # Output stream for no balance events
          #--------------------------------------------------------------------
          DiscountErrorOutput
          {
            ModuleName = OUT_Reject
            Module
            {
              DeleteEmptyStream = TRUE # defaults to TRUE
  
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/discountError
                  OutputPrefix          = test_
                  OutputSuffix          = .dsc
                  TempPrefix            = tmptest_
                  TempDataPath          = ./data/discountError
                  TempDataPrefix        = dsc.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          }

          #--------------------------------------------------------------------
          # Output stream for dead-locked events.
          #--------------------------------------------------------------------
          DiscountDeadlockOutput
          {
            ModuleName = OUT_Reject
            Module
            {
              DeleteEmptyStream = TRUE # defaults to TRUE
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/discountError
                  OutputPrefix          = test_
                  OutputSuffix          = .dlk
                  TempPrefix            = tmptest_
                  TempDataPath          = ./data/discountError
                  TempDataPrefix        = dlk.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          }  # end of DiscountDeadlockOutput
 
          #--------------------------------------------------------------------
          # The /service/gsm/telephony output stream
          #--------------------------------------------------------------------
          TELOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gsm

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
               
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/out/gsm/telephony
                  OutputPrefix          = test_tel_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_tel_
                  TempDataPath          = ./data/out/gsm/telephony
                  TempDataPrefix        = tel.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of TELOutput

          #--------------------------------------------------------------------
          # The /service/ip/gprs output stream
          #--------------------------------------------------------------------
          GPRSIPOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/gprs

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath = ./data/out/gprs
                  OutputPrefix = test_GPRSIP
                  OutputSuffix = .out
                  TempPrefix   = .

                  TempDataPath    = ./data/out/gprs
                  TempDataPrefix  = gprs_ip.tmp.
                  TempDataSuffix  = .data

                  Replace = TRUE
                }
              }
            }
          } # end of GPRSIPOutput

          #--------------------------------------------------------------------
          # The /service/telco/gprs output stream
          #--------------------------------------------------------------------
          GPRSTELCOOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gprs

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath = ./data/out/gprs
                  OutputPrefix = test_GPRSTELCO
                  OutputSuffix = .out
                  TempPrefix   = .

                  TempDataPath    = ./data/out/gprs
                  TempDataPrefix  = gprs_telco.tmp.
                  TempDataSuffix  = .data

                  Replace = TRUE
                }
              }
            }
          } # end of GPRSTELCOOutput

          #--------------------------------------------------------------------
          # The /service/telco/gsm/fax output stream
          #--------------------------------------------------------------------
          FAXOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gsm

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/out/gsm/fax
                  OutputPrefix          = test_fax_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_fax_
                  TempDataPath          = ./data/out/gsm/fax
                  TempDataPrefix        = fax.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of FaxOutput
          #--------------------------------------------------------------------
          # The /service/telco/gsm/sms output stream
          #--------------------------------------------------------------------
          SMSOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/session/telco/gsm

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/out/gsm/sms
                  OutputPrefix          = test_sms_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_sms_
                  TempDataPath          = ./data/out/gsm/sms
                  TempDataPrefix        = sms.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of SMSOutput
    
          #--------------------------------------------------------------------
          # The /service/wap output stream
          #--------------------------------------------------------------------
          WAPOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = RATING_PIPELINE
            EventType = /event/delayed/activity/wap/interactive

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True # defaults to TRUE

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/out/wap
                  OutputPrefix          = test_wap_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_wap_
                  TempDataPath          = ./data/out/wap
                  TempDataPrefix        = wap.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of WAPOutput

          #--------------------------------------------------------------------
          # SuspenseCreateOutput stream
          #--------------------------------------------------------------------
          SuspenseCreateOutput
          {
            ModuleName = OUT_GenericStream
            EventType = /suspended_usage
            Module
            {
              Grammar = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreationGrammar.dsc
              DeleteEmptyStream = True
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/reject
                  OutputPrefix          = suspense_create_
                  OutputSuffix          = .out
                  TempPrefix            = tmpsuspense_create_
                  TempDataPath          = ./data/reject
                  TempDataPrefix        = susp.create.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of SuspenseCreateOutput

          #--------------------------------------------------------------------
          # SuspenseUpdateOutput stream
          #--------------------------------------------------------------------
          SuspenseUpdateOutput
          {
            ModuleName = OUT_GenericStream
            EventType = /tmp_suspended_usage

            Module
            {
              Grammar = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdateGrammar.dsc
              DeleteEmptyStream = True

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/reject
                  OutputPrefix          = suspense_update_
                  OutputSuffix          = .out
                  TempPrefix            = tmpsuspense_update_
                  TempDataPath          = ./data/reject
                  TempDataPrefix        = susp.update.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of SuspenseUpdateOutput
        } # end of OutputCollection

        OutputLog
        {
          FilePath        = ./log/stream
          FileName        = TAPInRePricePipeline
          FilePrefix      = Stream_
          FileSuffix      = .log

          SuppressErrors
          {
            ERR_SPEC_VERSION_INVALID
            ERR_RELEASE_VERSION_INVALID
          }
        }
        
        SequenceGeneration = Unit

        EdrTraceEnabled = False
        EdrTrace
        {
            TraceLog
            {
                 FilePath   = ./log/edrLog
                 FileName   = edrTraceLog
                 FilePrefix = log_
                 FileSuffix = .log
            }

            TraceStartPoint =  Input
            TraceEndPoint   = Output

        } # END EdrTrace

        
      } # end of Output    
      
    } # END TAPInRePricePipeline

    StopRapGeneratorPipeline
    {
      Active = TRUE

      RejectStream = DevNull
      MultiThreaded = FALSE

      TransactionManager
      {
        RedoEnabled = False
        SingleTransaction = False

        BinaryLogFileName = ./tam/StopRapBinaryLogFile.dat
      }

      EdrFactory
      {
        Realtime = true
        Description =  ./formatDesc/Formats/TAP3-NG/containerDesc.dsc
      }


      DataDescription
      {
        Standard
        {
          ModuleName = Standard
          Module
          {
            StreamFormats
            {
              Stop_RAP = ./formatDesc/Formats/TAP3-NG/StopRapInfo.dsc
              Generic = ./formatDesc/Formats/TAP3-NG/GenericBlocks.dsc
              TAP3    = ./formatDesc/Formats/TAP3-NG/TAP_0312_Blocks.dsc
              RAP     = ./formatDesc/Formats/TAP3-NG/RAP_0105_Blocks.dsc
            }
            InputMapping
            {
              Mapping1 = ./iScriptLib/iScriptLib_Roaming/StopRapInfo_InMap.dsc
            }
            OutputMapping
            {
            }
          }
        }
      }#End DataDescription

      #---------------------------------
      # Pipeline Log Section
      #---------------------------------
      PipelineLog
      {
        ModuleName  = LOG
        Module
        {
          ITO
          {
            FilePath          = ./log/pipeline
            FileName          = pipeline_StopRapGeneratorPipeline.log 
            ProcessName       = ifw
            MessageGroup      = IFW
            ShowOriginator    = TRUE
            SuppressErrors
            {
              ERR_SPEC_VERSION_INVALID
              ERR_RELEASE_VERSION_INVALID
            }
          }


          Buffer
          {
            Size = 1000
          }
        }
      }

      InputBuffer
      {
        Size = 100
      }

      OutputBuffer
      {
        Size = 100
      }


      Input
      {
        UnitsPerTransaction = 1
        InputModule
        {
          ModuleName = INP_GenericStream
          Module
          {
            DefaultOutput = StopRapOutput
            Grammar = ./formatDesc/Formats/TAP3-NG/StopRapInfo_InGrammar.dsc

            InputStream
            {
              ModuleName = EXT_InFileManager
              Module
              {
                InputPath = ./data/stoprap/in
                InputPrefix = RC
                #InputSuffix     = .edr

                DonePath = ./data/done
                DonePrefix = StopRap_
                DoneSuffix = .done

                ErrorPath = ./data/error
                ErrorPrefix = StopRap_
                ErrorSuffix = .err

                TempPrefix = tmp_StopRap
                Replace = True
                InputDirEmptyTimeout = 60
              }
            }
          }
        }
      }

      #---------------------------------
      # Functions Section
      #---------------------------------
      Functions
      {
        Standard
        {
          FunctionPool
          {

            #----------------------------------------------------------------
            # Update TapInfo for Stop Rap Out
            #----------------------------------------------------------------
            UpdateTapInfo_StopRapout
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  UpdateTapInfo_StopRapout
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_UpdateTapInfo_StopRapout.isc
                    DatabaseConnection = ifw.DataPool.Login
                  }
                }
              }
            }
         }

        }
      }
      #---------------------------------
      # Output Section
      #---------------------------------
      Output
      {
        ChargePrecision              = 3
        WriteDefaultEdr              = False
        SpecificationVersionNumber   = 2

        SequenceGeneration           = Unit
        #Unit - Transaction

        MaxErrorRates
        {
          INF_EDR_REJECTED           = 70
          ERR_CUST_NOT_FOUND         = 55
          ERR_CHARGED_ZONE_NOT_FOUND = 55
        }

        OutputCollection
        {

          #--------------------------------------------------------------------
          # The DevNull stream
          #--------------------------------------------------------------------
          DevNull
          {
            ModuleName = OUT_DevNull
            Module
            {
            }
          } # end of DevNull

         
          #--------------------------------------------------------------------
          # The StopRapOutput stream
          #--------------------------------------------------------------------
          StopRapOutput
          {
            ModuleName = OUT_GenericStream
            Module
            {
              Grammar = ./formatDesc/Formats/TAP3-NG/RAP_0105_OutGrammar.dsc
              DeleteEmptyStream = False
              Sequencer = SEQ_GEN_RAPOUT
              StopRapStream = True
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/stoprap/out
                  OutputPrefix          = RC
                  TempPrefix            = tmprap_
                  TempDataPath          = ./data/stoprap/out
                  TempDataPrefix        = rap.tmp.
                  TempDataSuffix        = .data
                  UseInputStreamName    = [8,12;3,7]
                  SequencerPrefix       = ""
                  AppendSequenceNumber  = True
                }
              }
            }
          } # end of StopRapOutput

        }

        OutputLog
        {
          FilePath        = ./log/stream
          FileName        = stream
          FilePrefix      = StopRapGenlog_
          FileSuffix      = .log

          SuppressErrors
          {
            ERR_SPEC_VERSION_INVALID
            ERR_RELEASE_VERSION_INVALID
          }
        }
      }
    }# StopRapGeneratorPipeline


  } # END Pipelines
} # END of ifw
