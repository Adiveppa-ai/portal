}  

//==============================================================================
// Process Detail EDR record
//==============================================================================
function onDetailEdr
{
  if (debug)
  {
    logStdout("onDetailEdr \n");
  }
  checkEdrErrors();
}
function onInvalidDetailEdr
{
  if (debug)
  {
    logStdout("onInvalidDetailEdr \n");
  }
  checkEdrErrors();
}
