/******************************************************************************************************************************
 * This function will validate ChargedPartyInformation. It will raise error code 30 for ChargedPartyInformation.
 ******************************************************************************************************************************/
 
function validateChargedPartyInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",324";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "chargedPartyIdList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargedPartyIdList ( myContext, nMyIndices, "chargedPartyIdList", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargedPartyInformation", "324", "30", "Missing Charged Party Identification within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Missing Charged Party Identification within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargedPartyHomeIdList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargedPartyHomeIdList ( myContext, nMyIndices, "chargedPartyHomeIdList", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargedPartyLocationList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargedPartyLocationList ( myContext, nMyIndices, "chargedPartyLocationList", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargedPartyEquipment";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargedPartyEquipment ( myContext, nMyIndices, "chargedPartyEquipment", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate TransactionStatus. It will raise error code 20 for TransactionStatus.
 ******************************************************************************************************************************/
 
function validateTransactionStatus ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",303";

  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"1" , "0", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TransactionStatus", "303", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

