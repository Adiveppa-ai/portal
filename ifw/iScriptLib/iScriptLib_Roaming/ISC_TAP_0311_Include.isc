function mapMsisdn ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  edrString(DETAIL.A_NUMBER) = strIAC + edrStringEx( myContext, indices, nParentIndices );
  edrString(DETAIL.INTERN_A_NUMBER_ZONE) = edrString(DETAIL.A_NUMBER);

  if ( strStartsWith ( parentContext, "DETAIL.gprsCall" ) == true )
  {
    edrString(DETAIL.ASS_GPRS_EXT.A_NUMBER_USER, 0) = strIAC + edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith ( parentContext, "DETAIL.mobileTerminatedCall" ) == true )
  {
    edrString(DETAIL.ASS_GSMW_EXT.DIALED_DIGITS, 0) = strIAC + edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith ( parentContext, "DETAIL.serviceCentreUsage" ) == true )
  {
    edrString(DETAIL.ASS_GSMW_EXT.A_NUMBER_USER, 0) = strIAC + edrStringEx( myContext, indices, nParentIndices );
    edrString(DETAIL.ASS_GSMW_EXT.DIALED_DIGITS, 0) = strIAC + edrStringEx( myContext, indices, nParentIndices );
  }
  else
  {
    edrString(DETAIL.ASS_GSMW_EXT.A_NUMBER_USER, 0) = strIAC + edrStringEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapImsi ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "DETAIL.gprsCall" ) == true )
  {
    edrString(DETAIL.ASS_GPRS_EXT.PORT_NUMBER, 0) = edrStringEx( myContext, indices, nParentIndices );
    edrString(DETAIL.TYPE_OF_A_IDENTIFICATION)    = "I"; //I=IMSI , M=MSISDN, P=IP ,  S=SIM ,  ...
  }
  else
  {
    edrString(DETAIL.ASS_GSMW_EXT.PORT_NUMBER, 0) = edrStringEx( myContext, indices, nParentIndices );
    edrString(DETAIL.TYPE_OF_A_IDENTIFICATION)    = "I"; //I=IMSI , M=MSISDN, P=IP ,  S=SIM ,  ...
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
