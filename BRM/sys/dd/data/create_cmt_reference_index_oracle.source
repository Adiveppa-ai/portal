	$PIN_CONF_TBLSPACEX0
	$PIN_CONF_STORAGE_MED ;

create unique index i_poid_id0_n_obj_type on cmt_reference_t ( poid_id0, obj_type )
	$PIN_CONF_TBLSPACEX0
	$PIN_CONF_STORAGE_MED ;

