# Pre-defined /unique_account_no object for root account.
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS>
0 PIN_FLD_POID           POID [0] $PIN_CONF_DB_NO /unique_account_no 1 0
0 PIN_FLD_ACCOUNT_NO      STR [0] "ROOT"
0 PIN_FLD_ACCOUNT_OBJ    POID [0] $PIN_CONF_DB_NO /account 1 0
0 PIN_FLD_CREATED_T    TSTAMP [0] ($PIN_CONF_DATE_NOW)
0 PIN_FLD_MOD_T        TSTAMP [0] (0)
</PCM_OP>

#=============================================================================#

# Pre-defined /uniqueness object for root login, /service/pcm_client.
<PCM_OP $PIN_OPNAME=$PIN_CONF_INIT_OPNAME; $PIN_OPFLAGS=$PIN_CONF_INIT_OPFLAGS> 
