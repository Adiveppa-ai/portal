DECLARE
	v_sql_statement	VARCHAR2(32767);
	v_con		NUMBER :=0;
BEGIN
v_sql_statement:= ' CREATE OR REPLACE TRIGGER evt_resrc_map_trigger
AFTER UPDATE OF version ON config_t
FOR EACH ROW
WHEN (old.poid_type = ''/config/event_resource_map'')
DECLARE
BEGIN
	evt_resrc_map(:old.poid_id0);
END;
'; 

	select count(*) into v_con from user_views where view_name = 'CONFIG_T';
       if(v_con = 0) then
                EXECUTE IMMEDIATE v_sql_statement;
        end if;
END;
