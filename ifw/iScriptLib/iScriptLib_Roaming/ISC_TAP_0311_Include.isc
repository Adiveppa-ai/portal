function mapLCSQosDelivered ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "lCSTransactionStatus";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapLCSTransactionStatus ( myContext, nMyIndices, "lCSTransactionStatus", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "horizontalAccuracyDelivered";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapHorizontalAccuracyDelivered ( myContext, nMyIndices, "horizontalAccuracyDelivered", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "verticalAccuracyDelivered";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapVerticalAccuracyDelivered ( myContext, nMyIndices, "verticalAccuracyDelivered", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "responseTime";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapResponseTime ( myContext, nMyIndices, "responseTime", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "positioningMethod";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapPositioningMethod ( myContext, nMyIndices, "positioningMethod", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "trackingPeriod";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTrackingPeriod ( myContext, nMyIndices, "trackingPeriod", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "trackingFrequency";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTrackingFrequency ( myContext, nMyIndices, "trackingFrequency", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "ageOfLocation";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapAgeOfLocation ( myContext, nMyIndices, "ageOfLocation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
