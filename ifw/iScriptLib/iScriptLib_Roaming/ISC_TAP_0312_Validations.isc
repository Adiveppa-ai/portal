/******************************************************************************************************************************
 * This function will validate ContentTransactionBasicInfo. It will raise error code 30 for ContentTransactionBasicInfo.
 ******************************************************************************************************************************/
 
function validateContentTransactionBasicInfo ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",304";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  timeStampEntries        = 0;
  arrayClear( referencedTimeStamp );
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "orderPlacedTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    timeStampEntries = timeStampEntries + 1;
    referencedTimeStamp[1] = 1;
    validateOrderPlacedTimeStamp ( myContext, nMyIndices, "orderPlacedTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "requestedDeliveryTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    timeStampEntries = timeStampEntries + 1;
    referencedTimeStamp[2] = 2;
    validateRequestedDeliveryTimeStamp ( myContext, nMyIndices, "requestedDeliveryTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "actualDeliveryTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {  
    timeStampEntries = timeStampEntries + 1;
    referencedTimeStamp[3] = 3;
    validateActualDeliveryTimeStamp ( myContext, nMyIndices, "actualDeliveryTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "totalTransactionDuration";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalTransactionDuration ( myContext, nMyIndices, "totalTransactionDuration", 0, errorContext );
  }
 
  childContext = myContext + "." + "transactionStatus";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransactionStatus ( myContext, nMyIndices, "transactionStatus", 0, errorContext );
  }

  if( timeStampEntries == 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Content Transaction Basic Info", "304", "30", "No timestamp present within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "No timestamp present within group");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ContentTransaction. It will raise error code 30, 31, 32, 33 for ContentTransaction.
 ******************************************************************************************************************************/
 
function validateContentTransaction ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",17";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "contentTransactionBasicInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateContentTransactionBasicInfo ( myContext, nMyIndices, "contentTransactionBasicInfo", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentTransaction", "17", "30", "Missing Content Transaction Basic Info");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing Content Transaction Basic Info");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargedPartyInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargedPartyInformation ( myContext, nMyIndices, "chargedPartyInformation", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentTransaction", "17", "31", "Missing Charged Party Infomation");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","", "Missing Charged Party Infomation");
    edrSetIsValidDetail(false);
  }

 
  childContext = myContext + "." + "servingPartiesInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateServingPartiesInformation ( myContext, nMyIndices, "servingPartiesInformation", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentTransaction", "17", "32", "Missing Serving Parties Infomation");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Missing Serving Parties Infomation");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "contentServiceUsed";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateContentServiceUsedList ( myContext, nMyIndices, "contentServiceUsed", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentTransaction", "17", "33", "Missing Content Service Used");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1","", "Missing Content Service Used");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}
 
