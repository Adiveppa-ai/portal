      SENDIND_CLEARINGHOUSE_BID         -> TRAILER.SENDING_CLEARINGHOUSE_BID;
      ORIGINAL_SERVING_CARRIER_SID      -> TRAILER.SENDER;
      TOTAL_NUMBER_RECORDS              -> TRAILER.TOTAL_NUMBER_OF_RECORDS;
      BATCH_TOTAL_CHARGE_AND_TAX        -> TRAILER.TOTAL_WHOLESALE_CHARGED_VALUE;
      SETTLEMENT_PERIOD                 -> TRAILER.SETTLEMENT_PERIOD;
      CLEARINGHOUSE_ID                  -> TRAILER.CLEARINGHOUSE_ID;
      R70_BATCH_TOTAL_CHARGE_TAX_SIGN   -> TRAILER.CIBER_R70_BATCH_TOTALS_SIGN;
      R70_ORIGINAL_TOTAL_CHARGE_TAX_SIGN-> TRAILER.CIBER_R70_ORIGINAL_TOTALS_SIGN;
//    R70_SYSTEM_RESERVED_FILLER          AscString(3);
      ORIGINAL_HOME_CARRIER_SID         -> TRAILER.RECIPIENT;
      ORIGINAL_BATCH_SEQUENCE_NUMBER    -> TRAILER.ORIGINAL_SEQUENCE_NUMBER;
      ORIGINAL_BATCH_CREATION_DATE      -> TRAILER.ORIGINAL_CREATION_TIMESTAMP;
      ORIGINAL_TOTAL_NUMBER_RECORDS     -> TRAILER.ORIGINAL_TOTAL_NUMBER_OF_RECORDS;
      ORIGINAL_TOTAL_CHARGE_AND_TAX     -> TRAILER.ORIGINAL_TOTAL_WHOLESALE_CHARGED_VALUE;
      CURRENCY_TYPE                     -> TRAILER.CURRENCY;
    }
  }

