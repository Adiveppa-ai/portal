-- New table for storing encrypted-Aes keys
-- cryptkey_t
create table cryptkey_t (
	crypt_scheme 		varchar2(10),           -- to store scheme name
	crypt_key_id 		int,		        -- to store key_id
	crypt_key 		varchar2(255),          -- to store actual key
