/******************************************************************************************************************************
 * This function will validate EquipmentIdentifier. It will raise error code 30, 31 for EquipmentIdentifier.
 ******************************************************************************************************************************/
 
function validateImeiOrEsn ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",429";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  Bool imeiIsPresent      = false;
 
  childContext = myContext + "." + "imei";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    imeiIsPresent = true;
    validateImei ( myContext, nMyIndices, "imei", 0, errorContext );
  }
 
  childContext = myContext + "." + "esn";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
     if( imeiIsPresent == true)
     {
       // FieldName, AppId, ErrorCode,ErrorDescription
       edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Equipment Identifier", "429", "30", 
                                                 "Both mandatory items IMEI and ESN present within group");
     }
     validateEsn ( myContext, nMyIndices, "esn", 0, errorContext );
  }
  else
  {
    if( imeiIsPresent == false )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Equipment Identifier", "429", "31",
                                                   "Neither mandatory items IMEI or ESN present within group");
    }
  }
                                  
 
  //logContext( myContext, nMyIndices );
}

