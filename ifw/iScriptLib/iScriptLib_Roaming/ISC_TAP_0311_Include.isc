function mapTaxRate ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  taxRate[lastCode] = edrStringEx( myContext, indices, nParentIndices );
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapTaxType ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  taxType[lastCode] = edrStringEx( myContext, indices, nParentIndices );
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapTaxation ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  lastCode = -1;
                                                                                                             
  childContext = myContext + "." + "taxCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxCode ( myContext, nMyIndices, "taxCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "taxType";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxType ( myContext, nMyIndices, "taxType", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "taxRate";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxRate ( myContext, nMyIndices, "taxRate", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "chargeType";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapChargeType ( myContext, nMyIndices, "chargeType", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "taxIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxIndicator ( myContext, nMyIndices, "taxIndicator", 0 );                 
  }                                                                                                          

  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapTaxationList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "Taxation";                                            
  Long TaxationListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < TaxationListEntries; i = i + 1 )                                                      
  {                                                                                                          
    mapTaxation ( myContext, nMyIndices, "Taxation", i );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapAccountingInfo ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( myContext != "HEADER.accountingInfo" )
  {
    return;
  }
  
  childContext = myContext + "." + "taxation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTaxationList ( myContext, nMyIndices, "taxation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "discounting";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapDiscountingList ( myContext, nMyIndices, "discounting", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "localCurrency";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapLocalCurrency ( myContext, nMyIndices, "localCurrency", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "tapCurrency";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTapCurrency ( myContext, nMyIndices, "tapCurrency", 0 );                               
  }                                                                                                          
  else
  {
    theTapCurrency = defaultTapCurrency;
  }
                                                                                                             
  childContext = myContext + "." + "currencyConversionInfo";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapCurrencyConversionList ( myContext, nMyIndices, "currencyConversionInfo", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "tapDecimalPlaces";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTapDecimalPlaces ( myContext, nMyIndices, "tapDecimalPlaces", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapBatchControlInfo ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( myContext != "HEADER.batchControlInfo" )
  {
    return;
  }
                                                                                                             
  childContext = myContext + "." + "sender";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSender ( myContext, nMyIndices, "sender", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "recipient";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRecipient ( myContext, nMyIndices, "recipient", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFileSequenceNumber ( myContext, nMyIndices, "fileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileCreationTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapFileCreationTimeStamp ( myContext, nMyIndices, "fileCreationTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transferCutOffTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTransferCutOffTimeStamp ( myContext, nMyIndices, "transferCutOffTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileAvailableTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapFileAvailableTimeStamp ( myContext, nMyIndices, "fileAvailableTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "specificationVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSpecificationVersionNumber ( myContext, nMyIndices, "specificationVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "releaseVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapReleaseVersionNumber ( myContext, nMyIndices, "releaseVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileTypeIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFileTypeIndicator ( myContext, nMyIndices, "fileTypeIndicator", 0 );                               
  }                                                                                                          
  else
  {
    theFileTypeIndicator = "";
  }
                                                                                                             
  childContext = myContext + "." + "rapFileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapTransferBatch ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "batchControlInfo";                                                       
