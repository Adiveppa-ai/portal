  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TrackedCustomerInformation", "367", "30", "Mandatory group Tracked Customer Identification missing within group");    
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group Tracked Customer Identification missing within group");    
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "trackedCustomerHomeIdList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackedCustomerHomeIdList ( myContext, nMyIndices, "trackedCustomerHomeIdList", 0, errorContext );
  }
 
  childContext = myContext + "." + "trackedCustomerLocList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
