/******************************************************************************************************************************
 * This function will validate ObjectType. It will raise error code 20, 21 for ObjectType.
 ******************************************************************************************************************************/
 
function validateObjectType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",281";
  if( lastContentTransactionCode == 3 and lastContentTransactionType == 11 and 
        ( edrLongEx(myContext, indices, nParentIndices) < 1 or edrLongEx(myContext, indices, nParentIndices) > 6 ) )
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ObjectType", "281", "20", "Object Type out of range for Content Transaction Code and Type Pull/Streaming combination");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Object Type out of range for Content Transaction Code and Type Pull/Streaming combination");
    edrSetIsValidDetail(false);
  }
  else if( lastContentTransactionCode == 3 and lastContentTransactionType == 12 and 
             ( edrLongEx(myContext, indices, nParentIndices) < 20 or edrLongEx(myContext, indices, nParentIndices) > 23 ) )
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ObjectType", "281", "21", "Object Type out of range for Content Transaction Code and Type Pull/Download combination");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", errorContext, "0", "-1", "-1","", "Object Type out of range for Content Transaction Code and Type Pull/Download combination");
    edrSetIsValidDetail(false);
  }
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

