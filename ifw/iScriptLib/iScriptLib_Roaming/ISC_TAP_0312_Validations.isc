/******************************************************************************************************************************
 * This function will validate NonChargedNumber. It will raise error code 10, 11 for NonChargedNumber.
 ******************************************************************************************************************************/
 
function validateNonChargedNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",402";
  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true )
  {
    if ( lastChargedPartyStatus == 0  )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "NonChargedNumber", "402", "10", "Syntax error and Charged Party Status is originating");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1","", "Syntax error and Charged Party Status is originating");
      edrSetIsValidDetail(false);
    }
    if ( lastChargedPartyStatus == 1  )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "NonChargedNumber", "402", "11", "Syntax error and Charged Party Status is terminating");
    }
  }       
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

