/******************************************************************************************************************************
 * This function will validate ChargedPartyIdentifier. It will raise error code 100 for ChargedPartyIdentifier.
 ******************************************************************************************************************************/
 
function validateChargedPartyIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  Bool   checkType         = true;
  Long   ret               = -1;
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",287";
  String chargedPartyIdentifier = edrStringEx(myContext, indices, nParentIndices);
  switch( lastChargedPartyIdType )
  {
     case 1:
     case 2:
     case 3:
     {
       ret = strSearchRegExpr(chargedPartyIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(chargedPartyIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(chargedPartyIdentifier);
     }
     break;
     case 6:
     case 7:
     {
       ret = strSearchRegExpr(chargedPartyIdentifier, "[^0-9A-Za-z]");
     }
     break;
     case 8:
     {
       checkType = validateEmail(chargedPartyIdentifier);
     }
     break;
  }
  if ((ret >= 0) or (checkType == false))
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Party Identifier", "287", "100", 
                                              "Item content does not match Charged Party Id Type");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1","",
                                              "Item content does not match Charged Party Id Type");
    edrSetIsValidDetail(false);
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate ChargedPartyIdType. It will raise error code 20 for ChargedPartyIdType.
 ******************************************************************************************************************************/
 
function validateChargedPartyIdType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",305";

  lastChargedPartyIdType = edrLongEx(myContext, indices, nParentIndices);

  if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "8", "1", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Party Id Type", "305", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

