  }
}


//------------------------------------------------------------------------------
// validateCallEventDetailsCount()
//
// This function will be used to validate the total number of call event details
//------------------------------------------------------------------------------
function validateCallEventDetailsCount
{
  if (debug)
  {
    logStdout("validateCallEventDetailsCount()\n");
  }

  if ((edrInputState(TRAILER.TAP_TOTAL_NUMBER_OF_RECORDS)) == MISSING)
  {
    // Set Fatal Error
    String offset = "-1";

    // offset = longToStr( edrFieldTokenBytePos(TRAILER.TAP_TOTAL_NUMBER_OF_RECORDS)));
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","33","15","2",offset,"-1",
		"Missing Total Call Event Details");
    setAssociatedTapErr ("ERR_TAP3_MISSING_TOTAL_CALL_EVENT_DELTAILS", LOG_CRITICAL , "33","15", "2");
    edrDemandRollback();
  }
  else
  {
    if ((edrLong(TRAILER.TAP_TOTAL_NUMBER_OF_RECORDS)) <= 0)
    {
      // Set Fatal Error
      String offset = "-1";
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","43","2",offset,"-1",
                  "Call Event Details count value out of range");
      setAssociatedTapErr ("ERR_TAP3_CALL_EVENT_DETAILS_COUNT_OOR", LOG_CRITICAL , "20","43", "2");
      edrDemandRollback();
      return;
    }
    else if ((edrLong(TRAILER.TAP_TOTAL_NUMBER_OF_RECORDS)) != record_length)
    {
      // Set Fatal Error
      String offset = "-1";

      // offset = longToStr( edrFieldTokenBytePos(TRAILER.TAP_TOTAL_NUMBER_OF_RECORDS)));
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","43","2",offset,"-1",
 		  "Call Event Details does not match the total in the trailer record");
      setAssociatedTapErr ("ERR_TAP3_TOTAL_CALL_EVENT_DETAILS_MISMATCH", LOG_CRITICAL , "100","43", "2");
      edrDemandRollback();
    }
  }
}

//------------------------------------------------------------------------------
// getMinMaxCallDate()
//
// This function will be used to find the min and max call event detail timestamp
//------------------------------------------------------------------------------
function getMinMaxCallDate
{
  if (debug)
  {
    logStdout("getMinCallDate()\n");
  }

  Date callEventDate;

  // check if it's a content usage
  if ( edrNumDatablocks(DETAIL.ASS_CONT_EXT) > 0 )
  {
    // if the content charging point is provided, use that as a pointer to
    // the date to be used as start timestamp
    if ( edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_CHARGING_POINT, 0, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_CHARGING_POINT, 0, 0) != EDR_INPUT_MISSING )
    {
      Long contentChargingPoint = edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_CHARGING_POINT, 0, 0);
      if (contentChargingPoint == 1)
      {
        if ( edrInternalState(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) != EDR_INPUT_MISSING )
          callEventDate = edrDate(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0);
        else
          return;
      }
      else if (contentChargingPoint == 2)
      {
        if ( edrInternalState(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) != EDR_INPUT_MISSING )
          callEventDate = edrDate(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0);
        else
          return;
      }
      else if (contentChargingPoint == 3)
      {
        if ( edrInternalState(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) != EDR_INPUT_MISSING )
          callEventDate = edrDate(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0);
        else
          return;
      }
      else
      {
        return;
      }
    }

    // content charging point is not provided, there should be only one of the three dates
    else
    {
      if ( edrInternalState(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) != EDR_INPUT_MISSING )
      {
        callEventDate = edrDate(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0);
      }
      else if ( edrInternalState(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) != EDR_INPUT_MISSING )
      {
        callEventDate = edrDate(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0);
      }
      else if ( edrInternalState(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) != EDR_INPUT_MISSING )
      {
        callEventDate = edrDate(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0);
      }
      else
      {
        return;
      }
    }
  }

  // check if it's a location service usage
  else if ( edrNumDatablocks(DETAIL.ASS_LOCN_EXT) > 0 )
  {
    if ( edrInternalState(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0) != EDR_INPUT_MISSING )
    {
      callEventDate = edrDate(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0);
    }
    else
    {
      return;
    }
  }

  // or a normal gsm/gprs/scu usage
  else
  {
    // special handling for SCU type of records
    if (edrString(DETAIL.RECORD_TYPE) == type_SCU)
    {
      // use the charging point to know which date is to be used as
      // the start timestamp
      if ( edrInternalState(DETAIL.CHARGING_POINT) != STATE_CLEARED and edrInputState(DETAIL.CHARGING_POINT) != EDR_INPUT_MISSING )
      {
        if ( edrString(DETAIL.CHARGING_POINT) == "C" )
        {
          if ( edrInternalState(DETAIL.CHARGING_END_TIMESTAMP) != STATE_CLEARED and edrInputState(DETAIL.CHARGING_END_TIMESTAMP) != EDR_INPUT_MISSING )
            callEventDate = edrDate(DETAIL.CHARGING_END_TIMESTAMP);
          else
            return;
        }
        else if ( edrString(DETAIL.CHARGING_POINT) == "D" )
        {
          if ( edrInternalState(DETAIL.CHARGING_START_TIMESTAMP) != STATE_CLEARED and edrInputState(DETAIL.CHARGING_START_TIMESTAMP) != EDR_INPUT_MISSING )
            callEventDate = edrDate(DETAIL.CHARGING_START_TIMESTAMP);
          else
            return;
        }
        else
        {
          return;
        }
      }

      // ok so the charging point is not provided, use whatever date that is provided
      else
      {
        if ( edrInternalState(DETAIL.CHARGING_START_TIMESTAMP) != STATE_CLEARED and edrInputState(DETAIL.CHARGING_START_TIMESTAMP) != EDR_INPUT_MISSING )
        {
          callEventDate = edrDate(DETAIL.CHARGING_START_TIMESTAMP);
        }
        else if ( edrInternalState(DETAIL.CHARGING_END_TIMESTAMP) != STATE_CLEARED and edrInputState(DETAIL.CHARGING_END_TIMESTAMP) != EDR_INPUT_MISSING )
        {
          callEventDate = edrDate(DETAIL.CHARGING_END_TIMESTAMP);
        }
        else
        {
          return;
        }
      }
    }

    // rest of the records
    else
    {
      callEventDate = edrDate(DETAIL.CHARGING_START_TIMESTAMP);
    }
  }

  if ( dateIsValid(callEventDate) != false )
  {
    if (dateDiff(minDate, callEventDate) > 0)
    {
      minDate = callEventDate;
    }
    
    if (dateDiff(maxDate, callEventDate) < 0)
    {
      maxDate = callEventDate;
    }
  }

}

//------------------------------------------------------------------------------
// getTotalContentAdvisedCharge() 
//
// This function is used to find the Advised Charge Information within Content
//------------------------------------------------------------------------------
function getTotalContentAdvisedCharge
{
  if (debug)
  {
    logStdout("getTotalContentAdvisedCharge()\n");
  }
  Long blockEntries;
  Long blockIndex;
  blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if(edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE, 0, blockIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE, 0, blockIndex) != MISSING)
    {
       adviseChargeEntries =  adviseChargeEntries + 1;
    }
  }
}



//------------------------------------------------------------------------------
// getTapFileName()
//
// This function will be used to find the tap file name
//------------------------------------------------------------------------------
function getTapFileName
{
  if (debug)
  {
    logStdout("getTapFileName()\n");
  }

  tapFileName = edrString(INTERNAL.STREAM_NAME);
}


//------------------------------------------------------------------------------
// validateEarliestTimeStamp()
//
// This function will be used to validate the earliest timestamp
//------------------------------------------------------------------------------
function  validateEarliestTimeStamp
{
  if (debug)
  {
    logStdout("validateEarliestTimeStamp()\n");
  }

  Date firstCall = edrDate(TRAILER.FIRST_START_TIMESTAMP);

  if (dateIsValid(firstCall) == true)
  {
    if (dateDiff(minDate, firstCall) != 0)
    {
      // Set Fatal Error
      String offset = "-1";

      // offset = longToStr( edrFieldTokenBytePos(TRAILER.FIRST_START_TIMESTAMP));
      // edrAddError("ERR_TAP3_RET",3,"severe","errorcode",tag,depth,offset,arrayIndex,ruleID);
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","100","101","3",offset,"-1",
		"First call event time does not match earlist call");
      setAssociatedTapErr ("ERR_TAP3_FIRST_CALL_EVENT_TIMES_MISSMATCH", LOG_WARNING , "100","101", "3");
    }
  }
}

//------------------------------------------------------------------------------
// validateLatestTimeStamp()
//
// This function will be used to validate the latest timestamp
//------------------------------------------------------------------------------
function  validateLatestTimeStamp
{
  if (debug)
  {
    logStdout("validateLatestTimeStamp()\n");
  }

  Date lastCall = edrDate(TRAILER.LAST_START_TIMESTAMP);

  if (dateIsValid(lastCall) == true)
  {
    if (dateDiff(maxDate, lastCall) != 0)
    {
      // Set Fatal Error
      String offset = "-1";

      // offset = longToStr( edrFieldTokenBytePos(TRAILER.LAST_START_TIMESTAMP));
      // edrAddError("ERR_TAP3_RET",3,"severe","errorcode",tag,depth,offset,arrayIndex,ruleID);
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","100","133","3",offset,"-1",
		"Last call event time does not match latest call");
      setAssociatedTapErr ("ERR_TAP3_LAST_CALL_EVENT_TIMES_MISSMATCH", LOG_WARNING , "100","133", "3");
    }
  }
}

//-----------------------------------------------------------------------------
// This function will fetch the calculated Sum of Advised charge based on Refund value.
//-----------------------------------------------------------------------------          
function Decimal getCalculatedAdvisedSum (String Currency, Long Refund)
{
  Decimal CalcSum = -1.00;
  Long i;

  if(Refund == 0)
  {
       for( i = 0; i < AdvCurrencyEntries; i = i+1 )
       {
         if(Currency == AdvChargeCurrency_Arr[i])
         {
           CalcSum = totalCalcAdvisdchrg_Arr[i];
           return CalcSum;
         }
       }
  }
  else
  {
       for( i = 0; i < AdvCurrencyEntriesRefund; i = i+1 )
       {
         if(Currency == AdvChargeCurrencyRefund_Arr[i])
         {
           CalcSum = totalCalcAdvisdchrgRefund_Arr[i];
           return CalcSum;
         }
       }
  }

   return CalcSum;
}

//-----------------------------------------------------------------------------
// This function will fetch the calculated Sum of Commission based on Refund value.
//-----------------------------------------------------------------------------
function Decimal getCalculatedCommissionSum (String Currency, Long Refund)
{
  Decimal CalcSum = -1.00;
  Long i;

  if(Refund == 0)
  {
       for( i = 0; i < AdvCurrencyEntries; i = i+1 )
       {
         if(Currency == AdvChargeCurrency_Arr[i])
         {
           CalcSum = totalCalcCommission_Arr[i];
           return CalcSum;
         }
       }
  }
  else
  {
       for( i = 0; i < AdvCurrencyEntriesRefund; i = i+1 )
       {
         if(Currency == AdvChargeCurrencyRefund_Arr[i])
         {
           CalcSum = totalCalcCommissionRefund_Arr[i];
           return CalcSum;
         }
       }
  }

   return CalcSum;
}


//-----------------------------------------------------------------------------
// This function will fetch the calculated Sum of charge based on Refund value.
//-----------------------------------------------------------------------------          
function Decimal getCalculatedChargeSum (String chargeType, Long Refund)
{
  Decimal CalcSum = -1.00;
  Long i;

  if(Refund == 0)
  {
       for( i = 0; i < chargeTypeEntries; i = i+1 )
       {
         if(chargeType == chargeType_Arr[i])
         {
           CalcSum = totalCalcCharge_Arr[i];
           return CalcSum;
         }
       }
  }
  else
  {
       for( i = 0; i < chargeTypeEntriesRefund; i = i+1 )
       {
         if(chargeType == chargeTypeRefund_Arr[i])
         {
           CalcSum = totalCalcChargeRefund_Arr[i];
           return CalcSum;
         }
       }
  }

   return CalcSum;
}
   


//------------------------------------------------------------------------------
// validateAuditControlInformation()
//
// This function will be used to validate the total charge refund, Total Advised Charge, Total Advised Charge refund,
// Total Commision, Total Commision refund, Advised Charge currency, Total Discount Refund and Total Tax Refund.
//------------------------------------------------------------------------------
function  validateAuditControlInformation
{
  if (debug)
  {
    logStdout("validateAuditControlInformation()\n");
  }
  Long blockIndex;
  Long packetIndex;
  Long blockEntries;
  Long totalChargeBlockEntries;
  String offset 	= "-1";
  Long i;

  Decimal totalDiscountRefund = edrDecimal(TRAILER.ASS_ROAMING_EXT.TOTAL_DISCOUNT_REFUND,0);
  Decimal totalTaxRefund = edrDecimal(TRAILER.ASS_ROAMING_EXT.TOTAL_TAX_REFUND,0);

  Long totalTaxRefundState = edrInputState(TRAILER.ASS_ROAMING_EXT.TOTAL_TAX_REFUND,0);
  Long totalTaxRefundStateI = edrInternalState(TRAILER.ASS_ROAMING_EXT.TOTAL_TAX_REFUND,0);
  Long totalDiscountRefundState = edrInputState(TRAILER.ASS_ROAMING_EXT.TOTAL_DISCOUNT_REFUND,0);
  Long totalDiscountRefundStateI = edrInternalState(TRAILER.ASS_ROAMING_EXT.TOTAL_DISCOUNT_REFUND,0);

  Decimal totalCalcAdvisdchrg = -1.00;
  Decimal totalCalcAdvisdchrgRefund = -1.00;
  Decimal totalCalcCommission = -1.00;
  Decimal totalCalcCommissionRefund = -1.00;
  Decimal totalCalcCharge = -1.00;
  Decimal totalCalcChargeRefund = -1.00;

  totalChargeBlockEntries = edrNumDatablocks(TRAILER.TOTAL_CHARGE_VALUE_LIST);
  for (i = 0; i < totalChargeBlockEntries; i = (i + 1))
  {
    String chargeType = edrString(TRAILER.TOTAL_CHARGE_VALUE_LIST.CHARGE_TYPE, i);

    Decimal totalChargeRefund = edrDecimal(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_REFUND, i);
    Long totalChargeRefundState = edrInputState(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_REFUND, i);
    Long totalChargeRefundStateI = edrInternalState(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_REFUND, i);

    Decimal totalCharge	= edrDecimal(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_VALUE, i) / theAbsoluteAmountDivider ;
    Long totalChargeState = edrInputState(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_VALUE, i);
    Long totalChargeStateI = edrInternalState(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_VALUE, i);

    totalCalcCharge = getCalculatedChargeSum(chargeType, 0);
    totalCalcChargeRefund  =  getCalculatedChargeSum(chargeType, 1);

    if ( totalCharge < 0.0 and totalChargeStateI != STATE_CLEARED and totalChargeState != EDR_INPUT_MISSING )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","241","4",offset,"-1","Total Charge out of range");
      setAssociatedTapErr ("ERR_TAP3_TOTAL_CHARGE_OOR", LOG_CRITICAL , "20", "241", "4");
      edrDemandRollback();
    }

    if ( totalCharge != totalCalcCharge and totalChargeStateI != STATE_CLEARED and totalChargeState != EDR_INPUT_MISSING )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","241","4",offset,"-1",
                "Total charge does not match the calculated sum of charges");
      setAssociatedTapErr ("ERR_TAP3_TOTAL_CHARGE_MISSMATCH", LOG_CRITICAL , "100", "241", "4");
      edrDemandRollback();
    }

    if ( totalChargeRefund <= 0.0 and totalChargeRefundStateI != STATE_CLEARED and totalChargeRefundState != EDR_INPUT_MISSING )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","355","4",offset,"-1","Total Charge Refund out of range");
      setAssociatedTapErr ("ERR_TAP3_TOTAL_CHARGE_REFUND_OOR", LOG_CRITICAL , "20", "355", "4");
      edrDemandRollback();
    }

    if ( totalChargeRefund != totalCalcChargeRefund and totalChargeRefundStateI != STATE_CLEARED and totalChargeRefundState != EDR_INPUT_MISSING )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","355","4",offset,"-1",
                "Total charge refund does not match the calculated sum of refund charges");
      setAssociatedTapErr ("ERR_TAP3_TOTAL_CHARGE_REFUND_IS_NOT_CORRECT", LOG_CRITICAL , "100", "355", "4");
      edrDemandRollback();
    }
  }


  blockEntries = edrNumDatablocks(TRAILER.ASS_ROAMING_EXT);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
   {
     Long packetEntries= edrNumDatablocks(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST, blockIndex);
     for (packetIndex = 0; packetIndex < (packetEntries - 1); packetIndex = packetIndex + 1)
     {

       String AdvChargeCurrency = 
		edrString(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.ADVISED_CHARGE_CURRENCY, blockIndex, packetIndex);

       Decimal TotalAdvisdchrg = edrDecimal(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_ADVISEDCHARGE, blockIndex, packetIndex);
       Decimal TotalAdvisdchrgRefund = 
		edrDecimal(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_ADVISEDCHARGE_REFUND, blockIndex, packetIndex);
       Long TotalAdvisdchrgState = edrInputState(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_ADVISEDCHARGE, blockIndex, packetIndex);
       Long TotalAdvisdchrgStateI = edrInternalState(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_ADVISEDCHARGE, blockIndex, packetIndex);
       Long TotalAdvisdchrgRefundState = edrInputState(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_ADVISEDCHARGE_REFUND, blockIndex, packetIndex);
       Long TotalAdvisdchrgRefundStateI = edrInternalState(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_ADVISEDCHARGE_REFUND, blockIndex, packetIndex);

       Decimal totalCommission = 
		edrDecimal(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_COMMISSION,blockIndex, packetIndex);
       Decimal totalCommissionRefund = 
		edrDecimal(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_COMMISSION_REFUND,blockIndex, packetIndex);
       Long totalCommissionState = edrInputState( TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_COMMISSION,blockIndex, packetIndex);       
       Long totalCommissionStateI = edrInternalState( TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_COMMISSION,blockIndex, packetIndex);       
       Long totalCommissionRefundState = edrInputState(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_COMMISSION_REFUND,blockIndex, packetIndex);
       Long totalCommissionRefundStateI = edrInternalState(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST.TOTAL_COMMISSION_REFUND,blockIndex, packetIndex);

       totalCalcAdvisdchrg	 = getCalculatedAdvisedSum(AdvChargeCurrency, 0);
       totalCalcAdvisdchrgRefund = getCalculatedAdvisedSum(AdvChargeCurrency, 1);
       totalCalcCommission	 = getCalculatedCommissionSum(AdvChargeCurrency, 0);
       totalCalcCommissionRefund = getCalculatedCommissionSum(AdvChargeCurrency, 1);
       
       Bool currencyPresent  = false;
       Long i;


       if (TotalAdvisdchrg < 0.0 and TotalAdvisdchrgStateI != STATE_CLEARED and TotalAdvisdchrgState != EDR_INPUT_MISSING)
       {
         // Set Fatal Error
         edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","356","2",offset,"-1",
                "Total Advised Charge Value out of Range ");
         setAssociatedTapErr ("ERR_TAP3_TOTAL_ADVISED_CHARGE_OOR", LOG_CRITICAL , "20","356", "2");
         edrDemandRollback();
       }

      // totalCalcAdvisdchrg will be -1 when all the Advised charge in the detail records are of type Refund.
       if ( TotalAdvisdchrg != totalCalcAdvisdchrg and TotalAdvisdchrgStateI != STATE_CLEARED and TotalAdvisdchrgState != EDR_INPUT_MISSING and totalCalcAdvisdchrg != -1.00 )
       {
         // Set Fatal Error
         edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","356","4",offset,"-1",
                "Total Advised Charge does not match the calculated sum of advised charges");
         setAssociatedTapErr ("ERR_TAP3_TOTAL_ADVISED_CHARGE_IS_NOT_CORRECT", LOG_CRITICAL , "100", "356", "4");
         edrDemandRollback();
       }

       if (TotalAdvisdchrgRefund <= 0.0 and TotalAdvisdchrgRefundStateI != STATE_CLEARED and TotalAdvisdchrgRefundState != EDR_INPUT_MISSING)
       {
         // Set Fatal Error
         edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","357","2",offset,"-1",
                "Total Advised Charge Refund Value out of Range ");
         setAssociatedTapErr ("ERR_TAP3_TOTAL_ADVISED_CHARGE_REFUND_OOR", LOG_CRITICAL , "20","357", "2");
        edrDemandRollback();
      }

      if ( TotalAdvisdchrgRefund != totalCalcAdvisdchrgRefund and TotalAdvisdchrgRefundStateI != STATE_CLEARED and TotalAdvisdchrgRefundState != EDR_INPUT_MISSING )
      {
        // Set Fatal Error
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","357","4",offset,"-1",
                "Total Advised Charge refund does not match the calculated sum of refund charges");
        setAssociatedTapErr ("ERR_TAP3_TOTAL_ADVISED_CHARGE_REFUND_IS_NOT_CORRECT", LOG_CRITICAL , "100", "357", "4");
        edrDemandRollback();
      }



      if ( totalCommission <= 0.0  and totalCommissionStateI != STATE_CLEARED and totalCommissionState != EDR_INPUT_MISSING)
      {
         // Set Fatal Error
         edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","358","4",offset,"-1","Total Commission out of range");
         setAssociatedTapErr ("ERR_TAP3_TOTAL_COMMISSION_OOR", LOG_CRITICAL , "20", "358", "4");

         edrDemandRollback();
      }

       if ( totalCommission != totalCalcCommission and totalCommissionStateI != STATE_CLEARED and totalCommissionState != EDR_INPUT_MISSING )
       {
         // Set Fatal Error
         edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","358","4",offset,"-1",
                "Total Commission does not match the calculated sum of charges");
         setAssociatedTapErr ("ERR_TAP3_TOTAL_COMMISSION_IS_NOT_CORRECT", LOG_CRITICAL , "100", "358", "4");
         edrDemandRollback();
       }

       if ( totalCommissionRefund <= 0.0 and totalCommissionRefundStateI != STATE_CLEARED and totalCommissionRefundState != EDR_INPUT_MISSING )
       {
        // Set Fatal Error
         edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","359","4",offset,"-1","Total Commission refund out of range");
         setAssociatedTapErr ("ERR_TAP3_TOTAL_COMMISSION_REFUND_OOR", LOG_CRITICAL , "20", "359", "4");

         edrDemandRollback();
       }

      if ( totalCommissionRefund != totalCalcCommissionRefund and totalCommissionRefundStateI != STATE_CLEARED and totalCommissionRefundState != EDR_INPUT_MISSING )
      {
        // Set Fatal Error
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","359","4",offset,"-1",
                "Total charge Commission refund does not match the calculated sum of refund charges");
        setAssociatedTapErr ("ERR_TAP3_TOTAL_CHARGE_COMMISSION_IS_NOT_CORRECT", LOG_CRITICAL , "100", "359", "4");
        edrDemandRollback();
      }

       if(strLength(AdvChargeCurrency) != 3)
       {
         edrAddError("ERR_TAP3_RET", LOG_CRITICAL, "fatal", "10", "348", "4",
                offset, "-1", "Advised Charge Currency Syntax Error");
         setAssociatedTapErr("ERR_TAP3_ADVISED_CHARGE_CURRENCY_SE", LOG_CRITICAL ,"10" ,"348" ,"4");
         edrDemandRollback();
       }


       for( i = 0 ; i < numOfCurrencyCode and currencyPresent == false ; i = i + 1 )
       {
         if( AdvChargeCurrency == currencyCode[i])
         {
           currencyPresent = true;
         }
       }
       if(currencyPresent == false)
       {
         // Set Fatal Error
         edrAddError("ERR_TAP3_RET", LOG_CRITICAL, "fatal", "20", "348", "4",
                offset, "-1", "Advised Charge Currency Value Out of range");
         setAssociatedTapErr("ERR_TAP3_ADVISED_CHARGE_CURRENCY_OOR", LOG_CRITICAL ,"20" ,"348" ,"4");
         edrDemandRollback();
       }

     }

  }


   if ( totalDiscountRefund <= 0.0 and totalDiscountRefundStateI != STATE_CLEARED and totalDiscountRefundState != EDR_INPUT_MISSING )
   {
     // Set Fatal Error
     edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","354","3",offset,"-1","Total Discount refund out of range");
     setAssociatedTapErr ("ERR_TAP3_TOTAL_DISCOUNT_REFUND_OOR", LOG_CRITICAL , "20", "354", "3");

     edrDemandRollback();
   }

   if ( totalTaxRefund <= 0.0 and totalTaxRefundStateI != STATE_CLEARED and totalTaxRefundState != EDR_INPUT_MISSING)
   {
     // Set Fatal Error
     edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","353","3",offset,"-1","Total Tax refund out of range");
     setAssociatedTapErr ("ERR_TAP3_TOTAL_TAX_REFUND_OOR", LOG_CRITICAL , "20", "353", "3");

     edrDemandRollback();
   }


  // Cleanup the array

  if ( arraySize( AdvChargeCurrency_Arr ) > 0 )
  {
    arrayClear( AdvChargeCurrency_Arr );
    arrayClear( totalCalcAdvisdchrg_Arr );
    arrayClear( totalCalcCommission_Arr );
    AdvCurrencyEntries = 0;
  }
  if ( arraySize( AdvChargeCurrencyRefund_Arr ) > 0 )
  {
    arrayClear( AdvChargeCurrencyRefund_Arr );
    arrayClear( totalCalcAdvisdchrgRefund_Arr );
    arrayClear( totalCalcCommissionRefund_Arr );
    AdvCurrencyEntriesRefund = 0;
  }
  if ( arraySize( chargeType_Arr ) > 0 )
  {
    arrayClear( chargeType_Arr );
    arrayClear( totalCalcCharge_Arr );
    chargeTypeEntries = 0;
  }
  if ( arraySize( chargeTypeRefund_Arr ) > 0 )
  {
    arrayClear( chargeTypeRefund_Arr );
    arrayClear( totalCalcChargeRefund_Arr );
    chargeTypeEntriesRefund = 0;
  }

}
//------------------------------------------------------------------------------
// validateChargeType()                               
//
// This Function will be used to validate the Charge Type
//------------------------------------------------------------------------------
function validateChargeType
{
  if (debug)
  {
    logStdout("validateChargeType()\n");
  }
  Long blockIndex;
  Long blockEntries = edrNumDatablocks(TRAILER.TOTAL_CHARGE_VALUE_LIST);
  for (blockIndex = 0 ; blockIndex < blockEntries ; blockIndex = (blockIndex + 1) )
  {
    if (edrInputState(TRAILER.TOTAL_CHARGE_VALUE_LIST.CHARGE_TYPE, blockIndex) == MISSING)
    {
      return;
    }
    String TotalValueChargeType = edrString(TRAILER.TOTAL_CHARGE_VALUE_LIST.CHARGE_TYPE, blockIndex);
    Long ret = strSearchRegExpr(TotalValueChargeType, "[^0-9]");
    if( ret >= 0 )
    {
      // Set Fatal Error
      String offset = "-1";
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","11","71","4",offset,"-1", "Charge Type Syntax Error");
      setAssociatedTapErr ("ERR_TAP3_CHARGE_TYPE_SYNTAX", LOG_CRITICAL , "11","71", "4");
      edrDemandRollback();
      return;
    }
    if( (TotalValueChargeType != "00") AND (TotalValueChargeType != "01") AND (TotalValueChargeType != "02")
         AND (TotalValueChargeType != "03") AND (TotalValueChargeType != "04") AND (TotalValueChargeType != "05")
         AND (TotalValueChargeType != "14") AND (TotalValueChargeType != "15") AND (TotalValueChargeType !="21")
         AND (TotalValueChargeType != "100") AND (TotalValueChargeType != "101") AND (TotalValueChargeType != "102") )
    {
      // Set Fatal Error
      String offset = "-1";
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","21","71","4",offset,"-1", "Charge Type Out of Range");
      setAssociatedTapErr ("ERR_TAP3_CHARGE_TYPE_ORR", LOG_CRITICAL , "21","71", "4");
      edrDemandRollback();
      return;
    } 
  }
}



//------------------------------------------------------------------------------
// validateTotalAdvisedCharge()
//
// This Function will be used to validate the Total Advised Charge
//-----------------------------------------------------------------------------
function validateTotalAdvisedCharge
{
  if (debug)
  {
   logStdout("validateTotalAdvisedCharge()\n");
  }
   if ((edrNumDatablocks(TRAILER.ASS_ROAMING_EXT.ADV_CHARGE_LIST, 0) == 0) and
        (adviseChargeEntries > 0))
    {
    String offset = "-1";
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","39","15","2",offset,"-1",
                               "TotalAdvisedChargeValue missing within group and Advise Charge Info Present within the Content");

    setAssociatedTapErr ("ERR_TAP3_TOTAL_ADVISED_CHARGE", LOG_CRITICAL , "39","15", "2");
    edrDemandRollback();
    }
}

//------------------------------------------------------------------------------
// validateSumTotalTaxValue()
//
// This function will be used to validate the sum of the total tax of the TAP file
//------------------------------------------------------------------------------
function  validateSumTotalTaxValue
{
  if (debug)
  {
    logStdout("validateSumTotalTaxValue()\n");
  }

  Decimal sumTotalTax = edrDecimal(TRAILER.TOTAL_TAX_VALUE);
  Decimal tapTotalTax = edrDecimal(TRAILER.TAP_TOTAL_TAX_VALUE);

  if (tapTotalTax != sumTotalTax and edrInputState(TRAILER.TAP_TOTAL_TAX_VALUE) != MISSING and
                                     edrInternalState(TRAILER.TAP_TOTAL_TAX_VALUE) != STATE_CLEARED)
  {
    // Set Fatal Error
    String offset = "-1";

    // offset = longToStr( edrFieldTokenBytePos(TRAILER.TAP_TOTAL_TAX_VALUE));
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","226","2",offset,"-1",
		"Total tax value does not match sum of all taxes ");
    setAssociatedTapErr ("ERR_TAP3_TOTAL_TAX_MISSMATCH", LOG_CRITICAL , "100","226", "2");
    edrDemandRollback();
  }
}



//------------------------------------------------------------------------------
// validateTrailerRecord()
//
// This function will be used to validate the trailer record
//------------------------------------------------------------------------------
function validateTrailerRecord
{
  if (debug)
  {
    logStdout("validateTrailerRecord()\n");
  }

  if ( notFlag != "NOTIFICATION")
  {
  	validateTotalChargeValueList();
  	validateTotalTaxValue();
  	validateSumTotalTaxValue();
  	validateTotalDiscountValue();
  	validateCallEventDetailsCount();
        validateEarliestTimeStamp();
        validateLatestTimeStamp();
        validateChargeType();    
	validateAuditControlInformation();
        validateTotalAdvisedCharge();
  }

  return ;
}


//------------------------------------------------------------------------------
// validateHeaderRecord()
//
// This function will be used to validate the header record
//------------------------------------------------------------------------------
function validateHeaderRecord
{
  if (debug)
  {
    logStdout("validateHeaderRecord()\n");
  }

  validateSender();
  validateRecipient();
  validateFileSequenceNumber();
  validateFileCreationTimeStamp();
  validateFileCreationTimeStampCrossValidation();
  validateTransferCutOffTimeStamp();
  validateFileAvailableTimeStamp();
  validateFileAvailableTimeStampCrossValidation();
  validateSpecificationVersionNumber();
  validateReleaseVersionNumber();
  validateTapDecimalPlaces();
  validateTapCurrency();
  validateCountryCodeList();
  validateFileTypeIndicator();
  validateRapFileSequenceNumber();
  validateInternationalAccessCode();   

  return ;
}

//==============================================================================
// Process Begin EDR record
//==============================================================================
function onBeginEdr
{
  initBegin();
  getTapFileName();

} // end onBeginEdr

//==============================================================================
// Process Header EDR record
//==============================================================================
function onHeaderEdr
{
  hasChargeRefund = false;

  theAbsoluteAmountDivider = 1.0;
  if( edrInternalState(HEADER.TAP_DECIMAL_PLACES) != STATE_CLEARED and edrInputState(HEADER.TAP_DECIMAL_PLACES) != MISSING )
  {
     Long tapDecimal = edrLong(HEADER.TAP_DECIMAL_PLACES);
     Long i;
     if( tapDecimal >= 0 and tapDecimal <= 6 )
     {
       for (i=0 ; i < tapDecimal ; i=i+1)
       {
         theAbsoluteAmountDivider = theAbsoluteAmountDivider * 10.0;
       }
     }
  }
  else
  {
    theAbsoluteAmountDivider = 1.0;
  }

  notFlag = edrString(HEADER.SENDER_COUNTRY_CODE); 
  //----------------------------------------------------------------------------
  // Validate Header Record
  //----------------------------------------------------------------------------
  validateHeaderRecord();

} // end onHeaderEdr

//=============================================================================
// Check the ChargeRefundIndicator for CONTENT type EDRs
//==============================================================================
function checkHasChargeRefund
{
  if ( edrNumDatablocks( DETAIL.ASS_CONT_EXT ) > 0 )
  {
    Long blocks = edrNumDatablocks( DETAIL.ASS_CBD.CP, 0 );
    Long i;
    for (i = 0; i < blocks; i = i + 1)
    {
      if ( edrLong( DETAIL.ASS_CBD.CP.CHARGE_REFUND_INDICATOR, 0, i ) == 1 )
      {
        hasChargeRefund = true;
      } // if
    } // for
  } // if
}

//==============================================================================
// Calculates Charge and Charge refund based on ChargeRefundIndicator for All records
//==============================================================================
function sumChargeOrRefund
{  
  Long blockIndex;
  Long packetIndex;
  Long blockEntries;
  Bool newEntry = true;
  String chargeType;
  Long j;


  String offset = "-1";

  blockEntries = edrNumDatablocks(DETAIL.ASS_CBD);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long packetEntries= edrNumDatablocks(DETAIL.ASS_CBD.CP, blockIndex);
    for (packetIndex = 0; packetIndex < packetEntries; packetIndex = packetIndex + 1)
    {
      chargeType = edrString(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, packetIndex);
      if ( edrString(DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex) != "N" and chargeType != "" )
      {
        if ( edrInternalState(DETAIL.ASS_CBD.CP.CHARGE_REFUND_INDICATOR, blockIndex, packetIndex) != STATE_CLEARED
                  and edrInputState(  DETAIL.ASS_CBD.CP.CHARGE_REFUND_INDICATOR, blockIndex, packetIndex ) != EDR_INPUT_MISSING
                  and edrLong( DETAIL.ASS_CBD.CP.CHARGE_REFUND_INDICATOR, blockIndex, packetIndex ) == 1 )
        {
          newEntry = true;
          for( j = 0; j < chargeTypeEntriesRefund; j = (j+1) )
          {
            if(chargeType == chargeTypeRefund_Arr[j])
            {
              totalCalcChargeRefund_Arr[j] = totalCalcChargeRefund_Arr[j] +
                  edrDecimal( DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex );
              newEntry = false;
            }
          }
  
          if(newEntry == true)
          {
            chargeTypeRefund_Arr[j] = chargeType;
            totalCalcChargeRefund_Arr[j] = edrDecimal( DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex );
            chargeTypeEntriesRefund = chargeTypeEntriesRefund + 1;
          }
  
        } //if
        else
        {
          newEntry = true;
          for( j = 0; j < chargeTypeEntries; j = (j+1) )
          {
            if(chargeType == chargeType_Arr[j])
            {
              totalCalcCharge_Arr[j] = totalCalcCharge_Arr[j] +
                 edrDecimal( DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex );
              newEntry = false;
            }
          }
  
          if(newEntry == true)
          {
            chargeType_Arr[j] = chargeType;
	    totalCalcCharge_Arr[j] = edrDecimal( DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex );
            chargeTypeEntries = chargeTypeEntries + 1;
          }
        } //else

      } // end of if
    }
  }
}



//==============================================================================
// Calculates Advised Charge and Commission based on ChargeRefundIndicator for CONTENT type EDRs
//==============================================================================
function SumAdvisedChargeOrRefund
{
  
  if ( edrNumDatablocks( DETAIL.ASS_CBD ) > 0 )
  {
    Long blocks = edrNumDatablocks( DETAIL.ASS_CBD.CP, 0 );
    Long i;
    Long j;
    Bool newEntry = true;
    String Currency;

    for (i = 0; i < blocks; i = i + 1)
    {
      Currency = edrString(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE_CURRENCY, 0, i);
      if ( edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CHARGE_REFUND_INDICATOR, 0, i) != STATE_CLEARED
                and edrInputState(  DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CHARGE_REFUND_INDICATOR, 0, i ) != EDR_INPUT_MISSING
                and edrLong( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CHARGE_REFUND_INDICATOR, 0, i ) == 1 )
      {
        newEntry = true;
        for( j = 0; j < AdvCurrencyEntriesRefund; j = (j+1) )
        {
          if(Currency == AdvChargeCurrencyRefund_Arr[j])
          {
            totalCalcAdvisdchrgRefund_Arr[j] = totalCalcAdvisdchrgRefund_Arr[j] +
                edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE, 0, i );
            totalCalcCommissionRefund_Arr[j] = totalCalcCommissionRefund_Arr[j] +
                edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.COMMISSION, 0, i );
            newEntry = false;
          }
        }

        if(newEntry == true)
        {
          AdvChargeCurrencyRefund_Arr[j] = Currency;
          totalCalcAdvisdchrgRefund_Arr[j] = edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE, 0, i );
          totalCalcCommissionRefund_Arr[j] = edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.COMMISSION, 0, i );
          AdvCurrencyEntriesRefund = AdvCurrencyEntriesRefund + 1;
        }

      } //if
      else
      {
        newEntry = true;
        for( j = 0; j < AdvCurrencyEntries; j = (j+1) )
        {
          if(Currency == AdvChargeCurrency_Arr[j])
          {
            totalCalcAdvisdchrg_Arr[j] = totalCalcAdvisdchrg_Arr[j] +
                edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE, 0, i );
            totalCalcCommission_Arr[j] = totalCalcCommission_Arr[j] +
                edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.COMMISSION, 0, i );
            newEntry = false;
          }
        }

        if(newEntry == true)
        {
          AdvChargeCurrency_Arr[j] = Currency;
          totalCalcAdvisdchrg_Arr[j] = edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE, 0, i );
          totalCalcCommission_Arr[j] = edrDecimal( DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.COMMISSION, 0, i );	 
          AdvCurrencyEntries = AdvCurrencyEntries + 1;
        }
      } //else

    } //for
  } // if
} // function

