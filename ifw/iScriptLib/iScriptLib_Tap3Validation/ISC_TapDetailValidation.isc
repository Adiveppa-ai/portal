//------------------------------------------------------------------------------
// validateServiceUsedListObjectType()
//
// This function will be used to validate the ServiceUsedListObjectType
//------------------------------------------------------------------------------
function validateServiceUsedListObjectType
{
  const String ruleID  = "TAP3.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE";
  const String severe  = "severe";
  const String warning = "warning";
  const String tag     = "281";
  const String depth   = "5";
  const String offset  = "-1";

  if (debug)
  {
    logStdout("validateServiceUsedListObjectType()\n");
  }

  Long blockIndex;
  Long blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    // offset = longToStr(edrFieldTokenBytePos(
    //		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE, 0, blockIndex));
    Long objectState = edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE, 0, blockIndex);
    Long objectStateI = edrInternalState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE, 0, blockIndex);

    if (objectStateI != STATE_CLEARED and objectState != EDR_INPUT_MISSING)
    {
      if (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_CODE,
		0, blockIndex) == 3)
      {
        Long objectType = edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.OBJECT_TYPE,0, blockIndex);
        if (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE,
                0, blockIndex) == 11)
        {
          if ( objectType < 0  or objectType > 6 )
          {
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "20", tag, depth,
                        offset, longToStr(blockIndex), ruleID);
            setAssociatedTapErr("ERR_TAP3_SERVICE_USED_LIST_OBJECT_TYPE", LOG_MAJOR ,"20" ,tag ,depth);
          }
        }
        else if (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_TRANSACTION_TYPE,
                0, blockIndex) == 12)
        {
          if ( objectType < 0 or (objectType > 0 and objectType < 20) or (objectType > 23 and objectType < 30) or ( objectType > 34 and objectType > 40 ) or ( objectType > 44 and objectType < 60 and objectType != 50 ) or ( objectType > 62 and objectType < 80 and objectType != 70 ) or ( objectType > 82 and objectType != 90 and objectType != 100 ))
          {
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "21", tag, depth,
                        offset, longToStr(blockIndex), ruleID);
            setAssociatedTapErr("ERR_TAP3_SERVICE_USED_LIST_OBJECT_TYPE", LOG_MAJOR ,"21" ,tag ,depth);
          }
        }
      }
    }
  }
}

