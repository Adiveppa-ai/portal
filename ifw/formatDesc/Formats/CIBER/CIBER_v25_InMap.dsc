CIBER_V25
{     
  //----------------------------------------------------------------------------
  // Header records
  //----------------------------------------------------------------------------
  BATCH_HEADER
  {
    STD_MAPPING
    {
      "010"                             -> HEADER.RECORD_TYPE;
      "+0000"                           -> HEADER.UTC_TIME_OFFSET;
      " "                               -> HEADER.DATA_TYPE_INDICATOR;
      "0049"                            -> HEADER.ORIGIN_COUNTRY_CODE;   
      "0049"                            -> HEADER.SENDER_COUNTRY_CODE;
      CIBER_RECORD_TYPE                 -> HEADER.CIBER_RECORD_TYPE;
      BATCH_CREATION_DATE               -> HEADER.CREATION_TIMESTAMP;
      BATCH_CREATION_DATE               -> HEADER.TRANSMISSION_DATE;
      BATCH_CREATION_DATE               -> HEADER.TRANSFER_CUTOFF_TIMESTAMP;
      BATCH_SEQUENCE_NUMBER             -> HEADER.SEQUENCE_NUMBER;
      BATCH_SEQUENCE_NUMBER             -> HEADER.ORIGIN_SEQUENCE_NUMBER;
      SENDING_CARRIER_SID               -> HEADER.SENDER;
      RECEIVING_CARRIER_SID             -> HEADER.RECIPIENT;
      CIBER_RECORD_RELEASE_NUMBER       -> HEADER.SPECIFICATION_VERSION_NUMBER;
      CIBER_RECORD_RELEASE_NUMBER       -> HEADER.RELEASE_VERSION;
      ORIGINAL_RETURN_INDICATOR         -> HEADER.RETURN_INDICATOR;
      CURRENCY_TYPE                     -> HEADER.CURRENCY;
      SETTLEMENT_PERIOD                 -> HEADER.SETTLEMENT_PERIOD;
      CLEARINGHOUSE_ID                  -> HEADER.CLEARINGHOUSE_ID;
      CIBER_BATCH_REJECT_REASON_CODE    -> HEADER.BATCH_REJECT_REASON;
      BATCH_CONTENTS                    -> HEADER.BATCH_CONTENTS;
    }
  }

  BATCH_HEADER_CLEARINGHOUSE
  {
    STD_MAPPING
    {
      "010"                             -> HEADER.RECORD_TYPE;
      "+0000"                           -> HEADER.UTC_TIME_OFFSET;
      " "                               -> HEADER.DATA_TYPE_INDICATOR;
      "0049"                            -> HEADER.ORIGIN_COUNTRY_CODE;   
      "0049"                            -> HEADER.SENDER_COUNTRY_CODE;
      CIBER_RECORD_TYPE                 -> HEADER.CIBER_RECORD_TYPE;
      BATCH_CREATION_DATE               -> HEADER.CREATION_TIMESTAMP;
      BATCH_CREATION_DATE               -> HEADER.TRANSMISSION_DATE;
      BATCH_CREATION_DATE               -> HEADER.TRANSFER_CUTOFF_TIMESTAMP;
      BATCH_SEQUENCE_NUMBER             -> HEADER.SEQUENCE_NUMBER;
      BATCH_SEQUENCE_NUMBER             -> HEADER.ORIGIN_SEQUENCE_NUMBER;
      SENDING_CLEARINGHOUSE_BID         -> HEADER.SENDING_CLEARINGHOUSE_BID;
      ORIGINAL_SERVING_CARRIER_SID      -> HEADER.SENDER;
      CIBER_RECORD_RELEASE_NUMBER       -> HEADER.SPECIFICATION_VERSION_NUMBER;
      CIBER_RECORD_RELEASE_NUMBER       -> HEADER.RELEASE_VERSION;
      ORIGINAL_RETURN_INDICATOR         -> HEADER.RETURN_INDICATOR;
      CURRENCY_TYPE                     -> HEADER.CURRENCY;
      SETTLEMENT_PERIOD                 -> HEADER.SETTLEMENT_PERIOD;
      CLEARINGHOUSE_ID                  -> HEADER.CLEARINGHOUSE_ID;
      CIBER_BATCH_REJECT_REASON_CODE    -> HEADER.BATCH_REJECT_REASON;
      ORIGINAL_HOME_CARRIER_SID         -> HEADER.RECIPIENT;
      BATCH_CONTENTS                    -> HEADER.BATCH_CONTENTS;
    }
  }

  //----------------------------------------------------------------------------
  // Trailer records
  //----------------------------------------------------------------------------
  BATCH_TRAILER
  {
    STD_MAPPING
    {
      "090"                             -> TRAILER.RECORD_TYPE;
      CIBER_RECORD_TYPE                 -> TRAILER.CIBER_RECORD_TYPE;
      BATCH_CREATION_DATE               -> TRAILER.CREATION_TIMESTAMP;
      BATCH_SEQUENCE_NUMBER             -> TRAILER.SEQUENCE_NUMBER;
      BATCH_SEQUENCE_NUMBER             -> TRAILER.ORIGIN_SEQUENCE_NUMBER;
      SENDING_CARRIER_SID               -> TRAILER.SENDER;
      RECEIVING_CARRIER_SID             -> TRAILER.RECIPIENT;
      TOTAL_NUMBER_RECORDS              -> TRAILER.TOTAL_NUMBER_OF_RECORDS;
      BATCH_TOTAL_CHARGE_AND_TAX        -> TRAILER.TOTAL_WHOLESALE_CHARGED_VALUE;
      SETTLEMENT_PERIOD                 -> TRAILER.SETTLEMENT_PERIOD;
      CLEARINGHOUSE_ID                  -> TRAILER.CLEARINGHOUSE_ID;
      R70_BATCH_TOTAL_CHARGE_TAX_SIGN   -> TRAILER.CIBER_R70_BATCH_TOTALS_SIGN;
      R70_ORIGINAL_TOTAL_CHARGE_TAX_SIGN-> TRAILER.CIBER_R70_ORIGINAL_TOTALS_SIGN;
//    R70_SYSTEM_RESERVED_FILLER          AscString(3);
      ORIGINAL_TOTAL_NUMBER_RECORDS     -> TRAILER.ORIGINAL_TOTAL_NUMBER_OF_RECORDS;
      ORIGINAL_TOTAL_CHARGE_AND_TAX     -> TRAILER.ORIGINAL_TOTAL_WHOLESALE_CHARGED_VALUE;
//    SYSTEM_RESERVED_FILLER1             AscString(8);
      CURRENCY_TYPE                     -> TRAILER.CURRENCY;
    }
  }

  BATCH_TRAILER_CLEARINGHOUSE
  {
    STD_MAPPING
    {
      "090"                             -> TRAILER.RECORD_TYPE;
      CIBER_RECORD_TYPE                 -> TRAILER.CIBER_RECORD_TYPE;
