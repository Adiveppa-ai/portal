function mapGprsCall ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( createNewDetail(record_GPRS, type_GPRS) == false )
  {
  }
  edrString(DETAIL.BASIC_SERVICE) = "813";
                                                                                                             
  childContext = myContext + "." + "gprsBasicCallInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapGprsBasicCallInformation ( myContext, nMyIndices, "gprsBasicCallInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "gprsLocationInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapGprsLocationInformation ( myContext, nMyIndices, "gprsLocationInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "equipmentIdentifier";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapImeiOrEsn ( myContext, nMyIndices, "equipmentIdentifier", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "gprsServiceUsed";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapGprsServiceUsed ( myContext, nMyIndices, "gprsServiceUsed", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "camelServiceUsed";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapCamelServiceUsed ( myContext, nMyIndices, "camelServiceUsed", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
