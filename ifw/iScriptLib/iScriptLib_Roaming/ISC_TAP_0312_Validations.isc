 ******************************************************************************************************************************/
 
function validateContentProviderName ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",334";

  if( strLength(edrStringEx(myContext, indices, nParentIndices)) > 24 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Content Provider Name", "334", "100", "Length greater than 24 characters");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1", "","Length greater than 24 characters");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

