//------------------------------------------------------------------------------
// validateTotalCharges(Long recordType)
// Ensure that the total charges in the CIBER record equal the sum of all the
// charges within the record.
//------------------------------------------------------------------------------
function validateTotalCharges(Long recordType) 
{
  Decimal sumOfCharges=0.00;

  if (debug)
    logStdout("validateTotalCharges()\n");

  if (recordType == 10) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.SSU_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }
  if (recordType == 20) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.SSU_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  if (recordType == 11) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  if (recordType == 30) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  if (recordType == 50) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.MISC_SURCHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  if (recordType == 22) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.AIR_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.OTHER_CHARGE_1, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  if (recordType == 32 or recordType == 42) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.OTHER_CHARGE_1, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  if (recordType == 52) {
   sumOfCharges =  edrDecimal(DETAIL.ASS_CIBER_EXT.OTHER_CHARGE_1, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.OCC_CHARGE, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_STATE_TAX, 0) +
		   edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_LOCAL_TAX, 0);

    if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX, 0) != 
        sumOfCharges)
    {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","009",
		"CIBER25.ASS_CIBER_EXT.TOTAL_CHARGE_AND_TAX");
    }
  }

  return;

} 

//------------------------------------------------------------------------------
// validateCiber22Record() 
//------------------------------------------------------------------------------
function validateCiber22Record
{

  if (debug)
    logStdout("validateCiber22Record()\n");

  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
     validateReturnCode();
  }
  
  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateAge(22);
  }

  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateESNIMEI();
  }

  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateTLDN_NO();
  }

  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateAirTimeRateCharge();
  }

  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateOtherChargeNo1();
  }
  
  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateTotalCharges(22);
  }
 
  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateFraudIndicator();
  }

  if (edrString( DETAIL.ERROR_REJECT_TYPE ) == ""){
    validateToll();
  }

  return ;
}

