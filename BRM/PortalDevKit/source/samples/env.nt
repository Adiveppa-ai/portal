# This file lists makefile macros that must be set in order
# to build the Infranet source samples on Microsoft Windows NT
#
# There are two options on defining these macros:
#   * Define them as environment variables or
#   * Uncomment and define them in this file
#


# Absolute path to this directory
# ex:  SAMPLESROOT=c:\InfranetSDK\source\samples
# SAMPLESROOT=c:\InfranetSDK\source\samples

# Absolute path to Java 2 SE v.1.2 (JDK 1.2) or later directory
# ex:  JDK_HOME=c:\jdk1.2.2
# JDK_HOME=

# Absolute path to pcm.jar & pcmext.jar
# ex:  PCM_JAR=c:\infranet\jars\pcm.jar
# ex:  PCMEXT_JAR=c:\infranet\jars\pcmext.jar
# PCM_JAR=
# PCMEXT_JAR=

# Absolute path to Infranet lib directory
# ex:  LIBDIR=c:\infranet\lib
# LIBDIR=c:\infranet\lib

# Absolute path to Infranet include directory
# ex:  INCLDIR=c:\infranet\include
# INCLDIR=c:\infranet\include
