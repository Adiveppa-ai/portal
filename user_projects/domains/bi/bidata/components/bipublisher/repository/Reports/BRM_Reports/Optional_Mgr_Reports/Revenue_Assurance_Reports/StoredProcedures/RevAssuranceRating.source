                    IF  edr_status = psuccess
                     AND(( batch_type = 2
                     AND  original_batch_id =  suspended_from_batch_id) OR  batch_type = 5) THEN
                      success_recycle_count_ra10 := success_recycle_count_ra10 +  total_count;
                    END IF;

                    -- Written-off Count

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_count_ra10 := writtenoff_count_ra10 +  total_count;
                    END IF;

                    -- Mediation and Mediation-update success Duration

                    IF  edr_status = psuccess
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      success_static_duration_ra10 := success_static_duration_ra10 +  total_duration;
                    END IF;

                    -- Mediation and Mediation-update failed Duration

                    IF  edr_status = psuspense
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      failed_static_duration_ra10 := failed_static_duration_ra10 +  total_duration;
                    END IF;

                    -- Recycle success Duration

                    IF  edr_status = psuccess
                     AND  batch_type = 2
                     AND  original_batch_id =  suspended_from_batch_id THEN
                      success_recycle_duration_ra10 := success_recycle_duration_ra10 +  total_duration;
                    END IF;

                    -- Written-off Duration

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_duration_ra10 := writtenoff_duration_ra10 +  total_duration;
                    END IF;

                    currentamount_ra10 :=  total_retail_amount +  old_retail_amount +  total_discount_value +  old_discount_value;

                    -- Mediation success Amount

                    IF  edr_status = psuccess
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      success_static_amount_ra10 := success_static_amount_ra10 + currentamount_ra10;
                    END IF;

                    -- Rerating success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 1 and success_static_count_ra10 > 0 THEN
                      success_rerating_amount_ra10 := success_rerating_amount_ra10 + currentamount_ra10;
                    END IF;

                    -- Rerating failed Amount

                    IF  edr_status = psuspense
                     AND  batch_type = 1 and success_static_count_ra10 > 0 THEN
                      failed_rerating_amount_ra10 := failed_rerating_amount_ra10 + currentamount_ra10;
                    END IF;

                    -- Recycle success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 2 THEN
                      success_recycle_amount_ra10 := success_recycle_amount_ra10 + currentamount_ra10;
                    END IF;

                    -- Set the flags accordingly
                    IF  batch_type = 0 OR  batch_type = 1 OR  batch_type = 2 OR  batch_type = 4 OR  batch_type = 5 THEN
                      flag_rerate_recycle_ra10 := 1;
                    END IF;

                    IF  batch_type = 3 THEN
                      flag_writtenoff_ra10 := 1;
                    END IF;

                 -- Revenue Assurance Scope is rerating.
                 ELSIF pRaScope = 'Rerating' THEN
                    IF batch_type = 1 OR batch_type = 2 OR batch_type = 5 THEN
                      flag_rerate_recycle_ra10 := 1;
                    END IF;

                    IF batch_type = 3 THEN
                      flag_writtenoff_ra10 := 1;
                    END IF;

                    -- Rerating/Rerating Update success Count

                    IF  edr_status = psuccess
                     AND  (batch_type = 1 OR batch_type = 5) THEN
                      success_static_count_ra10 := success_static_count_ra10 +  total_count;
                    END IF;

                    -- Rerating/Rerating Update failed Count

                    IF  edr_status = psuspense
                     AND( batch_type = 1  OR batch_type = 5 ) THEN
                      failed_static_count_ra10 := failed_static_count_ra10 +  total_count;
                    END IF;

                    -- Recycle/Rerate-Recycle success Count
                    IF  edr_status = psuccess
                     AND( batch_type = 2) THEN
                      success_recycle_count_ra10 := success_recycle_count_ra10 +  total_count;
                    END IF;

                    -- Written-off Count

                    IF edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_count_ra10 := writtenoff_count_ra10 +  total_count;
                    END IF;

                    -- Rerating and Rerating-update success Duration

                    IF  edr_status = psuccess
                     AND( batch_type = 1 OR  batch_type = 5) THEN
                      success_static_duration_ra10 := success_static_duration_ra10 +  total_duration;
                    END IF;

                    -- Rerating and Rerating-update failed Duration

                    IF  edr_status = psuspense
                     AND( batch_type = 1 OR  batch_type = 5) THEN
                      failed_static_duration_ra10 := failed_static_duration_ra10 +  total_duration;
                    END IF;

                    -- Recycle success Duration

                    IF  edr_status = psuccess AND  batch_type = 2 THEN
                      success_recycle_duration_ra10 := success_recycle_duration_ra10 +  total_duration;
                    END IF;

                    -- Written-off Duration

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_duration_ra10 := writtenoff_duration_ra10 +  total_duration;
                    END IF;

                    currentamount_ra10 :=  total_retail_amount +  total_discount_value;

                    -- Rerating success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 1 THEN
                      success_rerating_amount_ra10 := success_rerating_amount_ra10 + currentamount_ra10;
                    END IF;

                    -- Rerating failed Amount

                 --   IF  edr_status = psuspense
                  --   AND  batch_type = 1 THEN
                  --    failed_rerating_amount_ra10 := failed_rerating_amount_ra10 + currentamount_ra10;
                  --  END IF;

                    -- Recycle success Amount

                    IF  edr_status = psuccess
                     AND  ( batch_type = 2 or batch_type = 5 ) THEN
                      success_recycle_amount_ra10 := success_recycle_amount_ra10 + currentamount_ra10;
                    END IF;
                 END IF;
              END LOOP;
            END;

            -- This query corresponds to RA_14 scenario where the grouping is based on Service Type, Revenue Stream,
            -- EDR Status and Output Stream and object type is /process_audit/batchstat/svctype_revstream_status_outputstream
            DECLARE
            l_ref_cur refcursor;

            BEGIN
            l_ref_cur := ref_cur(myquery(6));

              LOOP
               FETCH l_ref_cur into 	EDR_STATUS,
                                        TOTAL_COUNT,
                                        TOTAL_DURATION,
                                        OLD_RETAIL_AMOUNT,
                                        TOTAL_RETAIL_AMOUNT,
                                        TOTAL_DISCOUNT_VALUE,
                                        OLD_DISCOUNT_VALUE,
                                        BATCH_TYPE,
                                        PROCESS_NAME,
                                        BATCH_ID,
                                        original_batch_id,
                                        suspended_from_batch_id ;
               EXIT WHEN l_ref_cur%NOTFOUND;
                IF pRaScope='Batch Rating' THEN

                    -- Mediation success Count

                    IF  edr_status = psuccess
                     AND( batch_type = 0  OR batch_type = 4 ) THEN
                      success_static_count_ra14 := success_static_count_ra14 +  total_count;
                    END IF;

                    -- Mediation failed Count

                    IF  edr_status = psuspense
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      failed_static_count_ra14 := failed_static_count_ra14 +  total_count;
                    END IF;

                    -- Recycle/Rerate-Recyle success Count

                    IF  edr_status = psuccess
                     AND(( batch_type = 2
                     AND  original_batch_id =  suspended_from_batch_id) OR  batch_type = 5) THEN
                      success_recycle_count_ra14 := success_recycle_count_ra14 +  total_count;
                    END IF;

                    -- Written-off Count

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_count_ra14 := writtenoff_count_ra14 +  total_count;
                    END IF;

                    -- Mediation and Mediation-update success Duration

                    IF  edr_status = psuccess
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      success_static_duration_ra14 := success_static_duration_ra14 +  total_duration;
                    END IF;

                    -- Mediation and Mediation-update failed Duration

                    IF  edr_status = psuspense
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      failed_static_duration_ra14 := failed_static_duration_ra14 +  total_duration;
                    END IF;

                    -- Recycle success Duration

                    IF  edr_status = psuccess
                     AND  batch_type = 2
                     AND  original_batch_id =  suspended_from_batch_id THEN
                      success_recycle_duration_ra14 := success_recycle_duration_ra14 +  total_duration;
                    END IF;

                    -- Written-off Duration

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_duration_ra14 := writtenoff_duration_ra14 +  total_duration;
                    END IF;

                    currentamount_ra14 :=  total_retail_amount +  old_retail_amount +  total_discount_value +  old_discount_value;

                    -- Mediation success Amount

                    IF  edr_status = psuccess
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      success_static_amount_ra14 := success_static_amount_ra14 + currentamount_ra14;
                    END IF;

                    -- Rerating success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 1 and success_static_count_ra14 > 0 THEN
                      success_rerating_amount_ra14 := success_rerating_amount_ra14 + currentamount_ra14;
                    END IF;

                    -- Rerating failed Amount

                    IF  edr_status = psuspense
                     AND  batch_type = 1 and success_static_count_ra14 > 0 THEN
                      failed_rerating_amount_ra14 := failed_rerating_amount_ra14 + currentamount_ra14;
                    END IF;

                    -- Recycle success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 2 THEN
                      success_recycle_amount_ra14 := success_recycle_amount_ra14 + currentamount_ra14;
                    END IF;

                    -- Set the flags accordingly
                    IF  batch_type = 0 OR  batch_type = 1 OR  batch_type = 2 OR  batch_type = 4 OR  batch_type = 5 THEN
                      flag_rerate_recycle_ra14 := 1;
                    END IF;

                    IF  batch_type = 3 THEN
                      flag_writtenoff_ra14 := 1;
                    END IF;

                 -- Revenue Assurance Scope is rerating.
                 ELSIF pRaScope = 'Rerating' THEN
                    IF batch_type = 1 OR batch_type = 2 OR batch_type = 5 THEN
                      flag_rerate_recycle_ra14 := 1;
                    END IF;

                    IF batch_type = 3 THEN
                      flag_writtenoff_ra14 := 1;
                    END IF;

                    -- Rerating/Rerating Update success Count

                    IF  edr_status = psuccess
                     AND  (batch_type = 1 OR batch_type = 5) THEN
                      success_static_count_ra14 := success_static_count_ra14 +  total_count;
                    END IF;

                    -- Rerating/Rerating Update failed Count

                    IF  edr_status = psuspense
                     AND( batch_type = 1  OR batch_type = 5 ) THEN
                      failed_static_count_ra14 := failed_static_count_ra14 +  total_count;
                    END IF;

                    -- Recycle/Rerate-Recycle success Count
                    IF  edr_status = psuccess
                     AND( batch_type = 2) THEN
                      success_recycle_count_ra14 := success_recycle_count_ra14 +  total_count;
                    END IF;

                    -- Written-off Count

                    IF edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_count_ra14 := writtenoff_count_ra14 +  total_count;
                    END IF;

                    -- Rerating and Rerating-update success Duration

                    IF  edr_status = psuccess
                     AND( batch_type = 1 OR  batch_type = 5) THEN
                      success_static_duration_ra14 := success_static_duration_ra14 +  total_duration;
                    END IF;

                    -- Rerating and Rerating-update failed Duration

                    IF  edr_status = psuspense
                     AND( batch_type = 1 OR  batch_type = 5) THEN
                      failed_static_duration_ra14 := failed_static_duration_ra14 +  total_duration;
                    END IF;

                    -- Recycle success Duration

                    IF  edr_status = psuccess AND  batch_type = 2 THEN
                      success_recycle_duration_ra14 := success_recycle_duration_ra14 +  total_duration;
                    END IF;

                    -- Written-off Duration

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_duration_ra14 := writtenoff_duration_ra14 +  total_duration;
                    END IF;

                    currentamount_ra14 :=  total_retail_amount +  total_discount_value;

                    -- Rerating success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 1 THEN
                      success_rerating_amount_ra14 := success_rerating_amount_ra14 + currentamount_ra14;
                    END IF;

                    -- Rerating failed Amount

                 --   IF  edr_status = psuspense
                  --   AND  batch_type = 1 THEN
                  --    failed_rerating_amount_ra14 := failed_rerating_amount_ra14 + currentamount_ra14;
                  --  END IF;

                    -- Recycle success Amount

                    IF  edr_status = psuccess
                     AND  ( batch_type = 2 or batch_type = 5 ) THEN
                      success_recycle_amount_ra14 := success_recycle_amount_ra14 + currentamount_ra14;
                    END IF;
                 END IF;
              END LOOP;
            END;

    OPEN l_cursor FOR
        SELECT
                    success_recycle_count_ra02 as success_recycle_count_ra02,
                    success_static_count_ra02 as success_static_count_ra02,
                    failed_static_count_ra02 as failed_static_count_ra02,
                    writtenoff_count_ra02 as writtenoff_count_ra02 ,
                    flag_rerate_recycle_ra02 as flag_rerate_recycle_ra02,
                    flag_writtenoff_ra02 as flag_writtenoff_ra02,
                    success_recycle_duration_ra02 as success_recycle_duration_ra02,
                    success_static_duration_ra02 as success_static_duration_ra02,
                    failed_static_duration_ra02 as failed_static_duration_ra02,
                    writtenoff_duration_ra02 as writtenoff_duration_ra02,
                    success_recycle_amount_ra02 as success_recycle_amount_ra02,
                    success_static_amount_ra02 as success_static_amount_ra02,
                    failed_static_amount_ra02 as failed_static_amount_ra02,
                    success_rerating_amount_ra02 as success_rerating_amount_ra02,
                    failed_rerating_amount_ra02 as failed_rerating_amount_ra02,
                    CurrentAmount_ra02 as CurrentAmount_ra02,
                    success_recycle_count_ra10 as success_recycle_count_ra10,
                    success_static_count_ra10 as success_static_count_ra10,
                    failed_static_count_ra10 as failed_static_count_ra10,
                    writtenoff_count_ra10 as writtenoff_count_ra10 ,
                    flag_rerate_recycle_ra10 as flag_rerate_recycle_ra10,
                    flag_writtenoff_ra10 as flag_writtenoff_ra10,
                    success_recycle_duration_ra10 as success_recycle_duration_ra10,
                    success_static_duration_ra10 as success_static_duration_ra10,
                    failed_static_duration_ra10 as failed_static_duration_ra10,
                    writtenoff_duration_ra10 as writtenoff_duration_ra10,
                    success_recycle_amount_ra10 as success_recycle_amount_ra10,
                    success_static_amount_ra10 as success_static_amount_ra10,
                    failed_static_amount_ra10 as failed_static_amount_ra10,
                    success_rerating_amount_ra10 as success_rerating_amount_ra10,
                    failed_rerating_amount_ra10 as failed_rerating_amount_ra10,
                    CurrentAmount_ra10 as CurrentAmount_ra10,
                    success_recycle_count_ra04 as success_recycle_count_ra04,
                    success_static_count_ra04 as success_static_count_ra04,
                    failed_static_count_ra04 as failed_static_count_ra04,
                    writtenoff_count_ra04 as writtenoff_count_ra04 ,
                    flag_rerate_recycle_ra04 as flag_rerate_recycle_ra04,
                    flag_writtenoff_ra04 as flag_writtenoff_ra04,
                    success_recycle_duration_ra04 as success_recycle_duration_ra04,
                    success_static_duration_ra04 as success_static_duration_ra04,
                    failed_static_duration_ra04 as failed_static_duration_ra04,
                    writtenoff_duration_ra04 as writtenoff_duration_ra04,
                    success_recycle_amount_ra04 as success_recycle_amount_ra04,
                    success_static_amount_ra04 as success_static_amount_ra04,
                    failed_static_amount_ra04 as failed_static_amount_ra04,
                    success_rerating_amount_ra04 as success_rerating_amount_ra04,
                    failed_rerating_amount_ra04 as failed_rerating_amount_ra04,
                    CurrentAmount_ra04 as CurrentAmount_ra04,
                    success_recycle_count_ra08 as success_recycle_count_ra08,
                    success_static_count_ra08 as success_static_count_ra08,
                    failed_static_count_ra08 as failed_static_count_ra08,
                    writtenoff_count_ra08 as writtenoff_count_ra08 ,
                    flag_rerate_recycle_ra08 as flag_rerate_recycle_ra08,
                    flag_writtenoff_ra08 as flag_writtenoff_ra08,
                    success_recycle_duration_ra08 as success_recycle_duration_ra08,
                    success_static_duration_ra08 as success_static_duration_ra08,
                    failed_static_duration_ra08 as failed_static_duration_ra08,
                    writtenoff_duration_ra08 as writtenoff_duration_ra08,
                    success_recycle_amount_ra08 as success_recycle_amount_ra08,
                    success_static_amount_ra08 as success_static_amount_ra08,
                    failed_static_amount_ra08 as failed_static_amount_ra08,
                    success_rerating_amount_ra08 as success_rerating_amount_ra08,
                    failed_rerating_amount_ra08 as failed_rerating_amount_ra08,
                    CurrentAmount_ra08 as CurrentAmount_ra08,
                    success_recycle_count_ra14 as success_recycle_count_ra14,
                    success_static_count_ra14 as success_static_count_ra14,
                    failed_static_count_ra14 as failed_static_count_ra14,
                    writtenoff_count_ra14 as writtenoff_count_ra14 ,
                    flag_rerate_recycle_ra14 as flag_rerate_recycle_ra14,
                    flag_writtenoff_ra14 as flag_writtenoff_ra14,
                    success_recycle_duration_ra14 as success_recycle_duration_ra14,
                    success_static_duration_ra14 as success_static_duration_ra14,
                    failed_static_duration_ra14 as failed_static_duration_ra14,
                    writtenoff_duration_ra14 as writtenoff_duration_ra14,
                    success_recycle_amount_ra14 as success_recycle_amount_ra14,
                    success_static_amount_ra14 as success_static_amount_ra14,
                    failed_static_amount_ra14 as failed_static_amount_ra14,
                    success_rerating_amount_ra14 as success_rerating_amount_ra14,
                    failed_rerating_amount_ra14 as failed_rerating_amount_ra14,
                    CurrentAmount_ra14 as CurrentAmount_ra14,
                    success_recycle_count_ra06 as success_recycle_count_ra06,
                    success_static_count_ra06 as success_static_count_ra06,
                    failed_static_count_ra06 as failed_static_count_ra06,
                    writtenoff_count_ra06 as writtenoff_count_ra06 ,
                    flag_rerate_recycle_ra06 as flag_rerate_recycle_ra06,
                    flag_writtenoff_ra06 as flag_writtenoff_ra06,
                    success_recycle_duration_ra06 as success_recycle_duration_ra06,
                    success_static_duration_ra06 as success_static_duration_ra06,
                    failed_static_duration_ra06 as failed_static_duration_ra06,
                    writtenoff_duration_ra06 as writtenoff_duration_ra06,
                    success_recycle_amount_ra06 as success_recycle_amount_ra06,
                    success_static_amount_ra06 as success_static_amount_ra06,
                    failed_static_amount_ra06 as failed_static_amount_ra06,
                    success_rerating_amount_ra06 as success_rerating_amount_ra06,
                    failed_rerating_amount_ra06 as failed_rerating_amount_ra06,
                    CurrentAmount_ra06 as CurrentAmount_ra06
        FROM
                    DUAL;
   END IF;
   RETURN l_cursor;

   EXCEPTION
          WHEN INVALID_BATCH_ID THEN
               RAISE_APPLICATION_ERROR (-20001, 'Batch ID cannot be NULL');
          WHEN INVALID_FLOW_TYPE THEN
               RAISE_APPLICATION_ERROR (-20002, 'Flow Type cannot be NULL');
          WHEN INVALID_CONTROL_POINT THEN
               RAISE_APPLICATION_ERROR (-20003, 'Control Point cannot be NULL');
           return l_cursor;
  END RARatingDetail;

  FUNCTION CreateDynamicQuery(
            pstartdate        IN VARCHAR2,
            penddate          IN VARCHAR2,
            ptransstartdate   IN VARCHAR2,
            ptransenddate     IN VARCHAR2,
            pflowtype         IN VARCHAR2,
            pcontrolpoint     IN VARCHAR2,
            pservicetype      IN VARCHAR2,
            pbatchid          IN VARCHAR2,
            pdetailstablename IN VARCHAR2,
            pRaScope           IN VARCHAR2) RETURN VARCHAR2 AS
      dquery VARCHAR2(6000) := NULL;
      groupby VARCHAR2(200) := NULL;
      orderby VARCHAR2(200) := NULL;
      BEGIN
      -- Based on RA scope, create the query to fetch dynamic data.
        dquery := 'select
                        EDR_STATUS,
                        sum(v1.TOTAL_COUNT) TOTAL_COUNT,
                        sum(v1.TOTAL_DURATION) TOTAL_DURATION,
                        sum(v1.OLD_RETAIL_AMOUNT) OLD_RETAIL_AMOUNT,
                        sum(v1.TOTAL_RETAIL_AMOUNT) TOTAL_RETAIL_AMOUNT,
                        sum(v1.TOTAL_DISCOUNT_VALUE) TOTAL_DISCOUNT_VALUE,
                        sum(v1.OLD_DISCOUNT_VALUE) OLD_DISCOUNT_VALUE,
                        v1.BATCH_TYPE BATCH_TYPE,
                        v1.PROCESS_NAME,
                        v1.BATCH_ID,
                        v1.original_batch_id,
                        v1.suspended_from_batch_id
                  from
                      (select /*+ ORDERED */
                          EDR_STATUS,';
                  IF (pServiceType is NOT NULL) THEN -- add only when service type is requested
                          dQuery :=  dQuery || ' SERVICE_TYPE,';
                  END IF;
        dQuery :=  dQuery || ' details.TOTAL_COUNT ,
                          details.TOTAL_DURATION ,
                          details.OLD_RETAIL_AMOUNT ,
                          details.TOTAL_RETAIL_AMOUNT ,
                          details.TOTAL_DISCOUNT_VALUE,
                          details.OLD_DISCOUNT_VALUE,
                          BATCH_TYPE ,
                          PROCESS_NAME,
                          BATCH_ID,
                          details.original_batch_id,
                          details.suspended_from_batch_id
                       from   (select /*+ USE_NL (proc_aud_t proc_aud_bstat_t) NO_MERGE */
                                        proc_aud_t.poid_id0,
                                        proc_aud_bstat_t.batch_type,
                                        proc_aud_t.process_name,
                                        proc_aud_bstat_t.batch_id
                              FROM proc_aud_t,
                                        proc_aud_bstat_t
                              WHERE proc_aud_bstat_t.OBJ_ID0 = proc_aud_t.POID_ID0 ';
                                IF (pRaScope = 'Batch Rating') THEN
                                 dQuery :=  dQuery || ' and proc_aud_bstat_t.BATCH_TYPE in (0, 2, 4) ' ;
                                ELSIF (pRaScope = 'Rerating') THEN
                                 dQuery :=  dQuery || ' and proc_aud_bstat_t.BATCH_TYPE in (1, 2, 5) ';
                                END IF;
                                dQuery :=  dQuery || ' and proc_aud_t.PROCESS_NAME = ''' || pcontrolpoint || '''
                                and proc_aud_t.CREATED_T >= (bipext.infStrToTimet(''' || pstartdate || ''', 2))
                                and proc_aud_t.CREATED_T <=  (DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
							bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
							bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
                                and proc_aud_t.VERSION_ID = 4) p, ' || pdetailstablename || ' details
                       where details.OBJ_ID0 = p.POID_ID0
                              and details.SUSPENDED_FROM_BATCH_ID = ''' || pbatchid || '''
                              and (details.USAGE_START_T >= (bipext.infStrToTimet(''' || ptransstartdate || ''', 2))
                              and  details.USAGE_START_T <= (DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
							bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
							bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2))))
                       UNION ALL
                       select /*+ ORDERED */
                           EDR_STATUS,';
                      IF (pServiceType is NOT NULL) THEN
                          dQuery :=  dQuery || ' SERVICE_TYPE,';
                      END IF;
        dQuery :=  dQuery || ' details.TOTAL_COUNT ,
                           details.TOTAL_DURATION ,
                           details.OLD_RETAIL_AMOUNT ,
                           details.TOTAL_RETAIL_AMOUNT ,
                           details.TOTAL_DISCOUNT_VALUE,
                           details.OLD_DISCOUNT_VALUE,
                           BATCH_TYPE ,
                           PROCESS_NAME,
                           BATCH_ID,
                           details.ORIGINAL_BATCH_ID,
                           details.SUSPENDED_FROM_BATCH_ID
                        from  (select /*+ USE_NL (proc_aud_t proc_aud_bstat_t) NO_MERGE */
                                        proc_aud_t.poid_id0,
                                        proc_aud_bstat_t.batch_type,
                                        proc_aud_t.process_name,
                                        proc_aud_bstat_t.BATCH_ID
                               FROM proc_aud_t,
                                        proc_aud_bstat_t
                               WHERE proc_aud_bstat_t.OBJ_ID0 = proc_aud_t.POID_ID0 ' ;
                                IF (pRaScope = 'Batch Rating') THEN
                                  dQuery :=  dQuery || ' and proc_aud_bstat_t.BATCH_TYPE in (1, 2, 3, 5) ';
                                ELSIF (pRaScope = 'Rerating') THEN
                                  dQuery :=  dQuery || ' and proc_aud_bstat_t.BATCH_TYPE = 3 ';
                                END IF;
                                  dQuery :=  dQuery || ' and proc_aud_t.PROCESS_NAME in
                                  (select CONTROL_POINT
                                        from CONFIG_CONTROLPOINTS_LINKS_T
                                        where PARENT_CTRL_POINT = ''' || pControlPoint || ''')
                                  and proc_aud_t.CREATED_T >= (bipext.infStrToTimet(''' || pstartdate || ''', 2))
                                  and proc_aud_t.CREATED_T <=  (DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
								bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
								bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
                                  and proc_aud_t.VERSION_ID = 4) p, ' || pdetailstablename || ' details
                         where details.OBJ_ID0 = p.POID_ID0 ' ;
                             IF (pRaScope = 'Batch Rating') THEN
                              dQuery :=  dQuery || ' and details.ORIGINAL_BATCH_ID = ''' || pbatchid || '''';
                             ELSIF (pRaScope = 'Rerating') THEN
                              dQuery :=  dQuery || ' and details.SUSPENDED_FROM_BATCH_ID = ''' || pbatchid || '''';
                             END IF;
                              dQuery :=  dQuery || ' AND (details.usage_start_t >=(bipext.infstrtotimet(''' || ptransStartDate || ''',   2))
                              AND details.usage_start_t <=(DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
					bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
					bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)) ))) v1 ';

                  IF (pServiceType is NOT NULL) THEN  -- add only when service type is requested
                      dQuery :=  dQuery || ' WHERE service_type = ''' || pServiceType || '''';
                  END IF;
     groupby := ' Group By EDR_STATUS, BATCH_TYPE, PROCESS_NAME, BATCH_ID, ORIGINAL_BATCH_ID, SUSPENDED_FROM_BATCH_ID ';
     orderby := ' Order By EDR_STATUS, BATCH_TYPE, PROCESS_NAME, BATCH_ID, ORIGINAL_BATCH_ID, SUSPENDED_FROM_BATCH_ID ';

     dquery := dquery || groupby || orderby;
     RETURN dquery;

  END;


  FUNCTION ref_cur(dquery IN VARCHAR2) RETURN rarating.refcursor IS
      l_ref_cur rarating.refcursor;
  BEGIN
      OPEN l_ref_cur FOR dquery;
	if (l_ref_cur is null) then
	  OPEN l_ref_cur FOR
			SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   NULL                                     EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   OUTPUT_STREAM                            OUTPUT_STREAM,
   REVENUE_STREAM                           REVENUE_STREAM,
   SERVICE_TYPE                             SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   UPPER(OUTPUT_STREAM)                     UOUTPUT_STREAM,
   UPPER(REVENUE_STREAM)                    UREVENUE_STREAM,
   UPPER(SERVICE_TYPE)                      USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   8                                        POID_VAL
FROM((("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0")
INNER JOIN "GDTLS_STYPE_RSTRM_OSTRM_T" "GDTLS_STYPE_RSTRM_OSTRM_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_STYPE_RSTRM_OSTRM_T"."OBJ_ID0";
	  end if;
      RETURN l_ref_cur;
  END;

END RARating;
/
