sub display_results {
  local($locindex, $sessnum, $testnum ) = @_;
  local ($resp);

  $nn = $locindex / 2;
  $result_path = $TEST[$locindex+1];
  $version = $TEST[$locindex];
  if ( -e "$result_path/report$sessnum.$testnum" ) {  # display only if result exists
        open (INFILE, "$result_path/report$sessnum.$testnum") ||
            die "$ME: Unable to open file '$result_path/report$sessnum.$testnum': $!\n";
       $itmc_code = "";

       @util = ( "", "", 0,0,0, );
       $index1 = 0;
       while (<INFILE>) {
                $line = $_;
                if ($line =~ m/OP-bal[-_]impact/) {
			$itmc_code = "(PRER)";
		}
                if ($line =~ m/OP-find[-_]verify/) {
			$itmc_code = "(EAA)";
		}
                if ($line =~ m/OP-update[-_]/) {
			$itmc_code = "(CSR)";
		}
                if ($line =~ m/OP-purchase[-_]/) {
			$itmc_code = "(BUY)";
		}
                if ($line =~ m/OP-item[-_]/) {
			$itmc_code = "(SRCH)";
		}
                if ($line =~ m/STOP_ACCOUNTING/) {
			$itmc_code = "(TST-STOP)";
		}
                if ($line =~ m/START_ACCOUNTING/) {
			$itmc_code = "(TST-START)";
		}
                if ($line =~ m/AUTHENTICATE/) {
			$itmc_code = "(TST-AUTHEN)";
		}
                if ($line =~ m/AUTHORIZE/) {
			$itmc_code = "(TST-AUTHOR)";
		}
                if ($line =~ m/collisions/) {
                   while (<INFILE>) {
                       $line = $_;
		       if ($line =~ m/^\s*SUMMARY:\s+/) {
			  last;
		       }
		       @util=split(/[\t ]+/,$line);
		       if ( $util[1] ne "" ) {
			$utils[$index1] = sprintf ( "%s ( %s, %s, %s ) ", $util[1], $util[3], $util[4],$util[5]);
			$index1++;
		       }
		   } 
		}
                if ($line =~ m/^\s*SUMMARY:\s+/) {
		   $line = <INFILE>;
                   @words=split(/[\t ]+/,$line);
		}
                if ($line =~ m/^Mean time\s+/) {
                   @words=split(/[\t ]+/,$line);
		   ($resp,$resp1, $resp3) = split (/m/,$words[5]);
		}
                if ( ($line =~ m/^Accounts\s+/) || ($line =~ m/created:\s+/)) {
                   @words=split(/[\t ]+/,$line);
		   $words[2] = $words[4];
		   $words[1] = "pin_loader";
                   if ( $testnum == 2 ) {
			$itmc_code = "(REGI)";
		   }
	           else {
			$itmc_code = "(REGC)";
		   }	
		   $words[3] = $resp/1000 ;
		   $utils[0] = "";
		   $utils[1] = "";
		   $utils[2] = "";
		}
                if ( ($line =~ m/^Test completed\s+/) || ($line =~ m/Response:\s+/)) {
                   @words=split(/[\t ]+/,$line);
		   $words[2] = $words[5];
		   $words[1] = "test_loopback";
                   if ( $testnum == 2 ) {
			$itmc_code = "(cm)";
		   }
	           else {
			$itmc_code = "(dm)";
		   }	
		   ($resp,$resp1, $resp3) = split (/m/,$words[7]);
		   $words[3] = $resp/1000 ;
		   $utils[0] = "";
		   $utils[1] = "";
		   $utils[2] = "";
		}
       }
	## add some ITM-C codes
       if ( $words[1] eq "connect_load" ) {
		$itmc_code = "(CONN)";
       }
       if ( $words[1] eq "sessload" ) {
		$itmc_code = "(ERR)";
       }
       if ( $words[1] eq "pin_collect" ) {
		$itmc_code = "(CCS)";
       }
       if ( $words[1] eq "bill_accts" ) {
		$itmc_code = "(BC)";
       }
       if ( $nn == 0 && $words [2] != 0) { # header before first line
	       printf ( "              Test %1d.%02d  %s %s\n", $sessnum, $testnum, $words[1], $itmc_code );
       }
       if ( $words [2] != 0 ) {
	       printf ( " %-19s  %7.2f      %3.2f  %s %s %s \n", $version, $words [2], $words[3] , $utils[0], $utils[1],$utils[2]);
       }
       close (INFILE);
  }
}

