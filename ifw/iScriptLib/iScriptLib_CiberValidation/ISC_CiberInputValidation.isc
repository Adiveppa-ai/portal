}

//------------------------------------------------------------------------------
// validateChargeNoIndicator_30(); 
// Cross field validation for CIBER Record 30 between
//     Special Feature Used
//     Charge No (1,2,3,4) Indicator
//------------------------------------------------------------------------------
function validateChargeNoIndicator_30
{
  if (debug)
    logStdout("validateChargeNoIndicator_30()\n");

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED, 0), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "03" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "04" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "05" or 
