function mapTapDecimalPlaces ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  theTapDecimalPlaces = edrLongEx( myContext, indices, nParentIndices );
  edrLong(HEADER.TAP_DECIMAL_PLACES) = theTapDecimalPlaces;
  theAbsoluteAmountDivider = 1.0;
  Long i;
  for (i=0; i < theTapDecimalPlaces; i=i+1)
  {
    theAbsoluteAmountDivider = theAbsoluteAmountDivider * 10.0;
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapExchangeRate ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  exchangeRate[lastCode] = edrLongEx( myContext, indices, nParentIndices );
  Long i;
  Long nbDecimals = 1;
  for (i=0; i < numberOfDecimalPlaces[lastCode]; i=i+1)
  {
    nbDecimals = nbDecimals * 10;
  }
  exchangeRateFactor[lastCode] = (longToDecimal(exchangeRate[lastCode]) / longToDecimal(nbDecimals));
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
