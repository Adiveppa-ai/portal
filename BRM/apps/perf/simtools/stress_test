###############################################################################
# del_pinconf()
#	input:
#		pinconf_file
#		prefix (dm, cm etc.)
#		assoc array of pinconf entries  to remove
###############################################################################
sub del_pinconf { 
	local ($file, $prefix, %PINCONF) = @_;
	local ($tmpoutfile) = "$file.yyy";

	if ($DEBUG) {
		printout("$ME: $prefix\n");
	}
	
	save_pinconf_file($file);	
	
        #
        # Open pin.conf for output
        # Open pin.conf.yyy for input
        #
        open (FILE, "$file") ||
            die "$ME: Unable to open file '$file': $!\n";
        open (OUTFILE, ">$tmpoutfile") ||
            die "$ME: Unable to create file '$tmpoutfile': $!\n";
 
	# Read entries from pin.conf
	# If line matches key to be substituted, delete
	# Write line to pin.conf.yyy
	# 
	while (<FILE>) {
		$line = $_;
		$matched = 0;

		foreach $pinkey (keys(%PINCONF)) {
			if ($line =~ m/^\s*-\s+$prefix\s+$pinkey\s+/) {
				$matched = 1;
				if ($DEBUG) {
					printout("$ME:    Removing key $pinkey\n");
				}
			}
		} # end foreach

		if ($matched == 0) {
			print OUTFILE "$line";
		}

	} # end while

	#
	# Close filehandles
	# 
	close(FILE); 
	close(OUTFILE); 

	if ($DEBUG) {
		printout("$ME:    Renaming $tmpoutfile to $file\n");
	}
	
	#
	# Moving pin.conf.yyy to pin.conf
	#
        unlink "$file";
        (rename "$tmpoutfile", "$file") ||
            die "$ME: Cannot rename $tmpoutfile to $file: $!\n";
}

