<?xml version="1.0" encoding="UTF-8"?>
<xs:schema targetNamespace="http://www.portal.com/InfranetXMLSchema" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="http://www.portal.com/InfranetXMLSchema" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xs:include schemaLocation="CMT_Balances.xsd"/>
	<xs:include schemaLocation="CMT_Types.xsd"/>
	<!-- Extension schemas  -->
	<xs:include schemaLocation="serviceExtensions.xsd"/>
	<xs:include schemaLocation="serviceTelcoGSMExtension.xsd"/>
	<xs:include schemaLocation="payinfoExtensions.xsd"/>
	<xs:include schemaLocation="payinfoCreditCardExtension.xsd"/>
	<xs:include schemaLocation="payinfoDebitCardExtension.xsd"/>
	<xs:include schemaLocation="payinfoInvoiceExtension.xsd"/>
	<xs:include schemaLocation="promotionExtensions.xsd"/>
	<xs:include schemaLocation="promotionAccountLevelExtension.xsd"/>
	<xs:include schemaLocation="promotionServiceLevelExtension.xsd"/>
	<xs:include schemaLocation="deviceExtensions.xsd"/>
	<xs:include schemaLocation="deviceNUMExtension.xsd"/>
	<xs:include schemaLocation="deviceSIMExtension.xsd"/>
	<xs:include schemaLocation="loan.xsd"/>
	<xs:element name="Sbsc">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="ActSbsc" type="Subscriber" minOccurs="1" maxOccurs="unbounded"/>
				<xs:element name="SbscPrms" type="SbscPrmsType" minOccurs="0" maxOccurs="1" nillable="false"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:complexType name="SbscPrmsType">
		<xs:sequence>
			<xs:element name="PlObj" type="Poid" minOccurs="1" maxOccurs="1" nillable="false"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="Subscriber">
		<xs:sequence>
			<xs:element name="Act" type="AccountType" minOccurs="1" maxOccurs="1" nillable="false"/>
			<xs:element name="ActSub" type="Subscriptions" minOccurs="1" maxOccurs="1" nillable="false"/>
			<xs:element name="PurBun" type="PurchasedBundleType" minOccurs="0" maxOccurs="unbounded"/>
			<xs:choice minOccurs="0" maxOccurs="unbounded">
				<xs:element name="PurPrd" type="PurchasedProductType" minOccurs="0" maxOccurs="unbounded"/>
				<xs:element name="PurDis" type="PurchasedDiscountType" minOccurs="0" maxOccurs="unbounded"/>
			</xs:choice>
			<xs:element name="OffOvr" type="OfferingOverrideType" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="ActDev" type="AccountDevices" minOccurs="0" maxOccurs="1"/>
			<xs:element name="ABinfo" type="Billinfo" minOccurs="1" maxOccurs="unbounded"/>
			<xs:element name="APinfo" type="Payinfo" minOccurs="1" maxOccurs="unbounded"/>
			<xs:element name="AGSDisc" type="GroupSharingDiscount" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="AGSCrg" type="GroupSharingCharge" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="AMOGSrg" type="MemberOfGroupCharge" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="AMOGDist" type="MemberOfGroupDiscount" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="ActProm" type="Promotion" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="AGSPro" type="GroupSharingProfile" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="AMOGPro" type="MemberOfProfileSharing" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="ActBal" type="AccountBalances" minOccurs="0" maxOccurs="1"/>
			<xs:element name="AGSProd" type="GroupSharingProduct" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="AMOGProd" type="MemberOfGroupProduct" minOccurs="0" maxOccurs="unbounded"/>
			<xs:element name="ActLoan" type="Loan" minOccurs="0" maxOccurs="1"/>
			<xs:element name="SbscContract" type="SubscriberContractType" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="parenRef" type="Id" use="optional"/>
		<xs:attribute name="id" type="Id" use="required"/>
		<xs:attribute name="global" type="xs:string" use="optional" default="true"/>
		<!-- global attribute signifies user permission to read or write the object -->
		<xs:attribute name="payParenRef" type="Id" use="optional"/>
		<xs:attribute name="isParent" type="YesOrNo" use="optional"/>
		<xs:attribute name="numOfChlds" type="xs:integer" use="optional" default="0"/>
		<!-- Count of the number of members in the members array of class /group -->
		<xs:attribute name="bal_grp_name" type="xs:string" use="optional"/>
	</xs:complexType>
	<xs:complexType name="AccountType">
		<xs:sequence>
			<xs:element name="ActNo" minOccurs="1" maxOccurs="1" nillable="false">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="60"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Curr" type="xs:string" minOccurs="1" maxOccurs="1" nillable="false"/>
			<xs:element name="CustSegList" type="xs:string" minOccurs="1" maxOccurs="1" nillable="false"/>
			<xs:element name="SubSta" type="SubscriberStatus" default="A" minOccurs="1" maxOccurs="1"/>
			<xs:element name="BType" type="BusinessType" minOccurs="1" maxOccurs="1"/> 
			<xs:element name="Eff" type="dateTime-or-zero"  minOccurs="1" maxOccurs="1"/>
			<xs:element name="CrtT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="AccCode1" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="AccCode2" type="xs:string" minOccurs="0" maxOccurs="1"/>
                        <xs:element name="GLSgmt" type="xs:string" minOccurs="0" maxOccurs="1"/>
                        <xs:element name="Locale" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="ANArr" type="NameinfoArray" minOccurs="1" maxOccurs="unbounded"/>
			<xs:element name="SrvAACAccess" minOccurs="0" maxOccurs="1">
                                <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                                <xs:maxLength value="60"/>
                                        </xs:restriction>
                                </xs:simpleType>
                        </xs:element>
                        <xs:element name="SrvAACPkg" minOccurs="0" maxOccurs="1">
                                <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                                <xs:maxLength value="60"/>
                                        </xs:restriction>
                                </xs:simpleType>
                        </xs:element>
                        <xs:element name="SrvAACPromo" minOccurs="0" maxOccurs="1">
                                <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                                <xs:maxLength value="60"/>
                                        </xs:restriction>
                                </xs:simpleType>
                        </xs:element>
                        <xs:element name="SrvAACSerial" minOccurs="0" maxOccurs="1">
                                <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                                <xs:maxLength value="60"/>
                                        </xs:restriction>
                                </xs:simpleType>
                        </xs:element>
                        <xs:element name="SrvAACSrc" minOccurs="0" maxOccurs="1">
                                <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                                <xs:maxLength value="60"/>
                                        </xs:restriction>
                                </xs:simpleType>
                        </xs:element>
                        <xs:element name="SrvAACVen" minOccurs="0" maxOccurs="1">
                                <xs:simpleType>
                                        <xs:restriction base="xs:string">
                                                <xs:maxLength value="60"/>
                                        </xs:restriction>
                                </xs:simpleType>
                        </xs:element>
			<xs:element name="AEArr" type="ExemptionsArray" minOccurs="0" maxOccurs="unbounded"/>

			<!-- If Subscriber status is not specified a default of 'active' will be chosen -->
			<!-- If Effective time is not specified it will be defaulted to created time -->
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="NameinfoArray">
		<xs:sequence>
			<xs:element name="Add" type="Address" minOccurs="0" maxOccurs="1"/>
			<xs:element name="City" type="City" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Comp" minOccurs="0">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="90"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="CntTyp" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="255"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Cnt" type="Country" minOccurs="0" maxOccurs="1"/>
			<xs:element name="EAdd" type="EmailAddr" minOccurs="0" maxOccurs="1"/>
			<xs:element name="FNm" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="90"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="MNm" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="90"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="LNm" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="90"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Sal" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="75"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Stt" type="State" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Tit" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="90"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Zip" type="Zip" minOccurs="0" maxOccurs="1"/>
			<xs:element name="APhArr" type="PhonesArray" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="elem" type="xs:integer" use="required"/>
	</xs:complexType>
	<xs:complexType name="PhonesArray">
		<xs:sequence>
			<xs:element name="Ph" minOccurs="1" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="75"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="PhTyp" type="PhoneType" minOccurs="1" maxOccurs="1"/>
		</xs:sequence>
		<xs:attribute name="elem" type="xs:integer" use="required"/>
	</xs:complexType>
	<xs:complexType name="PurchasedProductType">
