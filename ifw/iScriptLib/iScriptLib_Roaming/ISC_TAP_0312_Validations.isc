/******************************************************************************************************************************
 * This function will validate PDPContextStartTimestamp. It will raise error code 30 for PDPContextStartTimestamp.
 ******************************************************************************************************************************/
 
function validatePDPContextStartTimestamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
