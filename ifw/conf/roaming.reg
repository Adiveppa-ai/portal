        } # END BacKOut 
       } # END Functions

      #--------------------------------------------------
      # Output Section
      #--------------------------------------------------
      Output
      {
        WriteDefaultEdr            = False

        MaxErrorRates
        {
        }

        OutputCollection
        {
          #--------------------------------------------------------------------
          # The /service/telco/gsm/telephony output stream for BackOutOnly
          #--------------------------------------------------------------------
          GSMOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = BACKOUT_PIPELINE
            EventType = /event/delayed/session/telco/gsm/roaming

            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True #defaults to true

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/backout/out/gsm
                  OutputPrefix          = test_gsm_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_gsm_
                  TempDataPath          = ./data/outcollect/settlement/backout/out/gsm
                  TempDataPrefix        = test.gsm.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of BackOutOnlyTELOutput 

          #--------------------------------------------------------------------
          # The /service/ip/gprs output stream for BackOutOnly
          #--------------------------------------------------------------------
          GPRSOutput
          {
            ModuleName = OUT_GenericStream

            ProcessType = BACKOUT_PIPELINE
            EventType = /event/delayed/session/gprs/roaming
            Module
            {
              Grammar = ./formatDesc/Formats/Solution42/V670_EVENT_LOADER_OutGrammar.dsc
              DeleteEmptyStream = True #defaults to true

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/backout/out/gprs
                  OutputPrefix          = test_gprs_
                  OutputSuffix          = .out
                  TempPrefix            = tmptest_gprs_
                  TempDataPath          = ./data/outcollect/settlement/backout/out/gprs
                  TempDataPrefix        = test.gprs.tmp.
                  TempDataSuffix        = .data
                  Replace               = TRUE
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of BackOutOnlyGPRSOutput 
         
          #--------------------------------------------------------------------
          # SuspenseCreateOutput stream
          #--------------------------------------------------------------------
          SuspenseCreateOutput
          {
            ModuleName = OUT_GenericStream
            EventType = /suspended_usage
            Module
            {
              Grammar = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageCreationGrammar.dsc
              DeleteEmptyStream = True
              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/backout/reject
                  OutputPrefix          = suspense_create_
                  OutputSuffix          = .out
                  TempPrefix            = tmpsuspense_create_
                  TempDataPath          = ./data/outcollect/settlement/backout/reject
                  TempDataPrefix        = susp.create.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of SuspenseCreateOutput
 
          #--------------------------------------------------------------------
          # SuspenseUpdateOutput stream
          #--------------------------------------------------------------------
          SuspenseUpdateOutput
          {
            ModuleName = OUT_GenericStream
            EventType = /tmp_suspended_usage

            Module
            {
              Grammar = ./formatDesc/Formats/SuspenseHandling/SuspendedUsageUpdateGrammar.dsc
              DeleteEmptyStream = True

              OutputStream
              {
                ModuleName = EXT_OutFileManager
                Module
                {
                  OutputPath            = ./data/outcollect/settlement/backout/reject
                  OutputPrefix          = suspense_update_
                  OutputSuffix          = .out
                  TempPrefix            = tmpsuspense_update_
                  TempDataPath          = ./data/outcollect/settlement/backout/reject
                  TempDataPrefix        = susp.update.tmp.
                  TempDataSuffix        = .data
                  Replace               = True
                  AppendSequenceNumber  = False
                }
              }
            }
          } # end of SuspenseUpdateOutput          
        } # end of OutputCollection

        OutputLog
        {
          FilePath        = ./log/stream
          FileName        = TAPSettlementBkOutPipeline
          FilePrefix      = Stream_
          FileSuffix      = .log

          SuppressErrors
          {
            ERR_SPEC_VERSION_INVALID
            ERR_RELEASE_VERSION_INVALID
          }
        }
        
        SequenceGeneration = Unit

        EdrTraceEnabled = False
        EdrTrace
        {
            TraceLog
            {
                 FilePath   = ./log/edrLog
                 FileName   = edrTraceLog
                 FilePrefix = log_
                 FileSuffix = .log
            }

            TraceStartPoint =  Input
            TraceEndPoint   = Output

        } # END EdrTrace


      } # end of Output

    } # END Settlement_BCKOUT

    TAPInProcessingPipeline
    {
      Active                      = True
      
      CountryCode                 = 49
      MobileCountryCode           = 262
      #NationalAccessCode          = 0
      #InternationalAccessCode     = 00
      InternationalAccessCodeSign = +
      NetworkDestinationCode      = 172
      RejectStream                = RapOutput
      
      TransactionManager
      {
        RedoEnabled       = True
        SingleTransaction = False
        WriteToLogEnabled = True
        BinaryLogFileName = ./tam/binaryLogFileTAPInProcessingPipeline.dat
      }
      
      EdrFactory 
      {
        DataConnection = ifw.DataPool.Login 
        Description = ./formatDesc/Formats/TAP3-NG/containerDesc.dsc
        UsageStatistic = ./log/statistic/edrStatisticTAPInProcessingPipeline.txt
        EdrVersionDataConnection = ifw.DataPool.LoginInfranet
      }

      DataDescription
      {
        Standard
        {
          ModuleName = Standard
          Module
          {
            StreamFormats
            {
              Generic = ./formatDesc/Formats/TAP3-NG/GenericBlocks.dsc
              TAP3    = ./formatDesc/Formats/TAP3-NG/TAP_0312_Blocks.dsc
              RAP     = ./formatDesc/Formats/TAP3-NG/RAP_0105_Blocks.dsc
              SOL42   = ./formatDesc/Formats/Solution42/SOL42_V670_REL.dsc
            }

            InputMapping
            {          
            }

            OutputMapping
            {
              SOL42 = ./formatDesc/Formats/Solution42/SOL42_V670_REL_OutMap.dsc
            }
          }
        }
      }

      PipelineLog 
      { 
        ModuleName = LOG
        Module 
        { 
          ITO 
          { 
            WriteMessageKey = True
            FilePath        = ./log/pipeline
            FileName        = pipeline_TAPInProcessingPipeline.log
            ProcessName     = ifw
            MessageGroup    = IFW
            ShowOriginator  = True
          }

          Buffer 
          { 
            Size = 500
          } 
        } 
      }

      InputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }

      OutputBuffer
      {
        BlockTransfer = False
        Size = 1
        BlockSize = 1
      }
      
      #------------------------------------------------------------------------
      # Input section
      #------------------------------------------------------------------------
      Input
      {
        UnitsPerTransaction = 1

        InputModule
        {
          ModuleName = INP_GenericStream
          Sequencer = SEQ_GEN_RAPOUT
          UseSenderAsSeqGenKey = True
          RapOutStream = RapOutput

          Module
          {
            DefaultOutput = TAPInProcessingOutput
            Grammar       = ./formatDesc/Formats/TAP3-NG/TAP_0312_InGrammar.dsc

            InputStream
            {
              ModuleName = EXT_InFileManager
              Module
              {
                InputPath   = ./data/incollect/tapin/in
                InputPrefix = CD
                #InputPrefix = test_
                #InputSuffix = .edr
 
                DonePath    = ./data/incollect/tapin/done
                DonePrefix  = test_TAPInProcessingPipeline_
                DoneSuffix  = .done
           
                ErrorPath   = ./data/incollect/tapin/error
                ErrorPrefix = test_TAPInProcessingPipeline_
                ErrorSuffix = .err

                TempPrefix  = temp_TAPInProcessingPipeline_
                Replace     = True
                InputDirEmptyTimeout = 10
              }
            }
          }
        }
      }

      #------------------------------------------------------------------------
      # Function section
      #------------------------------------------------------------------------
      Functions 
      {
        Processing
        {
          FunctionPool
          {

            #----------------------------------------------------------------
            # TAP Validation IScript
            #----------------------------------------------------------------
            ValidationScript
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  ValidationScript
                  {
                     FileName = ./iScriptLib/iScriptLib_Roaming/ISC_TAP_0312_Validations.isc
                  }
                }
              }
            }

            #----------------------------------------------------------------
            # Business Mapping
            #----------------------------------------------------------------
            BusinessMapping
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  BusinessMapping
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_TAP_0312_InMap.isc 
                  }
                }
              }
            }


            #----------------------------------------------------------------
            # Update TAP Info
            #----------------------------------------------------------------
            UpdateTapInfo_Tapin
            {
              ModuleName = FCT_IScript
              Module
              {
                Active = True
                Source = FILE
                Scripts
                {
                  UpdateTapInfo_Tapin
                  {
                    FileName = ./iScriptLib/iScriptLib_Roaming/ISC_UpdateTapInfo_Tapin.isc
                    DatabaseConnection = ifw.DataPool.Login
                  }
                }
              }
            }


            #--------------------------------------------------
            # Rejection
            #--------------------------------------------------
            Rejection
            {
              ModuleName = FCT_Reject
              Module
              {
                Active           = True
                NotifyOnReject   = True
                UseRejectStream  = True
                MinErrorSeverity = 1
                StreamMap
                {
                  garbage      = DevNull
                }
              }
            }

