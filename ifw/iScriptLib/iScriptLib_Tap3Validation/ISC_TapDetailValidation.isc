//-----------------------------------------------------------------------------
// validateHasCBDBlock
//
// This function will be used to validate if this block has any
// charge breakdown blocks.
//-----------------------------------------------------------------------------
function validateHasCBDBlock
{
  if (debug)
  {
    logStdout("validateHasCBDBlock()\n");
  }

  if (edrNumDatablocks(DETAIL.ASS_CBD) == 0)
  {
    const String ruleID     = "Missing ChargeBreakDown block";
    const String severe     = "severe";
    const String arrayIndex = "-1";
    const String offset     = "-1";
    String tag;
    String depth;

    // offset = longToStr(edrFieldTokenBytePos(DETAIL.ASS_CBD));
    switch (edrString(DETAIL.RECORD_TYPE))
    {
      case type_SCU:
      {
        tag   = "12";
        depth = "3";
        edrSetIsValidDetail(false);
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "34", tag, depth,
		offset, arrayIndex, ruleID);
        setAssociatedTapErr("ERR_TAP3_MISSING_CBD_BLOCK", LOG_MAJOR ,"34" ,tag ,depth);	
      }
      break;

      case type_MOC:
      case type_MTC:
      {
        tag   = "39";
        depth = "4";
        edrSetIsValidDetail(false);
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "32", tag, depth,
		offset, arrayIndex, ruleID);
        setAssociatedTapErr("ERR_TAP3_MISSING_CBD_BLOCK", LOG_MAJOR ,"32" ,tag ,depth);	
      }
      break;

      case type_GPRS_SG:
      case type_GPRS_GG:
      {
        tag   = "121";
        depth = "4";
        edrSetIsValidDetail(false);
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "32", tag, depth,
		offset, arrayIndex, ruleID);
        setAssociatedTapErr("ERR_TAP3_MISSING_CBD_BLOCK", LOG_MAJOR ,"32" ,tag ,depth);	
      }
      break;

      case type_LOCN:
      {
        tag   = "382";
        depth = "4";
        edrSetIsValidDetail(false);
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "31", tag, depth,
		offset, arrayIndex, ruleID);
        setAssociatedTapErr("ERR_TAP3_MISSING_CBD_BLOCK", LOG_MAJOR ,"31" ,tag ,depth);	
      }
      break;
    }
  }
}


