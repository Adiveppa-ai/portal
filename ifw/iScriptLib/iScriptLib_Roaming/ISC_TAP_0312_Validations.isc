  childContext = myContext + "." + "chargedParty";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateChargedParty ( myContext, nMyIndices, "chargedParty", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapFileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "simToolkitIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateSimToolkitIndicator ( myContext, nMyIndices, "simToolkitIndicator", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "geographicalLocation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateGeographicalLocation ( myContext, nMyIndices, "geographicalLocation", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "locationArea";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateLocationArea ( myContext, nMyIndices, "locationArea", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "cellId";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateCellId ( myContext, nMyIndices, "cellId", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "eventReference";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateEventReference ( myContext, nMyIndices, "eventReference", 0, errorContext );                 
  }
  else
  {
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Mobile Session", "434", "10", "Syntax Error");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error"); 
     edrSetIsValidDetail(false);
  }  
                                                                                                             
  childContext = myContext + "." + "recEntityCodeList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateRecEntityCodeList ( myContext, nMyIndices, "recEntityCodeList", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "serviceStartTimestamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateServiceStartTimestamp ( myContext, nMyIndices, "serviceStartTimestamp", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "causeForTerm";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateCauseForTerm ( myContext, nMyIndices, "causeForTerm", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalCallEventDuration";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateTotalCallEventDuration ( myContext, nMyIndices, "totalCallEventDuration", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "nonChargedParty";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateNonChargedParty ( myContext, nMyIndices, "nonChargedParty", 0, errorContext );                 
  }
  else
  {
    if (mobileSessionServiceType == 1) //MO Voice over LTE
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Mobile Session", "434", "40", "Group Non Charged Party missing within group and Mobile Session Service is MO Voice over LTE");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "40", errorContext, "0", "-1", "-1", "","Group Non Charged Party missing within group and Mobile Session Service is MO Voice over LTE"); 
      edrSetIsValidDetail(false);
    }
  }    

  childContext = myContext + "." + "requestedDestination";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateRequestedDestination ( myContext, nMyIndices, "requestedDestination", 0, errorContext );
  }

  childContext = myContext + "." + "sessionChargeInfoList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateSessionChargeInfoList ( myContext, nMyIndices, "sessionChargeInfoList", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            


/******************************************************************************************************************************/



/******************************************************************************************************************************
 * This function is used to process Detail EDR record. This function will also validate TransferBatch, it will raise error code
 * 34 for TransferBatch.
 ******************************************************************************************************************************/ 
function onDetailEdr
{
  String myContext = "DETAIL";
  Long  nMyIndices = 0;
  String errorContext;
  String childContext;
  contentChargingPoint           = 0;
  advisedChargeInfoCount         = 0;
  lastTotalCallEventDuration     = 0;
  lastResponseTime               = 0;
  lastLCSTransactionStatus       = 0;
  mobileSessionServiceType       = 0;
  messagingEventServiceType      = 0;
  networkElementType             = 0;
  lastCauseForTerm               = 0;
  callEventStartUtcTimeOffset    = "";
  chargingUtcTimeOffset          = "";
  lastCompletionTimeStamp        = "";
  lastDepositTimeStamp           = "";
  lastOrderPlacedTimeStamp       = "";
  lastRequestedDeliveryTimeStamp = "";
  lastActualDeliveryTimeStamp    = "";
  lastChargeDetailTimeStamp      = "";
  lastCallEventStartTimeStamp    = "";
  lastChargingTimeStamp          = "";
  lastLcsRequestTimestamp        = "";
  hasChargeRefund = false;
  callEventDetailsPresent = true;
  callIndicatesInternational = false;
  completionUtcTimeOffsetCodeIsMissing = false;
  depositUtcTimeOffsetCodeIsMissing = false;
  orderPlacedUtcTimeOffsetCodeIsMissing = false;
  requestedDeliveryUtcTimeOffsetCodeIsMissing = false;
  actualDeliveryUtcTimeOffsetCodeIsMissing = false;
  WiFiNetworkUsage = false;
  errorContext = "1,3";

  endLocalTimeStamp = "";
  endUTCTimeOffset = "";
  String dupTag = "";
  PGWRecEntityCode = false ;
  SGWRecEntityCode = false ;
  GGSNRecEntityCode = false ; 

  childContext = myContext + "." + "mobileOriginatedCall";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMobileOriginatedCall ( myContext, nMyIndices, "mobileOriginatedCall", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }

  childContext = myContext + "." + "mobileTerminatedCall";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMobileTerminatedCall ( myContext, nMyIndices, "mobileTerminatedCall", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
 
  childContext = myContext + "." + "supplServiceEvent";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateSupplServiceEvent ( myContext, nMyIndices, "supplServiceEvent", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
 
  childContext = myContext + "." + "serviceCentreUsage";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    if ( messageDescriptionInfoListIsMissing == true)
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "TransferBatch", "1", "34", "Group Message Description Information not present and a Service Centre Usage is present within Transfer Batch");
      messageDescriptionInfoListIsMissing = false;
    }
    validateServiceCentreUsage ( myContext, nMyIndices, "serviceCentreUsage", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
 
  childContext = myContext + "." + "gprsCall";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsCall ( myContext, nMyIndices, "gprsCall", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
 
  childContext = myContext + "." + "contentTransaction";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateContentTransaction ( myContext, nMyIndices, "contentTransaction", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
 
  childContext = myContext + "." + "locationService";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLocationService ( myContext, nMyIndices, "locationService", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
 
  childContext = myContext + "." + "messagingEvent";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMessagingEvent ( myContext, nMyIndices, "messagingEvent", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
  
  childContext = myContext + "." + "mobileSession";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMobileSession ( myContext, nMyIndices, "mobileSession", 0, errorContext );
    callEventDetailCount = callEventDetailCount + 1;
  }
  
   switch(edrString(DETAIL.RECORD_TYPE))
   {
     case type_MOC:
     {
           dupTag = "9";
     }
     break;

     case type_MTC:
     {
       dupTag = "10";
     }
     break;

     case type_MSS:
     {
       dupTag = "11";
     }
     break;

     case type_SCU:
     {
       dupTag = "12";
     }
     break;

     case type_GPRS:
     {
       dupTag = "14";
     }
     break;

     case type_CONT:
     {
       dupTag = "17";
     }
     break;

     case type_LOCN:
     {
       dupTag = "297";
     }
     break;
	 
	 //TODO: Check this
	 case type_MSG:
     {
       dupTag = "433";
     }
     break;
	 
	 case type_MSESS:
     {
       dupTag = "434";
     }
     break;
  }
  if(dateDiff(availableDate,strToDate(endLocalTimeStamp)) > exceptionalTimeScale )
  {
     edrAddError("ERR_TAP3_RET", 3, "severe", "261", dupTag, "2", "0", "-1","", 
		"Call older than allowed by BARG in 'Exceptional Situations' in BARG PRD BA.08");
     edrAddError("ERR_TAP3_SEVERE", 3, "ValidationRule ", dupTag, "261", 
		"Call older than allowed by BARG in 'Exceptional Situations' in BARG PRD BA.08");
     edrSetIsValidDetail(false);
  }
  else if(dateDiff(availableDate,strToDate(endLocalTimeStamp)) > standardTimeScale )
  {
     edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ValidationRule", dupTag, "260", 
	"Call old. Call is older than 'Standard Timescale' specified in BARG PRD BA.08. ");
  }
}

/***************************************************************************
 * function initializeForNewHeader
 ***************************************************************************/

function initializeForNewHeader
{
  Long i;
  taxationListIsMissing           = false; 
  discountListIsMissing           = false;  
  currencyConversionListIsMissing = false;
  notificationFilePresent         = false;
  accountingInfoIsMissing         = false;
  callEventDetailsPresent         = false;
  auditControlInfoPresent         = false;
  messageDescriptionInfoListIsMissing = false;
  callEventDetailCount            = 0;
  detailTimeStampEntries          = 0;
 

  arrayClear( discountCode );
  arrayClear( discountApplied_Type );
  arrayClear( discountApplied );
  arrayClear( exchangeRateCode );
  arrayClear( numberOfDecimalPlaces );
  arrayClear( exchangeRate );
  
  // Clear TAX related DATA
  arrayClear( taxCode );
  arrayClear( taxType );
  arrayClear( taxRate );
  arrayClear( chargeType );
  taxCodeIsDuplicate = false;
  taxTypeIsDuplicate = false;
  taxRateIsDuplicate = false;
  chargeTypeIsDuplicate = false;
  
  // Clear RecEntity Information related DATA
  arrayClear( recEntityCode );
  arrayClear( recEntityType );
  arrayClear( recEntityId );
  recEntityCodeIsDuplicate = false;
  recEntityTypeIsDuplicate = false;
  
  // Clear Message Description Information related DATA
  arrayClear( messageDescriptionCode );
  arrayClear( messageDescription );
  messageDescriptionCodeIsDuplicate = false;
  
  // Clear UTC Time Offset Information related DATA
  arrayClear( utcTimeOffsetCode );
  arrayClear( utcTimeOffset );
  utcTimeOffsetIsDuplicate = false;
  
  for( i = 0; i < 100; i = i + 1 )
  {
    //Initializing Array with -1 to overwrite the default value 0
    exchangeRateCode[ i ] = -1;
    discountCode[ i ] = -1;
    utcTimeOffsetCode[ i ] = -1;
  }
  
  for( i = 0; i < 1000; i = i + 1 )
  {
    //Initializing Array with -1 to overwrite the default value 0
    messageDescriptionCode[ i ] = -1;
    taxCode[ i ] = -1;
  }
  
  for( i = 0; i <= 10000; i = i + 1 )
  {
    //Initializing Array with -1 to overwrite the default value 0
    recEntityCode[ i ] = -1;
  }
}


/******************************************************************************************************************************
 * This function is used to process Header EDR record. This function will also validate TransferBatch, it will raise error code
 * 30, 32 for TransferBatch.
 ******************************************************************************************************************************/

function onHeaderEdr
{
  String myContext = "HEADER";
  Long  i;
  Long  nMyIndices = 0;
  String childContext;
  String errorContext;
  
  String originalBlock;
  Long startIndex;
  Long endIndex;

  
  initializeForNewHeader();  

  if ( edrLong(HEADER.BATCH_CTRL_INFO_END_INDEX) != 0 )
  {
    startIndex = edrLong(HEADER.BATCH_CTRL_INFO_START_INDEX);
    endIndex   = edrLong(HEADER.BATCH_CTRL_INFO_END_INDEX);
    originalBlock = "";
    for( i = startIndex; i <= endIndex; i = i + 1 )
    {
      originalBlock = originalBlock + edrTokenString(i);
    }
    BatchControlInfoStr = strStrToHexStr(originalBlock);
  }

  if ( edrLong(HEADER.ACCOUNTING_INFO_END_INDEX) != 0 )
  {
    startIndex = edrLong(HEADER.ACCOUNTING_INFO_START_INDEX);
    endIndex   = edrLong(HEADER.ACCOUNTING_INFO_END_INDEX);
    originalBlock = "";
    for( i = startIndex; i <= endIndex; i = i + 1 )
    {
      originalBlock = originalBlock + edrTokenString(i);
    }
    AccountingInfoStr = strStrToHexStr(originalBlock);
  }

  if ( edrLong(HEADER.NETWORK_INFO_END_INDEX) != 0 )
  {
    startIndex = edrLong(HEADER.NETWORK_INFO_START_INDEX);
    endIndex   = edrLong(HEADER.NETWORK_INFO_END_INDEX);
    originalBlock = "";
    for( i = startIndex; i <= endIndex; i = i + 1 )
    {
      originalBlock = originalBlock + edrTokenString(i);
    }
    NetworkInfoStr = strStrToHexStr(originalBlock);
  }

  if ( edrLong(HEADER.MESSAGE_DESCRIPTION_END_INDEX) != 0 )
  {
    startIndex = edrLong(HEADER.MESSAGE_DESCRIPTION_START_INDEX);
    endIndex   = edrLong(HEADER.MESSAGE_DESCRIPTION_END_INDEX);
    originalBlock = "";
    for( i = startIndex; i <= endIndex; i = i + 1 )
    {
      originalBlock = originalBlock + edrTokenString(i);
    }
    MessageDescriptionStr = strStrToHexStr(originalBlock);
  }


  childContext = myContext + "." + "notification";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    errorContext = "2";
    notificationFilePresent = true;
    validateNotification ( myContext, nMyIndices, "notification", 0, errorContext );
  }

  childContext = myContext + "." + "batchControlInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    errorContext = "1";
    validateBatchControlInfo ( myContext, nMyIndices, "batchControlInfo", 0, errorContext );
  }
  else if( notificationFilePresent == false )
  {
    
    rollbackReason = "TransferBatch,1,30";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferBatch", "1", "30", "Mandatory group Batch Control Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "1", "0", "-1", "-1", "","Mandatory group Batch Control Information missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

  childContext = myContext + "." + "accountingInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    errorContext = "1";
    validateAccountingInfo ( myContext, nMyIndices, "accountingInfo", 0, errorContext );
  }
  else
  {
    accountingInfoIsMissing = true;
  }

  childContext = myContext + "." + "networkInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    errorContext = "1";
    validateNetworkInfo ( myContext, nMyIndices, "networkInfo", 0, errorContext );
  }
  else if( notificationFilePresent == false )
  {
    
    rollbackReason = "TransferBatch,1,32";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferBatch", "1", "32", "Mandatory group Network Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "1", "0", "-1", "-1", "","Mandatory group Network Information missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

  childContext = myContext + "." + "messageDescriptionInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    errorContext = "1";
    validateMessageDescriptionInfoList ( myContext, nMyIndices, "messageDescriptionInfo", 0, errorContext );
  }
  else
  {
    messageDescriptionInfoListIsMissing = true;
  }
}

/******************************************************************************************************************************
 * This function is used to process Trailer EDR record. This function will also validate TransferBatch, it will raise error code
 * 35, 36 for TransferBatch.
 ******************************************************************************************************************************/

function onTrailerEdr
{
  String errorContext;
  String myContext = "TRAILER";
  Long  nMyIndices = 0;
  String childContext;
  
  String originalBlock;
  Long startIndex;
  Long endIndex;
  Long i;
  errorContext = "1";
  auditControlInfoPresent = true;

  if ( (callEventDetailsPresent == false) and (notificationFilePresent == false) )
  {
    rollbackReason = "TransferBatch,1,35";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferBatch", "1", "35", "Group Call Event Details not present within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "35", "1", "0", "-1", "-1","", "Group Call Event Details not present within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

  if ( edrLong(TRAILER.AUDIT_CONTROL_INFO_END_INDEX) != 0 )
  {
    startIndex = edrLong(TRAILER.AUDIT_CONTROL_INFO_START_INDEX);
    endIndex   = edrLong(TRAILER.AUDIT_CONTROL_INFO_END_INDEX);
    originalBlock = "";
    for( i = startIndex; i <= endIndex; i = i + 1 )
    {
      originalBlock = originalBlock + edrTokenString(i);
    }
    AuditControlInfoStr = strStrToHexStr(originalBlock);
  }
  
  childContext = myContext + "." + "auditControlInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateAuditControlInfo ( myContext, nMyIndices, "auditControlInfo", 0, errorContext );
  }
  else if( notificationFilePresent == false )
  {
    rollbackReason = "TransferBatch,1,36";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferBatch", "1", "36", "Mandatory group AUDIT Control Information missing from group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "36", "1", "0", "-1", "-1","", "Mandatory group AUDIT Control Information missing from group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

  resetGlobalVariables();
  
}

/*************************************************************************
 * getTapFileName()
 *
 * This function will be used to find the tap file name
 ************************************************************************/
function getTapFileName
{

  tapFileName = edrString(INTERNAL.STREAM_NAME);

}

/*************************************************************************
 * initBegin()
 ************************************************************************/
function initBegin
{
  tapFileName = "";
}

/*************************************************************************
 * Process Begin EDR record
 ************************************************************************/
function onBeginEdr
{
  initBegin();
  getTapFileName();

} // end onBeginEdr

/*************************************************************************
 * This function is used to process End EDR record.This function will also 
 * validate TransferBatch, it will raise error code 36 for TransferBatch.
 ************************************************************************/

function onEndEdr
{
 if( auditControlInfoPresent == false and notificationFilePresent == false )
 {
    rollbackReason = "TransferBatch,1,36";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferBatch", "1", "36", "Mandatory group AUDIT Control Information missing from group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "36", "1", "0", "-1", "-1","", "Mandatory group AUDIT Control Information missing from group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
 }
}


/***************************************************************************
 * function BEGIN
 ***************************************************************************/
function BEGIN
{

