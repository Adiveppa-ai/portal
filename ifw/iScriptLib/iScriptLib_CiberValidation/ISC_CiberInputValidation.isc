//==============================================================================
// Adding Infranet Billing Record to Basic Detail Record
//==============================================================================
function onHeaderEdr
{
  //----------------------------------------------------------------------------
  // initialize global variables
  //----------------------------------------------------------------------------
  init();
//  string	batchcontents;
// string	currencyType;
  batchcontents = edrString(HEADER.BATCH_CONTENTS);
  if (edrString(HEADER.CIBER_RECORD_TYPE) == "01"){
    returnIndicator = edrString(HEADER.RETURN_INDICATOR);
  }
  currencyType = edrString(HEADER.CURRENCY);

}

//==============================================================================
// Adding Infranet Billing Record to Basic Detail Record
//==============================================================================
function onDetailEdr
{
  //----------------------------------------------------------------------------
  // initialize global variables
  //----------------------------------------------------------------------------
//  init();

  //---------------------------------------------------------------------------
  // get the CIBER record 
  //---------------------------------------------------------------------------
  if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "22") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber22Record();
    }
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "32") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber32Record();
    }
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "42") {
    if (batchcontents == "1") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","092",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber42Record();
    }
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "52") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber52Record();
    }
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "10") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber10Record();
    }
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "11") {
    if (batchcontents == "1") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","092",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber11Record();
    }
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "20") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber20Record();
    } 
  }

  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "30") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber30Record();
    }
  }
  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "50") {
    if (batchcontents == "2") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","19","093",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber50Record();
    }
  }
  else if (edrString(DETAIL.ASS_CIBER_EXT.CIBER_RECORD_TYPE, 0) == "70") {
    if (batchcontents == "2" or batchcontents == "1") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","20","200",
		"CIBER25.ASS_CIBER_EXT.CIBER_RECORD_TYPE");
    }
    else {
      validateCiber70Record();
    }
  }

} // end onDetailEdr + end iScript
