	$PIN_CONF_TBLSPACEX0
	$PIN_CONF_STORAGE_MED ;

create unique index i_cmt_reference_t on cmt_reference_t ( input_id, poid_id, obj_type )
        $PIN_CONF_TBLSPACEX0
        $PIN_CONF_STORAGE_MED ;
		
