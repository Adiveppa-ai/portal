/***************************************************************************
 * Function To add the UTC Time Offset to Local Timestamp.
 ***************************************************************************/
function String addUTCToLocalTimestamp( String localTimestamp, String utcOffset)
{
  String utcSign = "";
  Long utcHour = -1;
  Long utcMinute = -1;

  utcSign = strSubstr(utcOffset, 0, 1);
  utcHour = strToLong(strSubstr(utcOffset, 1, 2));
  utcMinute = strToLong(strSubstr(utcOffset, 3, 2));
 
   if ( utcSign == "+" )
  {
    utcHour = utcHour * -1;
    utcMinute = utcMinute * -1;
  }

  localTimestamp = dateToStr(dateAdd(strToDate(localTimestamp),0,0,0,utcHour,utcMinute));

  return localTimestamp;
}

/***************************************************************************
 * Function To Validate Out Of Range Error
 ***************************************************************************/
function Bool validateOOR( String edrValueStr, String upperLimitStr, String lowerLimitStr, String oorType)
{
  switch ( oorType )
  {
 
    case "INTEGER_TYPE" :
    {
      Long edrValue   = strToLong(edrValueStr);
      Long upperLimit = strToLong(upperLimitStr);
      Long lowerLimit = strToLong(lowerLimitStr);

      if( edrValue < lowerLimit or edrValue > upperLimit )
      {
        return true;
      }
      else
      {
        return false;
      }
    }
    break;
 
    case "DOUBLE_TYPE" :
    {
      Decimal edrValue   = strToDecimal(edrValueStr);
      Decimal upperLimit = strToDecimal(upperLimitStr);
      Decimal lowerLimit = strToDecimal(lowerLimitStr);
      if( edrValue < lowerLimit or edrValue > upperLimit )
      {
        return true;
      }
      else
      {
        return false;
      }
    }
    break;
 
    default:
    { 
      return false;
    }
  }
}

/***************************************************************************
 * Function To Validate Syntax Error
 ***************************************************************************/
function Bool validateSyntax( String edrValueStr, String syntaxErrorType )
{
  switch ( syntaxErrorType )
  {
    case "CHECK_NUM" :
    {
      if ( (strSearchRegExpr(edrValueStr, "[^0-9]") >= 0) or (strLength(edrValueStr) == 0) )
      {
        return true;
      }
      return false;
    }
    break;
    case "CHECK_ALPHA_UPPER" :
    {
      if ( (strSearchRegExpr(edrValueStr, "[^A-Z]") >= 0) or (strLength(edrValueStr) == 0) )
      {
        return true;
      }
      return false;
    }
    break;
    case "CHECK_ALPHA_LOWER" :
    {
      if ( (strSearchRegExpr(edrValueStr, "[^a-z]") >= 0) or (strLength(edrValueStr) == 0) )
      {
        return true;
      }
      return false;
    }
    break;
    case "CHECK_ALPHANUMERIC" :
    {
      if ( (strSearchRegExpr(edrValueStr, "[^0-9a-zA-Z]") >= 0) or (strLength(edrValueStr) == 0) )
      {
        return true;
      }
      return false;
    }
    break;
    case "CHECK_ALPHANUMERIC_UPPER" :
    {
      if ( (strSearchRegExpr(edrValueStr, "[^0-9A-Z]") >= 0) or (strLength(edrValueStr) == 0) )
      {
        return true;
      }
      return false;
    }
    break;
    default:
    {
      return false;
    }
  }
}

