/******************************************************************************************************************************
 * This function will validate CamelServiceUsed. It will raise error code 33 for CamelServiceUsed.
 ******************************************************************************************************************************/
 
function validateCamelServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",57";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  camelServiceLevelIsMissing = false;
  exchangeRateCodeIsMissing = false;
 
  childContext = myContext + "." + "camelServiceLevel";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCamelServiceLevel ( myContext, nMyIndices, "camelServiceLevel", 0, errorContext );
  }
  else
  {
    camelServiceLevelIsMissing = true;
  }
 
  childContext = myContext + "." + "camelServiceKey";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCamelServiceKey ( myContext, nMyIndices, "camelServiceKey", 0, errorContext );
  }
  else 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "CamelServiceUsed", "57", "33", "Missing CAMEL Service Key");
  }

 
  childContext = myContext + "." + "defaultCallHandling";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDefaultCallHandlingIndicator ( myContext, nMyIndices, "defaultCallHandling", 0, errorContext );
  }
 
  childContext = myContext + "." + "exchangeRateCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateExchangeRateCode ( myContext, nMyIndices, "exchangeRateCode", 0, errorContext );
  }
  else
  {
    exchangeRateCodeIsMissing = true;
  }
 
  childContext = myContext + "." + "taxInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTaxInformationList ( myContext, nMyIndices, "taxInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "discountInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateDiscountInformation ( myContext, nMyIndices, "discountInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "camelInvocationFee";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCamelInvocationFee ( myContext, nMyIndices, "camelInvocationFee", 0, errorContext );
  }
 
  childContext = myContext + "." + "threeGcamelDestination";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateThreeGcamelDestination ( myContext, nMyIndices, "threeGcamelDestination", 0, errorContext );
  }
 
  childContext = myContext + "." + "cseInformation";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCseInformation ( myContext, nMyIndices, "cseInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

