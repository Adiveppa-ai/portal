/******************************************************************************************************************************
 * This function will validate CallingNumber. It will raise error code 10, 20 for CallingNumber.
 ******************************************************************************************************************************/
 
function validateCallingNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",405";

  Bool   countryCodeFound = false;
  Long   i;

  String lastCallingNumber = edrStringEx(myContext, indices, nParentIndices);
  for( i = 0 ; i < numOfCountryCode and countryCodeFound == false ; i = i + 1 )
  {
    if (strStartsWith(lastCallingNumber, countryCodeArray[i]))
    {
      countryCodeFound = true;
    }
  }

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true )   
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Calling Number", "405", "10", "Calling Number Syntax Error"); 
  }
  else if( countryCodeFound == false and validateSyntax(lastCallingNumber, "CHECK_NUM") == false )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Calling Number", "405", "20", "Number not in international format");
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function calls the validation functions validateCallingNumber, validateClirIndicator and validateSMSOriginator.
 ******************************************************************************************************************************/

function validateCallOriginator ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",41";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "callingNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallingNumber ( myContext, nMyIndices, "callingNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "clirIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateClirIndicator ( myContext, nMyIndices, "clirIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "sMSOriginator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSMSOriginator ( myContext, nMyIndices, "sMSOriginator", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MtBasicCallInformation. It will raise error code 30, 31, 32 for MtBasicCallInformation.
 ******************************************************************************************************************************/
 
function validateMtBasicCallInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",153";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "chargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeableSubscriber ( myContext, nMyIndices, "chargeableSubscriber", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MtBasicCallInformation", "153", "30", "Mandatory group Chargeable Subscriber missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Mandatory group Chargeable Subscriber missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "callOriginator";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCallOriginator ( myContext, nMyIndices, "callOriginator", 0, errorContext );
  }
 
  childContext = myContext + "." + "originatingNetwork";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateOriginatingNetwork ( myContext, nMyIndices, "originatingNetwork", 0, errorContext );
  }
 
  childContext = myContext + "." + "callEventStartTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCallEventStartTimeStamp ( myContext, nMyIndices, "callEventStartTimeStamp", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MtBasicCallInformation", "153", "31", "Mandatory item Call Event Start Timestamp missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory item Call Event Start Timestamp missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "totalCallEventDuration";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalCallEventDuration ( myContext, nMyIndices, "totalCallEventDuration", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MtBasicCallInformation", "153", "32", "Mandatory item Total Call Event Duration missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Mandatory item Total Call Event Duration missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "simToolkitIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSimToolkitIndicator ( myContext, nMyIndices, "simToolkitIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "causeForTerm";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCauseForTerm ( myContext, nMyIndices, "causeForTerm", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MobileTerminatedCall. It will raise error code 30, 31, 32 for MobileTerminatedCall.
 ******************************************************************************************************************************/
 
function validateMobileTerminatedCall ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",10";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "basicCallInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateMtBasicCallInformation ( myContext, nMyIndices, "basicCallInformation", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileTerminatedCall", "10", "30", "Mandatory group MT Basic Call Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group MT Basic Call Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "locationInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLocationInformation ( myContext, nMyIndices, "locationInformation", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileTerminatedCall", "10", "31", "Mandatory group Location Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory group Location Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "equipmentIdentifier";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateImeiOrEsn ( myContext, nMyIndices, "equipmentIdentifier", 0, errorContext );
  }
 
  childContext = myContext + "." + "basicServiceUsedList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateBasicServiceUsedList ( myContext, nMyIndices, "basicServiceUsedList", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileTerminatedCall", "10", "32", "Mandatory group Basic Service Used missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Mandatory group Basic Service Used missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "camelServiceUsed";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCamelServiceUsed ( myContext, nMyIndices, "camelServiceUsed", 0, errorContext );
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ThirdPartyNumber. It will raise error code 20 for ThirdPartyNumber.
 ******************************************************************************************************************************/
 
function validateThirdPartyNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",403";
  Bool countryCodeFound = false;
  Long j;

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ThirdPartyNumber", "403", "10", "Syntax error");
  }
  else 
  {  
    for( j = 0 ; j < numOfCountryCode and countryCodeFound == false ; j = j + 1 )
    {
      if ( strStartsWith(edrStringEx(myContext, indices, nParentIndices), countryCodeArray[j]) == true )
      {
        countryCodeFound = true;
      }
    }
    if ( countryCodeFound == false )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ThirdPartyNumber", "403", "20", "Number not represented in international format");
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

