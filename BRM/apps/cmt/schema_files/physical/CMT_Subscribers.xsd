	<xs:complexType name="ExemptionsArray">
		<xs:sequence>
			<xs:element name="CertNum" minOccurs="0" maxOccurs="1">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="60"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="End" type="dateTime-or-zero" minOccurs="0" maxOccurs="1" nillable="true"/>
			<xs:element name="Perc" type="xs:decimal" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Str" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Typ" type="ExemptionsType" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="Promotion">
		<xs:sequence>
			<xs:element name="PrmNm" type="PromotionName" minOccurs="0" maxOccurs="1"/>
			<xs:element name="CrtT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Eff" type="dateTime-or-zero"  minOccurs="1" maxOccurs="1"/>
			<xs:element ref="PrmExtn" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
		<xs:attribute name="id" type="Id" use="required"/>
		<xs:attribute name="type" type="xs:string" use="required"/>
		<xs:attribute name="global" type="xs:string" use="optional" default="true"/>
		<!-- global attribute signifies user permission to read or write the object -->
		<!-- type is the type of promotion like /profile/acct_extrating -->
	</xs:complexType>
	<xs:complexType name="Subscriptions">
		<xs:sequence>
			<xs:element name="ActSrv" type="Service" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="Service">
		<xs:sequence>
			<xs:element name="CWhn" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Log" minOccurs="1" maxOccurs="1" nillable="false">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="255"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Pass" minOccurs="1" maxOccurs="1" nillable="false">
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:maxLength value="255"/>
					</xs:restriction>
