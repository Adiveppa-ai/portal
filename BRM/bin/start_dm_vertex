#
# start_dm_vertex
#
# The underlying database (if any) must already be started
# when this script runs.
#
VERSION=15.0
PATH=/usr/bin:/bin

PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/dm_vertex

QM=${PINDIR}/bin/dm_vertex

QMDIR=${PINDIR}/sys/dm_vertex
QMLOG=${LOGDIR}/dm_vertex.log
QMPID=${LOGDIR}/dm_vertex.pid

if [ -r ${QMPID} ]; then
  /bin/ps -f -p `cat ${QMPID}` | grep ${QM} > /dev/null
  if [ $? -eq 0 ]; then
        echo "ERROR: dm_vertex is already running"
        exit 1
  fi
fi

if [ ! -x ${QM} ]; then
        echo "HELP: executable \"${QM}\" not found!"
        exit 1
fi       

if [ ! -d ${QMDIR} ]; then
        echo "HELP: ${QM} dir \"${QMDIR}\" not found!"
        exit 1
fi

if [ ! -d ${LOGDIR} ]; then
	mkdir -p ${LOGDIR}
	if [ $? -ne 0 ]; then
		echo "HELP: problems making QM LOGDIR \"${LOGDIR}\"!"
		exit 1
	fi
fi       

# XXX ought to save old log file, or check for > some-size...
( cd ${QMDIR} ;
  echo "started ${QM} at..." >> ${QMLOG}
  date >> ${QMLOG}
  ${QM} >> ${QMLOG} 2>&1 &
  echo $! > ${QMPID} ;
  chmod 640 ${QMLOG} ;
  chmod 640 ${QMPID} )

# use rc from qm startup
exit $?
