#
# start_dm_email
#
# The underlying database (if any) must already be started
# when this script runs.
#
VERSION=15.0
PATH=/usr/bin:/bin

DM_EMAIL_SMTP_SERVER=${DM_EMAIL_SMTP_SERVER}
PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/dm_email

QM=${PINDIR}/bin/dm_email

QMDIR=${PINDIR}/sys/dm_email
QMLOG=${LOGDIR}/dm_email.log
QMPID=${LOGDIR}/dm_email.pid

if [ -r ${QMPID} ]; then
  /bin/ps -f -p `cat ${QMPID}` | grep ${QM} > /dev/null
  if [ $? -eq 0 ]; then
        echo "ERROR: dm_email is already running"
        exit 1
  fi
fi

if [ ! -x ${QM} ]; then
        echo "HELP: executable \"${QM}\" not found!"
        exit 1
fi

if [ ! -d ${QMDIR} ]; then
        echo "HELP: ${QM} dir \"${QMDIR}\" not found!"
        exit 1
fi

if [ ! -d ${LOGDIR} ]; then
        mkdir -p ${LOGDIR}
        if [ $? -ne 0 ]; then
                echo "HELP: problems making QM LOGDIR \"${LOGDIR}\"!"
                exit 1
        fi
fi

# XXX ought to save old log file, or check for > some-size...
( cd ${QMDIR} ;
  echo "started ${QM} at..." >> ${QMLOG}
  date >> ${QMLOG}
  ${QM} >> ${QMLOG} 2>&1 &
  echo $! > ${QMPID} ;
  chmod 640 ${QMLOG} ;
  chmod 640 ${QMPID} )

# use rc from qm startup
exit $?