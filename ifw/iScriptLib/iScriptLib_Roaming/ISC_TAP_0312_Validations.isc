/******************************************************************************************************************************
 * This function will validate TaxValue. It will raise error code 20 for TaxValue.
 ******************************************************************************************************************************/
 
function validateTaxValue ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",397";

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TaxValue", "397", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }
 
  Long lastTaxValue = edrLongEx( myContext, indices, nParentIndices );
  if ( hasChargeRefund == false )
  {
    totalCalcTaxValue = totalCalcTaxValue + lastTaxValue;
  }
  else
  {
    totalCalcTaxRefund = totalCalcTaxRefund + lastTaxValue;
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TaxCode. It will raise error code 20, 100 for TaxCode.
 ******************************************************************************************************************************/

function validateTaxCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",212";
  Long i;

  if( ( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"999" , "0", "INTEGER_TYPE") == true )  and 
      ( strStartsWith(parentContext, "HEADER.accountingInfo") == true ) )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",20" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TaxCode", "212", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "212", "0", "-1", "-1","", "Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
    edrLongEx( myContext, indices, nParentIndices ) = -1;
    return;
  }

  lastCode = edrLongEx( myContext, indices, nParentIndices );

  if ( strStartsWith(parentContext, "HEADER") == true )
  { 
    if( taxCode[ lastCode ] == lastCode )
    {
      taxCodeIsDuplicate = true;
    }
    else
    {
      taxCode[ lastCode ] = lastCode;
    }    
  }
  else
  {
    if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"999" , "0", "INTEGER_TYPE") == true ) 
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TaxCode", "212", "11", "Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", "212", "0", "-1", "-1", "","Syntax Error");
      edrSetIsValidDetail(false);
	  return;
    }  
    if( taxCode[ lastCode ] != lastCode )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TaxCode", "212", "100", "Specified Tax Rate Code was not defined in the group Taxation");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1", "","Specified Tax Rate Code was not defined in the group Taxation");
      edrSetIsValidDetail(false);
    }
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TaxInformation and AccountingInfo. It will raise error code 30, 31 for TaxInformation and
 * error code 30 for AccountingInfo.
 ******************************************************************************************************************************/
 
function validateTaxInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",213";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  if ( taxationListIsMissing == true )      
  {
    rollbackReason   = "AccountingInfo," +  "1 ,5 " + ",30" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AccountingInfo", "5", "30", "Missing Taxation Group"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "5", "0", "-1", "-1","", "Missing Taxation Group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "taxCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxCode ( myContext, nMyIndices, "taxCode", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TaxInformation", "213", "30", "Mandatory item Tax Rate Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Mandatory item Tax Rate Code missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "taxValue";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxValue ( myContext, nMyIndices, "taxValue", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TaxInformation", "213", "31", "Mandatory item Tax Value missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Mandatory item Tax Value missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "taxableAmount";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxableAmount ( myContext, nMyIndices, "taxableAmount", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateTaxInformation for each element of Tax Information List.
 ******************************************************************************************************************************/

function validateTaxInformationList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",214";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "TaxInformation";
  Long TaxInformationListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < TaxInformationListEntries; i = i + 1 )
  {
    validateTaxInformation ( myContext, nMyIndices, "TaxInformation", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate UtcTimeOffsetCode. It will raise error code 20, 100 for UtcTimeOffsetCode.
 ******************************************************************************************************************************/
 
function validateUtcTimeOffsetCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",232";
  
  chargeDetailUtcTimeOffset = "";

  utcTimeOffsetIsDuplicate = false;

  if( (strStartsWith(parentContext, "HEADER.networkInfo") == true) and
      (validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"99" , "0", "INTEGER_TYPE") == true) )
  {
    rollbackReason = "NetworkInfo" + errorContext + ",20" + ":" + NetworkInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "UtcTimeOffsetCode", "232", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "232", "0", "-1", "-1", "","Value out of range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
    edrLongEx( myContext, indices, nParentIndices ) = -1;
    return;
  }
  
  Long tmpUtcTimeOffsetCode = edrLongEx( myContext, indices, nParentIndices );
  lastCode = edrLongEx( myContext, indices, nParentIndices );
  
  if( strStartsWith(parentContext, "HEADER") == true )
  {    
    if( utcTimeOffsetCode[ lastCode ] == tmpUtcTimeOffsetCode )
    {
      utcTimeOffsetIsDuplicate = true;
    }
    else
    {
      utcTimeOffsetCode[ lastCode ] = lastCode;
    }
  }
  else if ( strStartsWith(parentContext, "DETAIL") == true )
  {
    if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"99" , "0", "INTEGER_TYPE") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "UtcTimeOffsetCode", "232", "11", "Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", "232", "0", "-1", "-1", "","Syntax Error");
      edrSetIsValidDetail(false);
      return;
    }
    if( lastCode != utcTimeOffsetCode[lastCode] )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "UtcTimeOffsetCode", "232", "100", "Specified UTC Time Offset Code not defined in group UTC Time Offset Information");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1", "","Specified UTC Time Offset Code not defined in group UTC Time Offset Information");
      edrSetIsValidDetail(false);
    }
  }
  
  if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicCallInformation.callEventStartTimeStamp") == true or
      strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicCallInformation.callEventStartTimeStamp") == true or
      strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation.callEventStartTimeStamp") == true )
  {
    callEventStartUtcTimeOffset = utcTimeOffset[lastCode];
  }
  
    if( strStartsWith(parentContext, "DETAIL") == true )
    {
      if( ( strEndsWith(parentContext, "callEventStartTimeStamp") == true ) or 
	      ( strEndsWith(parentContext, "completionTimestamp") == true ) or
	      ( strEndsWith(parentContext, "lCSRequestTimestamp") == true ) or
	      ( strEndsWith(parentContext, "actualDeliveryTimestamp") == true ) or
	      ( strEndsWith(parentContext, "supplServiceEvent.supplServiceUsed.chargingTimeStamp") == true ) )
      {
        endUTCTimeOffset = utcTimeOffset[lastCode];
      }
    }

  if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or 
       strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or 
         strStartsWith(parentContext, "DETAIL.gprsCall.gprsServiceUsed.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or
           strStartsWith(parentContext, "DETAIL.locationService.locationServiceUsage.chargeInformationList.ChargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true or
              strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed.chargeInformation.chargeDetailList.ChargeDetail.chargeDetailTimeStamp") == true )
  {
    chargeDetailUtcTimeOffset = utcTimeOffset[lastCode];
  }

  if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicServiceUsedList.BasicServiceUsed.chargingTimeStamp") == true
      or strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicServiceUsedList.BasicServiceUsed.chargingTimeStamp")
      == true or strStartsWith(parentContext, "DETAIL.locationService.locationServiceUsage.chargingTimeStamp") == true  or
      strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed.chargingTimeStamp") == true )
  {
    chargingUtcTimeOffset = utcTimeOffset[lastCode];
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}
 
/******************************************************************************************************************************
 * This function will validate ChargeDetailTimeStamp and CallEventStartTimestamp. It will raise error code 30, 100, 101 for
 * ChargeDetailTimeStamp and error code 100 for CallEventStartTimestamp.
 ******************************************************************************************************************************/

function validateChargeDetailTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",410";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );


    Long callEventStartUtcTimeOffset_Hr = 0;
    Long callEventStartUtcTimeOffset_Mn = 0;
    Long chargeDetailUtcOffset_Hr = 0;
    Long chargeDetailUtcOffset_Mn = 0;
    Long chargingUtcTimeOffset_Hr = 0;
    Long chargingUtcTimeOffset_Mn = 0;


    if(strSubstr(callEventStartUtcTimeOffset,0,1) == "+")
    {
      callEventStartUtcTimeOffset_Hr = - (strToLong(strSubstr(callEventStartUtcTimeOffset,1,2)));
      callEventStartUtcTimeOffset_Mn = - (strToLong(strSubstr(callEventStartUtcTimeOffset,3,2)));
    }
    else
    {
      callEventStartUtcTimeOffset_Hr = strToLong(strSubstr(callEventStartUtcTimeOffset,1,2));
      callEventStartUtcTimeOffset_Mn = strToLong(strSubstr(callEventStartUtcTimeOffset,3,2));
    }

    if(strSubstr(chargeDetailUtcTimeOffset,0,1) == "+")
    {
      chargeDetailUtcOffset_Hr = - (strToLong(strSubstr(chargeDetailUtcTimeOffset,1,2)));
      chargeDetailUtcOffset_Mn = - (strToLong(strSubstr(chargeDetailUtcTimeOffset,3,2)));
    }
    else
    {
      chargeDetailUtcOffset_Hr = strToLong(strSubstr(chargeDetailUtcTimeOffset,1,2));
      chargeDetailUtcOffset_Mn = strToLong(strSubstr(chargeDetailUtcTimeOffset,3,2));
    }

    if(strSubstr(chargingUtcTimeOffset,0,1) == "+")
    {
      chargingUtcTimeOffset_Hr = - (strToLong(strSubstr(chargingUtcTimeOffset,1,2)));
      chargingUtcTimeOffset_Mn = - (strToLong(strSubstr(chargingUtcTimeOffset,3,2)));
    }
    else
    {
      chargingUtcTimeOffset_Hr = strToLong(strSubstr(chargingUtcTimeOffset,1,2));
      chargingUtcTimeOffset_Mn = strToLong(strSubstr(chargingUtcTimeOffset,3,2));
    }

    if( (dateDiff( dateAdd(strToDate(lastChargeDetailTimeStamp), 0, 0, 0, chargeDetailUtcOffset_Hr, chargeDetailUtcOffset_Mn, 0),
         dateAdd(strToDate(lastCallEventStartTimeStamp), 0, 0, 0, callEventStartUtcTimeOffset_Hr, callEventStartUtcTimeOffset_Mn,
         0) ) < 0) and (lastChargeDetailTimeStamp != "") and (lastCallEventStartTimeStamp != "") and
        (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or 
         strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true ) )
    {
      if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
      {
        objTag = "1,3,9,147,44";
      }
      else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
      {
        objTag = "1,3,10,153,44";
      }
      else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
      {
        objTag = "1,3,14,114,44";
      }
         // Error Setting
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Call Event Start Timestamp", "44", "100",
                                                "Call event start timestamp after charge detail timestamp");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", objTag, "0", "-1", "-1","",
                                                "Call event start timestamp after charge detail timestamp");
      edrSetIsValidDetail(false);
    } 
    if( (dateDiff( dateAdd(strToDate(lastChargeDetailTimeStamp), 0, 0, 0, chargeDetailUtcOffset_Hr, chargeDetailUtcOffset_Mn, 0),
        dateAdd(strToDate(lastChargingTimeStamp), 0, 0, 0, chargingUtcTimeOffset_Hr, chargingUtcTimeOffset_Mn, 0) ) < 0) and
        (lastChargeDetailTimeStamp != "") and (lastChargingTimeStamp != "") and (lastCharge > 0.0) )
    {
         // Error Setting
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetailTimestamp", "410", "100",
      "ChargeDetailTimestamp earlier than ChargingTimestamp and the Charge associated with this ChargeDetail is greater than zero");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1","",
      "ChargeDetailTimestamp earlier than ChargingTimestamp and the Charge associated with this ChargeDetail is greater than zero");
      edrSetIsValidDetail(false);
    } 

    if( (dateDiff( dateAdd(strToDate(lastCallEventStartTimeStamp), 0, 0, 0, callEventStartUtcTimeOffset_Hr, 
         callEventStartUtcTimeOffset_Mn, lastTotalCallEventDuration), dateAdd(strToDate(lastChargeDetailTimeStamp), 0, 0, 0,
         chargeDetailUtcOffset_Hr, chargeDetailUtcOffset_Mn, 0) ) < 0) and (lastChargeDetailTimeStamp != "") and
         (lastCallEventStartTimeStamp != "") and (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or 
          strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true or 
          strStartsWith(parentContext, "DETAIL.gprsCall") == true) )
    {
      // Error Setting
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetailTimestamp", "410", "101", "Charge Detail Timestamp is later than the end of the call (Call Event Start Timestamp plus Total Call Event Duration) and the Charge associated with this Charge Detail is greater than zero");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1", "","Charge Detail Timestamp is later than the end of the call (Call Event Start Timestamp plus Total Call Event Duration) and the Charge associated with this Charge Detail is greater than zero");
      edrSetIsValidDetail(false);
    }
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetailTimeStamp", "410", "30", "Missing UTC Time Offset Code");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing UTC Time Offset Code");
    edrSetIsValidDetail(false);
  }


 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ChargedUnits. It will raise error code 20 for ChargedUnits.
 ******************************************************************************************************************************/
 
function validateChargedUnits ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",68";

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Charged Units", "68", "20", "Charged Units Out Of Range");
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate ChargeableUnits and ChargeDetail. It will raise error code 20, 100, 101, 102, 103 for ChargeableUnits
 * and error code 32 for ChargeDetail.
 ******************************************************************************************************************************/
 
function validateChargeableUnits ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",65";
  Long chargeableUnits = edrLongEx( myContext, indices, nParentIndices );

  if( lastChargedItem == "E" or  lastChargedItem == "F" or  lastChargedItem == "L" )   
  {
    
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ChargeDetail", "63", "32",   
                "Associated item Charged Item is one of E,F or L and item Chargeable Units present within group");
  }

  if ( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Units", "65", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }

  if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true or strStartsWith(parentContext, "DETAIL.gprsCall") == true ) 
  {
    if( lastChargeType == "00" and lastChargedItem == "D" and chargeableUnits > lastTotalCallEventDuration )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Units", "65", "100",
                  "Chargeable Units for Charge Type '00' are greater than Total Call Event Duration for Charged Item 'D'");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1","",
                  "Chargeable Units for Charge Type '00' are greater than Total Call Event Duration for Charged Item 'D'");
      edrSetIsValidDetail(false);
    }
  }
  if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
  {
    if( lastChargeType == "00" and lastChargedItem == "X" and chargeableUnits > totalDataVolumeIncomingOutgoingValue )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Units", "65", "101",
      "Chargeable Units for Charge Type '00' are greater than the sum of Data Volume Incoming and Outgoing for Charged Item 'X'");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1","",
      "Chargeable Units for Charge Type '00' are greater than the sum of Data Volume Incoming and Outgoing for Charged Item 'X'");
      edrSetIsValidDetail(false);
    }
    if( lastChargeType == "00" and lastChargedItem == "V" and chargeableUnits > dataVolumeOutgoingValue )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Units", "65", "102",
      "Chargeable Units for Charge Type '00' are greater than the Data Volume Outgoing for Charged Item 'V'");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "102", errorContext, "0", "-1", "-1","",
      "Chargeable Units for Charge Type '00' are greater than the Data Volume Outgoing for Charged Item 'V'");  
      edrSetIsValidDetail(false);
    }
    if( lastChargeType == "00" and lastChargedItem == "W" and chargeableUnits > dataVolumeIncomingValue )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Chargeable Units", "65", "103",
      "Chargeable Units for Charge Type '00' are greater than the Data Volume Incoming for Charged Item 'W'");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "103", errorContext, "0", "-1", "-1","",
      "Chargeable Units for Charge Type '00' are greater than the Data Volume Incoming for Charged Item 'W'");
      edrSetIsValidDetail(false);
    }
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}


/******************************************************************************************************************************
 * This function will validate Charge and AccountingInfo. It will raise error code 20 for Charge and error code 34 for 
 * AccountingInfo.
 ******************************************************************************************************************************/ 

function validateCharge ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",62";
  Long lastChargeLong = edrLongEx( myContext, indices, nParentIndices );
  
  lastCharge = longToDecimal(lastChargeLong);
  if ( lastChargeLong  > 0 )
  {
    chargeGreaterThanZero = true;
  }
  if ( (currencyConversionListIsMissing == true) and (lastChargeLong  > 0) )     
  {
    rollbackReason   = "AccountingInfo," +  "1 ,5 " + ",34" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AccountingInfo", "5", "34", "Group Currency Conversion missing within group and the transfer includes one or more Charge greater than zero"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "34", "5", "0", "-1", "-1", "","Group Currency Conversion missing within group and the transfer includes one or more Charge greater than zero");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  
  if( lastChargeLong < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge", "62", "20", "Charge Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Charge Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  if( lastChargeType == "00" )
  {
    if ( hasChargeRefund == false )
    {
      totalCalcCharge = totalCalcCharge + lastChargeLong;
    }
    else
    {
      totalCalcChargeRefund = totalCalcChargeRefund + lastChargeLong;
    }
  }
  
    
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TaxIndicator. It will raise error code 10,20 for TaxIndicator.
 ******************************************************************************************************************************/

function validateTaxIndicator ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",432";

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Tax Indicator", "432", "10", "Tax Indicator Syntax Error");
  }
  else if( strToLong(edrStringEx(myContext, indices, nParentIndices)) != 1 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Tax Indicator", "432", "20", "Tax Indicator Out Of Range Error");
  }
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}
 
/******************************************************************************************************************************
 * This function will validate ChargeType. It will raise error code 10, 11, 20, 21, 22 for ChargeType.
 ******************************************************************************************************************************/

function validateChargeType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",71";
  Long   i;

  if( ( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true) or
        (strLength(edrStringEx(myContext, indices, nParentIndices)) != 2) ) and
      (strStartsWith(parentContext, "HEADER") == true) )
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",11" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Charge Type", "71", "11", "Charge Type Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "11", "71", "0", "-1", "-1", "","Charge Type Syntax Error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( (edrStringEx(myContext, indices, nParentIndices) != "00" and edrStringEx(myContext, indices, nParentIndices) != "01"
        and edrStringEx(myContext, indices, nParentIndices) != "03" and edrStringEx(myContext, indices, nParentIndices) != "04"
        and edrStringEx(myContext, indices, nParentIndices) != "21") and (strStartsWith(parentContext, "HEADER") ==  true) )
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",21" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Charge Type", "71", "21", "Charge Type Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "21", "71", "0", "-1", "-1", "","Charge Type Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( (edrStringEx(myContext, indices, nParentIndices) == "00") and (strStartsWith(parentContext, "HEADER")  == true) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Charge Type", "71", "22", "Charge Type Value is 00 ");
  }

  if( ( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true) or
        (strLength(edrStringEx(myContext, indices, nParentIndices)) != 2) ) and
      (strStartsWith(parentContext, "DETAIL") == true) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Type", "71", "10", "Charge Type Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Charge Type Syntax Error");
    edrSetIsValidDetail(false);
  }
  else if( (edrStringEx(myContext, indices, nParentIndices) != "00" and edrStringEx(myContext, indices, nParentIndices) != "01"
        and edrStringEx(myContext, indices, nParentIndices) != "03" and edrStringEx(myContext, indices, nParentIndices) != "04"
        and edrStringEx(myContext, indices, nParentIndices) != "21") and (strStartsWith(parentContext, "HEADER") == false) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Type", "71", "20", "Charge Type Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Charge Type Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  if (  strStartsWith(parentContext, "DETAIL") == true )
  {
    lastChargeType = edrStringEx( myContext, indices, nParentIndices );
    if( lastChargeType == "00" )
    {
      chargeType00Present = true;
    }
    chargeTypeArray[chargeTypeEntries] = lastChargeType;
    if( chargeTypeEntries > 0 )
    {
      for( i = 0; i < chargeTypeEntries; i = i+ 1 )
      {
        if( lastChargeType == chargeTypeArray[i] )
        {
          chargeTypeDuplicateEntries = true;
        }
      }
    }
    chargeTypeEntries = chargeTypeEntries + 1;  
    
  }
  
  if ( strStartsWith(parentContext, "HEADER.taxation") == true )
  {
    if ( taxCodeIsDuplicate == true )
    {
      if ( chargeType[ lastCode ] == edrStringEx( myContext, indices, nParentIndices ) )
      {
        chargeTypeIsDuplicate = true;
      } 
    }
    else
    {
      chargeType[ lastCode ] = edrStringEx( myContext, indices, nParentIndices );
    }
  }    
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate ChargeDetail and TransferBatch. It will raise error code 33, 38, 39 for ChargeDetail and
 * error code 31 for TransferBatch.
 ******************************************************************************************************************************/
 
function validateChargeDetail ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",63";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  lastCharge              = 0.0;
   
  childContext = myContext + "." + "chargeType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargeType ( myContext, nMyIndices, "chargeType", 0, errorContext );
  }
  else  
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetail", "63", "38", "Charge Type not present within group");  
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "38", errorContext, "0", "-1", "-1", "","Charge Type not present within group");
    edrSetIsValidDetail(false);
  }

  childContext = myContext + "." + "charge";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    if ( accountingInfoIsMissing == true )
    {
      rollbackReason = "TransferBatch,1,31";
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TransferBatch", "1", "31", "Group Accounting Information not present and a charge is present within the Transfer Batch");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "1", "0", "-1", "-1", "","Group Accounting Information not present and a charge is present within the Transfer Batch");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
      accountingInfoIsMissing = false;
    }
    validateCharge ( myContext, nMyIndices, "charge", 0, errorContext );
  }
  else  
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetail", "63", "39", "Charge not present within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "39", errorContext, "0", "-1", "-1", "","Charge not present within group");
    edrSetIsValidDetail(false);
  }
  
 
  childContext = myContext + "." + "chargeableUnits";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargeableUnits ( myContext, nMyIndices, "chargeableUnits", 0, errorContext );
  }
  else if( lastChargedItem == "D" or  lastChargedItem == "V" or  lastChargedItem == "W"
                                   or  lastChargedItem == "X" )
  {
    
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargeDetail", "63", "33",   
                "Associated item Charged Item is one of D,V,W or X and item Chargeable Units not present");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1","",
                "Associated item Charged Item is one of D,V,W or X and item Chargeable Units not present");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargedUnits";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargedUnits ( myContext, nMyIndices, "chargedUnits", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargeDetailTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeDetailTimeStamp ( myContext, nMyIndices, "chargeDetailTimeStamp", 0, errorContext );
  }
  lastChargeType = "";
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ChargeInformation and SupplServiceCode. It will raise error code 36, 37 for ChargeInformation and
 * error code 30 for SupplServiceCode.
 ******************************************************************************************************************************/
 
function validateChargeDetailList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",64";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "ChargeDetail";
  
  chargeGreaterThanZero   = false;
  chargeType00Present     = false;
  chargeTypeDuplicateEntries = false;
  chargeTypeEntries       = 0;
  arrayClear( chargeTypeArray ); 

  Long i;
  Long ChargeDetailListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  for( i = 0; i < ChargeDetailListEntries; i = i + 1 )
  {
    validateChargeDetail ( myContext, nMyIndices, "ChargeDetail", i, errorContext );
  }
  
  if( ChargeDetailListEntries > 0 and chargeType00Present == false )
  {  
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
    {
      objTag = "1,3,9,38,39,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
    {
      objTag = "1,3,10,38,39,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
      objTag = "1,3,14,121,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true )
    {
      objTag = "1,3,11,206,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true )
    {
      objTag = "1,3,12,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      objTag = "1,3,17,285,352,70,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.locationService") == true )
    {
      objTag = "1,3,297,382,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileSession") == true )
    {
      objTag = "1,3,434,448,449";
    }	
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Information", "69", "36",
                "Occurrence of group Charge Detail containing Charge Type '00' missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "36", objTag, "0", "-1", "-1","", 
                "Occurrence of group Charge Detail containing Charge Type '00' missing within group");
    edrSetIsValidDetail(false);
  }
  if( ChargeDetailListEntries > 1 and chargeTypeDuplicateEntries == true )
  {
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
    {
      objTag = "1,3,9,38,39,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
    {
      objTag = "1,3,10,38,39,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
      objTag = "1,3,14,121,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true )
    {
      objTag = "1,3,11,206,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true )
    {
      objTag = "1,3,12,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      objTag = "1,3,17,285,352,70,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.locationService") == true )
    {
      objTag = "1,3,297,382,69";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileSession") == true )
    {
	  objTag = "1,3,434,448,449";
    }	
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Information", "69", "37",  
                "More than one occurrence of Charge Detail present with the same Charge Type value");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "37", objTag, "0", "-1", "-1","",
                "More than one occurrence of Charge Detail present with the same Charge Type value");
    edrSetIsValidDetail(false);
  }  
  
  if ( strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true )
  {
    if ( lastSupplServiceCode == "FF" and chargeGreaterThanZero == false )
    {
     edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "SupplServiceCode", "209", "30", "USSD, value 'FF', present and associated Charge Information does not contain a charge greater than zero"); 
    }
  }
 
  //logContext( myContext, nMyIndices );
}
 
