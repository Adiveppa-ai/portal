			<xs:element name="CFeeAmt" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="CEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1" nillable="true"/>
			<xs:element name="CEndDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="CStrt" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
			<xs:element name="CStrDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="CrtT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="DlObj" type="Poid" minOccurs="0" maxOccurs="1" nillable="false"/>
			<xs:element name="PlObj" type="Poid" minOccurs="0" maxOccurs="1" nillable="false"/>
			<xs:element name="PrObj" type="Poid" minOccurs="1" maxOccurs="1" nillable="false"/>
			<xs:element name="PuDis" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="PuDiscAmt" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="PuFAmt" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="PuEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1" nillable="true"/>
