//------------------------------------------------------------------------------
// Block: ISC_TapAddErrorBlock
//------------------------------------------------------------------------------
// Module Description:
//   This module is used to add ASS_TAP3_ERR block in DETAIL block.
//   This module should be used after TAP3_VAL rules are applied.
//
//------------------------------------------------------------------------------
//
// Revision 1.0  2004/01/30 mliu
// added onInvalidDetailEdr checking and fixed the incorrect severity value
//
// Revision 1.0  2004/01/30 Prem 
// Initial rev.
//
//==============================================================================
//==============================================================================
// BEGIN Container
//==============================================================================

Bool    debug;
//==============================================================================
// BEGIN Container
//==============================================================================
function BEGIN
{
  debug = false;        // true;

  if (debug)
  {
    logStdout("Begin\n");
  }

}

//------------------------------------------------------------------------------
// init()
//------------------------------------------------------------------------------
function init
{
  if (debug)
  {
    logStdout("init()\n");
  }
}

//------------------------------------------------------------------------------
// addTap3ErrBlock()
//
// This function will be used to add the TAP3 error block
//------------------------------------------------------------------------------

function Bool addTap3ErrBlock(Long idx,String severity, String errorCode, String tag, String depth)
{
    if(debug)
    {
      logStdout("addTap3ErrBlock(" + longToStr(idx) + "," + severity + "," + errorCode + "," + tag + "," + depth + ") \n");
    }
    Long sev=0;
    if(severity == "warning")
    {
       sev = 1;
    }
    if(severity == "minor")
    {
       sev = 2;
    }
    if(severity == "severe")
    {
       sev = 3;
    }
    if(severity == "critical")
    {
       sev = 4;
    }
    if( edrAddDatablock(DETAIL.ASS_TAP3_ERR) == true)
    {
      edrString(DETAIL.ASS_TAP3_ERR.RECORD_TYPE, idx) = "670";
      edrLong(DETAIL.ASS_TAP3_ERR.RECORD_NUMBER, idx) = edrLong(DETAIL.RECORD_NUMBER);
      edrLong(DETAIL.ASS_TAP3_ERR.ERROR_SEVERITY, idx) = sev;
      edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_CODE,idx) = errorCode;
      edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_APPLICATION_TAG, idx) = tag;
      edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_DEPTH, idx) = depth;
      return true;
    }  
    else
    {
      logStdout( "ERROR edrAddDatablock failed for edr :" + longToStr(edrLong(DETAIL.RECORD_NUMBER)));
      return false;
    }
}    

function checkEdrErrors
{
  
  if (debug)
  {
    logStdout("checkEdrErrors \n");
  }
  //----------------------------------------------------------------------------
  // initialize global variables
  //----------------------------------------------------------------------------
  init();

  String paramList[]; 
  Long paramCount; 
  Long Tap3MaxParamCount = 7; 
  Long i = 0;
  Long index = 0;
  for ( i = 0; i < edrNumErrors() ; i = i+1 ) 
  { 
    if (edrGetError(i) == "ERR_TAP3_RET") 
    { 
      paramCount = edrGetErrorParameters(i, paramList); 
      if (paramCount != Tap3MaxParamCount) 
      { 
        logStdout( "ERROR " + longToStr(i) + ": " + edrGetError(i) + ", has missing parameters\n" ); 
      }
      index = edrNumDatablocks(DETAIL.ASS_TAP3_ERR);
      if(paramList[6] == "TAP3.B_NUMBERING_PLAN")
      {
        if(addTap3ErrBlock(index,paramList[0],paramList[1],paramList[2],paramList[3]) == true )
	{
           edrString(DETAIL.ASS_TAP3_ERR.ERROR_NAME, index) = "ERR_TAP3_B_NUMBERING_PLAN";
	}
      }	
      if(strStartsWith(paramList[6], "TAP3.BASIC_SERVICE"))
      {
        if(addTap3ErrBlock(index,paramList[0],paramList[1],paramList[2],paramList[3]) == true )
	{
           edrString(DETAIL.ASS_TAP3_ERR.ERROR_NAME, index) = "ERR_TAP3_BASIC_SERVICE";
	}
      }
      if(paramList[6] == "TAP3.BASIC_SERVICE")
      {
        if(addTap3ErrBlock(index,paramList[0],paramList[1],paramList[2],paramList[3]) == true )
        {
           edrString(DETAIL.ASS_TAP3_ERR.ERROR_NAME, index) = "ERR_TAP3_BASIC_SERVICE_SYNTAX";
        }
      }
      if(paramList[6] == "TAP3.B_TYPE_OF_NUMBER")
      {
        if(addTap3ErrBlock(index,paramList[0],paramList[1],paramList[2],paramList[3]) == true )
	{
           edrString(DETAIL.ASS_TAP3_ERR.ERROR_NAME, index) = "ERR_TAP3_B_TYPE_OF_NUMBER";
	}
