  }
 
  childContext = myContext + "." + "trackedCustomerEquipment";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTrackedCustomerEquipment ( myContext, nMyIndices, "trackedCustomerEquipment", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
