function mapSupplServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "DETAIL.mobileOriginatedCall") == true )
  {
    if ( edrAddDatablock( DETAIL.ASS_GSMW_EXT.SS_PACKET ) == false )
    {
    }
    ssPacketIdx = edrLong(DETAIL.ASS_GSMW_EXT.NUMBER_OF_SS_PACKETS , 0);
    edrLong(DETAIL.ASS_GSMW_EXT.NUMBER_OF_SS_PACKETS , 0) = ssPacketIdx + 1;

    records = records + 1;
    edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) = edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) + 1;
    edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.RECORD_TYPE, 0, ssPacketIdx) = extension_SS_EVENT;
    edrLong(DETAIL.ASS_GSMW_EXT.SS_PACKET.RECORD_NUMBER, 0, ssPacketIdx) = records;
    related_record = records;

    edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT, 0, ssPacketIdx) = edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith ( parentContext, "DETAIL.supplServiceEvent") == true )
  {
    edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT, 0, ssPacketIdx) = edrStringEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapSupplServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  service_Type = service_Suppl;
  if ( edrAddDatablock( DETAIL.ASS_GSMW_EXT.SS_PACKET ) == false )
  {
  }
  ssPacketIdx = edrLong(DETAIL.ASS_GSMW_EXT.NUMBER_OF_SS_PACKETS , 0);
  edrLong(DETAIL.ASS_GSMW_EXT.NUMBER_OF_SS_PACKETS , 0) = ssPacketIdx + 1;

  records = records + 1;
  edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) = edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) + 1;
  edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.RECORD_TYPE, 0, ssPacketIdx) = extension_SS_EVENT;
  edrLong(DETAIL.ASS_GSMW_EXT.SS_PACKET.RECORD_NUMBER, 0, ssPacketIdx) = records;
  related_record = records;
                                                                                                             
  childContext = myContext + "." + "supplServiceCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSupplServiceCode ( myContext, nMyIndices, "supplServiceCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "supplServiceActionCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSupplServiceActionCode ( myContext, nMyIndices, "supplServiceActionCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "ssParameters";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSsParameters ( myContext, nMyIndices, "ssParameters", 0 );                               
  }                                                                                                          

  edrString(DETAIL.INTERN_C_NUMBER_ZONE) = edrString(DETAIL.C_NUMBER);
                                                                                                             
  childContext = myContext + "." + "chargingTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargingTimeStamp ( myContext, nMyIndices, "chargingTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
	// related_info_id = 1;
  childContext = myContext + "." + "chargeInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargeInformation ( myContext, nMyIndices, "chargeInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  SsBasicServicesAffectedNb = 0;
  lastbasicServiceCodeSS = "";
  childContext = myContext + "." + "basicServiceCodeList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapBasicServiceCodeList ( myContext, nMyIndices, "basicServiceCodeList", 0 );                               
  }                                                                                                          

  if (SsBasicServicesAffectedNb > 0)
  {
    edrString(DETAIL.ASS_GSMW_EXT.BASIC_DUAL_SERVICE, 0) = SsBasicServicesAffected[SsBasicServicesAffectedNb - 1];
  }
  if (lastbasicServiceCodeSS != "")
  {
    edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.BASIC_SERVICE_CODE_LIST, 0, ssPacketIdx) = lastbasicServiceCodeSS;
  }
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
