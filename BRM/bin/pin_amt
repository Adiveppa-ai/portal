PIN_DIR=/home/pin/opt/portal/BRM
ORA_DIR=$ORACLE_HOME
JAVA_DIR=$JAVA_HOME

AMT_DIR=${PIN_DIR}/apps/amt
JAR_DIR=${PIN_DIR}/jars
CLASSPATH=.:$JAR_DIR/amt.jar:$JAR_DIR/pcm.jar:$JAR_DIR/pcmext.jar:${PIN_DIR}/apps/amt/ttjdbc6.jar:$ORA_DIR/jdbc/lib/ojdbc8.jar:$ORA_DIR/lib/ojdbc8.jar:$ORA_DIR/jdbc/lib/classes12.zip:$JAR_DIR/oraclepki.jar:$JAR_DIR/osdt_cert.jar:$JAR_DIR/osdt_core.jar

PATH=${PATH}:${ORA_DIR}/bin:${PIN_DIR}/jre/bin

export CLASSPATH PATH

JAVA=$JAVA_DIR/bin/java

$JAVA -DPIN_HOME=$PIN_DIR -DJAVA_OPTS="-Xmx2048m -Xms256m" com.portal.amt.AmtUI $*
