function mapTotalAdvisedChargeValue ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "advisedChargeCurrency";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapAdvisedChargeCurrency ( myContext, nMyIndices, "advisedChargeCurrency", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalAdvisedCharge";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalAdvisedCharge ( myContext, nMyIndices, "totalAdvisedCharge", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalAdvisedChargeRefund";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalAdvisedChargeRefund ( myContext, nMyIndices, "totalAdvisedChargeRefund", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalCommission";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalCommission ( myContext, nMyIndices, "totalCommission", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalCommissionRefund";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalCommissionRefund ( myContext, nMyIndices, "totalCommissionRefund", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
