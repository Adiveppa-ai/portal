/******************************************************************************************************************************
 * This function will validate BasicService. It will raise error code 30 for BasicService.
 ******************************************************************************************************************************/
 
function validateBasicService ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",36";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "serviceCode";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateBasicServiceCode ( myContext, nMyIndices, "serviceCode", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "BasicService", "36", "30", "Missing Basic Service Code");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing Basic Service Code");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "transparencyIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransparencyIndicator ( myContext, nMyIndices, "transparencyIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "fnur";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateFnur ( myContext, nMyIndices, "fnur", 0, errorContext );
  }
 
  childContext = myContext + "." + "userProtocolIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUserProtocolIndicator ( myContext, nMyIndices, "userProtocolIndicator", 0, errorContext );
  }
 
  childContext = myContext + "." + "guaranteedBitRate";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateGuaranteedBitRate ( myContext, nMyIndices, "guaranteedBitRate", 0, errorContext );
  }
 
  childContext = myContext + "." + "maximumBitRate";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMaximumBitRate ( myContext, nMyIndices, "maximumBitRate", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate BasicServiceUsed. It will raise error code 30, 32 for BasicServiceUsed.
 ******************************************************************************************************************************/
 
function validateBasicServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",39";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "basicService";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateBasicService ( myContext, nMyIndices, "basicService", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "BasicServiceUsed", "39", "30", "Missing Basic Service");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing Basic Service Code");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargingTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargingTimeStamp ( myContext, nMyIndices, "chargingTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargeInformationList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "BasicServiceUsed", "39", "32", "Missing Charge Information");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Missing Charge Information");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "hSCSDIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateHSCSDIndicator ( myContext, nMyIndices, "hSCSDIndicator", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate MobileTerminatedCall and MobileOriginatedCall. It will raise error code 35 for both
 * MobileTerminatedCall and MobileOriginatedCall.
 ******************************************************************************************************************************/
 
function validateBasicServiceUsedList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",38";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "BasicServiceUsed";
  Long BasicServiceUsedListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < BasicServiceUsedListEntries; i = i + 1 )
  { 
    if ( i > 0 )
    {
      if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileTerminatedCall", "10", "35", "More than one occurrence of group Basic Service Used present within group");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", errorContext, "0", "-1", "-1", "","More than one occurrence of group Basic Service Used present within group");
        edrSetIsValidDetail(false);
      }
      else if ( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
      {
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MobileOriginatedCall", "9", "35", "More than one occurrence of group Basic Service Used present within group");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", errorContext, "0", "-1", "-1", "","More than one occurrence of group Basic Service Used present within group");
        edrSetIsValidDetail(false);
      }
    }
    validateBasicServiceUsed ( myContext, nMyIndices, "BasicServiceUsed", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate SimToolkitIndicator. It will raise error code 10, 20 for SimToolkitIndicator.
 ******************************************************************************************************************************/
 
function validateSimToolkitIndicator ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",200";

  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 1) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "SimToolkitIndicator", "200", "10", "Syntax error");
  }
  else if( edrStringEx(myContext, indices, nParentIndices) != "1" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "SimToolkitIndicator", "200", "20", "Value out of range");
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}
 
