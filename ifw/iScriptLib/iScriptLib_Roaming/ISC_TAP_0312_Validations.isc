  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "PDPContextStartTimestamp", "260", "30", "Mandatory associated item UTC Time Offset Code missing");
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate PartialTypeIndicator and CauseForTermination. It will raise error code 10, 20 for
 * PartialTypeIndicator and error code 100 for CauseForTermination.
 ******************************************************************************************************************************/
 
function validatePartialTypeIndicator ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",166";
  lastPartialTypeIndicator = edrStringEx(myContext, indices, nParentIndices);
 
  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHA_UPPER") == true) or
       strLength(edrStringEx(myContext, indices, nParentIndices)) != 1 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "PartialTypeIndicator", "166", "10", "Syntax error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1","", "Syntax error"); 
    edrSetIsValidDetail(false);
  }
  else if( (edrStringEx( myContext, indices, nParentIndices ) != "F") and 
             (edrStringEx( myContext, indices, nParentIndices ) != "I") and  
               (edrStringEx( myContext, indices, nParentIndices ) != "L") )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "PartialTypeIndicator", "166", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }    

  if( (causeForTermIsPresent == true) and (edrStringEx( myContext, indices, nParentIndices ) == "F" or 
       edrStringEx( myContext, indices, nParentIndices ) == "I") )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Cause For Termination", "58", "100", 
                "Cause for termination specified and the call event represents first or intermediate partial");
  }
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CauseForTermination. It will raise error code 20 for CauseForTermination.
 ******************************************************************************************************************************/
 
function validateCauseForTerm ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",58";
  lastCauseForTerm = edrLongEx(myContext, indices, nParentIndices);

  if ( (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true) or ( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true) )
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "3", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CauseForTerm ", "58", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.gprsCall") == true and lastCauseForTerm != 4 and 
           lastCauseForTerm != 5 and lastCauseForTerm != 20 and lastCauseForTerm != 21 and lastCauseForTerm != 24)
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CauseForTerm ", "58", "20", "Value out of range"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
    edrSetIsValidDetail(false);
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.mobileSession") == true) and (lastCauseForTerm != 1) and (lastCauseForTerm != 5) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CauseForTerm ", "58", "20", "Value out of range"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TotalCallEventDuration. It will raise error code 20, 200 for TotalCallEventDuration.
 ******************************************************************************************************************************/
 
function validateTotalCallEventDuration ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",223";
  Long totalDuration = 24 * 3600;
  totalCallEventDurationExceeded = false;
  lastTotalCallEventDuration = edrLongEx( myContext, indices, nParentIndices );
  
  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TotalCallEventDuration", "223", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }
  else if( edrLongEx(myContext, indices, nParentIndices) > totalDuration )
  {
    totalCallEventDurationExceeded = true; 
    // FieldName, AppId, ErrorCode,ErrorDescription
    if( strStartsWith(parentContext, "DETAIL.gprsCall") == false )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "TotalCallEventDuration", "223", "200", "Total Call Event Duration exceeds limit defined by BARG in BA.12");
    }
  }

   Date myLocalDate  = dateAdd(strToDate(endLocalTimeStamp),0,0,0,0,0,lastTotalCallEventDuration);
   endLocalTimeStamp = dateToStr( myLocalDate);

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CallEventStartTimeStamp. It will raise error code 30 for CallEventStartTimeStamp.
 ******************************************************************************************************************************/
 
function validateCallEventStartTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",44";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );

  }
  else  
  {    
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallEventStartTimeStamp", "44", "30", "Missing UTC Time Offset Code");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing UTC Time Offset Code");
    edrSetIsValidDetail(false);
  }
    endLocalTimeStamp = addUTCToLocalTimestamp( endLocalTimeStamp, endUTCTimeOffset);
 
  //logContext( myContext, nMyIndices );
}

