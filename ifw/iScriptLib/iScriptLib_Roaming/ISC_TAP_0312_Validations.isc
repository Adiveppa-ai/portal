/******************************************************************************************************************************
 * This function will validate ContentServiceUsed. It will raise error code 30, 31, 32, 33, 34, 35, 102, 103 for ContentServiceUsed.
 ******************************************************************************************************************************/
 
function validateContentServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",352";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  Bool chargeInformationIsPrensentWithinContent = false;
  dataVolumeIncomingIsPresent = false;
  dataVolumeOutgoingIsPresent = false;
  lastContentTransactionCode = -1;
  lastContentTransactionType = -1;
 
  childContext = myContext + "." + "contentTransactionCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateContentTransactionCode ( myContext, nMyIndices, "contentTransactionCode", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "30", "Missing Content Transaction Code");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing Content Transaction Code");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "contentTransactionType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateContentTransactionType ( myContext, nMyIndices, "contentTransactionType", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "31", "Missing Content Transaction Type");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","", "Missing Content Transaction Type");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "objectType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateObjectType ( myContext, nMyIndices, "objectType", 0, errorContext );
  }
  else
  {
    if( lastContentTransactionCode == 3 and lastContentTransactionType == 11 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "34",  
           "Object Type missing within group and 'Pull' Content Transaction Code used within 'Streaming' Content Transaction Type");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", errorContext, "0", "-1", "-1","",
           "Object Type missing within group and 'Pull' Content Transaction Code used within 'Streaming' Content Transaction Type");
      edrSetIsValidDetail(false);
    }
    else if( lastContentTransactionCode == 3 and lastContentTransactionType == 12 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "35",  
           "Object Type missing within group and 'Pull' Content Transaction Code used within 'Download' Content Transaction Type");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", errorContext, "0", "-1", "-1","",
           "Object Type missing within group and 'Pull' Content Transaction Code used within 'Download' Content Transaction Type");
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "transactionDescriptionSupp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransactionDescriptionSupp ( myContext, nMyIndices, "transactionDescriptionSupp", 0, errorContext );
  }
 
  childContext = myContext + "." + "transactionShortDescription";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransactionShortDescription ( myContext, nMyIndices, "transactionShortDescription", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ContentServiceUsed", "352", "32", "Missing Content Transaction Short Description"); 
  }
 
  childContext = myContext + "." + "transactionDetailDescription";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransactionDetailDescription ( myContext, nMyIndices, "transactionDetailDescription", 0, errorContext );
  }
 
  childContext = myContext + "." + "transactionIdentifier";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransactionIdentifier ( myContext, nMyIndices, "transactionIdentifier", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "33", "Missing Content Transaction Identifier");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1", "","Missing Content Transaction Identifier");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "transactionAuthCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTransactionAuthCode ( myContext, nMyIndices, "transactionAuthCode", 0, errorContext );
  }
 
  childContext = myContext + "." + "dataVolumeIncoming";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    dataVolumeIncomingIsPresent = true;
    validateDataVolumeIncoming ( myContext, nMyIndices, "dataVolumeIncoming", 0, errorContext );
  }
 
  childContext = myContext + "." + "dataVolumeOutgoing";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    dataVolumeOutgoingIsPresent = true;
    validateDataVolumeOutgoing ( myContext, nMyIndices, "dataVolumeOutgoing", 0, errorContext );
  }
 
  childContext = myContext + "." + "totalDataVolume";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalDataVolume ( myContext, nMyIndices, "totalDataVolume", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargeRefundIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    hasChargeRefund = true;
    validateChargeRefundIndicator ( myContext, nMyIndices, "chargeRefundIndicator", 0, errorContext );
  }
  else
  {
    hasChargeRefund = false;
  }
 
  childContext = myContext + "." + "contentChargingPoint";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateContentChargingPoint ( myContext, nMyIndices, "contentChargingPoint", 0, errorContext );
  }
  else
  {
    if( timeStampEntries > 1 )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "103",
                  "Content Charging Point missing and more than one timestamp present within Content Transaction Basic Info");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "103", errorContext, "0", "-1", "-1","",
                  "Content Charging Point missing and more than one timestamp present within Content Transaction Basic Info");
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "chargeInformationList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    chargeInformationIsPrensentWithinContent = true;
    validateChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0, errorContext );
  }
 
  childContext = myContext + "." + "advisedChargeInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    advisedChargeInfoCount = advisedChargeInfoCount + 1;
    validateAdvisedChargeInformation ( myContext, nMyIndices, "advisedChargeInformation", 0, errorContext );
  }
  else
  {
    if( chargeInformationIsPrensentWithinContent == false )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "102",
                  "Neither of groups Charge Information or Advised Charge Information present within group"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "102", errorContext, "0", "-1", "-1","",
                  "Neither of groups Charge Information or Advised Charge Information present within group");
      edrSetIsValidDetail(false);
    }
  }

 
  //hasChargeRefund = false;
 
  //logContext( myContext, nMyIndices );
}

