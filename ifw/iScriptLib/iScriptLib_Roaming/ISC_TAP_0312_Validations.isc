/******************************************************************************************************************************
 * This function will validate LocationIdentifier. It will raise error code 100 for LocationIdentifier.
 ******************************************************************************************************************************/
 
function validateLocationIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;  
  errorContext = errorContext + ",289";
  
  Long   i;
  Bool   identifierIsValid = false;
  String locationIdentifier = edrStringEx( myContext, indices, nParentIndices );
 
  switch( lastLocationIdType )
  {  
    case 2:
    {
      for( i = 0 ; i < numOfCountryCode and identifierIsValid == false ; i = i + 1 )
      {
        if (locationIdentifier == countryCodeArray[i])
        {
          identifierIsValid = true;
        }
      }
    }
    break;
    case 6:
    {
      identifierIsValid = validateIpV4(locationIdentifier);
    }
    break;
    case 7:
    {
      identifierIsValid = validateIpV6(locationIdentifier);
    }
    break;
    case 8:
    {    
      for( i = 0; i < numOfPlmnoCode and identifierIsValid == false; i = i + 1 )
      {
        if( PLMNOCode[i] == locationIdentifier )
        {
          identifierIsValid = true;
        }
      }          
    }
    break;
    default:
    {
      identifierIsValid = true;
    }
  }
  if ( identifierIsValid == false)
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Location Identifier", "289", "100", "Item content does not match Location Id Type");
  } 
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

