function String getIacList
{
  String localString = "";
  Long size1 = arraySize(calledNumberAnalysisIACarray);
  Long size2 = 0;
  Long i;
  Long j;

  for (i = 0; i < size1; i = i + 1)
  {
    size2 = arraySize(calledNumberAnalysisIACarray[i]);
    for (j = 0; j < size2; j = j + 1)
    {
      localString = localString + calledNumberAnalysisIACarray[i][j] + ", ";
    }
  }

  if (localString == "")
  {
    return NORM_IAC_STRING;
  }
  else
  {
    //strip the last comma
    localString = strSubstr(localString, 0, strLength(localString) - 1);
    return localString;
  }
}

function String getCcList
{
  String localString = "";
  Long size1 = arraySize(calledNumberAnalysisCCarray);
  Long size2 = 0;
  Long i;
  Long j;

  for (i = 0; i < size1; i = i + 1)
  {
    size2 = arraySize(calledNumberAnalysisCCarray[i]);
    for (j = 0; j < size2; j = j + 1)
    {
      localString = localString + calledNumberAnalysisCCarray[i][j] + ", ";
    }
  }

  if (localString == "")
  {
    return NORM_CC_STRING;
  }
  else
  {
    //strip the last comma
    localString = strSubstr(localString, 0, strLength(localString) - 1);
    return localString;
  }
}

function String buildNullFiller(Long desiredLen, Long effectiveLen)
{
  String filler = "";
  if (effectiveLen < desiredLen)
  {
    switch (effectiveLen)
    {
      case 0 : filler="00000";break;
      case 1 : filler="0000"; break;
      case 2 : filler="000";  break;
      case 3 : filler="00";   break;
      case 4 : filler="0";    break;
      default:                break;
    }
  }
  return filler;
}



                                                                                                             
function mapOperatorSpecInformation ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "HEADER" ) == true )
  {
    edrString(HEADER.OPERATOR_SPECIFIC_INFO) = edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith ( parentContext, "DETAIL" ) == true )
  {
    edrString(DETAIL.OPERATOR_SPECIFIC_INFO) = edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith ( parentContext, "TRAILER" ) == true )
  {
    edrString(TRAILER.OPERATOR_SPECIFIC_INFO) = edrStringEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapOperatorSpecInfoList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "OperatorSpecInformation_Elem";                                       
  Long OperatorSpecInfoListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < OperatorSpecInfoListEntries; i = i + 1 )                                                      
  {                                                                                                          
    indices[nMyIndices] = i;                                                                                 
    Long nChildIndices  = nMyIndices + 1;                                                                    
    mapOperatorSpecInformation ( childContext, nChildIndices, "OperatorSpecInformation", 0 );                         
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapFileTypeIndicator ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( myContext == "HEADER.notification.fileTypeIndicator" or
       myContext == "HEADER.batchControlInfo.fileTypeIndicator" or 
       myContext == "HEADER.acknowledgement.fileTypeIndicator" or
       myContext == "HEADER.rapBatchControlInfoRap.fileTypeIndicator" )
  {
    theFileTypeIndicator = edrStringEx( myContext, indices, nParentIndices );
    edrString(HEADER.DATA_TYPE_INDICATOR) = theFileTypeIndicator;
  }

  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapReleaseVersionNumber ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( myContext == "HEADER.notification.releaseVersionNumber" or
       myContext == "HEADER.batchControlInfo.releaseVersionNumber" or 
       myContext == "HEADER.acknowledgement.releaseVersionNumber" or
       myContext == "HEADER.rapBatchControlInfoRap.releaseVersionNumber" )
  {
