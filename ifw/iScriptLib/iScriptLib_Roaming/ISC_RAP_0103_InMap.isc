include "ISC_TAP_0311_Include.isc";
                                                                                                                                                                    
function mapOperatorSpecList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "OperatorSpecInformation_Elem";                                       
  Long OperatorSpecListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < OperatorSpecListEntries; i = i + 1 )                                                      
  {                                                                                                          
    indices[nMyIndices] = i;                                                                                 
    Long nChildIndices  = nMyIndices + 1;                                                                    
    mapOperatorSpecInformation ( childContext, nChildIndices, "OperatorSpecInformation", 0 );                         
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapAckFileAvailableTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "localTimeStamp";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "utcTimeOffset";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
