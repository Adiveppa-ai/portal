  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "RecEntityCode_Elem";                                       
  Long RecEntityCodeListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < RecEntityCodeListEntries; i = i + 1 )                                                      
  {                                                                                                          
    indices[nMyIndices] = i;                                                                                 
    Long nChildIndices  = nMyIndices + 1;                                                                    
    mapRecEntityCode ( childContext, nChildIndices, "RecEntityCode", 0 );                         
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
