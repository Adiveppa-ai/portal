/******************************************************************************************************************************
 * This function will validate GprsDestination and CamelServiceUsed. It will raise error code 30, 31 for GprsDestination and
 * error code 35 for CamelServiceUsed.
 ******************************************************************************************************************************/
 
function validateGprsDestination ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",116";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  accessPointNameOIIsPresent = false;

  if( (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true) 
      or (strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true) )
  {
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
    {
      objTag = "1,3,9,57";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
    {
      objTag = "1,3,10,57";
    }
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CamelServiceUsed", "57", "35", "GPRS Destination present within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", objTag, "0", "-1", "-1", "","GPRS Destination present within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "accessPointNameNI";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateAccessPointNameNI ( myContext, nMyIndices, "accessPointNameNI", 0, errorContext );
  }
  else
  {
    if (strStartsWith(parentContext, "DETAIL.gprsCall.camelServiceUsed") == true)
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "GPRS Destination", "116", "34", 
                                                 "Mandatory item Access Point Name NI missing within group where it occurs within group 3G CAMEL Destination");
    }
    else
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Destination", "116", "30",
                                                "Mandatory item Access Point Name NI missing within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","",
                                                "Mandatory item Access Point Name NI missing within group");
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "accessPointNameOI";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    accessPointNameOIIsPresent = true;
    validateAccessPointNameOI ( myContext, nMyIndices, "accessPointNameOI", 0, errorContext );
  }
  else if( WiFiNetworkUsage == false and strStartsWith(parentContext, "DETAIL.gprsCall.camelServiceUsed") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "GPRS Destination", "116", "31", 
                                                 "Item Access Point Name OI missing within group");
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate CamelDestinationNumber and CamelServiceUsed. It will raise error code 10, 20 for 
 * CamelDestinationNumber and error code 36 for CamelServiceUsed.
 ******************************************************************************************************************************/
 
function validateCamelDestinationNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",404";
  Bool   countryCodeFound = false;
  Long   i;

  String lastCamelDestinationNumber = edrStringEx(myContext, indices, nParentIndices);

  for( i = 0 ; i < numOfCountryCode and countryCodeFound == false ; i = i + 1 )
  {
    if (strStartsWith(lastCamelDestinationNumber, countryCodeArray[i]))
    {
      countryCodeFound = true;
    }
  }

  if( strStartsWith(parentContext, "DETAIL.gprsCall") == true)
  {
    objTag = "1,3,14,57";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CamelServiceUsed", "57", "36", "Camel Destination Number present within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "36", objTag, "0", "-1", "-1","", "Camel Destination Number present within group");
    edrSetIsValidDetail(false);
  }

  if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.camelServiceUsed") == true or 
                    strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.camelServiceUsed") == true )
  {
    if( strSearchRegExpr(edrStringEx(myContext, indices, nParentIndices), "[^0-9A-E]") >= 0 ) 
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CAMEL Destination Number", "404", "10", "CAMEL Destination Number Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","CAMEL Destination Number Syntax Error");
      edrSetIsValidDetail(false);
    }
    else if( ((strSearchRegExpr(lastCamelDestinationNumber, "[^0-9A-E]") >= 0) or (countryCodeFound == false)) and
   (strLength(lastCamelDestinationNumber) > 7 or strSearchRegExpr(strSubstr(lastCamelDestinationNumber, 0, 1),  "[^0-9A-E]") >= 0) )    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CAMEL Destination Number", "404", "20",
                                                "Number not short code and not represented in International format");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "",
                                                "Number not short code and not represented in International format");
      edrSetIsValidDetail(false);
    }
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate Destination. It will raise error code 41 for Destination.
 ******************************************************************************************************************************/
 
function validateThreeGcamelDestination ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",431";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "camelDestinationNumber";

  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCamelDestinationNumber ( myContext, nMyIndices, "camelDestinationNumber", 0, errorContext );
  }
  else
  {
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.camelServiceUsed") == true and calledNumberIsMissing == true 
        and callIndicatesInternational == true )
    {
      objTag = "1,3,9,147,89";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Destination", "89", "41",
              "CalledNumber not present and CallTypeLevel1 indicates an international call and CAMELDestinationNumber not present");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "41", objTag, "0", "-1", "-1","",
              "CalledNumber not present and CallTypeLevel1 indicates an international call and CAMELDestinationNumber not present");
      edrSetIsValidDetail(false);
    }
  }
      
  childContext = myContext + "." + "gprsDestination";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGprsDestination ( myContext, nMyIndices, "gprsDestination", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate CamelInvocationFee and CAMELServiceUsed. It will raise error code 20, 21 for CamelInvocationFee
 * and error code 30, 40 for CAMELServiceUsed.
 ******************************************************************************************************************************/
 
function validateCamelInvocationFee ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",422";
  Long lastCamelInvocationFee = edrLongEx( myContext, indices, nParentIndices );
  totalCalcCharge = totalCalcCharge + lastCamelInvocationFee;

  if( edrLongEx( myContext, indices, nParentIndices ) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CAMEL Invocation Fee", "422", "20", "CAMEL Invocation Fee is negative");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","CAMEL Invocation Fee is negative");
    edrSetIsValidDetail(false);
  }
  else if( edrLongEx( myContext, indices, nParentIndices ) == 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "CAMEL Invocation Fee", "422", "21", "CAMEL Invocation Fee is Zero");
  }
  if( (camelServiceLevelIsMissing == true) and (edrLongEx( myContext, indices, nParentIndices ) > 0) )
  {
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
    {
      objTag = "1,3,9,57";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
    {
      objTag = "1,3,10,57";
    }
    else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
      objTag = "1,3,14,57";
    }
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CAMEL Service Used", "57", "30", 
                "CAMEL Service Level missing within group and CAMEL Invocation Fee is present and greater than zero");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", objTag, "0", "-1", "-1", "",
                 "CAMEL Service Level missing within group and CAMEL Invocation Fee is present and greater than zero");
    edrSetIsValidDetail(false);
  }
  if( (exchangeRateCodeIsMissing == true) and (edrLongEx( myContext, indices, nParentIndices ) > 0) )
  {
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
    {
      objTag = "1,3,9,57";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
    {
      objTag = "1,3,10,57";
    }
    else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
    {
      objTag = "1,3,14,57";
    }
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CAMEL Service Used", "57", "40",
                "Exchange Rate Code is missing within group and CAMEL Invocation Fee is greater than zero");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "40", objTag, "0", "-1", "-1", "",
                "Exchange Rate Code is missing within group and CAMEL Invocation Fee is greater than zero");
    edrSetIsValidDetail(false);
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

