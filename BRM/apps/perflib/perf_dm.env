#------------------------------------------------------------------------------#
# FILE: perf.env
#
# DESCRIPTION:
#
# Environment file (sourced by other scripts) to define the performance library
# settings.
#
# INFORMATION:
#
# BRM Performance Tools ...
#
# REVISION:
#
# $Revision: 1.55 $
# $Author: ihargrea $
# $Date: 2019/11/14 20:42:39 $
#------------------------------------------------------------------------------#

#------------------------------------------------------------------------------#
# PERFLIB_HOME
#
# Directory where Perflib is installed. This is, by default, the location where
# logs, data file etc. will be kept.
#------------------------------------------------------------------------------#
export PERFLIB_HOME
if [ -z "$PERFLIB_HOME" ]
then
   PERFLIB_HOME=$(pwd)
fi

if [ ! -d "$PERFLIB_HOME" ]
then
   echo "ERROR: \$PERFLIB_HOME[$PERFLIB_HOME] is not a valid directory" >&2
   exit 1
fi

#------------------------------------------------------------------------------#
# PERFLIB_DEBUG
#
# Set debug on - prints lots of (potentially) useful information on stderr.
#
# The value should be the OR'd combination of:
#
# 0  Debug off
# 1  Log summary information to stderr (e.g. file opening, flushing etc.)
# 2  Log detailed opcode execution information to stderr
# 4  Log trace information (log details on entry/exit) to stderr
#
# Default is to switch this behaviour off (i.e. 0)
#------------------------------------------------------------------------------#
export PERFLIB_DEBUG=0

#------------------------------------------------------------------------------#
# PERFLIB_LOGDIR - Define the directory where trace output will be written.
# The default is that all output will be produced in the directory where this
# script is launched.
#------------------------------------------------------------------------------#
export PERFLIB_LOGDIR=${PERFLIB_LOG_DIR:-$PERFLIB_HOME}
if [ ! -d "$PERFLIB_LOGDIR" ]
then
   echo "ERROR: \$PERFLIB_LOGDIR[$PERFLIB_LOGDIR] is not a valid directory" >&2
   exit 1
fi

#------------------------------------------------------------------------------#
# PERFLIB_OPCODE_BUCKET_FILE - define a file containing a list of opcodes for
# which more precise timing information is required. This file allows us to
# configure timing "buckets" to sub-divide the results for any opcode into
# separate time ranges.
# For example, we can specify ranges for the rating opocde to determine whether
# most rating opcodes execute in a certain range and whether there exist any
# strange cases where time is excessive (this can be used to determine whether
# the JRE is saturated).
#------------------------------------------------------------------------------#
#export PERFLIB_OPCODE_BUCKET_FILE=$PERFLIB_HOME/opcode_buckets.lst

#------------------------------------------------------------------------------#
# PERFLIB_MAX_LOG_SIZE - Determines the maximum number of opcodes that will be
# logged in any one log file. This can be used to prevent excessively large
# log files if detailed tracing is used for long periods.
#
# A value of 0 will imply the creation of a single file (i.e. no limit). Any
# positive value wil define the maximum number of opcodes (at level 1) that
# will be tracked before a new file will be opened.
#------------------------------------------------------------------------------#
export PERFLIB_MAX_LOG_SIZE=0

#------------------------------------------------------------------------------#
# PERFLIB_LICENSE - Defines the license key which enables the Perflib to work
# correctly. This key should have been provided to you. If not, please contact
# the person who supplied the library.
#------------------------------------------------------------------------------#
export PERFLIB_LICENSE="Enter License Key Here"

#------------------------------------------------------------------------------#
# PERFLIB_AGGREGATION_PERIOD - Defines the period of time over which data is
# recorded. This defines the buckets into which data will be collected so that
# they may be collected and reported in well-defined periods for analysis.
#
# The aggregation period may be specified in minutes, or hours and based on the
# value a working "day" will be split into a fixed set of period "buckets" into
# which data will aggregated.
#
# For example, hourly aggregation periods will cause data to be grouped as:
#
#   Hour  Number of
#         Daily Buckets   Example Bucket ranges
#   ----  --------------  ---------------------
#      1             24   00:00:00 to 01:00:00, 01:00:00 to 02:00:00 etc.
#      2             12   00:00:00 to 02:00:00, 02:00:00 to 04:00:00 etc.
#      3              8   00:00:00 to 03:00:00, 03:00:00 to 06:00:00 etc.
#      4              6   00:00:00 to 04:00:00, 04:00:00 to 08:00:00 etc.
#      5            N/A   not allowed
#      6              4   00:00:00 to 06:00:00, 06:00:00 to 12:00:00 etc.
#      7            N/A   not allowed
#      8              3   00:00:00 to 08:00:00, 08:00:00 to 16:00:00 etc.
#   9-10            N/A   not allowed
#     12              2   00:00:00 to 12:00:00, 12:00:00 to 00:00:00
#  13-23            N/A   not allowed
#     24              1   00:00:00 to 00:00:00
#
# Similarly, minute aggregation periods will cause data to be grouped as
# follows (data will always be rounded to the appropriate hour):
#
# Minute  Number of
#         Hourly Buckets  Example Bucket ranges
# ------  --------------  ---------------------
#      1              60  00:00:00 to 00:01:00, 00:01:00 to 00:02:00 etc.
#      2              30  00:00:00 to 00:02:00, 00:02:00 to 00:04:00 etc.
#      3              20  00:00:00 to 00:03:00, 00:03:00 to 00:06:00 etc.
#      4              15  00:00:00 to 00:04:00, 00:03:00 to 00:08:00 etc.
#      5              12  00:00:00 to 00:05:00, 00:05:00 to 00:10:00 etc.
#      6              10  00:00:00 to 00:06:00, 00:06:00 to 00:12:00 etc.
#    7-9             N/A  not allowed
#     10               6  00:00:00 to 00:10:00, 00:10:00 to 00:20:00 etc.
#     11             N/A  not allowed
#     12               5  00:00:00 to 00:12:00, 00:12:00 to 00:24:00 etc.
#  13-14             N/A  not allowed
#     15               4  00:00:00 to 00:15:00, 00:15:00 to 00:30:00 etc.
#  16-19             N/A  not allowed
#     20               3  00:00:00 to 00:20:00, 00:20:00 to 00:40:00 etc.
#  21-29             N/A  not allowed
#     30               2  00:00:00 to 00:30:00, 00:30:00 to 00:00:00
#  31-59             N/A  not allowed
#     60               1  00:00:00 to 00:60:00 (or 00:00:00)
#
# E.g. "PERFLIB_AGGREGATION_PERIOD=1h" will aggregate data into 24 hourly
# groups.
#
# The default value is 1h (i.e. hourly buckets)
#------------------------------------------------------------------------------#
export PERFLIB_AGGREGATION_PERIOD=1h

#------------------------------------------------------------------------------#
# PERFLIB_FLUSH_FREQUENCY - Defines the period of time after which aggregated
# opcode performance data will be flushed to file.
#
# E.g. "PERFLIB_FLUSH_FREQUENCY=60" will flush data every minute (60 seconds)
#
# NOTE: This will only apply if PERFLIB_AGGREGATION_PERIOD is set to define
#       aggregated reporting. If PERFLIB_FLUSH_FREQUENCY is set to 0 then the
#       data will be flushed for every opcode - this should not be used for
#       normal CM/MTA tracing (as it will log constantly), it is reserved for
#       future use.
#------------------------------------------------------------------------------#
export PERFLIB_FLUSH_FREQUENCY=3600

#------------------------------------------------------------------------------#
# PERFLIB_LOG_SINGLE_FILE - Log all data to a single output file (the default
# behaviour is to log to a separate file per CM). This option resolves the
# problem of generating large numbers of files for applications which often
# open and close contexts.
#
# The entry should be configured with the filename prefix which will be used.
# The file will be created in the directory defined in PERFLIB_LOGDIR and the
# process ID and timestamp are added to this prefix to generate the
# full, unique pathname).
#
# E.g. Setting PERFLIB_LOG_SINGLE_FILE=perf_log
#
# Will generate files of the form:
#
# $PERFLIB_LOGDIR/perf_log.8473.0.1260525429.478232000.plog.txt
#
# NOTE: If you are monitoring multiple applications you should have a separate
#       log file for each application. Failure to do so could result in trace
#       data being mixed-up for different applications.
#------------------------------------------------------------------------------#
export PERFLIB_LOG_SINGLE_FILE=perf_log

#------------------------------------------------------------------------------#
# PERFLIB_LOG_MAX_SINGLE_FILE_SIZE - Limit the size of aggregated files to
# 'approximately' this file size. As soon as any flush of data to the file
# causes this size to be exceeded, a new file will be created.
#
# The size is not controlled precisely so that any particular log file is always
# guaranteed to have a consisitent set of data in it. This functionality will
# simply allow file-sizes to be controlled to avoid excessively large files 
# being created.
#
# The size is specified in bytes. The example file-size configured below is
# 50Mb, the default value (if this parameter is not enabled or set to zero) is
# 1Gb.
#------------------------------------------------------------------------------#
#export PERFLIB_LOG_MAX_SINGLE_FILE_SIZE=52428800

#------------------------------------------------------------------------------#
# PERFLIB_PIN_SHLIB - Define the full path to the shared library in which core
# BRM functionality for CMs and applications are defined. This is necessary
# to locate some flist management functions which the PerfLib needs to access.
#
# The existing values are usually correct, but change them if your BRM
# installation libraries are somewhere else.
#
# The library required will depend on the application being traced:
#
# Connection Manager (CM)               : libcmpin.so
# MTA Application (e.g. pin_bill_accts) : libportal.so
# DM (dm_mon.so)                        : libdmpin.so
#
# NOTE: $LIBRARYEXTENSION is usually .so (Solaris/Linux/HP-Itanium) or .sl
#       for (HP PA-RISC) and is setup in the BRM environment.
#
# NOTE: For Infranet 6.5/6.7, this variable should be set to:
#
#       PERFLIB_PIN_SHLIB=$PIN_HOME/lib/libcm_main${LIBRARYEXTENSION}
#
#       The default settings described above are OK for 7.X systems.
#------------------------------------------------------------------------------#
#
# CM - use libcmpin
#
export PERFLIB_PIN_SHLIB=$PIN_HOME/lib/libcmpin${LIBRARYEXTENSION}

#
# MTA / custom applications - use libportal
#
#export PERFLIB_PIN_SHLIB=$PIN_HOME/lib/libportal${LIBRARYEXTENSION}

#
# DM - use libdmpin
#
# Also for the dm_mon.so example, you will need to set DM_MON_SHLIB to the
# main DM shared library you are "wrapping" - the example below is for a 10g
# BRM Oracle data manager (but the dm_mon.so example can wrap any DM).
#
export PERFLIB_PIN_SHLIB=$PIN_HOME/lib/libdmpin64${LIBRARYEXTENSION}
#export DM_MON_SHLIB=$PIN_HOME/sys/dm_oracle/dm_oracle10g.so

#------------------------------------------------------------------------------#
# PERFLIB_ALARM - General alarm to trigger the logging of information regarding
# any opcode call which exceeds a particular elapsed time. For full details on
# the configuration of this parameter, please see the example configuration
# file "config/alarm_config.lst".
#
# NOTE: Opcode-specific alarms with multiple severity levels may be configured
#       using the PERFLIB_ALARM_CONFIG_FILE. These options are mutually
#       exclusive (a global default configuration is supported in the opcode
#       specific configuration, allowing a catch-all behaviour which supplants
#       this simple global configuration).
#
# NOTE: This parameter is mutually exclusive with PERFLIB_ALARM_CONFIG_FILE
#
# NOTE: Alarms should NOT be used if tracing multi-thread applications.
#------------------------------------------------------------------------------#
#export PERFLIB_ALARM=1.0,*4096,WARNING

#------------------------------------------------------------------------------#
# PERFLIB_ALARM_CONFIG_FILE - Specifies a file containing a list of opcodes for
# which alarms may be raised. This file allows us to configure "buckets" for
# time limits to raise alarms with configurable severity codes, just like the
# global alarm setting PERFLIB_ALARM.
#
# NOTE: This parameter is mutually exclusive with PERFLIB_ALARM.
#
# NOTE: Alarms should NOT be used if tracing multi-thread applications.
#------------------------------------------------------------------------------#
#export PERFLIB_ALARM_CONFIG_FILE=$PERFLIB_HOME/alarm_config.lst

#------------------------------------------------------------------------------#
# PERFLIB_DATA_FILE - Control file for each application which is being
# traced. There must be ONE file per process - so if you have 3 different CMs
# to track, you'll need to setup 3 different perf.env files (or at least 3
# different sets of data files). Failure to do so may result in undefined
# behaviour.
#
# The filename may contain the following tokens which will be replaced when the
# file is created with process-specific values.
#
#    %p - PID
#    %t - Timestamp (as UNIX timestamp)
#    %T - Timestamp (as YYYYMMDDhhmiss time string)
#
# E.g. one might define:
#
#    PERFLIB_DATA_FILE=data_file_%p_%t.dat
#
# Which would generate a file of the form:
#
#    data_file_3484_1382849484.dat
#------------------------------------------------------------------------------#
export PERFLIB_DATA_FILE=$PERFLIB_HOME/perflib_dm_oracle_data.dat

#------------------------------------------------------------------------------#
# PERFLIB_DATA_FILE_RESET - Determines whether the data in a perflib data file
# is reset when a process restarts or not. If set to 'Y' the statistics will be
# reset to zero; if set to 'N' the statistics will be left to accumulate.
#------------------------------------------------------------------------------#
export PERFLIB_DATA_FILE_RESET=Y

#------------------------------------------------------------------------------#
# PERFLIB_VAR_XXXX - Initial values to set for perflib variables when an
# application starts. In most cases tracing will be enabled later whilst an
# application is running, but in some cases it is useful to start tracing data
# immediately (e.g. to monitor CM startup performance).
#
# The variables should be set to one of the following values:
#
# PERFLIB_VAR_TIME:
#    0 - Timing will be disabled at startup
#    1 - Real-time timing will be enabled at startup
#    2 - File-based timing will be enabled at startup
#    3 - File-based and Real-time timing will be enabled at startup
#
# PERFLIB_VAR_FLIST:
#    0 - Flist logging will be disabled
#    1 - Summary logging will be enabled at startup
#    2 - Full flist logging will be enabled at startup
#
# PERFLIB_VAR_ALARM:
#    0 - Alarms are disabled at startup
#    1 - Alarms are enabled at startup
#------------------------------------------------------------------------------#
export PERFLIB_VAR_TIME=0
export PERFLIB_VAR_FLIST=0
export PERFLIB_VAR_ALARM=0

#------------------------------------------------------------------------------#
# PERFLIB_AUTO_FLUSH - This may be set for a CM to ensure that data is flushed
# regularly in line with the PERFLIB_FLUSH_FREQUENCY setting. By default, if
# a CM does not receive any opcode requests, flushing will not be performed
# until the CM terminates or an opcode arrives. If you set this parameter to
# 0x01 the data will be automatically flushed at the appropriate time. If you
# also have a situation in which some very long operations are executed and
# you wish to ensure data is always logged on the flush frequency, the option
# 0x02 can be set to force flushing even within the execution of a single
# opcode (flushing is always handled outside a single opcode call, so if an
# opcode simply goes into an infinite loop, this will not be logged).
# Both options can be enabled together with the option 0x03.
#
# WARNING: this parameter must NOT be used in multi-thread applications - it
#          will not work and will probably, at best, only flush on one thread.
#          Future versions of the Perflib will implement auto-flush for MT
#          applications, but for now they are assumed to be MTA-like apps which
#          will either be working, or soon terminate.
#------------------------------------------------------------------------------#
export PERFLIB_AUTO_FLUSH=0

#------------------------------------------------------------------------------#
# PERFLIB_COLLECT_CPU_USAGE - This may be set for a CM to allow CPU utilisation
# data to be collected (using getrusage()). This collects user and system CPU
# data for each opcode. Valid values are:
#    0  - off (don't collect CPU data)
#    >0 - on (do collect CPU data for opcodes up to this "depth"). E.g. 1 will
#         collect for top-level opcodes, 2 for top and 2nd level etc.
#------------------------------------------------------------------------------#
export PERFLIB_COLLECT_CPU_USAGE=1

#------------------------------------------------------------------------------#
# PERFLIB_LOCK_METHOD - Defines the method used to lock between processes.
#    0 - Use POSIX shared-memory mutexes (default)
#    1 - Use file-based advisory locks
#------------------------------------------------------------------------------#
export PERFLIB_LOCK_METHOD=0

#------------------------------------------------------------------------------#
# PERFLIB_ASYNC_FLUSHING - Determines whether flushing to the trace file from
# memory is done within the opcode execution, or asynchronously in a separate
# thread. Flushing during opcode execution can cause problems with applications
# which expect low latency responses (as operations serialise on the trace
# file during writing, causing delays). Asynchronous flushing just copies a
# reference to the data so has almost no impact on opcode execution latencies.
#    0 - Flush data to the trace file within the opcode execution
#    1 - Flush data to the trace file in a separate processing thread
#------------------------------------------------------------------------------#
export PERFLIB_ASYNC_FLUSHING=1

#------------------------------------------------------------------------------#
# PERFLIB_TRACE_OBJECT_TYPE - Allow the poid-type of base opcode calls to be
# collected each call so that DB operations can be broken down and associated
# with particular DB objects:
#
#    0 - Do not collect object type data
#    1 - Collect object type and record it in RT/batch trace files
#------------------------------------------------------------------------------#
export PERFLIB_TRACE_OBJECT_TYPE=1

#------------------------------------------------------------------------------#
# PERFLIB_GROUP_TRANSACTIONS - Allows Perflib to track BRM transactions as a
# single unit. The opcodes executed as part of a transaction will be grouped
# under a virtual opcode, TRANSACTION_GROUP.
#
#    0 - Do not group transactions
#    1 - Group transactions
#------------------------------------------------------------------------------#
export PERFLIB_GROUP_TRANSACTIONS=0

#------------------------------------------------------------------------------#
# PERFLIB_ALARM_LOG_AT_LIMIT - Specifies whether an 'interim' alarm record will
# be generated event for alarms with only one limit. If this is set to 0 (the
# default) then only the 'final' alarm record will be generated when the opcode
# terminates. If it is set to 1, then an 'interim' alarm will be recorded as soon
# as the limit is breached, followed by a 'final' record when the operation
# completes.
#
# NOTE: Alarms should NOT be used if tracing multi-thread applications.
#------------------------------------------------------------------------------#
export PERFLIB_ALARM_LOG_AT_LIMIT=0

export DM_PERFLIB_ENABLED=0
