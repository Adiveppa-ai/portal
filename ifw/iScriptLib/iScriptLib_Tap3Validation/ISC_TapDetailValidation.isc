//------------------------------------------------------------------------------
// validateServiceUsedListPaymentMethod()
//
// This function will be used to validate the ServiceUsedListPaymentMethod
//------------------------------------------------------------------------------
function validateServiceUsedListPaymentMethod
{
  const String ruleID  = "TAP3.ASS_CONT_EXT.SERVICE_USED_LIST.PAYMENT_METHOD";
  const String severe  = "severe";
  const String warning = "warning";
  const String tag     = "347";
  const String depth   = "6";
  const String offset  = "-1";

  if (debug)
  {
    logStdout("validateServiceUsedListPaymentMethod()\n");
  }

  Long blockIndex;
  Long blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long paymentState = edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.PAYMENT_METHOD, 0, blockIndex);
    Long paymentStateI = edrInternalState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.PAYMENT_METHOD, 0, blockIndex);
    if (paymentStateI != STATE_CLEARED and paymentState != EDR_INPUT_MISSING)
    {
      Long paymentMethod = edrLong(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.PAYMENT_METHOD, 0, blockIndex);
      if ((paymentMethod < 0) or (paymentMethod > 8))
      {
        // offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.PAYMENT_METHOD, 0, blockIndex));
        edrAddError("ERR_TAP3_RET", LOG_WARNING, warning, "20", tag, depth, offset,
		longToStr(blockIndex), ruleID);
        setAssociatedTapErr("ERR_TAP3_SERVICE_USED_LIST_PAYMENT_METHOD", LOG_WARNING ,"20" ,tag ,depth);	
      }
    }
  }
}

//------------------------------------------------------------------------------
// validateServiceUsedListTotalDataVolume()
//
// This function will be used to validate the ServiceUsedListTotalDataVolume
//------------------------------------------------------------------------------
function validateServiceUsedListTotalDataVolume
{
  const String ruleID  = "TAP3.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME";
  const String severe  = "severe";
  const String warning = "warning";
  const String tag     = "343";
  const String depth   = "5";
  const String offset  = "-1";

  if (debug)
  {
    logStdout("validateServiceUsedListTotalDataVolume()\n");
  }

  Long blockIndex;
  Long blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long dataVolumeState = edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME, 0, blockIndex);
    Long dataVolumeStateI = edrInternalState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME, 0, blockIndex);
    if (dataVolumeStateI != STATE_CLEARED and dataVolumeState != EDR_INPUT_MISSING)
    {
      if (edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME,
		0, blockIndex) < 0)
      {
        // offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.TOTAL_DATA_VOLUME, 0, blockIndex));
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "20", tag, depth,
		offset, longToStr(blockIndex), ruleID);
        setAssociatedTapErr("ERR_TAP3_SERVICE_USED_LIST_TOTAL_DATA_VOLUME", LOG_MAJOR ,"20" ,tag ,depth);	
      }
    }
  }
}

