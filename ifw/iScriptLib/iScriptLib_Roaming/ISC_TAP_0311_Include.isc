function mapCurrencyConversion ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  lastCode = -1;
  childContext = myContext + "." + "exchangeRateCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapExchangeRateCode ( myContext, nMyIndices, "exchangeRateCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "numberOfDecimalPlaces";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapNumberOfDecimalPlaces ( myContext, nMyIndices, "numberOfDecimalPlaces", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "exchangeRate";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapExchangeRate ( myContext, nMyIndices, "exchangeRate", 0 );                               
  }                                                                                                          
  
  if (currencyEntries <= lastCode)
  {
    currencyEntries = lastCode + 1;
  }
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
