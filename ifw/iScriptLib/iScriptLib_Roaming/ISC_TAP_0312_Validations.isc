/******************************************************************************************************************************
 * This function will validate TotalDataVolume and ContentServiceUsed. It will raise error code 20 for TotalDataVolume and
 * error code 100, 101 for ContentServiceUsed.
 ******************************************************************************************************************************/
 
function validateTotalDataVolume ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",343";
  Long totalDataVolume = edrLongEx(myContext, indices, nParentIndices);
  
  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TotalDataVolume", "343", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }


  if( dataVolumeIncomingIsPresent == true and dataVolumeOutgoingIsPresent == true and 
                                              totalDataVolumeIncomingOutgoingValue != totalDataVolume )
  {
    objTag = "1,3,17,285,352";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ContentServiceUsed", "352", "100",
                "Total Data Volume value does not equal the sum of Data Volume Incoming + Data Volume Outgoing"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", objTag, "0", "-1", "-1","",
                "Total Data Volume value does not equal the sum of Data Volume Incoming + Data Volume Outgoing");
    edrSetIsValidDetail(false);
  }
  else if( (dataVolumeIncomingIsPresent == true and dataVolumeOutgoingIsPresent == false) or
           (dataVolumeIncomingIsPresent == false and dataVolumeOutgoingIsPresent == true) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ContentServiceUsed", "352", "101", 
                "Total Data Volume and either Data Volume Incoming or Data Volume Outgoing present within group");
  }
    
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate DataVolumeOutgoing. It will raise error code 20 for DataVolumeOutgoing.
 ******************************************************************************************************************************/
 
function validateDataVolumeOutgoing ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",251";

  dataVolumeOutgoingValue = edrLongEx(myContext, indices, nParentIndices);

  totalDataVolumeIncomingOutgoingValue = (dataVolumeIncomingValue + dataVolumeOutgoingValue);

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Data Volume Outgoing", "251", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }

 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

