  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapUtcTimeOffset ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  lastUtcTimeOffset = edrStringEx( myContext, indices, nParentIndices );

  if (strEndsWith(parentContext, "fileCreationTimeStamp") == true)
  {
    theFileCreationUtcTimeOffset = lastUtcTimeOffset;
    edrString(HEADER.UTC_TIME_OFFSET) = theFileCreationUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "fileAvailableTimeStamp") == true)
  {
    theFileAvailableUtcTimeOffset = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "transferCutOffTimeStamp") == true)
  {
  }
  else if (strEndsWith(parentContext, "earliestCallTimeStamp") == true)
  {
    edrString(TRAILER.FIRST_CHARGING_UTC_TIME_OFFSET) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "latestCallTimeStamp") == true)
  {
    edrString(TRAILER.LAST_CHARGING_UTC_TIME_OFFSET) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "UtcTimeOffsetInfo") == true)
  {
    utcTimeOffset[lastCode] = edrStringEx( myContext, indices, nParentIndices );
  }
  else if (strEndsWith(parentContext, "ackFileCreationTimeStamp") == true or
           strEndsWith(parentContext, "rapFileCreationTimeStamp") == true )
  {
    theFileCreationUtcTimeOffset = lastUtcTimeOffset;
    edrString(HEADER.UTC_TIME_OFFSET) = theFileCreationUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "ackFileAvailableTimeStamp") == true or
           strEndsWith(parentContext, "rapFileAvailableTimeStamp") == true )
  {
    theFileAvailableUtcTimeOffset = lastUtcTimeOffset;
  }
	  
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapLocalTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  lastLocalTimeStamp = edrStringEx( myContext, indices, nParentIndices );

  if (strEndsWith(parentContext, "fileCreationTimeStamp") == true)
  {
    theFileCreationTimeStamp = lastLocalTimeStamp;
    edrDate(HEADER.CREATION_TIMESTAMP) = strToDate(theFileCreationTimeStamp);
  }
  else if (strEndsWith(parentContext, "fileAvailableTimeStamp") == true)
  {
    theFileAvailableTimeStamp = lastLocalTimeStamp;
    edrDate(HEADER.TRANSMISSION_DATE) = strToDate(theFileAvailableTimeStamp);
  }
  else if (strEndsWith(parentContext, "transferCutOffTimeStamp") == true)
  {
    edrDate(HEADER.TRANSFER_CUTOFF_TIMESTAMP) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "earliestCallTimeStamp") == true)
  {
    edrDate(TRAILER.FIRST_START_TIMESTAMP) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "latestCallTimeStamp") == true)
  {
    edrDate(TRAILER.LAST_START_TIMESTAMP) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "chargingTimeStamp") == true)
  {
    if ((record_Type == record_MSS) or (record_Type == record_SCU) or (record_Type == record_VAS))
    {
      edrDate(DETAIL.CHARGING_START_TIMESTAMP) = strToDate(lastLocalTimeStamp);
      edrDate(DETAIL.CHARGING_END_TIMESTAMP) = strToDate(lastLocalTimeStamp);
    }

    if (service_Type == service_Basic)
    {
      edrDate(DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_START_TIMESTAMP, 0, bsPacketIdx) = strToDate(lastLocalTimeStamp);
      edrDate(DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_END_TIMESTAMP, 0, bsPacketIdx) = strToDate(lastLocalTimeStamp);
    }

    if (service_Type == service_Suppl)
    {
      edrDate(DETAIL.ASS_GSMW_EXT.SS_PACKET.CHARGING_START_TIMESTAMP, 0, ssPacketIdx) = strToDate(lastLocalTimeStamp);
      edrDate(DETAIL.ASS_GSMW_EXT.SS_PACKET.CHARGING_END_TIMESTAMP, 0, ssPacketIdx) = strToDate(lastLocalTimeStamp);
    }
  }
  else if (strEndsWith(parentContext, "chargeDetailTimeStamp") == true)
  {
    lastChargeDetailTimeStamp = lastLocalTimeStamp;
  }
  else if (strEndsWith(parentContext, "callEventStartTimeStamp") == true)
  {
    edrDate(DETAIL.CHARGING_START_TIMESTAMP) = strToDate(lastLocalTimeStamp);
    edrDate(DETAIL.CHARGING_END_TIMESTAMP) = strToDate(lastLocalTimeStamp);
    lastValidLocalTimeStamp = lastLocalTimeStamp;
  }
  else if (strEndsWith(parentContext, "orderPlacedTimeStamp") == true)
  {
    edrDate(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "requestedDeliveryTimeStamp") == true)
  {
    edrDate(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "actualDeliveryTimeStamp") == true)
  {
    edrDate(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "depositTimeStamp") == true)
  {
    lastValidLocalTimeStamp = lastLocalTimeStamp;
    edrDate(DETAIL.CHARGING_START_TIMESTAMP) = strToDate(lastLocalTimeStamp);

    Long i;
    for (i=0; i<edrNumDatablocks(DETAIL.ASS_CBD.CP, ACBidx); i=i+1)
    {
      if (edrDate(DETAIL.ASS_CBD.CP.CHARGING_START_TIMESTAMP, ACBidx, i) == defLocalTime)
      {
        edrDate(DETAIL.ASS_CBD.CP.CHARGING_START_TIMESTAMP, ACBidx, i) = edrDate(DETAIL.CHARGING_START_TIMESTAMP);
      }
    }
  }
  else if (strEndsWith(parentContext, "completionTimeStamp") == true)
  {
    edrDate(DETAIL.CHARGING_END_TIMESTAMP) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "lCSRequestTimestamp") == true)
  {
    edrDate(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "pDPContextStartTimestamp") == true)
  {
    edrDate(DETAIL.ASS_GPRS_EXT.PDP_CONTEXT_START_TIMESTAMP, 0) = strToDate(lastLocalTimeStamp);
  }
  else if (strEndsWith(parentContext, "ackFileCreationTimeStamp") == true or
           strEndsWith(parentContext, "rapFileCreationTimeStamp") == true )
  {
    theFileCreationTimeStamp = lastLocalTimeStamp;
    edrDate(HEADER.CREATION_TIMESTAMP) = strToDate(theFileCreationTimeStamp);
  }
  else if (strEndsWith(parentContext, "ackFileAvailableTimeStamp") == true or
           strEndsWith(parentContext, "rapFileAvailableTimeStamp") == true )
  {
    theFileAvailableTimeStamp = lastLocalTimeStamp;
    edrDate(HEADER.TRANSMISSION_DATE) = strToDate(theFileAvailableTimeStamp);
  }
  
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapTransferCutOffTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "localTimeStamp";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "utcTimeOffset";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapUtcTimeOffset ( myContext, nMyIndices, "utcTimeOffset", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
