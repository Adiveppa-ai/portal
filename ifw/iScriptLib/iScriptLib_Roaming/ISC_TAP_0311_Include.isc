function mapCallReference ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "DETAIL.locationService" ) == true )
  {
    edrString(DETAIL.ASS_LOCN_EXT.CALL_REFERENCE, 0) = edrStringEx( myContext, indices, nParentIndices );
  }
  else
  {
    edrString(DETAIL.ASS_GSMW_EXT.CALL_REFERENCE, 0) = edrStringEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapRecEntityCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "HEADER" ) == true )
  {
    lastCode = edrLongEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith ( parentContext, "DETAIL.locationService" ) == true )
  {
    edrLong(DETAIL.ASS_LOCN_EXT.REC_ENTITY_CODE, 0) = edrLongEx( myContext, indices, nParentIndices );
    if ( getRecEntityType( edrLongEx( myContext, indices, nParentIndices )) == recEntityType_GMLC )
    {
      edrString(DETAIL.ASS_LOCN_EXT.GMLC_ADDRESS, 0) = getRecEntityId( edrLongEx( myContext, indices, nParentIndices ));
    }
  }
  else if ( strStartsWith ( parentContext, "DETAIL.serviceCentreUsage" ) == true )
  {
    edrString(DETAIL.ASS_GSMW_EXT.ORIGINATING_SWITCH_IDENTIFICATION, 0) = getRecEntityId(edrLongEx( myContext, indices, nParentIndices ));
  }
  else if ( strStartsWith ( parentContext, "DETAIL.mobileOriginatedCall" ) == true or
            strStartsWith ( parentContext, "DETAIL.mobileTerminatedCall" ) == true or
            strStartsWith ( parentContext, "DETAIL.supplServiceEvent"    ) == true )
  {
    theRecEntityId = getRecEntityId(edrLongEx( myContext, indices, nParentIndices ));
    edrString(DETAIL.ASS_GSMW_EXT.ORIGINATING_SWITCH_IDENTIFICATION, 0) = theRecEntityId;
    edrString(DETAIL.ASS_GSMW_EXT.TERMINATING_SWITCH_IDENTIFICATION, 0) = theRecEntityId;
    if ( strStartsWith ( parentContext, "DETAIL.mobileOriginatedCall" ) == true )
    {
      edrString(DETAIL.INTERN_A_NUMBER_ZONE) = "0000" + theRecEntityId;
    }
    else if ( strStartsWith ( parentContext, "DETAIL.mobileTerminatedCall" ) == true )
    {
      edrString(DETAIL.INTERN_B_NUMBER_ZONE) = "0000" + theRecEntityId;
    }
  }
  else if ( strStartsWith ( parentContext, "DETAIL.gprsCall" ) == true )
  {
    theRecEntityType = getRecEntityType(edrLongEx( myContext, indices, nParentIndices ));
    if (theRecEntityType == recEntityType_GGSN)
    {
      edrString(DETAIL.ASS_GPRS_EXT.GGSN_ADDRESS, 0) = getRecEntityId(edrLongEx( myContext, indices, nParentIndices ));
      edrString(DETAIL.ASS_GPRS_EXT.ORIGINATING_SWITCH_IDENTIFICATION, 0) = edrString(DETAIL.ASS_GPRS_EXT.GGSN_ADDRESS, 0);
    }
    else if (theRecEntityType == recEntityType_SGSN)
    {
      edrString(DETAIL.ASS_GPRS_EXT.SGSN_ADDRESS, 0) = getRecEntityId(edrLongEx( myContext, indices, nParentIndices ));
      if ( edrAddDatablock( DETAIL.ASS_GPRS_EXT.SGSN_INFO_LIST) == false )
      {
      }
      else
      {
        edrString(DETAIL.ASS_GPRS_EXT.SGSN_INFO_LIST.SGSN_ADDRESS, 0, SGSNidx) = getRecEntityId(edrLongEx( myContext, indices, nParentIndices ));
        SGSNidx = SGSNidx + 1;
      }
    }
    else if (theRecEntityType == recEntityType_WLAN)
    {
      edrString(DETAIL.ASS_GPRS_EXT.WLAN_ADDRESS, 0) = getRecEntityId(edrLongEx( myContext, indices, nParentIndices ));
    }
  }

  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapLocationService ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( createNewDetail(record_LOCN, type_LOCN) == false )
  {
  }
  record_Type  = record_LOCN;
  service_Type = service_Location;
                                                                                                             
  childContext = myContext + "." + "rapFileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "recEntityCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRecEntityCode ( myContext, nMyIndices, "recEntityCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "callReference";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapCallReference ( myContext, nMyIndices, "callReference", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "trackingCustomerInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTrackingCustomerInformation ( myContext, nMyIndices, "trackingCustomerInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "lCSSPInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLCSSPInformation ( myContext, nMyIndices, "lCSSPInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "trackedCustomerInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTrackedCustomerInformation ( myContext, nMyIndices, "trackedCustomerInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "locationServiceUsage";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLocationServiceUsage ( myContext, nMyIndices, "locationServiceUsage", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
