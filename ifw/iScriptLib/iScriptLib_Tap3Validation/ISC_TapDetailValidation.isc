//------------------------------------------------------------------------------
// validateContentTransactionBasicInfo()
//
// This function will be used to validate Content Transaction Basic Info
//------------------------------------------------------------------------------
function validateContentTransactionBasicInfo
{
  if (debug)
  {
    logStdout("validateContentTransactionBasicInfo()\n");
  }

  Date orderPlacedTime = edrDate(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0);
  Date requestedDeliveryTime =  edrDate(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0);
  Date actualDeliveryTime =  edrDate(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0);
  Date chargeStartTimestamp;
  String offset = "-1";
  String service_Type;
  Long blockIndex;
  Long packetIndex;
  Long blockEntries;
  Long service_Index;
  Long chargingPoint;

  blockEntries = edrNumDatablocks(DETAIL.ASS_CBD);

  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";

  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long packetEntries= edrNumDatablocks(DETAIL.ASS_CBD.CP, blockIndex);
    for (packetIndex = 0; packetIndex < packetEntries; packetIndex = packetIndex + 1)
    {
      service_Type = edrString(DETAIL.ASS_CBD.CP.RELATED_SERVICE_TYPE, blockIndex, packetIndex);
      if( service_Type == "CONTENT")
      {
        chargeStartTimestamp = edrDate(DETAIL.ASS_CBD.CP.CHARGING_START_TIMESTAMP, blockIndex, packetIndex);
        service_Index = edrLong(DETAIL.ASS_CBD.CP.RELATED_SERVICE_INDEX, blockIndex, packetIndex);
        chargingPoint = edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_CHARGING_POINT, 0, service_Index);

        if( (dateDiff(chargeStartTimestamp, orderPlacedTime) < 0) and chargingPoint == 1 and
             dateIsValid(chargeStartTimestamp) == true and dateIsValid(orderPlacedTime) == true )
        {
          edrAddError("ERR_TAP3_RET", 3, "severe",  "100",  "300",  "4",
          offset, "-1", "Ordered Placed Time Incorrect");
          setAssociatedTapErr("ERR_TAP3_ORDERED_PLACED_TIMESTAMP_INCORRECT", 3, "100" ,"300" ,"4");
        }

        if( (dateDiff(chargeStartTimestamp, requestedDeliveryTime) < 0) and chargingPoint == 2 and
             dateIsValid(chargeStartTimestamp) == true and dateIsValid(requestedDeliveryTime) == true ) 
        {
          edrAddError("ERR_TAP3_RET", 3, "severe",  "100",  "301",  "4",
          offset, "-1", "requested Delivery Time Incorrect");
          setAssociatedTapErr("ERR_TAP3_REQUESTED_DELIVERY_TIMESTAMP_INCORRECT", 3, "100" ,"301" ,"4");
        }

        if( (dateDiff(chargeStartTimestamp, actualDeliveryTime) < 0) and chargingPoint == 3 and
             dateIsValid(chargeStartTimestamp) == true and dateIsValid(actualDeliveryTime) == true ) 
        {
          edrAddError("ERR_TAP3_RET", 3, "severe",  "100",  "302",  "4",
          offset, "-1", "Actual Delivery Time Incorrect");
          setAssociatedTapErr("ERR_TAP3_ACTUAL_DELIVERY_TIMESTAMP_INCORRECT", 3, "100" ,"302" ,"4");
        }
  
	if( (dateIsValid(orderPlacedTime) == false) and chargingPoint == 1 
		and (edrInternalState(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP, 0) != MISSING) )
	{
          edrAddError("ERR_TAP3_RET", 3, "severe",  "10",  "300",  "4",
                offset, "-1", "Ordered Placed Time Syntax Error");
          setAssociatedTapErr("ERR_TAP3_ORDERED_PLACED_TIMESTAMP_SE", 3, "10" ,"300" ,"4");
	}

	if(dateIsValid(requestedDeliveryTime) == false and chargingPoint == 2 
		and edrInternalState(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP, 0) != MISSING)
	{
	  edrAddError("ERR_TAP3_RET", 3, "severe",  "10",  "301",  "4",
	     offset, "-1", "requested Delivery Time Syntax Error");
	  setAssociatedTapErr("ERR_TAP3_REQUESTED_DELIVERY_TIMESTAMP_SE", 3, "10" ,"301" ,"4");
	}

	if(dateIsValid(actualDeliveryTime) == false and chargingPoint == 3 
		and edrInternalState(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) != STATE_CLEARED and edrInputState(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP, 0) != MISSING)
	{
	  edrAddError("ERR_TAP3_RET", 3, "severe",  "10",  "302",  "4",
	    offset, "-1", "Actual Delivery Time Syntax Error");
	  setAssociatedTapErr("ERR_TAP3_ACTUAL_DELIVERY_TIMESTAMP_SE", 3, "10" ,"302" ,"4");
	}

      }
    }
  }
}

//-----------------------------------------------------------------------------
// validateChargedPartyIdentifier 
//
// This function will be used to validate the ChargedPartyIdentifier
//-----------------------------------------------------------------------------
function validateChargedPartyIdentifier
{
  if (debug)
  {
    logStdout("validateChargedPartyIdentifier()\n");
  }
  const String ruleID     = "Item Content does not match ChargedParty Id Type";
  const String arrayIndex = "-1";
  const String offset     = "-1";
  Bool  checkType         = true;
  Long  ret               = -1;
  Long  blockIndex;
  Long  blockEntries      = edrNumDatablocks(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST, 0, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
   Long typeID = edrLong(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST.TYPE, 0, 0, blockIndex);
   String checkChargedPartyIdentifier = edrString(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST.IDENTIFIER, 0, 0, blockIndex);
   switch( typeID )
   {
     case 1:
     case 2:
     case 3:
     {
       ret = strSearchRegExpr(checkChargedPartyIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(checkChargedPartyIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(checkChargedPartyIdentifier);
     } 
     break;
     case 6:
     case 7:
     {
       ret = strSearchRegExpr(checkChargedPartyIdentifier, "[^0-9A-Za-z]");
     }
     break;
     case 8:
     {
       checkType = validateEmail(checkChargedPartyIdentifier); 
     }
     break;
   }
   if ((ret >= 0) or (checkType == false))
   {
     edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
     edrSetIsValidDetail(false);
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "287", "7",
                offset, arrayIndex, ruleID);
     setAssociatedTapErr("ERR_TAP3_CHARGED_PARTY_IDENTIFIER", LOG_MAJOR ,"100" ,"287" ,"7");
   }
  }
}



//----------------------------------------------------------------------------
// validateContentProviderIdentifier 
//
// This function will be used to validate the ContentProviderIdentifier
//----------------------------------------------------------------------------
function validateContentProviderIdentifier
{
  if (debug)
  {
    logStdout("validateContentProviderIdentifier()\n");
  }
  const String ruleID     = "Item Content does not match ContentProviderIdType";
  const String arrayIndex = "-1";
  const String offset     = "-1";
  Bool  checkType         = true;
  Long  ret               = -1;
  Long  blockIndex;
  Long  blockEntries      = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST,0 ,0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long typeID = edrLong(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.TYPE, 0 ,0, blockIndex);
    String checkContentProviderIdentifier = edrString(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.IDENTIFIER, 0, 0, blockIndex);
    switch( typeID )
    {
     case 1:
     {
       ret = strSearchRegExpr(checkContentProviderIdentifier, "[^A-Za-z ]");
       Long checkSpace = strSearchRegExpr(checkContentProviderIdentifier, "[A-Za-z]");
       if ( checkSpace < 0  and ret < 0 )
       {
          ret = 0;
       }
     }
     break;
     case 2:
     {
       ret = strSearchRegExpr(checkContentProviderIdentifier, "[^A-Z0-9]");
     }
     break;
     case 3:
     {
       ret = strSearchRegExpr(checkContentProviderIdentifier, "!(.+)");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(checkContentProviderIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(checkContentProviderIdentifier);
     }
     break;
   }
   if (ret >= 0 or checkType == false)
   {
     edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
     edrSetIsValidDetail(false);
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", "292", "6",
                offset, arrayIndex, ruleID);
     setAssociatedTapErr("ERR_TAP3_CONTENT_PROVIDER_IDENTIFIER", LOG_MAJOR ,"101" ,"292" ,"6");
   }
  }
}



//-----------------------------------------------------------------------------
// validateCustomerIdentifier
//
// This function will be used to validate the ChargedPartyIdentifier
// for the both group traked and tracking customer info.
//-----------------------------------------------------------------------------
function validateCustomerIdentifier
{
  if (debug)
  {
    logStdout("validateCustomerIdentifier()\n");
  }
  const String ruleID     = "Item Content does not match Customer Id Type";
  const String arrayIndex = "-1";
  const String offset     = "-1";
  Bool  checkType         = true;
  Long  ret               = -1;
  Long  blockIndex;
  Long  blockEntries;
  blockEntries            = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.ID_LIST, 0, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
   Long typeID = edrLong(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.ID_LIST.TYPE, 0, 0, blockIndex);
   String checkCustomerIdentifier = edrString(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.ID_LIST.IDENTIFIER, 0, 0, blockIndex);
   switch( typeID )
   {
     case 1:
     case 2:
     case 3:
     {
       ret = strSearchRegExpr(checkCustomerIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(checkCustomerIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(checkCustomerIdentifier);
     }
     break;
     case 6:
     case 7:
     {
       ret = strSearchRegExpr(checkCustomerIdentifier, "[^0-9A-Za-z]");
     }
     break;
     case 8:
     {
       checkType = validateEmail(checkCustomerIdentifier); 
     }
     break;
   }
   if (ret >= 0 or checkType == false)
   {
     edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
     edrSetIsValidDetail(false);
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "364", "7",
                offset, arrayIndex, ruleID);
     setAssociatedTapErr("ERR_TAP3_CUSTOMER_IDENTIFIER", LOG_MAJOR ,"100" ,"364" ,"7");
   }
  }
  blockEntries = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.ID_LIST, 0, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
   Long typeID = edrLong(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.ID_LIST.TYPE, 0, 0, blockIndex);
   String checkCustomerIdentifier = edrString(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.ID_LIST.IDENTIFIER, 0, 0, blockIndex);
   switch( typeID )
   {
     case 1:
     case 2:
     case 3:
     {
       ret = strSearchRegExpr(checkCustomerIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(checkCustomerIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(checkCustomerIdentifier);
     }
     break;
     case 6:
     case 7:
     {
       ret = strSearchRegExpr(checkCustomerIdentifier, "[^0-9A-Za-z]");
     }
     break;
     case 8:
     {
       checkType = validateEmail(checkCustomerIdentifier); 
     }
     break;
   }
   if (ret >= 0 or checkType == false)
   {
     edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
     edrSetIsValidDetail(false);
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "364", "7",
                offset, arrayIndex, ruleID);
     setAssociatedTapErr("ERR_TAP3_CUSTOMER_IDENTIFIER", LOG_MAJOR ,"100" ,"364" ,"7");
   }
  }
}


//-----------------------------------------------------------------------------
// validateHomeIdentifier 
//
// This function will be used to validate the HomeIdentifier
// for the both group traked and tracking Customer info.
//-----------------------------------------------------------------------------
function validateHomeIdentifier
{
  if (debug)
  {
    logStdout("validateHomeIdentifier()\n");
  }
  const String ruleID     = "Item Content does not match Home Id Type";
  const String arrayIndex = "-1";
  const String offset     = "-1";
  Bool  checkType         = true;
  Long  ret               = -1;
  Long  blockIndex;
  Long  blockEntries;
  blockEntries            = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.HOME_ID_LIST, 0 ,0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
   Long typeID = edrLong(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.HOME_ID_LIST.TYPE, 0, 0, blockIndex);
   String checkHomeIdentifier = edrString(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.HOME_ID_LIST.IDENTIFIER, 0, 0, blockIndex);
   switch( typeID )
   {
     case 1:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "[^A-Za-z ]");
       Long checkSpace = strSearchRegExpr(checkHomeIdentifier, "[A-Za-z]");
       if ( checkSpace < 0  and ret < 0 )
       {
          ret = 0;
       }
     }
     break;
     case 2:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "[^0-9A-Z]");
     }
     break;
     case 3:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "!(.+)");
     }
     break;
   }
   if (ret >= 0)
   {
     edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
     edrSetIsValidDetail(false);
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "288", "7",
                offset, arrayIndex, ruleID);
     setAssociatedTapErr("ERR_TAP3_HOME_IDENTIFIER", LOG_MAJOR ,"100" ,"288" ,"7");
   }
  }
  blockEntries = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.HOME_ID_LIST, 0, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
   Long typeID = edrLong(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.HOME_ID_LIST.TYPE, 0, 0, blockIndex);
   String checkHomeIdentifier = edrString(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.HOME_ID_LIST.IDENTIFIER, 0, 0, blockIndex);
   switch( typeID )
   {
     case 1:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "[^A-Za-z ]");
       Long checkSpace = strSearchRegExpr(checkHomeIdentifier, "[A-Za-z]");
       if ( checkSpace < 0  and ret < 0 )
       {
          ret = 0;
       }
     }
     break;
     case 2:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "[^0-9A-Z]");
     }
     break;
     case 3:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       ret = strSearchRegExpr(checkHomeIdentifier, "!(.+)");
     }
     break;
   }
   if (ret >= 0)
   {
     edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
     edrSetIsValidDetail(false);
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "288", "7",
                offset, arrayIndex, ruleID);
     setAssociatedTapErr("ERR_TAP3_HOME_IDENTIFIER", LOG_MAJOR ,"100" ,"288" ,"7");
   }
  }
}



