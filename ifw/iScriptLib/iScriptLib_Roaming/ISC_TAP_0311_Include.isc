function mapDataVolumeOutgoing ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
                                                                                                             
  if ( strEndsWith ( parentContext, "contentServiceUsed" ) == true )
  {
    edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.DATA_VOLUME_OUTGOING, 0, contentSvcUsedIdx) = edrLongEx( myContext, indices, nParentIndices );
  }
  else if ( strEndsWith ( parentContext, "gprsServiceUsed" ) == true )
  {
    edrDecimal(DETAIL.VOLUME_SENT) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
  }

  //logContext( myContext, nParentIndices );                                                                   
