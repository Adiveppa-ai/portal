function validateMessagingEvent ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  errorContext = errorContext + ",433";                                                        
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "messagingEventService";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateMessagingEventService ( myContext, nMyIndices, "messagingEventService", 0, errorContext );                 
  }
  else
  {
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Messaging Event", "433", "10", "Syntax Error");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error"); 
      edrSetIsValidDetail(false);
  }  
                                                                                                             
  childContext = myContext + "." + "chargedParty";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateChargedParty ( myContext, nMyIndices, "chargedParty", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapFileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "simToolkitIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateSimToolkitIndicator ( myContext, nMyIndices, "simToolkitIndicator", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "geographicalLocation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateGeographicalLocation ( myContext, nMyIndices, "geographicalLocation", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "eventReference";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateEventReference ( myContext, nMyIndices, "eventReference", 0, errorContext );                 
  }
  else
  {
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Messaging Event", "433", "10", "Syntax Error");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1","", "Syntax Error"); 
     edrSetIsValidDetail(false);
  }    
                                                                                                             
  childContext = myContext + "." + "recEntityCodeList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateRecEntityCodeList ( myContext, nMyIndices, "recEntityCodeList", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "networkElementList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateNetworkElementList ( myContext, nMyIndices, "networkElementList", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "locationArea";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateLocationArea ( myContext, nMyIndices, "locationArea", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "cellId";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateCellId ( myContext, nMyIndices, "cellId", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "serviceStartTimestamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateServiceStartTimestamp ( myContext, nMyIndices, "serviceStartTimestamp", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "nonChargedParty";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateNonChargedParty ( myContext, nMyIndices, "nonChargedParty", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "exchangeRateCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateExchangeRateCode ( myContext, nMyIndices, "exchangeRateCode", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "callTypeGroup";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateCallTypeGroup ( myContext, nMyIndices, "callTypeGroup", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "charge";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateCharge ( myContext, nMyIndices, "charge", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "taxInformationList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateTaxInformationList ( myContext, nMyIndices, "taxInformationList", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );                 
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            



