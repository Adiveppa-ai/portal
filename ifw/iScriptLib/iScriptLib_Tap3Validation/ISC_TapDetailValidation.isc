//------------------------------------------------------------------------------
// validateNonChargedNumber()
//
// This function will be used to validate the non charged number
//------------------------------------------------------------------------------
function validateNonChargedNumber
{
  if (debug)
  {
    logStdout("validateNonChargedNumber\n");
  }

  String offset;
  if (edrString(DETAIL.USAGE_DIRECTION) == "0")
  {
    if (edrInputState(DETAIL.ASS_GSMW_EXT.DIALED_DIGITS, 0) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GSMW_EXT.DIALED_DIGITS, 0));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "158", "5",
		offset, "-1", "Missing Non Charged Number");
      setAssociatedTapErr("ERR_TAP3_MISSING_NON_CHARGED_NUMBER", LOG_MAJOR ,"30" ,"158" ,"5");	
    }
  }
}


//------------------------------------------------------------------------------
// validateCLIRIndicatorforSCU()
//
// This function will be used to validate CLIR Status Indicator for SCU
//------------------------------------------------------------------------------
function validateCLIRIndicatorforSCU
{
  if (debug)
  {
    logStdout("validateCLIRIndicatorforSCU\n");
  }

  String offset;

  Long tmpCLIRIndicator = strToLong(edrString(DETAIL.USAGE_CLASS));

  if ( (tmpCLIRIndicator != 0) and (tmpCLIRIndicator != 1) )
  {
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "75", "4",
                offset, "-1", "CLIR Indicator is out of range");
      setAssociatedTapErr("ERR_TAP3_CLIR_STATUS_INDICATOR_OOR", LOG_WARNING ,"20" ,"75" ,"4");  
  }
}

//------------------------------------------------------------------------------
// validateSIMToolkitIndicator()
//
// This function will be used to validate SIM Toolkit Indicator
//------------------------------------------------------------------------------
function validateSIMToolkitIndicator
{
  if (debug)
  {
    logStdout("validateSIMToolkitIndicator\n");
  }

  String offset;

  Long indicatorState = edrInputState(DETAIL.DISCOUNT_KEY);
  Long indicatorStateI = edrInternalState(DETAIL.DISCOUNT_KEY);

  if (indicatorStateI != STATE_CLEARED and indicatorState != EDR_INPUT_MISSING)
  {
      Long tmpSIMToolkitInd = strToLong(edrString(DETAIL.DISCOUNT_KEY));

      if ( tmpSIMToolkitInd != 1 )
      {
          offset = "-1";
          edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "200", "5",
                    offset, "-1", "SIM Toolkit Indicator is out of range");
          setAssociatedTapErr("ERR_TAP3_SIM_TOOLKIT_INDICATOR_OOR", LOG_WARNING ,"20" ,"200" ,"5");     
      }
  }
}


//------------------------------------------------------------------------------
// validateDualServiceRequested 
//
// This function will be used to validate the DualServiceRequested
//------------------------------------------------------------------------------
function validateDualServiceRequested 
{
  if (debug)
  {
    logStdout("validateDualServiceRequested\n");
  }
  String offset = "-1";
  Bool   found  = false;
  Long blockIndex;
  Long blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
  String basicDualService = edrString(DETAIL.ASS_GSMW_EXT.BASIC_DUAL_SERVICE, 0);
  for (blockIndex = 0; (blockIndex < blockEntries) and (found == false); blockIndex = (blockIndex + 1))
  {
    String basicService = edrString(DETAIL.ASS_GSMW_EXT.BS_PACKET.BASIC_SERVICE, 0, blockIndex);
    if(strSubstr(basicDualService, 0, 1) == "1")
    {
      if(strSubstr(basicService, 0, 1) == "1")
      {
        found = true;
      }
    }
    if(strSubstr(basicDualService, 0, 1) == "0")
    {
      if(strSubstr(basicService, 0, 1) == "0")
      {
        found = true;
      }
    }
  }
  if( (found == false) and (strSubstr(basicDualService, 0, 1) == "1") )
  {
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "99", "4",
                     offset, "-1", "Mismatch Dual Bearer Service Code");
    setAssociatedTapErr("ERR_TAP3_MISMATCH_DUAL_BEARER_SERVICE_CODE", LOG_MAJOR ,"100" ,"99" ,"4");
  }
  else if ( (found == false) and (strSubstr(basicDualService, 0, 1) == "0") )
  {
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "100", "4",
                     offset, "-1", "Mismatch Dual Tele Service Code");
    setAssociatedTapErr("ERR_TAP3_MISMATCH_DUAL_TELE_SERVICE_CODE", LOG_MAJOR ,"100" ,"100" ,"4");
  }
}



//------------------------------------------------------------------------------
// validateGeographicalLocation()
//
// This function will be used to validate the fields of Geographical Location
//------------------------------------------------------------------------------
function validateGeographicalLocation
{
  if (debug)
  {
    logStdout("validateGeographicalLocation\n");
  }

  if( edrString(DETAIL.GEOGRAPHICAL_LOCATION) != "")
  {
      String offset = "-1";

      // Retrive the individual fields from DETAIL.GEOGRAPHICAL_LOCATION
          String tmpGeographicalLocation = edrString(DETAIL.GEOGRAPHICAL_LOCATION);
          String tmpGeoLocArray[];

          Long nbElem = strSplit(tmpGeoLocArray, tmpGeographicalLocation, ",");
          Long i;
          String tmpServingNetwork;
          String tmpServingBID;
          String tmpServingLocDesc;
          Long   tmpLongitude;
          Long   tmpLatitude;

          for (i = 0; i < nbElem; i = i+2) //Every even index will contain key, so we jump 2 (i = i+2)
          {
              switch(strToLong(tmpGeoLocArray[i]))
              {
                 //These case values are defined as follwos in the input grammar
                 //  const String servingNetworkKey        = "1";
                 //  const String servingBIDKey            = "2";
                 //  const String servingLocationDescKey   = "3";
                 //  const String longitudeKey             = "4";
                 //  const String latitudeKey              = "5";

                 case 1: // This is ServingNetwork
                     tmpServingNetwork = tmpGeoLocArray[i+1];
                 break;
                 case 2: // This is ServingBID
                     tmpServingBID = tmpGeoLocArray[i+1];
                 break;
                 case 3: // This is ServingLocationDescription
                     tmpServingLocDesc = tmpGeoLocArray[i+1];
                 break;
                 case 4: // This is Longitude
                     tmpLongitude = strToLong(tmpGeoLocArray[i+1]);
                 break;
                 case 5: // This is Latitude
                     tmpLatitude = strToLong(tmpGeoLocArray[i+1]);
                 break;
          }

          }
         
          if ( (tmpLongitude < -648000) or (tmpLongitude > 648000) )
          {
              edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
              edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "139", "6",
                    offset, "-1", "Longitude is out of range");
              setAssociatedTapErr("ERR_TAP3_LONGITUDE_OOR", LOG_WARNING ,"20" ,"139" ,"6");    
          }

          if ( (tmpLatitude < -324000) or (tmpLatitude > 324000) )
          {
              edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
              edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "134", "6",
                    offset, "-1", "Latitude is out of range");
              setAssociatedTapErr("ERR_TAP3_LATITUDE_OOR", LOG_WARNING ,"20" ,"134" ,"6");    
          }

  }
}

//------------------------------------------------------------------------------
// validateSupplServiceUsed()
//
// This function will be used to validate the supplementary service used
// (MOC & MTC)
//------------------------------------------------------------------------------
function validateSupplServiceUsed
{
  if (debug)
  {
    logStdout("validateSupplServiceUsed\n");
  }

  Long blockIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.SS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if ((edrInputState(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT, 0, blockIndex));
      offset = "-1";
      edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "37", "209", "5",
		offset, longToStr(blockIndex), "Missing Supplementary Service Code");
      setAssociatedTapErr("ERR_TAP3_MISSING_SUPPLEMENTARY_SERVICE_CODE", LOG_WARNING ,"37" ,"209" ,"5");	
    }
    // Acceptable SupplServiceCode values are checked by iRules.

    if ((edrInputState(DETAIL.ASS_GSMW_EXT.SS_PACKET.ACTION_CODE,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GSMW_EXT.SS_PACKET.ACTION_CODE, 0, blockIndex));
      offset = "-1";
      edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "38", "206", "5",
		offset, longToStr(blockIndex), "Missing Action Code");
      setAssociatedTapErr("ERR_TAP3_MISSING_ACTION_CODE", LOG_WARNING ,"38" ,"206" ,"5");	
    }
  }
}

//------------------------------------------------------------------------------
// validateSupplServiceUsedMSS()
//
// This function will be used to validate the supplementary service used (MSS)
//------------------------------------------------------------------------------
function validateSupplServiceUsedMSS
{
  if (debug)
  {
    logStdout("validateSupplServiceUsedMSS\n");
  }

  Long blockIndex;
  Long blockEntries;
  String offset;
  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.SS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if ( edrInternalState(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT, 0, blockIndex) != STATE_CLEARED and (edrInputState(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT, 0, blockIndex)) != MISSING and
                (edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT , 0, blockIndex) == "FF") )
    {
      Long cpIndex;
      Long cpEntries = edrNumDatablocks(DETAIL.ASS_CBD);
      for (cpIndex = 0; cpIndex < cpEntries; cpIndex = (cpIndex + 1))
      {
        Long packetIndex;
        Long packetEntries = edrNumDatablocks(DETAIL.ASS_CBD.CP, cpIndex);
        for(packetIndex = 0; packetIndex < packetEntries; packetIndex = (packetIndex + 1))
        {
          if ( edrDecimal(DETAIL.ASS_CBD.CP.ACTUAL_CHARGED_AMOUNT_VALUE, cpIndex, packetIndex) <= 0.0 and
               edrInputState(DETAIL.ASS_CBD.CP.ACTUAL_CHARGED_AMOUNT_VALUE, cpIndex, packetIndex) != MISSING and
               edrInternalState(DETAIL.ASS_CBD.CP.ACTUAL_CHARGED_AMOUNT_VALUE, cpIndex, packetIndex) != STATE_CLEARED )  
          {
            offset = "-1";
            edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "30", "209", "5",
                offset, longToStr(blockIndex), "Code is FF and charge not greater than 0");
            setAssociatedTapErr("ERR_TAP3_SS_CODE_INCORRECT", LOG_WARNING ,"30" ,"209" ,"5");
          }
        }
      }
    }

    if ((edrInputState(DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GSMW_EXT.SS_PACKET.SS_EVENT, 0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "206", "5",
		offset, longToStr(blockIndex), "Missing Supplementary Service Code");
      setAssociatedTapErr("ERR_TAP3_MISSING_SUPPLEMENTARY_SERVICE_CODE", LOG_MAJOR ,"30" ,"206" ,"5");	
    }

    // Acceptable SupplServiceCode values are checked by iRules.

    if ((edrInputState(DETAIL.ASS_GSMW_EXT.SS_PACKET.ACTION_CODE,
						0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GSMW_EXT.SS_PACKET.ACTION_CODE, 0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "206", "5",
		offset, longToStr(blockIndex), "Missing Action Code");
      setAssociatedTapErr("ERR_TAP3_MISSING_ACTION_CODE", LOG_MAJOR ,"31" ,"206" ,"5");	
    }
  }
}

