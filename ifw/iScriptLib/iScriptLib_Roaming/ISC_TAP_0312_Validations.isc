 ******************************************************************************************************************************/
 
function validateAccessPointNameOI ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",262";

  if ( strLength(edrStringEx(myContext, indices, nParentIndices)) > 37 )    
  {
    if (strStartsWith(parentContext, "DETAIL.gprsCall.camelServiceUsed") == true)
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "AccessPointNameOI", "262", "11", 
                                                 "Syntax error where group GPRS Destination occurs within group 3G CAMEL Destination");
    }
    else
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "AccessPointNameOI", "262", "10", "Syntax error where group GPRS Destination occurs within group GPRS Basic Call Information");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error where group GPRS Destination occurs within group GPRS Basic Call Information");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

