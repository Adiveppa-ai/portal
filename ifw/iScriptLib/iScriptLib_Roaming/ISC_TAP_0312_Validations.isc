/******************************************************************************************************************************
 * This function will validate NetworkIdentifier. It will raise error code 100, 101 for NetworkIdentifier.
 ******************************************************************************************************************************/
 
function validateNetworkIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",295";
  Long i;
  Bool   identifierIsValid = false;
  String networkIdentifier = edrStringEx( myContext, indices, nParentIndices );
 
  switch( lastNetworkIdType )
  {  
    case 6:
    {
      identifierIsValid = validateEmail(networkIdentifier);
    }
    break;
    case 3:
    {
       if ( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true and 
       strLength(edrStringEx(myContext, indices, nParentIndices)) == 5 )
       {
         identifierIsValid = true;
       }
    }
    break;
    case 2:
    {    
      for( i = 0; i < numOfPlmnoCode and identifierIsValid == false; i = i + 1 )
      {
        if( PLMNOCode[i] == networkIdentifier )
        {
          identifierIsValid = true;
        }
      }          
    }
    break;
    default:
    {
      identifierIsValid = true;
    }
  }
  if ( identifierIsValid == false)
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Network Identifier", "295", "100", "Item content does not match Location Id Type");
    }
    else
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Network Identifier", "295", "101", "Item content does not match Location Id Type");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1", "","Item content does not match Location Id Type");
      edrSetIsValidDetail(false);
    }  
    
  }   
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate NetworkIdType. It will raise error code 20, 21 for NetworkIdType.
 ******************************************************************************************************************************/
 
function validateNetworkIdType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",331";
  
  lastNetworkIdType = edrLongEx( myContext, indices, nParentIndices );
  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"6" , "1", "INTEGER_TYPE") == true )
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "NetworkIdType", "331", "20", "Value out of range");
    }
    else
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "NetworkIdType", "331", "21", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
      edrSetIsValidDetail(false);
    }
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate Network. It will raise error code 30, 31, 32, 33 for Network.
 ******************************************************************************************************************************/
 
function validateNetwork ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",332";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  lastNetworkIdType       = -1;
 
  childContext = myContext + "." + "networkIdType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateNetworkIdType ( myContext, nMyIndices, "networkIdType", 0, errorContext );
  }
  else
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Network", "332", "30", "Mandatory item Network Id Type missing within group");
    }
    else
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Network", "332", "32", "Mandatory item Network Id Type missing within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","", "Mandatory item Network Id Type missing within group");
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "networkIdentifier";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateNetworkIdentifier ( myContext, nMyIndices, "networkIdentifier", 0, errorContext );
  }
  else
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction") == true )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Network", "332", "31", "Mandatory item Network Identifier missing within group");
    }
    else
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Network", "332", "33", "Mandatory item Network Identifier missing within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1", "","Mandatory item Network Identifier missing within group");
      edrSetIsValidDetail(false);
    }
  }  
 
  //logContext( myContext, nMyIndices );
}

