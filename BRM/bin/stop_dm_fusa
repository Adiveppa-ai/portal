#

#
# stop_dm_fusa
#
# run this BEFORE stopping the underlying database (if any)
#
VERSION=15.0
PATH=/usr/bin:/bin

QM=dm_fusa
LOGDIR=/home/pin/opt/portal/BRM/var/dm_fusa
QMPID=${LOGDIR}/dm_fusa.pid

me=$0

if [ ! -f ${QMPID} ]; then
	echo "${me}: ERROR: no pid file: ${QMPID}, cannot kill \"${QM}\""
        exit 1
fi       

kill -QUIT `cat ${QMPID}`
rc=$?
if [ ${rc} -ne 0 ]; then
	echo "${me}: ERROR: kill ${QM} `cat ${QMPID}` FAILED"
	exit ${rc}
else
	rm ${QMPID}
fi

#
# fusamux addition
if [ -f ${LOGDIR}/fusamux.pid ]; then
	kill `cat ${LOGDIR}/fusamux.pid`
	rc=$?
	if [ ${rc} -ne 0 ]; then
		echo "${me}: ERROR: kill fusamux `cat ${QMPID}` FAILED: ${rc}"
	fi
	rm ${LOGDIR}/fusamux.pid
fi

exit 0
