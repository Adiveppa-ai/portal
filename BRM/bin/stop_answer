VERSION=15.0
PATH=/usr/bin:/bin

PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/dm_fusa

ANSDIR=${PINDIR}/apps/fusa_server
S_PID=${LOGDIR}/answer_s.pid
B_PID=${LOGDIR}/answer_b.pid
 
me=$0

if [ ! -f ${S_PID} ]; then
	echo "${me}: ERROR: no answer_s.pid file: ${S_PID}"
        exit 1
fi       

if [ ! -f ${B_PID} ]; then
	echo "${me}: ERROR: no answer_b.pid file: ${B_PID}"
        exit 1
fi       

kill `cat ${S_PID}`
rc=$?
if [ ${rc} -ne 0 ]; then
	echo "${me}: ERROR: kill answer_s `cat ${S_PID}` FAILED"
	exit ${rc}
else
	rm ${S_PID}
fi

kill `cat ${B_PID}`
rc=$?
if [ ${rc} -ne 0 ]; then
	echo "${me}: ERROR: kill answer_s `cat ${B_PID}` FAILED"
	exit ${rc}
else
	rm ${B_PID}
fi

exit 0
