/******************************************************************************************************************************
 * This function will validate DiscountRate. It will raise error code 20 for DiscountRate.
 ******************************************************************************************************************************/
 
function validateDiscountRate ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",92";
  tmpDiscountApplied_Type = discountApplied_discountRate;
  tmpDiscountApplied      = edrLongEx(myContext, indices, nParentIndices);

  if( hasDupDiscountingEntries == false )
  {
    discountApplied_Type[lastCode] = discountApplied_discountRate;
    discountApplied[lastCode]      = edrLongEx(myContext, indices, nParentIndices);
  }

  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"10000" , "0", "INTEGER_TYPE") == true )
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",20" + ":" + AccountingInfoStr;

    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "DiscountRate", "92", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "92", "0", "-1", "-1","", "Value out of range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate FixedDiscountValue. It will raise error code 20 for FixedDiscountValue.
 ******************************************************************************************************************************/
 
function validateFixedDiscountValue ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",411";
  tmpDiscountApplied_Type     = discountApplied_fixedDiscountValue;
  tmpDiscountApplied          = edrLongEx(myContext, indices, nParentIndices);

  if( hasDupDiscountingEntries == false )
  {
    discountApplied_Type[lastCode] = discountApplied_fixedDiscountValue;
    discountApplied[lastCode]      = edrLongEx(myContext, indices, nParentIndices);
  }

  if( edrLongEx(myContext, indices, nParentIndices) <= 0 )
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",20" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Fixed Discount Value", "411", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "411", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate DiscountApplied and Discounting. It will raise error code 30, 31 for DiscountApplied and 
 * error code 32, 33 for Discounting.
 ******************************************************************************************************************************/
 
function validateDiscountApplied ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",428";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  Bool fixedDiscountValueIsPresent = false;
 
  childContext = myContext + "." + "fixedDiscountValue";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    fixedDiscountValueIsPresent = true;
    validateFixedDiscountValue ( myContext, nMyIndices, "fixedDiscountValue", 0, errorContext );
  }
 
  childContext = myContext + "." + "discountRate";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    if( fixedDiscountValueIsPresent == true )
    {
      rollbackReason   = "AccountingInfo," +  errorContext + ",31" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discount Applied", "428", "31",
                                             "Both of mandatory items Fixed Discount Value and Discount Rate present within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "428", "0", "-1", "-1", "",
                                             "Both of mandatory items Fixed Discount Value and Discount Rate present within group");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    validateDiscountRate ( myContext, nMyIndices, "discountRate", 0, errorContext );
  }
  else
  {
    if( fixedDiscountValueIsPresent == false )
    {
      rollbackReason   = "AccountingInfo," +  errorContext + ",30" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discount Applied", "428", "30",
                                          "Neither of mandatory items Fixed Discount Value or Discount Rate present within group");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "428", "0", "-1", "-1", "",
                                          "Neither of mandatory items Fixed Discount Value or Discount Rate present within group");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }

  if( hasDupDiscountingEntries == true )
  {
    if((discountApplied[lastCode] == tmpDiscountApplied) and (discountApplied_Type[lastCode] == tmpDiscountApplied_Type))
    {
      rollbackReason   = "AccountingInfo," +  "1 ,5 ,95 ,94" + ",33" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discounting", "94", "33", "Duplicate Discounting table entry"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "94", "0", "-1", "-1", "","Duplicate Discounting table entry");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else
    {
      rollbackReason   = "AccountingInfo," +  "1 ,5 ,95 ,94" + ",32" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discounting", "94", "32",
                  "More than one occurrence of group with same Discount Code where group Discount Applied is  not the same");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "94", "0", "-1", "-1","",
                  "More than one occurrence of group with same Discount Code where group Discount Applied is  not the same");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate Discounting. It will raise error code 30, 31 for Discounting.
 ******************************************************************************************************************************/
 
function validateDiscounting ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",94";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "discountCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDiscountCode ( myContext, nMyIndices, "discountCode", 0, errorContext );
  }
  else
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",31" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discounting", "94", "31", "Discount Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "94", "0", "-1", "-1", "","Discount Code missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "discountApplied";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateDiscountApplied ( myContext, nMyIndices, "discountApplied", 0, errorContext );
  }
  else
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",30" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Discounting", "94", "30", "Discount Applied missing within group"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "94", "0", "-1", "-1", "","Discount Applied missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateDiscounting for each element of Discounting List.
 ******************************************************************************************************************************/
 
function validateDiscountingList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",95";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "Discounting";
  Long DiscountingListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < DiscountingListEntries; i = i + 1 )
  {
    validateDiscounting ( myContext, nMyIndices, "Discounting", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate TaxRate and Taxation. It will raise error code 10, 20 for TaxRate and error code 34 for Taxation.
 ******************************************************************************************************************************/
 
function validateTaxRate ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",215";

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",10" + ":" + AccountingInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TaxRate", "215", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "215", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"9999999" , "0", "INTEGER_TYPE") == true )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",20" + ":" + AccountingInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TaxRate", "215", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "215", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  
  if ( taxCodeIsDuplicate == true )
  {
    if ( taxRate[ lastCode ] == edrStringEx( myContext, indices, nParentIndices ) )
    {
      taxRateIsDuplicate = true;
      if ( taxTypeIsDuplicate == true )
      {
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Taxation", "216", "34", "More than one occurrence of group with same Tax Rate Code where Tax Type and Tax Rate are the same (i.e. duplicate Taxation table entries)");
      }
    }
  }
  else
  {
    taxRate[ lastCode ] = edrStringEx( myContext, indices, nParentIndices );
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TaxType. It will raise error code 10, 20 for TaxType.
 ******************************************************************************************************************************/
 
function validateTaxType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",217";


  if( (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 2) )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",10" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TaxType", "217", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "217", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"4" , "1", "INTEGER_TYPE") == true )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",20" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TaxType", "217", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "217", "0", "-1", "-1", "","Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  
  if ( taxCodeIsDuplicate == true )
  {
    if ( taxType[ lastCode ] == edrStringEx( myContext, indices, nParentIndices ) )
    {
      taxTypeIsDuplicate = true;
    }
  }
  else
  {
    taxType[ lastCode ] = edrStringEx( myContext, indices, nParentIndices );
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate Taxation. It will raise error code 30, 31, 33 for Taxation.
 ******************************************************************************************************************************/
 
function validateTaxation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",216";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

 
  childContext = myContext + "." + "taxCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxCode ( myContext, nMyIndices, "taxCode", 0, errorContext );
  }
  else
  {
    rollbackReason = "AccountingInfo," + errorContext + ",30" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Taxation", "216", "30", "Mandatory item Tax Rate Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "216", "0", "-1", "-1","", "Mandatory item Tax Rate Code missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "taxType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxType ( myContext, nMyIndices, "taxType", 0, errorContext );
  }
  else
  {
    rollbackReason = "AccountingInfo," + errorContext + ",31" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Taxation", "216", "31", "Mandatory item Tax Type missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "216", "0", "-1", "-1", "","Mandatory item Tax Type missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "taxRate";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxRate ( myContext, nMyIndices, "taxRate", 0, errorContext );
  }
 
  childContext = myContext + "." + "chargeType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargeType ( myContext, nMyIndices, "chargeType", 0, errorContext );
  }

  childContext = myContext + "." + "taxIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTaxIndicator ( myContext, nMyIndices, "taxIndicator", 0, errorContext );
  }


  if ( taxCodeIsDuplicate == true )
  {
    if( taxTypeIsDuplicate != true and taxRateIsDuplicate != true)
    {
      rollbackReason = "AccountingInfo," + "1,5,216" + ",33" + ":" + AccountingInfoStr;
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Taxation", "216", "33", "More than one occurrence of group with same Tax Rate Code where Tax Type, Tax Rate and/or Charge Type are not the same");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "216", "0", "-1", "-1", "","More than one occurrence of group with same Tax Rate Code where Tax Type, Tax Rate and/or Charge Type are not the same");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }  
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateTaxation for each element of Taxation List.
 ******************************************************************************************************************************/
 
function validateTaxationList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",211";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "Taxation";
  Long TaxationListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  

  Long i;
  for( i = 0; i < TaxationListEntries; i = i + 1 )
  {
    taxCodeIsDuplicate = false;
    taxTypeIsDuplicate = false;
    taxRateIsDuplicate = false;
    chargeTypeIsDuplicate = false;
    validateTaxation ( myContext, nMyIndices, "Taxation", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate AccountingInfo. It will raise error code 32, 35 for AccountingInfo.
 ******************************************************************************************************************************/
 
function validateAccountingInfo ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",5";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "taxation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTaxationList ( myContext, nMyIndices, "taxation", 0, errorContext );
  }
  else
  {
    taxationListIsMissing = true;     
  }
 
  childContext = myContext + "." + "discounting";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateDiscountingList ( myContext, nMyIndices, "discounting", 0, errorContext );
  }
  else
  {
    discountListIsMissing = true;   
  } 
  childContext = myContext + "." + "localCurrency";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalCurrency ( myContext, nMyIndices, "localCurrency", 0, errorContext );
  }
  else    
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",32" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AccountingInfo", "5", "32", "Missing LocalCurrency"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "5", "0", "-1", "-1", "","Missing LocalCurrency");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "tapCurrency";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTapCurrency ( myContext, nMyIndices, "tapCurrency", 0, errorContext );
  }
 
  childContext = myContext + "." + "currencyConversionInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCurrencyConversionList ( myContext, nMyIndices, "currencyConversionInfo", 0, errorContext );
  }
  else
  {
    currencyConversionListIsMissing = true;   
  }
 
  childContext = myContext + "." + "tapDecimalPlaces";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTapDecimalPlaces ( myContext, nMyIndices, "tapDecimalPlaces", 0, errorContext );
  }
  else    
  { 
    rollbackReason   = "AccountingInfo," +  errorContext + ",35" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AccountingInfo", "5", "35", "Missing TapDecimalPlaces"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "35", "5", "0", "-1", "-1", "","Missing TapDecimalPlaces");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate BatchControlInfo and SpecificationVersionNumber. It will raise error code 30, 31, 32, 33, 34,
 * 36, 39 for BatchControlInfo and error code 30 for SpecificationVersionNumber.
 ******************************************************************************************************************************/
 
function validateBatchControlInfo ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",4";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  
  childContext = myContext + "." + "sender";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSender ( myContext, nMyIndices, "sender", 0, errorContext );
  }
  else   
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",30" + ":" + BatchControlInfoStr; 

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "30", "Missing sender field"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "4", "0", "-1", "-1", "","Missing sender field");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
    
 
  childContext = myContext + "." + "recipient";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecipient ( myContext, nMyIndices, "recipient", 0, errorContext );
  }
  else 
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",31" + ":" + BatchControlInfoStr; 

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "31", "Missing recipient field"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "4", "0", "-1", "-1", "","Missing recipient field");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "fileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateFileSequenceNumber ( myContext, nMyIndices, "fileSequenceNumber", 0, errorContext );
  }
  else   
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",32" + ":" + BatchControlInfoStr; 

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "32", "Missing file sequence number"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "4", "0", "-1", "-1", "","Missing file sequence number");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "fileCreationTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateFileCreationTimeStamp ( myContext, nMyIndices, "fileCreationTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "transferCutOffTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTransferCutOffTimeStamp ( myContext, nMyIndices, "transferCutOffTimeStamp", 0, errorContext );
  }
  else 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "BatchControlInfo", "4", "36", "Missing file transfer cutoff timestamp");
  }
  childContext = myContext + "." + "fileAvailableTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateFileAvailableTimeStamp ( myContext, nMyIndices, "fileAvailableTimeStamp", 0, errorContext );
  }
  else 
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",33" + ":" + BatchControlInfoStr; 

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "33", "Missing file available timestamp"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "4", "0", "-1", "-1", "","Missing file available timestamp");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "specificationVersionNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSpecificationVersionNumber ( myContext, nMyIndices, "specificationVersionNumber", 0, errorContext );
  }
  else 
  {
    rollbackReason = "BatchControlInfo," + errorContext + ",34" + ":" + BatchControlInfoStr; 

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "34", "Missing file specification version number"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "34", "4", "0", "-1", "-1", "","Missing file specification version number");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "releaseVersionNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateReleaseVersionNumber ( myContext, nMyIndices, "releaseVersionNumber", 0, errorContext );
  }
  else
  {
    String rollbackReason = "BatchControlInfo," + "1,4,30" + ":" + BatchControlInfoStr;   
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "SpecificationVersionNumber", "201", "30", "Mandatory associated item Release Version Number missing");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "201", "0", "-1", "-1", "","Mandatory associated item Release Version Number missing");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "fileTypeIndicator";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateFileTypeIndicator ( myContext, nMyIndices, "fileTypeIndicator", 0, errorContext );
  }
  else
  { 
    String FileName = strSubstr(tapFileName, 0, 1);
    if(FileName == "T") 
    {
      rollbackReason = "BatchControlInfo," + errorContext + ",39" + ":" + BatchControlInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "BatchControlInfo", "4", "39", "FileTypeIndicator Mismatch"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "39", "4", "0", "-1", "-1", "","FileTypeIndicator Mismatch");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}


/*****************************************************************************************************************************
*    Support for TAP 3.12
******************************************************************************************************************************/

function validateNonChargedPublicUserId ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
  errorContext = errorContext + ",445";                                                        
    
  //No Validation : String
  
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function validateNonChargedPartyNumber ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
  errorContext = errorContext + ",444";                                                        
  Bool countryCodeFound = false; 
  Bool notNumberFound = false;
  Long j = 0;
  
  notNumberFound = validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") ;

  for( j = 0 ; j < numOfCountryCode and countryCodeFound == false ; j = j + 1 )
  {
    if ( strStartsWith(edrStringEx(myContext, indices, nParentIndices), countryCodeArray[j]) == true )
    {
      countryCodeFound = true;
    }
  }  

  if( notNumberFound == true or countryCodeFound == false )
  {
    if (mobileSessionServiceType == 1)
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Non-Charged Party Number", "444", "10", "Syntax error and Mobile Session Service is MO Voice over LTE");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error and Mobile Session Service is MO Voice over LTE");
      edrSetIsValidDetail(false);
    }
	
    if (mobileSessionServiceType == 2)
    {
       edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Non-Charged Party Number", "444", "11", "Syntax error and Mobile Session Service is MT Voice over LTE");    
    }
	
    if (messagingEventServiceType == 1 or messagingEventServiceType == 2)
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Non-Charged Party Number", "444", "12", "Syntax error and Messaging Event Service is MO SMS over IP or MT SMS over IP");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "12", errorContext, "0", "-1", "-1", "","Syntax error and Messaging Event Service is MO SMS over IP or MT SMS over IP");
      edrSetIsValidDetail(false);
    }
  }
  
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                                  
                                                                                                             
function validateNonChargedParty ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  errorContext = errorContext + ",443";                                                        
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext; 
  nonChargedPublicUserIdIsMissing = false; 
  nonChargedPartyNumberIsMissing = false;  
                                                                                                             
  childContext = myContext + "." + "nonChargedPartyNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateNonChargedPartyNumber ( myContext, nMyIndices, "nonChargedPartyNumber", 0, errorContext );                 
  }
  else
  {
    nonChargedPartyNumberIsMissing = true;
  }	
                                                                                                             
  childContext = myContext + "." + "nonChargedPublicUserId";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateNonChargedPublicUserId ( myContext, nMyIndices, "nonChargedPublicUserId", 0, errorContext );                 
  }
  else
  {
    nonChargedPublicUserIdIsMissing = true;
  }

  if ( nonChargedPartyNumberIsMissing == true and nonChargedPublicUserIdIsMissing == true and (mobileSessionServiceType == 1 or messagingEventServiceType == 1) )
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Non-Charged Party", "443", "30", "Neither Non Charged Party Number nor Non Charged Public User ID present");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Neither Non Charged Party Number nor Non Charged Public User ID present");
    edrSetIsValidDetail(false);
  }
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}

