<ObjectList
  xmlns="http://www.oracle.com/schemas/BusinessConfig"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.oracle.com/schemas/BusinessConfig ../../../xsd/config_rev_rec_schedule.xsd">

    <ConfigObject>
	<DESCR>Sample period based recognition 30/70 percentage over 20 days</DESCR>
	<NAME>Period based 30/70 over 20 days</NAME>

	<EXTENDED_INFO>
		<CODE>123456789</CODE>
        </EXTENDED_INFO>
	<GL_TIME_PERIODS elem="0">
		<GL_ID>100</GL_ID>
		<START_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<START_OFFSET>0</START_OFFSET>
		</START_TIME_INFO>
		<END_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<END_OFFSET>10</END_OFFSET>
		</END_TIME_INFO>
                <PERCENT>30</PERCENT>
	</GL_TIME_PERIODS>
        <GL_TIME_PERIODS elem="1">
		<GL_ID>100</GL_ID>
		<START_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<START_OFFSET>10</START_OFFSET>
		</START_TIME_INFO>
		<END_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<END_OFFSET>20</END_OFFSET>
		</END_TIME_INFO>
                <PERCENT>70</PERCENT>
	</GL_TIME_PERIODS>
    </ConfigObject>

    <ConfigObject>
        <DESCR>Sample milestone based recognition 20/80 percentage over 20 days</DESCR>
        <NAME>Milestone based 20/80 over 20 days</NAME>
        <EXTENDED_INFO>
                <CODE>987654321</CODE>
        </EXTENDED_INFO>
        <GL_MILESTONES elem="0">
		<GL_ID>100</GL_ID>
		<NAME>Delivery</NAME>
		<START_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<START_OFFSET>0</START_OFFSET>
		</START_TIME_INFO>
		<END_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<END_OFFSET>20</END_OFFSET>
		</END_TIME_INFO>
		<PERCENT>20</PERCENT>
		<MILESTONE_DEADLINE_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<END_OFFSET>25</END_OFFSET>
		</MILESTONE_DEADLINE_INFO>
	</GL_MILESTONES>
	<GL_MILESTONES elem="1">
		<NAME>INSTALLATION</NAME>
		<START_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<START_OFFSET>10</START_OFFSET>
		</START_TIME_INFO>
		<END_TIME_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
                        <END_OFFSET>20</END_OFFSET>
		</END_TIME_INFO>
		<PERCENT>80</PERCENT>
		<MILESTONE_DEADLINE_INFO>
			<MODE_STR>relative</MODE_STR>
			<UNIT_STR>day</UNIT_STR>
			<END_OFFSET>25</END_OFFSET>
		</MILESTONE_DEADLINE_INFO>
	</GL_MILESTONES>
    </ConfigObject>
</ObjectList>
