#!/home/pin/opt/portal/Thirdparty/perl-5.38.2/bin/perl

use Getopt::Std;
use strict;
use warnings; 

####################################################################
#-------------------------------------------------------------------
#
#  @(#)% %
#
# Copyright (c) 2007, 2024, Oracle and/or its affiliates. All rights reserved.
