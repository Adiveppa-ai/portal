#
# stop_pin_config_distribution
#
#
VERSION=15.0
PATH=/usr/bin:/bin

PIN_CONFIG_DISTRIBUTION=pin_config_distribution
LOGDIR=/home/pin/opt/portal/BRM/var/multi_db
PIN_CONFIG_DISTRIBUTIONPID=${LOGDIR}/pin_config_distribution.pid

me=$0

if [ ! -f ${PIN_CONFIG_DISTRIBUTIONPID} ]; then
	echo "${me}: ERROR: no pid file: ${PIN_CONFIG_DISTRIBUTIONPID}, cannot kill \"${PIN_CONFIG_DISTRIBUTION}\""
        exit 1
fi       

kill `cat ${PIN_CONFIG_DISTRIBUTIONPID}`
rc=$?
if [ ${rc} -ne 0 ]; then
	echo "${me}: ERROR: kill ${PIN_CONFIG_DISTRIBUTION} \
		`cat ${PIN_CONFIG_DISTRIBUTIONPID}` FAILED"
	exit ${rc}
else
	rm ${PIN_CONFIG_DISTRIBUTIONPID}
fi

exit 0
