/******************************************************************************************************************************
 * This function will validate ContentProviderIdentifier. It will raise error code 100, 101 for ContentProviderIdentifier.
 ******************************************************************************************************************************/
 
function validateContentProviderIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  Bool   checkType         = true;
  Long   ret               = -1;

  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",292";
  String contentProviderIdentifier = edrStringEx(myContext, indices, nParentIndices);

  switch( lastContentProviderIdType )
  {
    case 1:
    {
       ret = strSearchRegExpr(contentProviderIdentifier, "[^A-Za-z'\. ]");
       Long checkSpace = strSearchRegExpr(contentProviderIdentifier, "[A-Za-z]");
       if ( checkSpace < 0  and ret < 0 )
       {
          ret = 0;
       }
     }
     break;
     case 2:
     {
       ret = strSearchRegExpr(contentProviderIdentifier, "[^A-Z0-9]");
     }
     break;
     case 3:
     {
       ret = strSearchRegExpr(contentProviderIdentifier, "!(.+)");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(contentProviderIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(contentProviderIdentifier);
     }
     break;
  }
  if (ret >= 0 or checkType == false)
  {
    if( strStartsWith(parentContext, "DETAIL.contentTransaction.servingPartiesInformation.contentProviderIdList") == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Content Provider Identifier", "292", "100",
                                                   "Item content does not match Content Provider Id Type");
    }
    else
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Content Provider Identifier", "292", "101",
                                                   "Item content does not match Content Provider Id Type");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1","",
                                                   "Item content does not match Content Provider Id Type");
      edrSetIsValidDetail(false);
    }
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

