<xs:schema 
  targetNamespace="http://www.oracle.com/schemas/BusinessConfig"
  xmlns="http://www.oracle.com/schemas/BusinessConfig"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  attributeFormDefault="unqualified"
  elementFormDefault="qualified">

  <xs:annotation>
    <xs:documentation xml:lang="en">
    Schema definition for /config/tax_supplier.
    </xs:documentation>
  </xs:annotation>

  <xs:include schemaLocation="PinTypes.xsd" />

  <xs:element name="ObjectList">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="ConfigObject" minOccurs="1" maxOccurs="1">
          <xs:complexType>
            <xs:sequence>
              <xs:element name="POID" type="PinPoid" minOccurs="0" />
              <xs:element name="ACCOUNT_OBJ" type="PinPoid" minOccurs="0" />
              <xs:element name="DESCR" type="xs:string" minOccurs="0" />
              <xs:element name="HOSTNAME" type="xs:string" minOccurs="0" />
              <xs:element name="NAME" type="xs:string" minOccurs="1" />
              <xs:element name="PROGRAM_NAME" type="xs:string" minOccurs="0" />
              <xs:element name="VALUE" type="xs:string" minOccurs="0" />
              <xs:element name="VERSION" type="xs:string" minOccurs="0" />
              <xs:element name="TAX_SUPPLIERS" minOccurs="0"
                          maxOccurs="unbounded">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="ADDRESS" type="xs:string" 
                                minOccurs="0" />
                    <xs:element name="DEFAULT_FLAG"
                                type="xs:nonNegativeInteger" minOccurs="0" />
                    <xs:element name="DESCR" type="xs:string" 
                                minOccurs="1" />
                    <xs:element name="NAME" type="xs:string" 
                                minOccurs="1" />
                    <xs:element name="NEXUSINFO" type="xs:string" 
                                minOccurs="0" />
                    <xs:element name="REGULATED_FLAG"
                                type="xs:nonNegativeInteger" minOccurs="0" />
                    <xs:element name="VATINFO" minOccurs="0" 
                                maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="CANON_COUNTRY" type="xs:string" 
                                      minOccurs="1" />
                          <xs:element name="VAT_CERT" type="xs:string" 
                                      minOccurs="1" />
                        </xs:sequence>
                        <xs:attribute name="elem" 
                                      type="xs:nonNegativeInteger" />
                      </xs:complexType>
                    </xs:element>
                  </xs:sequence>
                  <xs:attribute name="elem" type="xs:nonNegativeInteger" />
                </xs:complexType>
              </xs:element>
            </xs:sequence>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
      <xs:attribute name="configName" type="xs:string" 
                    default="/config/tax_supplier" />
      <xs:attribute name="configMode" type="xs:string" default="replace" />
    </xs:complexType>
  </xs:element>

</xs:schema>
