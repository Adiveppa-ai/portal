//==============================================================================
// Constant Variables
//==============================================================================

Bool debug;

String	batchcontents;
String	currencyType;
String	returnIndicator;

//==============================================================================
// BEGIN Container
//==============================================================================
function BEGIN
{
  debug = false;
  //debug = true;
}
   
//==============================================================================
// Function declarations
//==============================================================================

//------------------------------------------------------------------------------
// init()
//------------------------------------------------------------------------------
function init
{
  if ( debug )
    logStdout("init()\n");

  batchcontents = "UNDEFINED";
  currencyType = "UNDEFINED";
  returnIndicator = "UNDEFINED";
}

//------------------------------------------------------------------------------
// validateReturnCode()
// Perform cross field validations between Return Code and Batch Return 
// Indicator.
//------------------------------------------------------------------------------
function validateReturnCode
{
  if (debug)
    logStdout("validateReturnCode()\n");

  if(edrString(DETAIL.ASS_CIBER_EXT.RETURN_CODE, 0) == "0" and 
       returnIndicator == "2" )  {
    edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
    edrAddError("ERR_CIBER_RET",3,"4","18","044",
		"CIBER25.ASS_CIBER_EXT.RETURN_CODE");
  }

  if(edrString(DETAIL.ASS_CIBER_EXT.RETURN_CODE, 0) != "0" and 
       returnIndicator == "1" )  {
    edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
    edrAddError("ERR_CIBER_RET",3,"4","18","046",
		"CIBER25.ASS_CIBER_EXT.RETURN_CODE");
  }
  return;
}


//------------------------------------------------------------------------------
// validateAge(long recordType)
// Ensure that the CIBER record is not older than the permitted date.
//------------------------------------------------------------------------------
function validateAge(Long recordType) 
{
  Date currentDate = sysdate();
  Long thirtyDays  = 2592000; //Thirty days in seconds
  Long sixityDays  = 5184000; //Sixity days in seconds
  Long nintyDays  = 7776000;  //Ninty days in seconds

  if (debug)
    logStdout("validateAge()\n");

  Date callDate = edrDate(DETAIL.ASS_CIBER_EXT.CALL_DATE,  0);

  if (recordType == 10 or 
      recordType == 20 or
      recordType == 22) {
    if ( returnIndicator == "1" and 
       dateDiff(currentDate, callDate) > thirtyDays ) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","10","007",
		"CIBER25.ASS_CIBER_EXT.CALL_DATE");
    }
    if ( callDate > currentDate ) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","17","007",
		"CIBER25.ASS_CIBER_EXT.CALL_DATE");
    }

    if ( returnIndicator == "2" and 
       dateDiff( currentDate, callDate) > sixityDays ) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"5","13","045",
		"CIBER25.ASS_CIBER_EXT.CALL_DATE");
    }
  }

  if (recordType == 11 or 
      recordType == 30 or
      recordType == 32 or
      recordType == 42 
      ) {
    if ( returnIndicator == "1" and
       dateDiff( currentDate, callDate) > sixityDays ) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","10","007",
		"CIBER25.ASS_CIBER_EXT.CALL_DATE");
    }
    if ( callDate > currentDate ) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","17","007",
		"CIBER25.ASS_CIBER_EXT.CALL_DATE");
    }

    if ( returnIndicator == "2" and
       dateDiff( currentDate, callDate) > nintyDays ) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"5","13","045",
		"CIBER25.ASS_CIBER_EXT.CALL_DATE");
    }
  }

  if (recordType == 50 or 
      recordType == 52 ) {
    Date occEndDate = edrDate(DETAIL.ASS_CIBER_EXT.OCC_END_DATE, 0);
    Date occStartDate = edrDate(DETAIL.ASS_CIBER_EXT.OCC_START_DATE, 0);
    Date recordCreationDate = edrDate(DETAIL.ASS_CIBER_EXT.RECORD_CREATE_DATE, 0);
    
    if ( returnIndicator == "1" and
       dateDiff(currentDate, occEndDate) > thirtyDays) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","10","207",
		"CIBER25.ASS_CIBER_EXT.OCC_END_DATE");
    }
    if (occStartDate > occEndDate) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","25","207",
		"CIBER25.ASS_CIBER_EXT.OCC_END_DATE");
    }
    if (recordCreationDate > currentDate) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"4","17","208",
		"CIBER25.ASS_CIBER_EXT.OCC_END_DATE");
    }

    if ( returnIndicator == "2" and
       dateDiff(currentDate , occEndDate) > sixityDays) {
       edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
       edrAddError("ERR_CIBER_RET",3,"5","13","045",
		"CIBER25.ASS_CIBER_EXT.OCC_END_DATE");
    }
  }

  return;
}


//------------------------------------------------------------------------------
// validateESNIMEI(); 
// Validate the electronic serila number.
//------------------------------------------------------------------------------
function validateESNIMEI
{

  if (debug)
    logStdout("validateESNIMEI()\n");

  // Get the ESN/IMEI Indicator
  if (edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI_INDICATOR, 0) == "0" and 
     // edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0) != "0000000000000000000") 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0)) != 0){
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","105","CIBER25.ASS_CIBER_EXT.ESN_IMEI");
  }
  else if (edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI_INDICATOR, 0) == "1" and
      //strSubstr(edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0), 0, 11) == "00000000000") 
      strToLong(strSubstr(edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0), 0, 11)) == 0) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID); 
      edrAddError("ERR_CIBER_RET",3,"4","06","105","CIBER25.ASS_CIBER_EXT.ESN_IMEI");
  }
  else if (edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI_INDICATOR, 0) == "2" and
   //   strSubstr(edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0), 0, 16) == "0000000000000000") 
      strToLong(strSubstr(edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0), 0, 16)) == 0) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID); 
      edrAddError("ERR_CIBER_RET",3,"4","07","105","CIBER25.ASS_CIBER_EXT.ESN_IMEI");
  }
  else if (edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI_INDICATOR, 0) == "3" and
     // edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0) == "0000000000000000000") 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.ESN_IMEI, 0)) == 0){
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID); 
      edrAddError("ERR_CIBER_RET",3,"4","07","105","CIBER25.ASS_CIBER_EXT.ESN_IMEI");
  }
  return;
}

//------------------------------------------------------------------------------
// validateTLDN_NO(); 
// Perform cross field validations between the TLDN number and the TLDN
// number length.
//------------------------------------------------------------------------------
function validateTLDN_NO
{

  if (debug)
    logStdout("validateTLDN_NO()\n");

  // Get the TLDN length
  if ((edrLong(DETAIL.ASS_CIBER_EXT.TLDN_NO_LENGTH, 0) == 0 and 
       strToLong(edrString(DETAIL.ASS_CIBER_EXT.TLDN_NO, 0)) != 0)  or
       (edrLong(DETAIL.ASS_CIBER_EXT.TLDN_NO_LENGTH, 0) > 0 and 
        strToLong(edrString(DETAIL.ASS_CIBER_EXT.TLDN_NO, 0)) <= 0)) {
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","07","111","CIBER25.ASS_CIBER_EXT.TLDN_NO");
  }

  return;
}


//------------------------------------------------------------------------------
// validateAirTimeRateCharge(); 
// Validate the air tim echarge, rate period and multi rate period.
//------------------------------------------------------------------------------
function validateAirTimeRateCharge
{

  if (debug)
    logStdout("validateAirTimeRateCharge()\n");

  // Get the special features used 
  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "F") >= 0) and 
       edrDecimal(DETAIL.ASS_CIBER_EXT.AIR_CHARGE, 0) != 0.00) {
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","07","026","CIBER25.ASS_CIBER_EXT.AIR_CHARGE");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "F") >= 0) and 
       dateToStr(edrDate(DETAIL.ASS_CIBER_EXT.AIR_CONNECT_TIME, 0), "%H%M%S") 
		!= "000000") {

logStdout ("TESTTT" + dateToStr(edrDate(DETAIL.ASS_CIBER_EXT.AIR_CONNECT_TIME, 0), "%H%M%S") + "\n");

        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","07","022","CIBER25.ASS_CIBER_EXT.AIR_CONNECT_TIME");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "F") >= 0) and 
       edrString(DETAIL.ASS_CIBER_EXT.AIR_MULTIRATE_PERIOD, 0) != "0") {
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","06","025","CIBER25.ASS_CIBER_EXT.AIR_MULTIRATE_PERIOD");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "F") >= 0) and 
       edrString(DETAIL.ASS_CIBER_EXT.AIR_RATE_PERIOD, 0) != "00") {
        edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
	//edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
	edrAddError("ERR_CIBER_RET",3,"4","06","024","CIBER25.ASS_CIBER_EXT.AIR_RATE_PERIOD");
  }

  return;
}


//------------------------------------------------------------------------------
// validateOtherChargeNo1(); 
// Perform cross field validation between Other Charge 1 and Other Charge 1
// indicator.
//------------------------------------------------------------------------------
function validateOtherChargeNo1
{
  if (debug)
    logStdout("validateOtherChargeNo1()\n");

  // Get other charge no 1 indicator 
  if (edrString(DETAIL.ASS_CIBER_EXT.OTHER_CHARGE_1_INDICATOR, 0) == "00" and
      edrDecimal(DETAIL.ASS_CIBER_EXT.OTHER_CHARGE_1, 0) != 0.00) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","114","CIBER25.ASS_CIBER_EXT.OTHER_CHARGE_1");

  }

  return;
}


//------------------------------------------------------------------------------
// validateFraudIndicator(); 
// Perform cross field validation between Fraud Indicator and Fraud Sub Indicator
// 
//------------------------------------------------------------------------------
function validateFraudIndicator
{
  if (debug)
    logStdout("validateFraudIndicator()\n");

  // Get other charge no 1 indicator 
  if (edrString(DETAIL.ASS_CIBER_EXT.FRAUD_INDICATOR, 0) == "00" and
      edrString(DETAIL.ASS_CIBER_EXT.FRAUD_SUB_INDICATOR, 0) != "0") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","206","CIBER25.ASS_CIBER_EXT.FRAUD_INDICATOR");
  }
  return;
}

//------------------------------------------------------------------------------
// validateToll(); 
// Validate cross field validations for toll charge, toll rate period, toll
// rating point and special features used.
//------------------------------------------------------------------------------
function validateToll
{
  if (debug)
    logStdout("validateToll()\n");

  // Get other charge no 1 indicator 
  if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.TOLL_RATE_CLASS, 0) == "0") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","032","CIBER25.ASS_CIBER_EXT.TOLL_RATE_CLASS");
  }
  if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.TOLL_RATE_PERIOD, 0) == "00") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","030","CIBER25.ASS_CIBER_EXT.TOLL_RATE_PERIOD");
  }

  if (edrLong(DETAIL.ASS_CIBER_EXT.TOLL_RATING_POINT_LENGTH, 0) == 0 and
      edrString(DETAIL.ASS_CIBER_EXT.TOLL_RATING_POINT, 0) != "0000000000") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","120","CIBER25.ASS_CIBER_EXT.TOLL_RATE_POINT");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "J") >= 0) and
      edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","034","CIBER25.ASS_CIBER_EXT.TOLL_CHARGE");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "K") >= 0) and
      edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","034","CIBER25.ASS_CIBER_EXT.TOLL_CHARGE");
  }

  return;
}

//------------------------------------------------------------------------------
// validateToll_20(); 
// Perform cross field level validations for CIBER 20 record. Validate toll 
// charge, toll rate class, toll rate period and toll tariff desc. 
//------------------------------------------------------------------------------
function validateToll_20
{
  if (debug)
    logStdout("validateToll_20()\n");

  if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.TOLL_RATE_CLASS, 0) == "0") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","032","CIBER25.ASS_CIBER_EXT.TOLL_RATE_CLASS");
  }
  if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.TOLL_RATE_PERIOD, 0) == "00") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","030","CIBER25.ASS_CIBER_EXT.TOLL_RATE_PERIOD");
  }

  if (edrDecimal(DETAIL.ASS_CIBER_EXT.TOLL_CHARGE, 0) != 0.00 and
      edrString(DETAIL.ASS_CIBER_EXT.TOLL_TARIFF_DESC, 0) == "00") {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","029","CIBER25.ASS_CIBER_EXT.TOLL_TARIFF_DESC");
  }
  return ;
}


//------------------------------------------------------------------------------
// validateChargeNoIndicator_32(); 
// Perform cross field validation between charge no indicator and special 
// feature used.
//------------------------------------------------------------------------------
function validateChargeNoIndicator_32
{
  if (debug)
    logStdout("validateChargeNoIndicator_32()\n");

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "15" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "19" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "20" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "21" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "22" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "23" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "24" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_1_IND, 0) != "25" ) 
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","064","CIBER25.ASS_CIBER_EXT.CHARGE_NO_1_IND");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "15" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "19" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "20" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "21" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "22" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "23" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "24" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) != "25" ) 
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","071","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_IND");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "15" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "19" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "20" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "21" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "22" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "23" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "24" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_3_IND, 0) != "25" ) 
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","078","CIBER25.ASS_CIBER_EXT.CHARGE_NO_3_IND");
  }

  if ((strSearch(edrString(DETAIL.ASS_CIBER_EXT.SPECIAL_FEATURES_USED,0 ), "T") >= 0) and
      (edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "15" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "19" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "20" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "21" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "22" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "23" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "24" or 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_4_IND, 0) != "25" ) 
      ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","085","CIBER25.ASS_CIBER_EXT.CHARGE_NO_4_IND");
  }

  return;
}

//------------------------------------------------------------------------------
// validateChargeNo2(Long recordType); 
// Cross field validation between:
//    Charge No 2
//    Charge No 2 Indicator
//    Charge No 2 Connect Time
//    Charge No 2 Elapsed Time
//    Charge No 2 Chargeable Time
//    Charge No 2 Rate Period
//    Charge No 2 Multi Rate Period
//    Charge No 2 Surcharge Ind
//------------------------------------------------------------------------------
function validateChargeNo2(Long recordType) 
{
  if (debug)
    logStdout("validateChargeNo2()\n");

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2, 0) != 0.00 ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      edrDecimal(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2, 0) == 0.00 ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","077","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_CHARGEABLE_TIME, 0) != "000000" ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_CHARGEABLE_TIME, 0) == "000000" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","073","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_CHARGEABLE_TIME");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      dateToStr(edrDate(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_CONNECT_TIME, 0), "%H%M%S") != "000000" ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      dateToStr(edrDate(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_CONNECT_TIME, 0)) == "000000" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","072","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_CONNECT_TIME");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_ELAPSED_TIME, 0) != "000000" ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_ELAPSED_TIME, 0) == "000000" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","074","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_ELAPSED_TIME");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_MULTIRATE_PERIOD, 0) != "0" ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_MULTIRATE_PERIOD, 0) == "0" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","07","076","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_MULTIRATE_PERIOD");
  }

  if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_RATE_PERIOD, 0) != "00" ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_RATE_PERIOD, 0) == "00" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","075","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_RATE_PERIOD");
  }
  
  if(recordType == 32 or recordType == 42) {
    if ((edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0) == "00" and
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_SURCHARGE_IND, 0) != "0" ) or 
      strToLong(edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_IND, 0)) > 0 and 
      edrString(DETAIL.ASS_CIBER_EXT.CHARGE_NO_2_SURCHARGE_IND, 0) == "0" ) {
      edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_CIBER_RET";
      //edrAddError("ERR_CIBER_RET",3,retCode,retReason,fieldID,ruleID);
      edrAddError("ERR_CIBER_RET",3,"4","06","096","CIBER25.ASS_CIBER_EXT.CHARGE_NO_2_SURCHARGE_IND");
    }
  }

  return;
}


