#
# start_cmmp
#
#
VERSION=15.0
PATH=/usr/bin:/bin

PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/cmmp
PERFLIBDIR=/home/pin/opt/portal/BRM/apps/perflib

CM=${PINDIR}/bin/cmmp

CMDIR=${PINDIR}/sys/cmmp
CMLOG=${LOGDIR}/cmmp.log
CMPID=${LOGDIR}/cmmp.pid

abort()
{
   echo "ERROR : $CMD - $@" >&2
   exit 1
}

usage()
{
   cat - >&2 <<!
Usage: 	start_cm - Starts the CM process
	start_cm perflib -  Starts the CM process with Perflib enabled 
!
   exit 1
}

[ -n "$LIBRARYEXTENSION" ] || abort "LIBRARYEXTENSION is not set"
EXT=$LIBRARYEXTENSION



if [ -r ${CMPID} ]; then
  /bin/ps -f -p `cat ${CMPID}` | grep ${CM} > /dev/null
  if [ $? -eq 0 ]; then
        echo "ERROR: cmmp is already running"
        exit 1
  fi
fi

if [ ! -x ${CM} ]; then
	echo "HELP: executable \"${CM}\" not found!"
	exit 1
fi       

if [ \( ! -r  ${CMDIR}/pin.conf \) -a \( ! -r /etc/pin.conf \)  -a \( ! -r ${PINDIR}/config/pin.conf \) ]; then
        echo "HELP: no pin.conf for cmmp in \"${CMDIR}\" or /etc!"
        exit 1
fi       

if [ ! -d  ${LOGDIR} ]; then
	mkdir -p ${LOGDIR}
	if [ $? -ne 0 ]; then
		echo "HELP: problem making LOGDIR \"${LOGDIR}\"!"
		exit 1
	fi
fi       

if [ $# -eq 1 ]; then
	if [ "$1" = "perflib" ];then
		echo "Starting perflib"
		echo $PERFLIBDIR
		cd ${PERFLIBDIR}
		export DIR=$(pwd)
		(
   
			. $DIR/perf.env

			[ -n "$PERFLIB_PIN_SHLIB" ] || \
				abort "PERFLIB_PIN_SHLIB not set in $DIR/perf.env"
			[ -r "$PERFLIB_PIN_SHLIB" ] || abort "PERFLIB_PIN_SHLIB does not exist"
			
			PSHLIB="$PIN_HOME/lib/libperflib${EXT}"
			[ -r "$PSHLIB" ] || abort "PERFLIB[$PSHLIB] does not exist"
			
			export LD_PRELOAD="$PIN_HOME/lib/libperflib${EXT} $LD_PRELOAD"

			cd ${CMDIR} ;
			echo "started ${CM} at..." >> ${CMLOG}
			date >> ${CMLOG}
			${CM} >> ${CMLOG} 2>&1 &
			echo $! > ${CMPID} ;
			chmod 640 ${CMLOG} ;
			chmod 640 ${CMPID} 

		)

	else
		usage
		exit 0
	fi
  
elif [ $# -gt 1 ]
then
	usage
	exit 0
fi

if [ $# -eq 0 ]; then
# XXX ought to save old log file, or check for > some-size...
  ( cd ${CMDIR} ;
    echo "started ${CM} at..." >> ${CMLOG}
    date >> ${CMLOG}
    ${CM} >> ${CMLOG} 2>&1 &
    echo $! > ${CMPID} ;
    chmod 640 ${CMLOG} ;
    chmod 640 ${CMPID} )
fi
# get rc from cmmp startup
exit $?
