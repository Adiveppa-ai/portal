//------------------------------------------------------------------------------
// init()
//------------------------------------------------------------------------------
function init
{
  if (debug)
  {
    logStdout("init()\n");
  }
}

function setAssociatedTapErr (String errorName , Long errorSeverity , 
				String tapErrorCode , String tapErrorAppTag , String tapErrorDepth)
                                
{ 
  Long blockIndex;
  blockIndex = edrNumDatablocks(DETAIL.ASS_TAP3_ERR);
  if(edrAddDatablock(DETAIL.ASS_TAP3_ERR) == true){
   edrString(DETAIL.ASS_TAP3_ERR.RECORD_TYPE ,blockIndex) = "670";
   edrLong(DETAIL.ASS_TAP3_ERR.RECORD_NUMBER ,blockIndex) = edrLong(DETAIL.RECORD_NUMBER);
   edrString(DETAIL.ASS_TAP3_ERR.ERROR_NAME ,blockIndex) = errorName;
   edrLong(DETAIL.ASS_TAP3_ERR.ERROR_SEVERITY ,blockIndex) = errorSeverity;
   edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_CODE ,blockIndex) = tapErrorCode;
   edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_APPLICATION_TAG ,blockIndex) = tapErrorAppTag;
   edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_DEPTH ,blockIndex) = tapErrorDepth;
  }
}


//----------------------------------------------------------------------------
// function validateIpV4 
//
// This function will be used to validate the IP4 Address.
//----------------------------------------------------------------------------

function Bool validateIpV4(String ipAddress)
{
  String ListArray[];
  Long nbElem = strSplit( ListArray, ipAddress, "." );
  Long i;
  if(nbElem != 4)
  {
    return false;
  }
  for (i=0 ; i<nbElem ; i=i+1)
  {
    Long found = strSearchRegExpr(ListArray[i], "[^0-9]");
    if(found >= 0)
    {
      return false;
    }
    else
    {
      Long num = strToLong(ListArray[i]);
      if(num < 0 or num >255)
      {
        return false;
      }
    }
  }
  return true;
}



//----------------------------------------------------------------------------
// function validateIpV6
//
// This function will be used to validate the IP6 Address.
//----------------------------------------------------------------------------

function Bool validateIpV6(String ipAddress)
{
  String ListArray[];
  Long nbElem = strSplit( ListArray, ipAddress, ":" );
  Long i;
  if(nbElem != 8)
  {
    return false;
  }
  for (i=0 ; i<nbElem ; i=i+1)
  {
    if(strLength(ListArray[i]) > 4)
    {
      return false;
    }
    Long found = strSearchRegExpr(ListArray[i], "[^0-9A-Fa-f]");
    if(found >= 0)
    {
      return false;
    }
  }
  return true;
}



//----------------------------------------------------------------------------
// function validateEmail 
//
// This function will be used to validate the Email Address.
//----------------------------------------------------------------------------

function Bool validateEmail(String emailAddress)
{
  String ListArray[];
  Long nbElem = strSplit( ListArray, emailAddress, "@" );
  Long i;
  if(nbElem != 2)
  {
    return false;
  }
  for (i=0 ; i<nbElem ; i=i+1)
  {
    Long found = strSearchRegExpr(ListArray[i], "!.+");
    if(found >= 0)
    {
      return false;
    }
  }
  return true;
}



//------------------------------------------------------------------------------
// validateAdvisedCharge()
//
// This function will be used to validate the advise of charge
//------------------------------------------------------------------------------
function validateAdvisedCharge
{
  if (debug)
  {
    logStdout("validateAdvisedCharge()\n");
  }

  String offset;
  Long blockEntries;
  Long blockIndex;

  blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if (edrInternalState(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE,
		0, blockIndex) != STATE_CLEARED and (edrInputState(
		DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE,
		0, blockIndex)) != MISSING)
    {
      if (edrDecimal(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE,
						0, blockIndex) < 0.0)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.ADVISED_CHARGE,
	//	0, blockIndex)));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "349", "6",
		offset, longToStr(blockIndex), "Out Of Range Advised Charge");
        setAssociatedTapErr ("ERR_TAP3_ADVISED_CHARGE_OOR", LOG_MAJOR , "20","349","6");
      }
    }
  }
}


//------------------------------------------------------------------------------
// validateBasicHSCSDParameters()
//
// This function will be used to validate the basic HSCSD Parameters
//------------------------------------------------------------------------------
function validateBasicHSCSDParameters
{
  if (debug)
  {
    logStdout("validateBasicHSCSDParameters()\n");
  }

  String offset;
  Long blockEntries;
  Long blockIndex;

  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if (edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET,
		0, blockIndex)> 0)
    {
      if ((edrInputState(
  		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.NUMBER_OF_CHANNELS,
  		0, blockIndex, 0)) == MISSING)
      {
        // offset = longToStr(edrFieldTokenBytePos(
        //	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.NUMBER_OF_CHANNELS,
        //	0, blockIndex, 0));
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "35", "6",
  		offset, longToStr(blockIndex), "Missing Max Number of Channels");
        setAssociatedTapErr ("ERR_TAP3_MISSING_MAX_CHANNELS", LOG_MAJOR , "31","35","6");		
      }
  
      if ((edrInputState(
  		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.CHANNEL_CODING_OK_LIST,
  		0, blockIndex, 0)) == MISSING)
      {
        // offset = longToStr(edrFieldTokenBytePos(
        //	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.CHANNEL_CODING_OK_LIST,
        //	0, blockIndex, 0));
        offset = "-1";
        edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "34", "35", "6",
  		offset, longToStr(blockIndex), "Missing Channel Coding List");
        setAssociatedTapErr ("ERR_TAP3_MISSING_CHANNEL_CODE_LIST", LOG_WARNING , "34","35","6");		
      }
  
      if ((edrInputState(
  		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.CHANNEL_CODING_USED,
  		0, blockIndex, 0)) == MISSING)
      {
        // offset = longToStr(edrFieldTokenBytePos(
        //	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.CHANNEL_CODING_USED,
        //	0, blockIndex, 0));
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", "35", "6",
  		offset, longToStr(blockIndex), "Missing Channel Coding Used");
        setAssociatedTapErr("ERR_TAP3_MISSING_CHANNEL_CODE_USED", LOG_MAJOR ,"32" ,"35" ,"6");		
      }
      else {
        Long ccu = edrLong(
  		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.CHANNEL_CODING_USED,
  		0, blockIndex, 0);
        if ((ccu < 1) or (ccu > 3))
        {
  	// offset = longToStr(edrFieldTokenBytePos(
  	//	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.CHANNEL_CODING_USED,
  	//	0, blockIndex, 0));
  	offset = "-1";
  	edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "60", "7",
  		offset, longToStr(blockIndex), "Out Of Range Channel Coding");
  	setAssociatedTapErr("ERR_TAP3_OOR_CHANNEL_CODE", LOG_WARNING ,"20" ,"60" ,"7");	
        }
      }
  
      if ((edrInputState(
  		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.NUMBER_OF_CHANNELS_USED,
  		0, blockIndex, 0)) == MISSING)
      {
        // offset = longToStr(edrFieldTokenBytePos(
        //	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.NUMBER_OF_CHANNELS_USED,
        //	0, blockIndex, 0));
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "35", "6",
  		offset, longToStr(blockIndex), "Missing Number of Channels Used");
        setAssociatedTapErr("ERR_TAP3_MISSING_NUM_CHANNELS_USED", LOG_MAJOR ,"33" ,"35" ,"6");		
      }
    }
  }
}
  
//------------------------------------------------------------------------------
// validateHSCSDParameterModification()
//
// This function will be used to validate the HSCSD Parameter Modification
//------------------------------------------------------------------------------
function validateHSCSDParameterModification
{
  if (debug)
  {
    logStdout("validateHSCSDParameterModification()\n");
  }

  Long valid;
  Long pmIndex;
  Long blockIndex;
  Long blockEntries;
  String offset;

  Long callDuration = edrLong(DETAIL.TOTAL_CALL_EVENT_DURATION);

  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long pmBlock = edrNumDatablocks(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST, 0, blockIndex, 0);

    for (pmIndex = 0; pmIndex < pmBlock; pmIndex = (pmIndex + 1))
    {
      if ((edrInputState(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.CHANNEL_CODING_USED,
		0, blockIndex, 0, pmIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.CHANNEL_CODING_USED,
	//	0, blockIndex, 0, pmIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "125", "6",
		offset, longToStr(blockIndex), "Missing Channel Coding Used");
	setAssociatedTapErr("ERR_TAP3_MISSING_CHANNEL_CODE_USED", LOG_MAJOR ,"30" ,"125" ,"6");	
      }
      else
      {
	valid = edrLong(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.CHANNEL_CODING_USED,
		0, blockIndex, 0, pmIndex);
	if ((valid < 1) or (valid > 3))
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.CHANNEL_CODING_USED,
	  //	0, blockIndex, 0, pmIndex));
	  offset = "-1";
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "60", "7",
		offset, longToStr(blockIndex), "Out Of Range Channel Coding Used");
	  setAssociatedTapErr("ERR_TAP3_OOR_CHANNEL_CODE_USED", LOG_MAJOR ,"20" ,"60" ,"7");	
	}
      }

      if ((edrInputState(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.NUMBER_OF_CHANNELS_USED,
		0, blockIndex, 0, pmIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.NUMBER_OF_CHANNELS_USED,
	//	0, blockIndex, 0, pmIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
       edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "125", "6",
		offset, longToStr(blockIndex), "Mandatory item Number Of Channels Used missing within group.");
	setAssociatedTapErr("ERR_TAP3_NUM_CHANNEL_CODE_USED", LOG_MAJOR ,"31" ,"125" ,"6");	
      }

      if ((edrInputState(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.INITIATING_PARTY,
		0, blockIndex, 0, pmIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.INITIATING_PARTY,
	//	0, blockIndex, 0, pmIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", "125", "6",
		offset, longToStr(blockIndex), "Missing Initiating Party");
	setAssociatedTapErr("ERR_TAP3_MISSING_INITIATING_PARTY", LOG_MAJOR ,"32" ,"125" ,"6");	
      }
      else
      {
	valid = edrLong(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.INITIATING_PARTY,
		0, blockIndex, 0, pmIndex);
	if ((valid < 0) or (valid > 1))
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.INITIATING_PARTY,
	  //	0, blockIndex, 0, pmIndex));
	  offset = "-1";
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "130", "7",
		offset, longToStr(blockIndex), "Out Of Range Initiating Party");
	  setAssociatedTapErr("ERR_TAP3_OOR_INITIATING_PARTY", LOG_MAJOR ,"20" ,"130" ,"7");	
	}
      }

      if ((edrInputState(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.MODIFICATION_TIMESTAMP,
		0, blockIndex, 0, pmIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.MODIFICATION_TIMESTAMP,
	//	0, blockIndex, 0, pmIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "125", "6",
		offset, longToStr(blockIndex), "Missing Modification TimeStamp");
	setAssociatedTapErr("ERR_TAP3_MISSING_MOD_TIMESTAMP", LOG_MAJOR ,"33" ,"125" ,"6");	
      }
      else
      {

        // get the time stamp
        Date modificationTime = edrDate(
          DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.MODIFICATION_TIMESTAMP,
          0, blockIndex, 0, pmIndex);

        if( dateIsValid(modificationTime) == false)
        {
	  offset = "-1";
	  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", "150", "7",
			offset, "-1", "Modification timestamp Syntax Error");
	  setAssociatedTapErr("ERR_TAP3_MOD_TIMESTAMP_SE", LOG_MAJOR ,"10" ,"150" ,"7");	
       }

       else
       {
        Long diff_Date = dateDiff(modificationTime, edrDate(DETAIL.CHARGING_START_TIMESTAMP));
        if (diff_Date > callDuration)
        {
          // offset = longToStr(edrFieldTokenBytePos(
          //		DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_START_TIMESTAMP,
	  //		  0, blockIndex));
	  offset = "-1";
	  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "150", "7",
			offset, "-1", "Modification timestamp greater than call event end time ");
	  setAssociatedTapErr("ERR_TAP3_MOD_TIMESTAMP_GT_CALL_END_TIME", LOG_MAJOR ,"100" ,"150" ,"7");	

        }
       }
     }

      if ((edrInputState(
		DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.UTC_TIME_OFFSET,
		0, blockIndex, 0, pmIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.UTC_TIME_OFFSET,
	//	0, blockIndex, 0, pmIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "150", "7",
		offset, longToStr(blockIndex), "Missing Modification UTC Time Offset Code");
	setAssociatedTapErr("ERR_TAP3_MISSING_UTC_TIME_OFFSET_CODE", LOG_MAJOR ,"30" ,"150" ,"7");	
      }

    // Check whether AIUR Requested field is not missing
    // This check has been performed to avoid edrLong
    // returning a 0 value when AIUR Requested field is missing.
    if (edrInternalState(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.AIUR,
                                                0, blockIndex, 0, pmIndex) != STATE_CLEARED and (edrInputState(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.AIUR,
                                                0, blockIndex, 0, pmIndex)) != MISSING)
    {
      Long aiur = edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.AIUR,
                                                0, blockIndex, 0, pmIndex);

      // aiur should be in the range of 1 to 3 and 5 to 12.
      if ( (aiur < 1) or (aiur > 3 and aiur < 5) or (aiur > 12) )
      {
        // If not in range, raise Out Of Range error.
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);

        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "34", "6",
                offset, longToStr(blockIndex), "Out Of Range Air Interface User Rate Requested");
        setAssociatedTapErr ("ERR_TAP3_AIUR_REQUESTED_OOR", LOG_MAJOR, "20", "34", "6");
      }
    }
    }
  }
}

//------------------------------------------------------------------------------
// validateBasicServiceCode()
//
// This function will be used to validate the basic service code
//------------------------------------------------------------------------------
function validateBasicServiceCode
{
  if (debug)
  {
    logStdout("validateBasicServiceCode()\n");
  }

  Long blockIndex;
  Long blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
  Long   duration = edrLong(DETAIL.TOTAL_CALL_EVENT_DURATION);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if ((edrInputState(DETAIL.ASS_GSMW_EXT.BS_PACKET.BASIC_SERVICE,
						0, blockIndex)) == MISSING)
    {
      // String offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_GSMW_EXT.BS_PACKET.BASIC_SERVICE, 0, blockIndex));
      String offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "36", "4",
		offset, longToStr(blockIndex), "Missing Basic Service Code");
      setAssociatedTapErr("ERR_TAP3_MISSING_BASIC_SERVICE_CODE", LOG_MAJOR ,"30" ,"36" ,"4");		
    }
    // Acceptable BearerServiceCode/TeleServiceCode values are checked by iRules.

   else
   {
       String telService = edrString(DETAIL.ASS_GSMW_EXT.BS_PACKET.BASIC_SERVICE, 0, blockIndex);
       // SMS call
       if ((telService  == "020") or (telService == "021") or (telService == "022"))
       {
	 if (duration > 0)
	 {
           // String offset = longToStr(edrFieldTokenBytePos(
           // DETAIL.TOTAL_CALL_EVENT_DURATION));
           String offset = "-1";
           edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
           edrSetIsValidDetail(false);
           edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "223", "5",
		offset, "-1", "Total call duration is greater than 0 for SMS Calls");
	   setAssociatedTapErr("ERR_TAP3_SMS_CALL_GT_ZERO", LOG_MAJOR ,"100" ,"223" ,"5");	
	 }
       }

       if ((telService  == "020") or (telService == "021"))
       {
         if ((edrString(DETAIL.RECORD_TYPE) == type_MTC) and
           edrInputState(DETAIL.ASS_GSMW_EXT.A_NUMBER_USER, 0) == MISSING)
         {
           String offset = "-1";
           edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
           edrSetIsValidDetail(false);
           edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", "41", "5",
                offset, "-1", "Missing Calling Number for SMS calls");
           setAssociatedTapErr("ERR_TAP3_SMS_CALL_MISSING_CALLING_NUMBER", LOG_MAJOR, "35", "41" ,"5");
         }
       }
    }
  }
}


//------------------------------------------------------------------------------
// validateBasicServiceUsed()
//
// Function to validate the BasicServiceUsed block inside MOC/MTC
//------------------------------------------------------------------------------
function validateBasicServiceUsed
{
  if (debug)
  {
    logStdout("validateBasicServiceUsed()\n");
  }

  String offset = "-1";

  if (edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0) > 0)
  {
    Long transparencyIndicator = edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.TRANSPARENCY_INDICATOR, 0, 0);

    if( transparencyIndicator < 0 or transparencyIndicator > 1 )
    {
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);

      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "228", "6",
                offset, "-1", "Transparency Indicator out of range");
      setAssociatedTapErr("ERR_TAP3_TRANSPARENCY_INDICATOR_OOR", LOG_MAJOR, "20", "228","6");
    }
  }
}


//------------------------------------------------------------------------------
// validateChargeDetail()
//
// This function will be used to validate the charge detail
//------------------------------------------------------------------------------
function validateChargeDetail
{
  if (debug)
  {
    logStdout("validateChargeDetail()\n");
  }

  Long blockIndex;
  Long packetIndex;
  Long blockEntries;

  String offset = "-1";

  // Flag used to check whether any validation in a set of validations has failed.
  // Assume that the validations will pass thru.
  Bool allChargeDetailValGood = true;  

  blockEntries = edrNumDatablocks(DETAIL.ASS_CBD);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long packetEntries= edrNumDatablocks(DETAIL.ASS_CBD.CP, blockIndex);

    if (packetEntries == 0)
    {
      // offset = longToStr(edrFieldTokenBytePos(DETAIL.ASS_CBD.CP, blockIndex));
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "69", "5",
			offset, longToStr(blockIndex), "Missing Charge Packet List");
      setAssociatedTapErr("ERR_TAP3_MISSING_CHARGE_PACKET_LIST", LOG_MAJOR ,"33" ,"69" ,"5");			

      allChargeDetailValGood = false;
    }
    else
    {
      for (packetIndex = 0; packetIndex < packetEntries; packetIndex = packetIndex + 1)
      {
	if ((edrInputState(DETAIL.ASS_CBD.CP.DAY_CODE,
			blockIndex, packetIndex)) == MISSING)
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //		DETAIL.ASS_CBD.CP.DAY_CODE, blockIndex, packetIndex));
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "63", "6",
			offset, "packetIndex", "Missing Day Code");
	  setAssociatedTapErr("ERR_TAP3_MISSING_DAY_CODE", LOG_MAJOR ,"30" ,"63" ,"6");		

          allChargeDetailValGood = false;
	}
	// Acceptable DAY_CODE values are checked by iRules

	if ((edrInputState(DETAIL.ASS_CBD.CP.TIME_INTERVAL_CODE,
			blockIndex, packetIndex)) == MISSING)
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //		DETAIL.ASS_CBD.CP.TIME_INTERVAL_CODE, blockIndex, packetIndex));
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "63", "6",
			offset, longToStr(blockIndex), "Missing Time Interval Code");
	  setAssociatedTapErr("ERR_TAP3_MISSING_TIME_INTERVAL_CODE", LOG_MAJOR ,"31" ,"63" ,"6");		

          allChargeDetailValGood = false;
	}
	// Acceptable TIME_INTERVAL_CODE values are checked by iRules

        // Check whether ChargedItem(RUM) is missing
	if ((edrInputState(DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex)) == MISSING)
	{
          // ChargedItem(RUM) is missing
	  // offset = longToStr(edrFieldTokenBytePos(
	  //		DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex));
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "69", "5",
			offset, longToStr(blockIndex), "Missing Charged Item");
	  setAssociatedTapErr("ERR_TAP3_MISSING_CHARGED_ITEM", LOG_MAJOR ,"30" ,"69" ,"5");		

          allChargeDetailValGood = false;
	}
        // ChargedItem(RUM) is present
        // Check whether the ChargeAmount is > 0.0
	else if (edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex)  != 0.0)
        {
          // ChargeAmount is > 0.0. Check whether the ChargedItem(RUM) is "N".
          if (edrString(DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex) == "N")
          {
            // If so, then it is Charge Mismatch
  	    // offset = longToStr(edrFieldTokenBytePos(
  	    //		DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex));
    	    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "62", "7",
  	  	offset, longToStr(blockIndex), "Charge is not 0 and charge item is equal to N");
  	    setAssociatedTapErr("ERR_TAP3_CHARGE_MISMATCH", LOG_MAJOR ,"100" ,"62" ,"7");	

            allChargeDetailValGood = false;
          }
          // ChargedItem(RUM) is not "N". So, it could be anything other than "N", could be EMPTY (i.e "") also.
          // Check if ChargedItem(RUM) is not empty and whether ExchangeRateCode is Missing.
          else if ( ((edrInputState(DETAIL.ASS_CBD.CP.EXCHANGE_RATE, blockIndex, packetIndex)) == MISSING) and 
                    (edrString(DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex) != "") )
          {
             // If so, set the appropriate error for Exchange Rate Code missing.
             // Explanation: Item Exchange Rate Code missing within group and 
             // Charged Item not equal to 'N' and 
             // one or more Charge within an associated Charge Detail is greater than zero.
    	     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "69", "5", offset, 
                          longToStr(blockIndex), "Missing Exchange Rate Code");
  	     setAssociatedTapErr("ERR_TAP3_MISSING_EXCHANGE_RATE_CODE", LOG_MAJOR ,"31" ,"69" ,"5");	

             allChargeDetailValGood = false;
           }
        }
	// Acceptable RUM values are checked by iRules

        String error = "(NaN)";
        // decimalToStr returns "(Nan)" for invalid value.
        if ( error == decimalToStr(edrDecimal(DETAIL.NUMBER_OF_UNITS)) )
        {
          String chargeItem = edrString(DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex);
          Decimal charge = edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex);
          if ( (charge != 0.0) and ((chargeItem == "D") or (chargeItem == "V")) )
          {
            String offset = "-1";
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "65", "3",
            offset, longToStr(blockIndex), "Value out of Range");
            setAssociatedTapErr("ERR_TAP3_VALUE_OUT_OF_RANGE", LOG_MAJOR ,"20" ,"65" ,"3");
          }
          else
          {
            edrDecimal(DETAIL.NUMBER_OF_UNITS) = 0.0;
          }
        }

        String valchargeitem; 
        valchargeitem = edrString(DETAIL.ASS_CBD.CP.RUM, blockIndex, packetIndex);

        if ( (edrInputState(DETAIL.ASS_CBD.CP.CHARGEABLE_QUANTITY_VALUE, blockIndex, packetIndex) == EDR_INPUT_MISSING)
        and (edrInternalState(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex) != EDR_INPUT_MISSING)
        and ((valchargeitem == "D") or (valchargeitem == "V") or (valchargeitem == "W") or (valchargeitem == "X")  ))
        {
            String offset = "-1";
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "63", "3",
            offset, longToStr(blockIndex), "Chargeable units not present");
            setAssociatedTapErr("ERR_TAP3_CHARGEABLE_UNITS_NOT_PRESENT", LOG_MAJOR ,"33" ,"63" ,"3");
        }
        if ( (edrInternalState(DETAIL.ASS_CBD.CP.CHARGEABLE_QUANTITY_VALUE, blockIndex, packetIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CBD.CP.CHARGEABLE_QUANTITY_VALUE, blockIndex, packetIndex) != EDR_INPUT_MISSING) 
        and (edrInputState(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex) == EDR_INPUT_MISSING)
        and ((valchargeitem == "D") or (valchargeitem == "V") or (valchargeitem == "W") or (valchargeitem == "X")  ))
        {
            String offset = "-1";
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", "63", "3",
            offset, longToStr(blockIndex), "Charge not present");
            setAssociatedTapErr("ERR_TAP3_CHARGEABLE_UNITS_NOT_PRESENT", LOG_MAJOR ,"34" ,"63" ,"3");
        }
        if ( (edrInternalState(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, packetIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, packetIndex) != EDR_INPUT_MISSING)  
        and (edrInputState(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex) == EDR_INPUT_MISSING)
        and ((valchargeitem == "A") or (valchargeitem == "D") or (valchargeitem == "E") or (valchargeitem == "F")
        or (valchargeitem == "I") or (valchargeitem == "V") or (valchargeitem == "W") or (valchargeitem == "X")  ))
        {
            String offset = "-1";
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "36", "63", "3",
            offset, longToStr(blockIndex), "Charge not present but charge type present");
            setAssociatedTapErr("ERR_TAP3_CHARGEABLE_UNITS_NOT_PRESENT", LOG_MAJOR ,"36" ,"63" ,"3");
        }
        if ( (edrInputState(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, packetIndex) == EDR_INPUT_MISSING)   
        and (edrInternalState(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, packetIndex) != EDR_INPUT_MISSING)
        and ((valchargeitem == "A") or (valchargeitem == "D") or (valchargeitem == "E") or (valchargeitem == "F")
        or (valchargeitem == "I") or (valchargeitem == "V") or (valchargeitem == "W") or (valchargeitem == "X")  ))
        {
            String offset = "-1";
            edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
            edrSetIsValidDetail(false);
            edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "37", "63", "3",
            offset, longToStr(blockIndex), "Charge present but charge type not present");
            setAssociatedTapErr("ERR_TAP3_CHARGEABLE_UNITS_NOT_PRESENT", LOG_MAJOR ,"37" ,"63" ,"3");
        }
      }
    }
  }

  // If allChargeDetailValGood is not true, then any of the above validations might have failed.
  // The allChargeDetailValGood flag is introduced to reduce the following section of redundant code.
  if ( allChargeDetailValGood != true ) 
  {
    offset = "-1";
    edrSetIsValidDetail(false);
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
  }
}


//------------------------------------------------------------------------------
// validateTaxDetail()
//
// This function will be used to validate the tax detail
//------------------------------------------------------------------------------
function validateTaxDetail
{
  if (debug)
  {
    logStdout("validateTaxDetail()\n");
  }

  Long blockIndex;
  Long packetIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_CBD);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long packetEntries = edrNumDatablocks(DETAIL.ASS_CBD.TP, blockIndex);
    for (packetIndex = 0; packetIndex < packetEntries; packetIndex = packetIndex + 1)
    {
      if (edrInputState(DETAIL.ASS_CBD.TP.TAX_CODE,
					blockIndex, packetIndex) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CBD.TP.TAX_CODE, blockIndex, packetIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "213", "6",
		offset, longToStr(blockIndex), "Missing Tax Code");
	setAssociatedTapErr("ERR_TAP3_MISSING_TAX_CODE", LOG_MAJOR ,"30" ,"213" ,"6");	
      }
      else
      {
	Long code = strToLong(edrString(DETAIL.ASS_CBD.TP.TAX_CODE, blockIndex, packetIndex));
	if ((code < 0) or (code > 999))
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_CBD.TP.TAX_CODE, blockIndex, packetIndex));
	  offset = "-1";
	  edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "212", "7",
		offset, longToStr(blockIndex), "Out Of Range Tax Code");
	  setAssociatedTapErr("ERR_TAP3_TAX_CODE_OOR", LOG_WARNING ,"20" ,"212" ,"7");	
	}
      }

      if ((edrInputState(DETAIL.ASS_CBD.TP.CHARGE_TYPE, blockIndex, packetIndex) == MISSING)
        and (edrInternalState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex) != STATE_CLEARED and edrInputState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex) != MISSING))
      {
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", "213", "6",
                offset, longToStr(blockIndex), "Missing Charge Type and Taxable amount present");
        setAssociatedTapErr("ERR_TAP3_TAXABLE_AMOUNT_PRESENT_MISSING_CHARGE_TYPE", LOG_MAJOR ,"32" ,"213" ,"6");
      }

      Decimal TaxValue = edrDecimal(DETAIL.ASS_CBD.TP.TAX_VALUE, blockIndex, packetIndex);
      Decimal TaxableAmount = edrDecimal(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex);
      Decimal TaxRate = strToDecimal(edrString(DETAIL.ASS_CBD.TP.TAX_RATE, blockIndex, packetIndex));
      Long tpN = edrLong(DETAIL.ASS_CBD.TP.CHARGE_INFORMATION_COUNTER, blockIndex, packetIndex);
      Long CPIndex;
      Decimal Charge = 0.0;
      Bool chargeType_Present = false;

      Long chargePacketEntries = edrNumDatablocks(DETAIL.ASS_CBD.CP, blockIndex);
      for( CPIndex = 0 ; CPIndex < chargePacketEntries; CPIndex = CPIndex + 1)
      {
        if( edrString(DETAIL.ASS_CBD.TP.CHARGE_TYPE, blockIndex, packetIndex)
                        == edrString(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, CPIndex) and
            edrLong(DETAIL.ASS_CBD.CP.CHARGE_INFORMATION_COUNTER, blockIndex, CPIndex) == tpN)
        {
          chargeType_Present = true;
        }
      }
      if(chargeType_Present == true)
      {
        for( CPIndex = 0 ; CPIndex < chargePacketEntries; CPIndex = CPIndex + 1)
        {
          if( edrString(DETAIL.ASS_CBD.TP.CHARGE_TYPE, blockIndex, packetIndex)
                == edrString(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, CPIndex) and
              edrLong(DETAIL.ASS_CBD.CP.CHARGE_INFORMATION_COUNTER, blockIndex, CPIndex) == tpN)
          {
            Charge = Charge + 
		(edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, CPIndex) * theAbsoluteAmountMultilier);
          }
        }
      }
      else
      {
        for( CPIndex = 0 ; CPIndex < chargePacketEntries; CPIndex = CPIndex + 1)
        {
          if( edrString(DETAIL.ASS_CBD.CP.IMPACT_CATEGORY, blockIndex, CPIndex) != "00" and
              edrLong(DETAIL.ASS_CBD.CP.CHARGE_INFORMATION_COUNTER, blockIndex, CPIndex) == tpN)
          {
            Charge = Charge + 
		(edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, CPIndex) * theAbsoluteAmountMultilier);
          }
          else if (edrLong(DETAIL.ASS_CBD.CP.CHARGE_INFORMATION_COUNTER, blockIndex, CPIndex) == tpN)
          {
            Charge = (edrDecimal(DETAIL.ASS_CBD.CP.CHARGED_AMOUNT_VALUE, blockIndex, CPIndex) * theAbsoluteAmountMultilier);
          }
        }
      }

      if (edrInputState(DETAIL.ASS_CBD.TP.TAX_VALUE,
					blockIndex, packetIndex) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CBD.TP.TAX_VALUE, blockIndex, packetIndex));
	offset = "-1";
	edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "213", "6",
		offset, longToStr(blockIndex), "Missing Tax Value");
	setAssociatedTapErr("ERR_TAP3_MISSING_TAX_VALUE", LOG_MAJOR ,"31" ,"213" ,"6");	
      }
      else
      {
	Decimal value = edrDecimal(DETAIL.ASS_CBD.TP.TAX_VALUE, blockIndex, packetIndex);
	if (value < 0.0)
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_CBD.TP.TAX_VALUE, blockIndex, packetIndex));
	  offset = "-1";
	  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "397", "7",
		offset, longToStr(blockIndex), "Out Of Range Tax Value");
	  setAssociatedTapErr("ERR_TAP3_TAX_VALUE_OOR", LOG_MAJOR ,"20" ,"397" ,"7");	
	}
      }

      Decimal Calc_taxValue_frm_charge = round((Charge * (TaxRate/DIVIDE_VALUE))/100.00);
      Decimal Calc_taxValue_frm_taxableAm = round((TaxableAmount * (TaxRate/DIVIDE_VALUE))/100.00);

      if( (edrInputState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex) == MISSING and
                TaxValue != Calc_taxValue_frm_charge ) or
        (edrInternalState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex) != STATE_CLEARED 
        and edrInputState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex) != MISSING and
                TaxValue != Calc_taxValue_frm_taxableAm) )
      {
          offset = "-1";
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
          edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "22", "397", "6",
                offset, longToStr(blockIndex), "Tax value not correct");
          setAssociatedTapErr("ERR_TAP3_TAX_VALUE_INCORRECT", LOG_MAJOR ,"22" ,"397" ,"6");
      }

      Long taxState = edrInputState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex);
      Long taxStateI = edrInternalState(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex);
      if (taxStateI != STATE_CLEARED and taxState != EDR_INPUT_MISSING)
      {
	if (edrDecimal(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex) <= 0.0)
	{
	   //String offset = longToStr(edrFieldTokenBytePos
	   //	(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, blockIndex, packetIndex));
	   offset = "-1";
	   edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
           edrSetIsValidDetail(false);
	   edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "398", "7", offset,
		longToStr(blockIndex), "Out Of Range Tax Amount");
	   setAssociatedTapErr("ERR_TAP3_TAX_AMOUNT_OOR", LOG_MAJOR ,"20" ,"398" ,"7");	
	}
      }
    }
  }
}


//------------------------------------------------------------------------------
// validateChargedParty()
//
// This function will be used to validate the charged party
//------------------------------------------------------------------------------
function validateChargedParty
{
  if (debug)
  {
    logStdout("validateChargedParty()\n");
  }

  Long blockIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST, 0, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if ((edrInputState(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST.TYPE,
						0, 0, blockIndex)) == MISSING)
    {
      // offset = longToStr(edrFieldTokenBytePos(
      //	DETAIL.ASS_CONT_EXT.ID_LIST.TYPE, 0, 0, blockIndex));
      offset = "-1";
      edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
      edrSetIsValidDetail(false);
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "309", "5",
		offset, longToStr(blockIndex), "Missing Charged Party Type");
      setAssociatedTapErr("ERR_TAP3_MISSING_CHARGED_PARTY_TYPE", LOG_MAJOR ,"30" ,"309" ,"5");   		
    }
    else
    {
      Long typeID = edrLong(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST.TYPE,
						0, 0, blockIndex);
      if ((typeID < 1) or (typeID > 8))
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.ID_LIST.TYPE, 0, 0, blockIndex));
	offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "305", "6",
		offset, longToStr(blockIndex), "Out Of Range Tracked Party Type");
