-- all indexes on event tables are local partitioned, there are prefixed and non-prefixed 
--       local indexes
-- global indexes would be too slow in partition maintenance operations

-- when defining a unique index where partitioning key (here it is obj_id0)
-- 	 is not a subset of the index key, one needs to tag obj_id0 to the 
--	 index key to make local partition possible (Oracle8i does not support
--       unique local index that partitioning key is not a subset of 
--	 the index key)

-- /event
-- NOTE: subtables do NOT have rec_id, experience says it is slower.
create unique index i_event__id on event_t ( poid_id0 )
        tablespace pinx00
        initrans 64 storage (initial 1m next 100m maxextents unlimited pctincrease 0 freelists 32 )
        local (partition partition_historic, partition partition_last) ;

