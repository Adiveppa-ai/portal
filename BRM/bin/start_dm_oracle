#       accordance with a valid Oracle license or sublicense agreement.
#

#
# start_dm_oracle
#
# The underlying database (if any) must already be started
# when this script runs.
#
VERSION=15.0
PATH=/usr/bin:/bin


# Set the LIBPATH to include library(lib64) only in the case of AIX platform.
case `uname` in
  AIX)
   LIBPATH=$PIN_HOME/lib64:$LIBPATH
   ;;
esac
	
# This is for HP Itanium. It works around a change in the thread libraries
# for itanium which affects the way shared memory mutexes work
case `uname -m` in
  ia64**)
    export PTHREAD_DISABLE_HANDOFF=1
    ;;
esac

PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/dm_oracle

DM=${PINDIR}/bin/dm_oracle

DMDIR=${PINDIR}/sys/dm_oracle
DMLOG=${LOGDIR}/dm_oracle.log
DMPID=${LOGDIR}/dm_oracle.pid
DMPERFLIBENV=${PERFLIB_HOME}/perf_dm.env

if ! { [ ! -z ${DOCKER} ] && [ ${DOCKER} -eq 1 ]; }; then
  if [ -r ${DMPID} ]; then
  /bin/ps -f -p `cat ${DMPID}` | grep ${DM} > /dev/null
    if [ $? -eq 0 ]; then
        echo "ERROR: dm_oracle is already running"
        exit 1
    fi
  fi
fi

if [ ! -x ${DM} ]; then
        echo "HELP: executable \"${DM}\" not found!"
        exit 1
fi       

if [ ! -d ${DMDIR} ]; then
        echo "HELP: dm_oracle dir \"${DMDIR}\" not found!"
        exit 1
fi

if [ ! -d ${LOGDIR} ]; then
	mkdir -p ${LOGDIR}
	if [ $? -ne 0 ]; then
		echo "HELP: problems making dm_oracle LOGDIR \"${LOGDIR}\"!"
		exit 1
	fi
fi       

# XXX ought to save old log file, or check for > some-size...
if [ ! -z ${DOCKER} ] && [ ${DOCKER} -eq 1 ] ; then

  cd ${DMDIR} ;
  if [ -r ${DMPID} ]; then
    kill -0 `cat ${DMPID}`
    if [ $? -eq 0 ]; then
      echo "dm_oracle is already running"
      exit 1
    fi
  fi 
    echo "started dm_oracle at..."
    date
    ${DM} &
    echo $! > ${DMPID} ;
    chmod 640 ${DMPID}
else
 cd ${DMDIR} ;
 if [  -f ${DMPERFLIBENV} ]; then
    source ${DMPERFLIBENV}
 fi
  echo "started dm_oracle at..." >> ${DMLOG}
  date >> ${DMLOG}
  ${DM} >> ${DMLOG} 2>&1 &
  echo $! > ${DMPID} ;
  chmod 640 ${DMLOG} ;
  chmod 640 ${DMPID} 
fi

# use rc from dm_oracle startup
exit $?
