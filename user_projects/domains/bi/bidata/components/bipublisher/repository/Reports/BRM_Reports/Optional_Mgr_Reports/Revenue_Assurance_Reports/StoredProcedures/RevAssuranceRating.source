 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "GDTLS_T" "GDTLS_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"= ''' || pFlowType  || '''
 AND "PROC_AUD_T"."PROCESS_NAME"= ''' || pControlPoint || '''
 AND "GDTLS_T"."ORIGINAL_BATCH_ID" = ''' || pBatchID || '''
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet(''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND("GDTLS_T"."USAGE_START_T" >= bipext.infStrToTimet(''' || pTransStartDate || ''', 2)
 AND "GDTLS_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)))
 AND "PROC_AUD_T"."VERSION_ID" = 4';

-- This query corresponds to RA_15 scenario where the REL records are captured.
-- The object type is /process_audit/batchstat/rel
MyQuery(15) := ' SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   NULL      		                    OLD_DISCOUNT_VALUE,
   NULL                                     OLD_RETAIL_AMOUNT,
   NULL                                     ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   NULL                                     TOTAL_COUNT,
   NULL                                     TOTAL_DISCOUNT_VALUE,
   NULL                                     TOTAL_DURATION,
   NULL                                     TOTAL_RETAIL_AMOUNT,
   NULL                                     TOTAL_VOLUME_RECEIVED,
   NULL                                     TOTAL_VOLUME_SENT,
   NULL                                     TOTAL_WHOLESALE_AMOUNT,
   NULL                                     USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   NULL                                     EDR_STATUS,
  "GDTLS_REL_T"."OBJ_ID0"		    GDTLS_REL_T_OBJ_ID0,
  "GDTLS_REL_T"."TOTAL_VALUE"               GDTLS_REL_T_TOTAL_VALUE,
  "GDTLS_REL_T"."EVENT_COUNT"               GDTLS_REL_T_EVENT_COUNT,
   NULL                                     OUTPUT_STREAM,
   NULL                                     REVENUE_STREAM,
   NULL                                     SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   NULL                                     UOUTPUT_STREAM,
   NULL                                     UREVENUE_STREAM,
   NULL                                     USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   15                                       POID_VAL
FROM(("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "GDTLS_REL_T" "GDTLS_REL_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_REL_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"= ''' || pFlowType  || '''
 AND "PROC_AUD_T"."PROCESS_NAME"= ''' || pControlPoint || '''
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet(''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND "PROC_AUD_T"."VERSION_ID" = 4
ORDER BY POID_VAL,
  UFLOW_NAME,
  UPROCESS_NAME,
  USERVICE_TYPE,
  UREVENUE_STREAM,
  UOUTPUT_STREAM,
  UEDR_STATUS,
  SUSPENSE_CODE,
  GDTLS_REL_T_OBJ_ID0';

      OPEN l_cursor FOR
         MyQuery(1)  || ' UNION ALL ' || MyQuery(2)  || ' UNION ALL ' ||
         MyQuery(3)  || ' UNION ALL ' || MyQuery(4)  || ' UNION ALL ' ||
         MyQuery(5)  || ' UNION ALL ' || MyQuery(6)  || ' UNION ALL ' ||
         MyQuery(7)  || ' UNION ALL ' || MyQuery(8)  || ' UNION ALL ' ||
         MyQuery(9)  || ' UNION ALL ' || MyQuery(10) || ' UNION ALL ' ||
         MyQuery(11) || ' UNION ALL ' || MyQuery(12) || ' UNION ALL ' ||
         MyQuery(13) || ' UNION ALL ' || MyQuery(14) || ' UNION ALL ' ||
         MyQuery(15);
 END IF; -- End of  pReportType = 'NO'

    -- pReportType = 'YES' means request for dynamic report.

    IF pReportType = 'YES' THEN

           -- Create query for RA02
           myquery(1) := CreateDynamicQuery(pstartdate,  penddate, ptransstartdate, ptransenddate,
                                        pflowtype, pcontrolpoint, NULL, pbatchid, 'gdtls_sts_t', pRaScope);

           -- Create query for RA04
           myquery(2) := CreateDynamicQuery(pstartdate,  penddate, ptransstartdate, ptransenddate,
                                        pflowtype, pcontrolpoint, pservicetype, pbatchid, 'gdtls_stype_sts_t', pRaScope);

           -- Create query for RA06
           myquery(3) := CreateDynamicQuery(pstartdate,  penddate, ptransstartdate, ptransenddate,
                                        pflowtype, pcontrolpoint, NULL, pbatchid, 'GDTLS_RSTRM_STS_T', pRaScope);

           -- Create query for RA08
           myquery(4) := CreateDynamicQuery(pstartdate,  penddate, ptransstartdate, ptransenddate,
                                        pflowtype, pcontrolpoint, pservicetype, pbatchid, 'gdtls_rstrm_stype_sts_t', pRaScope);
           -- Create query for RA10
           myquery(5) := CreateDynamicQuery(pstartdate,  penddate, ptransstartdate, ptransenddate,
                                        pflowtype, pcontrolpoint, pservicetype, pbatchid, 'gdtls_stype_rstrm_sts_t', pRaScope);

           -- Create query for RA14
           myquery(6) := CreateDynamicQuery(pstartdate,  penddate, ptransstartdate, ptransenddate,
                                        pflowtype, pcontrolpoint, pservicetype, pbatchid, 'gdtls_stype_rstrm_sts_ostrm_t', pRaScope);

            -- This query corresponds to RA_02 scenario where the grouping is based on
            -- EDRStatus and object type is /process_audit/batchstat/status
            DECLARE
            l_ref_cur refcursor;

            BEGIN
            l_ref_cur := ref_cur(myquery(1));

              LOOP
               FETCH l_ref_cur into 	EDR_STATUS,
                                        TOTAL_COUNT,
                                        TOTAL_DURATION,
                                        OLD_RETAIL_AMOUNT,
                                        TOTAL_RETAIL_AMOUNT,
                                        TOTAL_DISCOUNT_VALUE,
                                        OLD_DISCOUNT_VALUE,
                                        BATCH_TYPE,
                                        PROCESS_NAME,
                                        BATCH_ID,
                                        original_batch_id,
                                        suspended_from_batch_id ;
               EXIT WHEN l_ref_cur%NOTFOUND;
                IF pRaScope='Batch Rating' THEN

                    -- Mediation success Count

                    IF  edr_status = psuccess
                     AND( batch_type = 0  OR batch_type = 4 ) THEN
                      success_static_count_ra02 := success_static_count_ra02 +  total_count;
                    END IF;

                    -- Mediation failed Count

                    IF  edr_status = psuspense
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      failed_static_count_ra02 := failed_static_count_ra02 +  total_count;
                    END IF;

                    -- Recycle/Rerate-Recyle success Count

                    IF  edr_status = psuccess
                     AND(( batch_type = 2
                     AND  original_batch_id =  suspended_from_batch_id) OR  batch_type = 5) THEN
                      success_recycle_count_ra02 := success_recycle_count_ra02 +  total_count;
                    END IF;

                    -- Written-off Count

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_count_ra02 := writtenoff_count_ra02 +  total_count;
                    END IF;

                    -- Mediation and Mediation-update success Duration

                    IF  edr_status = psuccess
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      success_static_duration_ra02 := success_static_duration_ra02 +  total_duration;
                    END IF;

                    -- Mediation and Mediation-update failed Duration

                    IF  edr_status = psuspense
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      failed_static_duration_ra02 := failed_static_duration_ra02 +  total_duration;
                    END IF;

                    -- Recycle success Duration

                    IF  edr_status = psuccess
                     AND  batch_type = 2
                     AND  original_batch_id =  suspended_from_batch_id THEN
                      success_recycle_duration_ra02 := success_recycle_duration_ra02 +  total_duration;
                    END IF;

                    -- Written-off Duration

                    IF  edr_status = pwrittenoff
                     AND  batch_type = 3 THEN
                      writtenoff_duration_ra02 := writtenoff_duration_ra02 +  total_duration;
                    END IF;

                    currentamount_ra02 :=  total_retail_amount +  old_retail_amount +  total_discount_value +  old_discount_value;

                    -- Mediation success Amount

                    IF  edr_status = psuccess
                     AND( batch_type = 0 OR  batch_type = 4) THEN
                      success_static_amount_ra02 := success_static_amount_ra02 + currentamount_ra02;
                    END IF;

                    -- Rerating success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 1 and success_static_count_ra02 > 0 THEN
                      success_rerating_amount_ra02 := success_rerating_amount_ra02 + currentamount_ra02;
                    END IF;

                    -- Rerating failed Amount

                    IF  edr_status = psuspense
                     AND  batch_type = 1 and success_static_count_ra02 > 0 THEN
                      failed_rerating_amount_ra02 := failed_rerating_amount_ra02 + currentamount_ra02;
                    END IF;

                    -- Recycle success Amount

                    IF  edr_status = psuccess
                     AND  batch_type = 2 THEN
                      success_recycle_amount_ra02 := success_recycle_amount_ra02 + currentamount_ra02;
                    END IF;

                    -- Set the flags accordingly
                    IF batch_type = 0 OR  batch_type = 1 OR  batch_type = 2 OR  batch_type = 4 OR  batch_type = 5 THEN
