FUNCTION create_index (i_index_name IN VARCHAR2, i_table_name IN VARCHAR2, i_column_names IN VARCHAR2, i_tablespace_name IN VARCHAR2, io_errmsg IN OUT VARCHAR2)
RETURN BOOLEAN AS
            ddl_stmt VARCHAR2(500);
            column_list_already_indexed EXCEPTION;
            PRAGMA EXCEPTION_INIT(column_list_already_indexed, -1408);
            resource_busy EXCEPTION;
            PRAGMA EXCEPTION_INIT(resource_busy, -54);
BEGIN
                IF (NOT index_exist_on_table(i_index_name,i_table_name,i_column_names, io_errmsg)) THEN
                    IF (table_exists(i_table_name, io_errmsg)) THEN

                        ddl_stmt := 'CREATE INDEX ' || i_index_name ||' ON '|| i_table_name ||'('|| i_column_names || ')  '||i_tablespace_name;

                        EXECUTE IMMEDIATE ddl_stmt;

                    END IF;
                END IF;

            RETURN TRUE;
EXCEPTION
            WHEN column_list_already_indexed THEN
                RETURN TRUE;
            WHEN resource_busy THEN

                BEGIN
                    DBMS_LOCK.Sleep( 15 );            
                    ddl_stmt := 'CREATE INDEX ' || i_index_name ||' ON '|| i_table_name ||'('|| i_column_names || ')  '||i_tablespace_name;
                    EXECUTE IMMEDIATE ddl_stmt;

                    RETURN TRUE;
                EXCEPTION
                    WHEN others THEN
                        io_errmsg := sqlerrm;
                        RETURN FALSE;
                END;
            WHEN others THEN
                io_errmsg := sqlerrm;
                RETURN FALSE;
END create_index;

FUNCTION create_unique_index (i_index_name IN VARCHAR2, i_table_name IN VARCHAR2, i_column_names IN VARCHAR2, i_tablespace_name IN VARCHAR2, io_errmsg IN OUT VARCHAR2)
RETURN BOOLEAN AS
            ddl_stmt VARCHAR2(500);
            column_list_already_indexed EXCEPTION;
            PRAGMA EXCEPTION_INIT(column_list_already_indexed, -1408);
            resource_busy EXCEPTION;
            PRAGMA EXCEPTION_INIT(resource_busy, -54);
BEGIN
                IF (NOT index_exist_on_table(i_index_name,i_table_name,i_column_names, io_errmsg)) THEN
                    IF (table_exists(i_table_name, io_errmsg)) THEN

                       ddl_stmt := 'CREATE UNIQUE INDEX ' || i_index_name ||' ON '|| i_table_name ||'('|| i_column_names || ')  '||i_tablespace_name;
                       EXECUTE IMMEDIATE ddl_stmt;

                    END IF;
                END IF;

            RETURN TRUE;
EXCEPTION
            WHEN column_list_already_indexed THEN
                RETURN TRUE;
            WHEN resource_busy THEN

                BEGIN
                    DBMS_LOCK.Sleep( 15 );            
                    ddl_stmt := 'CREATE INDEX ' || i_index_name ||' ON '|| i_table_name ||'('|| i_column_names || ')  '||i_tablespace_name;
                    EXECUTE IMMEDIATE ddl_stmt;

                    RETURN TRUE;
                EXCEPTION
                    WHEN others THEN
                        io_errmsg := sqlerrm;
                        RETURN FALSE;
                END;
            WHEN others THEN
                io_errmsg := sqlerrm;
                RETURN FALSE;
END create_unique_index;

