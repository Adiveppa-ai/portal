			<xs:element name="PuStr" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
			<xs:element name="PuStrDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="PrSta" type="ProductsStatus" minOccurs="1" maxOccurs="1"/>
			<xs:element name="Qnty" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="UsgDis" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="UsgEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1" nillable="true"/>
			<xs:element name="UsgEndDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="UsgStr" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
			<xs:element name="UsgStrDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="StFlags" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Flags" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Descr" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="EffctT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="PurPrdCycFees" type="PurchasedProductCycleType" minOccurs="0" maxOccurs="unbounded"/>
                        <xs:element name="PrcLstNm" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="RetryCnt" type="xs:integer" minOccurs="0" maxOccurs="1"/>
                        <xs:element name="NxtRetryT" type="xs:dateTime" minOccurs="0" maxOccurs="1"/>
			<xs:element name="CalendarDom" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="GracePeriod" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="RenewalMode" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="BasePrObj" type="Poid" minOccurs="0" maxOccurs="1" nillable="false"/>
			<xs:element name="OverrideRef" type="xs:string" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
		<xs:attribute name="serviceRef" type="xs:string" use="optional"/>
		<xs:attribute name="pkgId" type="xs:string" use="required"/>
		<xs:attribute name="id" type="xs:string" use="required"/>
	        <xs:attribute name="bundleRef" type="xs:string" use="optional"/>
	</xs:complexType>
        <xs:complexType name="PurchasedProductCycleType">
                <xs:sequence>
                        <xs:element name="ChargedFrom" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
                        <xs:element name="ChargedTo" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
                        <xs:element name="CycleFeeStart" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
                        <xs:element name="CycleFeeEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"  />
                        <xs:element name="Unit" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
                        <xs:element name="Count" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
                </xs:sequence>
        </xs:complexType>
	<xs:complexType name="PurchasedDiscountType">
		<xs:sequence>
			<xs:element name="CEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1" nillable="true"/>
			<xs:element name="CEndDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="CStrt" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
			<xs:element name="CStrDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="CrtT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="DObj" type="Poid" minOccurs="0" maxOccurs="1" nillable="false"/>
			<xs:element name="PlObj" type="Poid" minOccurs="0" maxOccurs="1" nillable="false"/>
			<xs:element name="DisObj" type="Poid" minOccurs="1" maxOccurs="1" nillable="false"/>
			<xs:element name="PurEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1" nillable="true"/>
			<xs:element name="PurEndDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="PurStr" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
			<xs:element name="PurStrDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Qnty" type="xs:decimal" minOccurs="1" maxOccurs="1"/>
			<xs:element name="DisStr" type="ProductsStatus" minOccurs="1" maxOccurs="1"/>
			<xs:element name="UsgEnd" type="dateTime-or-zero" minOccurs="1" maxOccurs="1" nillable="true"/>
			<xs:element name="UsgEndDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="UsgStrt" type="dateTime-or-zero" minOccurs="1" maxOccurs="1"/>
			<xs:element name="UsgStrDtls" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="StFlags" type="xs:string" minOccurs="0" maxOccurs="1"/>			
			<xs:element name="Flags" type="xs:integer" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Descr" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="EffctT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="OverrideRef" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="GracePeriod" type="xs:integer" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
		<xs:attribute name="serviceRef" type="xs:string" use="optional"/>
		<xs:attribute name="pkgId" type="xs:string" use="required"/>
		<xs:attribute name="id" type="xs:string" use="required"/>
		<xs:attribute name="bundleRef" type="xs:string" use="optional"/>
	</xs:complexType>
	<!-- OfferingOverrideValues -->
	<xs:complexType name="OfferingOverrideType">
		<xs:sequence>
			<xs:element name="CrtT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="ModT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="OffOvrUmap" type="OfferingOverrideUsagemapType" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
		<xs:attribute name="id" type="xs:string" use="required"/>
		<xs:attribute name="offeringRef" type="xs:string" use="required"/>
		<xs:attribute name="offeringTypeRef" type="xs:string" use="required"/>
	</xs:complexType>
	<!-- OfferingOverrideUsagemap -->
	<xs:complexType name="OfferingOverrideUsagemapType">
		<xs:sequence>
			<xs:element name="EndT" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="EvtType" type="Event" minOccurs="1" maxOccurs="1"/>
			<xs:element name="Date_ranges" type="DateRanges" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="DateRanges">
		<xs:sequence>
			<xs:element name="Start_t" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="End_t" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Price_tags" type="PriceTags" minOccurs="0" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="PriceTags">
		<xs:sequence>
			<xs:element name="Name" type="xs:string" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Amount" type="xs:decimal" minOccurs="0" maxOccurs="1"/>
			<xs:element name="Percent" type="xs:decimal" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="PurchasedBundleType">
		<xs:sequence>
			<xs:element name="Name" type="xs:string" minOccurs="0" maxOccurs="1"/> 
                        <xs:element name="Descr" type="xs:string" minOccurs="0" maxOccurs="1"/> 
