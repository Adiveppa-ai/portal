/******************************************************************************************************************************
 * This function will validate PriorityCode. It will raise error code 20 for PriorityCode.
 ******************************************************************************************************************************/
 
function validatePriorityCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",170";

  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"2" , "0", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "PriorityCode", "170", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate MessageStatus. It will raise error code 20 for MessageStatus.
 ******************************************************************************************************************************/
 
function validateMessageStatus ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",144";

  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"4" , "0", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MessageStatus", "144", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate ScuChargeType. It will raise error code 30, 31, 33, 34 for ScuChargeType.
 ******************************************************************************************************************************/
 
function validateScuChargeType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",192";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "messageStatus";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMessageStatus ( myContext, nMyIndices, "messageStatus", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuChargeType", "192", "30", "Mandatory item Message Status missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Mandatory item Message Status missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "priorityCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validatePriorityCode ( myContext, nMyIndices, "priorityCode", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuChargeType", "192", "31", "Mandatory item Priority Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","", "Mandatory item Priority Code missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "distanceChargeBandCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateDistanceChargeBandCode ( myContext, nMyIndices, "distanceChargeBandCode", 0, errorContext );
  }
 
  childContext = myContext + "." + "messageType";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMessageType ( myContext, nMyIndices, "messageType", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ScuChargeType", "192", "33", "Mandatory item Message Type missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1","", "Mandatory item Message Type missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "messageDescriptionCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateMessageDescriptionCode ( myContext, nMyIndices, "messageDescriptionCode", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "ScuChargeType", "192", "34", "Mandatory item Message Description Code missing within group");
  }
 
  //logContext( myContext, nMyIndices );
}

