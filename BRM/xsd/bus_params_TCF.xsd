        <xs:complexType name="BusParamsTCFType">
                <xs:sequence>
                        <xs:element name="RestrictDeviceToServiceStatePropagation" type="businessConfig:switch">
                                <xs:annotation>
                                        <xs:documentation xml:lang="en">
                                                This parameter is used to enable/disable Service inactivation when a Device associated with it is dissociated or swapped.
						The default is disabled(0), i.e. Service will be inactivated when the device is dissociated.
                                        </xs:documentation>
                                </xs:annotation>
                        </xs:element>

                </xs:sequence>
        </xs:complexType>

</xs:schema>


