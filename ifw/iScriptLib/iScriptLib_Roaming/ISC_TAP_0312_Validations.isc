function validateElementId ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
  errorContext = errorContext + ",437";
  String networkElementId = edrStringEx( myContext, indices, nParentIndices );
  Bool identifierIpV4IsValid = false;
  Bool identifierIpV6IsValid = false;  
    
  if (networkElementType == 1 and  (validateMsisdnSE(edrStringEx(myContext, indices, nParentIndices)) == true )  )
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Element ID", "437", "101", "Element Type refers to SMSC and syntax of the associated Element ID does not conform to MSISDN");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1","", "Element Type refers to SMSC and syntax of the associated Element ID does not conform to MSISDN"); 
    edrSetIsValidDetail(false);  
  }
  else
  {
    identifierIpV4IsValid = validateIpV4(networkElementId);
    identifierIpV6IsValid = validateIpV6(networkElementId);
  }
  
  if (networkElementType == 2 and identifierIpV4IsValid == false and identifierIpV6IsValid == false)
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Element ID", "437", "102", "Element Type refers to S-CSCF and syntax of the associated Element ID does not conform to text representation of IP address");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1", "","Element Type refers to S-CSCF and syntax of the associated Element ID does not conform to text representation of IP address"); 
    edrSetIsValidDetail(false);   
  }
  
  if (networkElementType == 3 and identifierIpV4IsValid == false and identifierIpV6IsValid == false)
  {
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Element ID", "437", "103", "Element Type refers to SM-IP-GW and syntax of the associated Element ID does not conform to text representation of IP address");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1", "","Element Type refers to SM-IP-GW and syntax of the associated Element ID does not conform to text representation of IP address"); 
     edrSetIsValidDetail(false);   
  }
  
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function validateElementType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
  errorContext = errorContext + ",438";                                                        

  networkElementType = edrLongEx( myContext, indices, nParentIndices);
  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"3" , "1", "INTEGER_TYPE") == true )
  {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Element Type", "438", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
      edrSetIsValidDetail(false);
  }  
  
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}

function validateNetworkElement ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  errorContext = errorContext + ",441";                                                        
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;
  networkElementType = 0;  
                                                                                                             
  childContext = myContext + "." + "elementType";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateElementType ( myContext, nMyIndices, "elementType", 0, errorContext );                 
  }
  else
  {
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Network Element", "441", "31", "Element Type missing within group");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Element Type missing within group"); 
     edrSetIsValidDetail(false); 
  }	 
                                                                                                                 
  childContext = myContext + "." + "elementId";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    validateElementId ( myContext, nMyIndices, "elementId", 0, errorContext );                 
  }
  else
  {
     edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Network Element", "441", "30", "Element ID missing within group");
     edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Element ID missing within group"); 
     edrSetIsValidDetail(false); 
  }  
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}

function validateNetworkElementList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  errorContext = errorContext + ",442";                                                        
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "NetworkElement";                                            
  Long NetworkElementListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < NetworkElementListEntries; i = i + 1 )                                                      
  {                                                                                                          
    validateNetworkElement ( myContext, nMyIndices, "NetworkElement", i, errorContext );                 
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}

