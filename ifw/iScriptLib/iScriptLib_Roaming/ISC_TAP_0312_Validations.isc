/******************************************************************************************************************************
 * This function will validate CustomerIdentifier. It will raise error code 100 for CustomerIdentifier.
 ******************************************************************************************************************************/
 
function validateCustomerIdentifier ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  Bool   checkType         = true;
  Long   ret               = -1;

  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",364";

  String customerIdentifier = edrStringEx(myContext, indices, nParentIndices);
  switch( lastCustomerIdType )
  {
     case 1:
     case 2:
     case 3:
     {
       ret = strSearchRegExpr(customerIdentifier, "[^0-9]");
     }
     break;
     case 4:
     {
       checkType = validateIpV4(customerIdentifier);
     }
     break;
     case 5:
     {
       checkType = validateIpV6(customerIdentifier);
     }
     break;
     case 6:
     case 7:
     {
       ret = strSearchRegExpr(customerIdentifier, "[^0-9A-Za-z]");
     }
     break;
     case 8:
     {
       checkType = validateEmail(customerIdentifier);
     }
     break;
  }
  if (ret >= 0 or checkType == false)
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Customer Identifier", "364", "100",
                                              "Item content does not match Customer Id Type"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1","",
                                              "Item content does not match Customer Id Type");
    edrSetIsValidDetail(false);
  } 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CustomerIdType. It will raise error code 20 for CustomerIdType. 
 ******************************************************************************************************************************/
 
function validateCustomerIdType ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",363";

  lastCustomerIdType = edrLongEx(myContext, indices, nParentIndices);

  if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "3", "1", "INTEGER_TYPE") == true and
           strStartsWith(parentContext, "DETAIL.locationService.trackedCustomerInformation") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Customer Id Type", "363", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "8", "1", "INTEGER_TYPE") == true and
           strStartsWith(parentContext, "DETAIL.locationService.trackingCustomerInformation") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Customer Id Type", "363", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

