<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ObjectList
  xmlns="http://www.oracle.com/schemas/BusinessConfig"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.oracle.com/schemas/BusinessConfig ../../../xsd/config_object.xsd">
 
  <ConfigObject configName="/config/price_tags" configMode="recreate">
    <DESCR>Configuration of price tags which are used to override product charges.</DESCR>
    <NAME>Price Tags Configuration</NAME>
    <PRICE_TAGS elem="0">
      <NAME>price_tag1</NAME>
      <DESCR>Dollar Override</DESCR>
      <RULE_TYPE>LIST</RULE_TYPE>
      <CONSTRAINTS>10;20;35;50;90;120</CONSTRAINTS>
      <RESOURCE_ID>840</RESOURCE_ID>
      <RESOURCE_UNIT>AMOUNT_USED</RESOURCE_UNIT>
      <PERMITTED>/service/email;/service/ip</PERMITTED>    
    </PRICE_TAGS>    
  </ConfigObject>
 
</ObjectList>
