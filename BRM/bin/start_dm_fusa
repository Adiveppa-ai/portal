#      accordance with a valid Oracle license or sublicense agreement.
#

#
# start_dm_fusa
#
# The underlying database (if any) must already be started
# when this script runs.
#
VERSION=15.0
PATH=/usr/bin:/bin

PINDIR=/home/pin/opt/portal/BRM
LOGDIR=/home/pin/opt/portal/BRM/var/dm_fusa

QM=${PINDIR}/bin/dm_fusa

QMDIR=${PINDIR}/sys/dm_fusa
QMLOG=${LOGDIR}/dm_fusa.log
QMPID=${LOGDIR}/dm_fusa.pid

if [ -r ${QMPID} ]; then
  /bin/ps -f -p `cat ${QMPID}` | grep ${QM} > /dev/null
  if [ $? -eq 0 ]; then
        echo "ERROR: dm_fusa is already running"
        exit 1
  fi
fi

if [ ! -x ${QM} ]; then
        echo "HELP: executable \"${QM}\" not found!"
        exit 1
fi       

if [ ! -d ${QMDIR} ]; then
        echo "HELP: qm dir \"${QMDIR}\" not found!"
        exit 1
fi

if [ ! -d ${LOGDIR} ]; then
	mkdir -p ${LOGDIR}
	if [ $? -ne 0 ]; then
		echo "HELP: problems making QM LOGDIR \"${LOGDIR}\"!"
		exit 1
	fi
fi       

# fusamux is an optional part of the dm_fusa, used for higher performance
# only start if configured: we use an uncommented line containing
# "fusamux fusamux_port" as the key.
if [ -f ${QMDIR}/pin.conf ] ; then
	DMFPC="${QMDIR}/pin.conf"
elif [ -f /etc/pin.conf ] ; then
	DMFPC="/etc/pin.conf"
else
	echo "no pin.conf in \"${QMDIR}\" or \"/etc\"for dm_fusa/fusamux"
	exit 1
fi
if grep '^[^#].*[ 	]fusamux[ 	][ 	]*fusamux_port[ 	]' \
    ${DMFPC} > /dev/null ; then
	# start the fusamux
	( cd ${QMDIR} ;
	  echo "started fusamux at..." >> ${LOGDIR}/fusamux.log
	  date >> ${LOGDIR}/fusamux.log 
	  ${PINDIR}/bin/fusamux >> ${LOGDIR}/fusamux.log 2>&1 &
	  echo $! > ${LOGDIR}/fusamux.pid ;
	  chmod 640 ${LOGDIR}/fusamux.log ;
	  chmod 640 ${LOGDIR}/fusamux.pid )
fi
#
# end of fusamux addition

# XXX ought to save old log file, or check for > some-size...
( cd ${QMDIR} ;
  echo "started QM at..." >> ${QMLOG}
  date >> ${QMLOG}
  ${QM} >> ${QMLOG} 2>&1 &
  echo $! > ${QMPID} ;
  chmod 640 ${QMLOG} ;
  chmod 640 ${QMPID} )

# use rc from qm startup
exit $?
