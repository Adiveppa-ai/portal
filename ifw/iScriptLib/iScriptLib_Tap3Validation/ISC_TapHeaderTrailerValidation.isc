}

//------------------------------------------------------------------------------
// initBegin()
//------------------------------------------------------------------------------
function initBegin
{
  if ( debug )
  {
    logStdout("initBegin()\n");
  }

  minDate = MAX_DATE;
  maxDate = MIN_DATE;
  tapFileName = "";

  notFlag = "";
  record_length = 0;
  adviseChargeEntries = 0;
}


function setAssociatedTapErr (String errorName , Long errorSeverity , 
				String tapErrorCode , String tapErrorAppTag , String tapErrorDepth )
                                
{
  Long blockIndex;
  if( debug )
  {
    logStdout("setAssociatedTapErr()\n");
  }  
  
  blockIndex = edrNumDatablocks(DETAIL.ASS_TAP3_ERR);
  if(edrAddDatablock(DETAIL.ASS_TAP3_ERR) == true){
    edrString(DETAIL.ASS_TAP3_ERR.RECORD_TYPE ,blockIndex) =  "670";
    edrLong(DETAIL.ASS_TAP3_ERR.RECORD_NUMBER ,blockIndex) = edrLong(DETAIL.RECORD_NUMBER);
    edrString(DETAIL.ASS_TAP3_ERR.ERROR_NAME ,blockIndex) = errorName;
    edrLong(DETAIL.ASS_TAP3_ERR.ERROR_SEVERITY ,blockIndex) = errorSeverity;
    edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_CODE ,blockIndex) = tapErrorCode;
    edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_APPLICATION_TAG ,blockIndex) = tapErrorAppTag;
    edrString(DETAIL.ASS_TAP3_ERR.TAP3_ERROR_DEPTH ,blockIndex) = tapErrorDepth;
  }
  
  blockIndex = edrNumDatablocks(HEADER.ASS_TAP3_ERR);
  if(edrAddDatablock(HEADER.ASS_TAP3_ERR) == true){
    edrString(HEADER.ASS_TAP3_ERR.RECORD_TYPE ,blockIndex) =  "670";
    edrLong(HEADER.ASS_TAP3_ERR.RECORD_NUMBER ,blockIndex) = edrLong(HEADER.RECORD_NUMBER);
    edrString(HEADER.ASS_TAP3_ERR.ERROR_NAME ,blockIndex) = errorName;
    edrLong(HEADER.ASS_TAP3_ERR.ERROR_SEVERITY ,blockIndex) = errorSeverity;
    edrString(HEADER.ASS_TAP3_ERR.TAP3_ERROR_CODE ,blockIndex) = tapErrorCode;
    edrString(HEADER.ASS_TAP3_ERR.TAP3_ERROR_APPLICATION_TAG ,blockIndex) = tapErrorAppTag;
    edrString(HEADER.ASS_TAP3_ERR.TAP3_ERROR_DEPTH ,blockIndex) = tapErrorDepth;
  }
  
  blockIndex = edrNumDatablocks(TRAILER.ASS_TAP3_ERR);
  if(edrAddDatablock(TRAILER.ASS_TAP3_ERR) == true){
    edrString(TRAILER.ASS_TAP3_ERR.RECORD_TYPE ,blockIndex) =  "670";
    edrLong(TRAILER.ASS_TAP3_ERR.RECORD_NUMBER ,blockIndex) = edrLong(TRAILER.RECORD_NUMBER);
    edrString(TRAILER.ASS_TAP3_ERR.ERROR_NAME ,blockIndex) = errorName;
    edrLong(TRAILER.ASS_TAP3_ERR.ERROR_SEVERITY ,blockIndex) = errorSeverity;
    edrString(TRAILER.ASS_TAP3_ERR.TAP3_ERROR_CODE ,blockIndex) = tapErrorCode;
    edrString(TRAILER.ASS_TAP3_ERR.TAP3_ERROR_APPLICATION_TAG ,blockIndex) = tapErrorAppTag;
    edrString(TRAILER.ASS_TAP3_ERR.TAP3_ERROR_DEPTH ,blockIndex) = tapErrorDepth;
  }  
}


//------------------------------------------------------------------------------
// validateSender()
//
// This function will be used to validate the sender
//------------------------------------------------------------------------------
function validateSender
{
  if (debug)
  {
    logStdout("validateSender()\n");
  }

  Long   headerState = edrInputState(HEADER.SENDER);
  Long   headerStateI = edrInternalState(HEADER.SENDER);
  String senderName = edrString(HEADER.SENDER);
  String senderFileName = strSubstr(tapFileName, 2, 5);
  String offset = "-1";
  String depth;
  Long   i;
  Bool	 senderPresent = false;

  if(edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
  {
    depth = "2";
  }
  else
  {
    depth = "3";
  }

  if (headerState == MISSING)
  {
    // Set Fata Error
    // offset = longToStr( edrFieldTokenBytePos( HEADER.SENDER));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","30","2","1",offset,"-1","Missing sender field ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_SENDER_FIELD", LOG_CRITICAL , "30","2", "1");
                               
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","30","4","2",offset,"-1","Missing sender field ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_SENDER_FIELD", LOG_CRITICAL , "30","4", "2");
    }
    edrDemandRollback();
  }
  else
  { 
    if ( (strLength(senderName) != 5) or (strSearchRegExpr(senderName, "[^A-Z0-9]") >= 0) )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","196",depth,offset,"-1",
          "Sender field syntax Error ");
      setAssociatedTapErr ("ERR_TAP3_SENDER_SE", LOG_CRITICAL , "10","196", depth);
      edrDemandRollback();
    }

    for( i = 0; i < numOfPlmno and senderPresent == false; i = i + 1 )
    {
      if( plmnoList[i] == senderName )
      {
        senderPresent = true;
      }
    }

    if ( senderPresent == false )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","196",depth,offset,"-1",
          "Sender field Value Out of Range ");
      setAssociatedTapErr ("ERR_TAP3_SENDER_OOR", LOG_CRITICAL , "20","196", depth);
      edrDemandRollback();
    }
  
    if (senderName != senderFileName)
    {
      // Set Fata Error
      // offset = longToStr( edrFieldTokenBytePos( HEADER.SENDER));
      if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
      {
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","196","2",offset,"-1",
          "Sender field does not match the file name ");
        setAssociatedTapErr ("ERR_TAP3_SENDER_FIELD_MISMATCH", LOG_CRITICAL , "100","196", "2");
      }
      else
      {
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","196","3",offset,"-1",
          "Sender field does not match the file name ");
        setAssociatedTapErr ("ERR_TAP3_SENDER_FIELD_MISMATCH", LOG_CRITICAL , "100","196", "3");
      }
      edrDemandRollback();
    }
  }
}


//------------------------------------------------------------------------------
// validateRecipient()
//
// This function will be used to validate the recipient
//------------------------------------------------------------------------------
function validateRecipient
{
  if (debug)
  {
    logStdout("validateRecipient()\n");
  }

  Long headerState = edrInputState(HEADER.RECIPIENT);
  Long headerStateI = edrInternalState(HEADER.RECIPIENT);

  String recipientName = edrString(HEADER.RECIPIENT);
  String recipientFileName = strSubstr(tapFileName, 7, 5);
  String offset = "-1";
  String depth;
  Long   i;
  Bool	 recipientPresent = false;

  if(edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
  {
    depth = "2";
  }
  else
  {
    depth = "3";
  }

  if (headerState == MISSING)
  {
    // Set Fata Error
    // offset = longToStr( edrFieldTokenBytePos( HEADER.RECIPIENT));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","31","2","1",offset,"-1","Missing recipient field ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_RECIPIENT_FIELD", LOG_CRITICAL , "31","2", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","31","4","2",offset,"-1","Missing recipient field ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_RECIPIENT_FIELD", LOG_CRITICAL , "31","4", "2");
    }
    edrDemandRollback();
  }
  else
  {
    if ( (strLength(recipientName) != 5) or (strSearchRegExpr(recipientName, "[^A-Z0-9]") >= 0) )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","182",depth,offset,"-1",
            "Recipient field syntax Error ");
      setAssociatedTapErr ("ERR_TAP3_RECIPIENT_FIELD_SE", LOG_CRITICAL , "10","182", depth);
      edrDemandRollback();
    }

    for( i = 0; i < numOfPlmno and recipientPresent == false; i = i + 1 )
    {
      if( plmnoList[i] == recipientName )
      {
        recipientPresent = true;
      }
    }

    if ( recipientPresent == false )
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","182",depth,offset,"-1",
          "Recipient field Value Out Of Range ");
      setAssociatedTapErr ("ERR_TAP3_RECIPIENT_FIELD_OOR", LOG_CRITICAL , "20","182", depth);

      edrDemandRollback();
    }

    if (recipientName != recipientFileName)
    {
      // Set Fata Error
      // offset = longToStr( edrFieldTokenBytePos( HEADER.RECIPIENT));
      if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
      {
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","182","2",offset,"-1",
       	  "Recipient field does not match the file name ");
        setAssociatedTapErr ("ERR_TAP3_RECIPIENT_FIELD_MISMATCH", LOG_CRITICAL , "100","182", "2");
      }
      else
      {
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","182","3",offset,"-1",
  	  "Recipient field does not match the file name ");
        setAssociatedTapErr ("ERR_TAP3_RECIPIENT_FIELD_MISMATCH", LOG_CRITICAL , "100","182", "3");
      }
      edrDemandRollback();
    }
  }
}


//------------------------------------------------------------------------------
// validateFileSequenceNumber()
//
// This function will be used to validate the file sequence number
//------------------------------------------------------------------------------
function validateFileSequenceNumber
{
  if (debug)
  {
    logStdout("validateFileSequenceNumber()\n");
  }

  Long headerState = edrInputState(HEADER.SEQUENCE_NUMBER);
  Long headerStateI = edrInternalState(HEADER.SEQUENCE_NUMBER);
  Long headerSequence = edrLong(HEADER.SEQUENCE_NUMBER);
  Long fileSequence = strToLong(strSubstr(tapFileName, 12, 5));
  String offset = "-1";

  if (headerState == MISSING)
  {
    // Set Fatal Error
    // offset = longToStr( edrFieldTokenBytePos( HEADER.SEQUENCE_NUMBER));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","32","2","1",offset,"-1",
		"Missing file sequence number");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_SEQ_NUM", LOG_CRITICAL , "32","2", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","32","4","2",offset,"-1",
		"Missing file sequence number");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_SEQ_NUM", LOG_CRITICAL , "32","4", "2");
    }
    edrDemandRollback();
  }
  else
  {
    if(( headerSequence < 1)  or ( headerSequence > 99999))   
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","109","2","0","-1",
              "Out of Range File Sequence Number");
      setAssociatedTapErr ("ERR_TAP3_FILE_SEQUENCE_NUMBER_OOR", LOG_CRITICAL , "20","109", "2");
      edrDemandRollback();
    }
    else if (headerSequence != fileSequence)
    {
      // Set Fatal Error
      // offset = longToStr( edrFieldTokenBytePos( HEADER.SEQUENCE_NUMBER));
      if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
      {
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","109","2",offset,"-1",
  	  "File sequence does not match sequence number in the file name");
        setAssociatedTapErr ("ERR_TAP3_FILE_SEQ_NUM_MISMATCH", LOG_CRITICAL , "100","109", "2");
      }
      else
      {
        edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","100","109","3",offset,"-1",
  	  "File sequence does not match sequence number in the file name");
        setAssociatedTapErr ("ERR_TAP3_FILE_SEQ_NUM_MISMATCH", LOG_CRITICAL , "100","109", "3");
      }
      edrDemandRollback();
    }
  }
}


//------------------------------------------------------------------------------
// validateFileCreationTimeStamp()
//
// This function will be used to validate the file creation timestamp
//------------------------------------------------------------------------------
function validateFileCreationTimeStamp
{
  if (debug)
  {
    logStdout("validateFileCreationTimeStamp()\n");
  }

  if ( edrInputState(HEADER.CREATION_TIMESTAMP) == MISSING)
  {
    // Set Fatal Error
    String offset = "-1";
    // offset = longToStr( edrFieldTokenBytePos( HEADER.CREATION_TIMESTAMP));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","34","2","1",offset,"-1",
		"Missing file creation timestamp ");
      setAssociatedTapErr ("ERR_TAP3_FILE_TIMESTAMP_CREAT_MISSING", LOG_WARNING , "34","2", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","35","4","2",offset,"-1",
		"Missing file creation timestamp ");
      setAssociatedTapErr ("ERR_TAP3_FILE_TIMESTAMP_CREAT_MISSING", LOG_WARNING , "34","4", "2");
    }
  }

}

//------------------------------------------------------------------------------
// validateFileCreationTimeStampCrossValidation()
//
// This function will be used to validate the file creation timestamp cross
// validation
//------------------------------------------------------------------------------
function validateFileCreationTimeStampCrossValidation
{
  if (debug)
  {
    logStdout("validateFileCreationTimeStampCrossValidation()\n");
  }

  Date cutOffDate = edrDate(HEADER.TRANSFER_CUTOFF_TIMESTAMP);
  Date creationDate = edrDate(HEADER.CREATION_TIMESTAMP);

  if (dateDiff(creationDate,cutOffDate) < 0)
  {
    // Set Fatal Error
    String offset = "-1";
    // offset = longToStr( edrFieldTokenBytePos( HEADER.CREATION_TIMESTAMP));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","100","108","2",offset,"-1",
	 	"File available time  earlier than icut off timestamp");
      setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_WARNING , "100","108", "2");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","100","108","3",offset,"-1",
		"File available time  earlier than cut off timestamp");
      setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_WARNING , "100","108", "3");
    }
  }
}

//------------------------------------------------------------------------------
// validateTransferCutOffTimeStamp()
//
// This function will be used to validate the file transfer cut off timestamp
//------------------------------------------------------------------------------
function validateTransferCutOffTimeStamp
{
  if (debug)
  {
    logStdout("validateTransferCutOffTimeStamp()\n");
  }

  String offset = "-1";

  if (edrInputState(HEADER.TRANSFER_CUTOFF_TIMESTAMP) == MISSING)
  {
    // Set Fatal Error
    // offset = longToStr( edrFieldTokenBytePos( HEADER.TRANSFER_CUTOFF_TIMESTAMP));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","36","2","1",offset,"-1",
		"Missing file transfer cutoff timestamp ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_TRANSFER_ICUT_OFF_TIMESTAMP", LOG_WARNING , "36","2", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","36","4","2",offset,"-1",
		"Missing file transfer cutoff timestamp ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_TRANSFER_ICUT_OFF_TIMESTAMP", LOG_WARNING , "36","4", "2");
    }
  }
  else if ( dateIsValid(edrDate(HEADER.TRANSFER_CUTOFF_TIMESTAMP)) == false )
  {
    // Set Fatal Error
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","227","3",offset,"-1",
                "Syntax Error Transfer Cutoff TimeStamp");
      setAssociatedTapErr ("ERR_TAP3_TRANSFER_CUTOFF_TIMESTAMP_SYNTAX", LOG_CRITICAL , "10", "227", "3"); 
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","227","5",offset,"-1",
                "Syntax Error Transfer Cutoff TimeStamp");
      setAssociatedTapErr ("ERR_TAP3_TRANSFER_CUTOFF_TIMESTAMP_SYNTAX", LOG_CRITICAL , "10", "227", "5"); 
    }
    edrDemandRollback();
  }
}


//------------------------------------------------------------------------------
// validateFileAvailableTimeStamp()
//
// This function will be used to validate the file available timestamp
//------------------------------------------------------------------------------
function validateFileAvailableTimeStamp
{
  if (debug)
  {
    logStdout("validateFileAvailableTimeStamp()\n");
  }
  
  if (edrInputState(HEADER.TRANSMISSION_DATE) == MISSING)
  {
    // Set Fatal Error
    String offset = "-1";

    // offset = longToStr( edrFieldTokenBytePos( HEADER.TRANSMISSION_DATE));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","35","2","1",offset,"-1",
		"Missing file available timestamp ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_AVAILABLE_TIMESTAMP", LOG_WARNING , "35","2", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","33","4","2",offset,"-1",
		"Missing file available timestamp ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_AVAILABLE_TIMESTAMP", LOG_CRITICAL , "33","4", "2");
      edrDemandRollback();
    }
  }
  else 
  {
    if (dateIsValid(edrDate(HEADER.TRANSMISSION_DATE)) == false)
    {
      // Set Fatal Error
      String offset = "-1";
      if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
      {
          edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","11","107","4",offset,"-1",
                      "Syntax Error for file available timestamp ");
          setAssociatedTapErr ("ERR_TAP3_FILE_AVAILABLE_TIMESTAMP_SYNTAX", LOG_WARNING , "11","84", "4");
      }
      else
      {
          edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","107","4",offset,"-1",
                      "Syntax Error for file available timestamp ");
          setAssociatedTapErr ("ERR_TAP3_FILE_AVAILABLE_TIMESTAMP_SYNTAX", LOG_CRITICAL , "10","84", "4");
          edrDemandRollback();
      }
    }
  }
}

//------------------------------------------------------------------------------
// validateFileAvailableTimeStampCrossValidation()
//
// This function will be used to validate the file available timestamp cross
// validation
//------------------------------------------------------------------------------
function validateFileAvailableTimeStampCrossValidation
{
  if (debug)
  {
    logStdout("validateFileAvailableTimeStampCrossValidation()\n");
  }

  Date availableDate = edrDate(HEADER.TRANSMISSION_DATE);
  Date cutOffDate = edrDate(HEADER.TRANSFER_CUTOFF_TIMESTAMP);
  Date creationDate = edrDate(HEADER.CREATION_TIMESTAMP);
  Date CurrentProcessingTime = sysdate();
  String offset = "-1";

  if (dateDiff(availableDate,cutOffDate) < 0)
  {
    // Set Fatal Error
    // offset = longToStr( edrFieldTokenBytePos( HEADER.TRANSMISSION_DATE));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","102","107","2",offset,"-1",
		"File available time  earlier than transfer cut off timestamp");
      setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_WARNING , "100","107", "2");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","100","107","3",offset,"-1",
		"File available time  earlier than transfer cut off timestamp");
      setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_WARNING , "102","107", "3");
    }
  }

  if (dateDiff(availableDate,creationDate) < 0)
  {
    // Set Fatal Error
    // offset = longToStr( edrFieldTokenBytePos( HEADER.TRANSMISSION_DATE));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","103","107","2",offset,"-1",
		"File available time  earlier than file creation timestamp");
      setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_WARNING , "103","107", "2");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","101","107","3",offset,"-1",
		"File available time  earlier than file creation timestamp");
      setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_WARNING , "101","107", "3");
    }
  }
  if (dateDiff(availableDate,CurrentProcessingTime) > 0 AND dateIsValid(availableDate) == true)
  {
     // Set Fatal Error
     edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","104","107","4",offset,"-1",
                "File available time  is after the file received time at the HPMN");
     setAssociatedTapErr ("ERR_TAP3_ICUT_OFF_TIMESTAMP_MISMATCH", LOG_CRITICAL , "104","107", "4");
     edrDemandRollback();
  } 
}


//------------------------------------------------------------------------------
// validateSpecificationVersionNumber()
//
// This function will be used to validate the Specification Version Number
//------------------------------------------------------------------------------
function validateSpecificationVersionNumber
{
  if (debug)
  {
    logStdout("validateSpecificationVersionNumber()\n");
  }
  String depth;
  if(edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
  {
    depth = "2";
  }
  else
  {
    depth = "3";
  }

  if (edrInputState(HEADER.SPECIFICATION_VERSION_NUMBER) == MISSING)
  {
    // Set Fatal Error
    String offset = "-1";

    // offset = longToStr( edrFieldTokenBytePos( HEADER.SPECIFICATION_VERSION_NUMBER));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","33","2","1",offset,"-1",
		"Missing file specification version number ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_SPEC_VER", LOG_CRITICAL , "33","2", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","34","4","2",offset,"-1",
		"Missing file specification version number ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_FILE_SPEC_VER", LOG_CRITICAL , "34","4", "2");
    }

    edrDemandRollback();
  }
  else if (edrLong(HEADER.SPECIFICATION_VERSION_NUMBER) != 3)
  {
    // Set Fatal Error
    String offset = "-1";
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","201",depth,offset,"-1",
        "Specification Version Number Out of Range Error ");
    setAssociatedTapErr ("ERR_TAP3_SPECIFICATION_VERSION_NUMBER_OOR", LOG_CRITICAL , "20","201", depth);
    edrDemandRollback();
  }
}


//------------------------------------------------------------------------------
// validateReleaseVersionNumber()
//
// This function will be used to validate the Release Version Number
//------------------------------------------------------------------------------
function validateReleaseVersionNumber
{
  if (debug)
  {
    logStdout("validateReleaseVersionNumber()\n");
  }
  String depth;
  if(edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
  {
    depth = "2";
  }
  else
  {
    depth = "3";
  }

  if (edrInputState(HEADER.RELEASE_VERSION) == MISSING)
  {
    // Set Fatal Error
    String offset = "-1";

    // offset = longToStr( edrFieldTokenBytePos(HEADER.RELEASE_VERSION));
    if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","30","201","1",offset,"-1",
		"Missing release version number ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_RELEASE_VER", LOG_CRITICAL , "30","201", "1");
    }
    else
    {
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","30","201","2",offset,"-1",
		"Missing release version number ");
      setAssociatedTapErr ("ERR_TAP3_MISSING_RELEASE_VER", LOG_CRITICAL , "30","201", "1");
    }
    edrDemandRollback();
  }
  else
  {
     Long tmpReleaseVersionNumber;
     tmpReleaseVersionNumber = edrLong(HEADER.RELEASE_VERSION);
     if(tmpReleaseVersionNumber != 10)
     {
       edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","189",depth,"0","-1",
               "Out of Range release version number ");
       setAssociatedTapErr ("ERR_TAP3_RELEASE_VER_OOR", LOG_CRITICAL , "20","189", depth);
       edrDemandRollback();
     } 
  }
}

//------------------------------------------------------------------------------
// validateTapCurrency()
//
// This function will be used to validate the Tap Currency
//------------------------------------------------------------------------------
function validateTapCurrency
{
  if (debug)
  {
    logStdout("validateTapCurrency()\n");
  }
  String TapCurrency = edrString(HEADER.ASS_ROAMING_EXT.TAP_CURRENCY, 0);
  String ruleID1          = "Tap Currency Syntax Error";
  String ruleID2          = "Tap Currency Value Out of Range";
  const String tag        = "210";
  const String arrayIndex = "-1";
  const String depth      = "3";
  const String offset     = "-1";
  Bool currencyPresent    = false;
  Long i;

  if( edrString(HEADER.SENDER_COUNTRY_CODE) != "NOTIFICATION" )
  {

    if(strLength(TapCurrency) != 3)
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET", LOG_CRITICAL, "fatal", "10", tag, depth,
      offset, arrayIndex, ruleID1);
      setAssociatedTapErr("ERR_TAP3_TAP_CURRENCY_SE", LOG_CRITICAL ,"10" ,tag ,depth);
      edrDemandRollback();
    }

  
    for( i = 0 ; i < numOfCurrencyCode and currencyPresent == false ; i = i + 1 )
    {
      if( TapCurrency == currencyCode[i])
      {
        currencyPresent = true;
      }
    }
    if(currencyPresent == false)
    {
      // Set Fatal Error
      edrAddError("ERR_TAP3_RET", LOG_CRITICAL, "fatal", "20", tag, depth,
	  offset, arrayIndex, ruleID2);
      setAssociatedTapErr("ERR_TAP3_TAP_CURRENCY_OOR", LOG_CRITICAL ,"20" ,tag ,depth);
      edrDemandRollback(); 
    }

  }
}


//------------------------------------------------------------------------------
// validateTapDecimalPlaces()
//
// This function will be used to validate the Tap Decimal Places
//------------------------------------------------------------------------------
function validateTapDecimalPlaces
{
  if (debug)
  {
    logStdout("validateTapDecimalPlaces()\n");
  }

  if (edrInputState(HEADER.TAP_DECIMAL_PLACES) == MISSING)
  {
    // Set Fatal Error
    String offset = "-1";

    // offset = longToStr( edrFieldTokenBytePos(HEADER.TAP_DECIMAL_PLACES));
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","35","5","2",offset,"-1",
		"Missing Tap Decimal Places");
    setAssociatedTapErr ("ERR_TAP3_MISSING_TAP_DEC_PLACES", LOG_CRITICAL , "35","5", "2");
    edrDemandRollback();
  }
  else 
  {
    Long TapDecimalPlaces = edrLong(HEADER.TAP_DECIMAL_PLACES);
    if ( (TapDecimalPlaces < 0) or (TapDecimalPlaces > 6))
    {
       // Set Fatal Error
       String offset = "-1";

       edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","244","2",offset,"-1",
                "Out of Range TapDecimalPlaces");
       setAssociatedTapErr ("ERR_TAP3_TAP_DEC_PLACES_OOR", LOG_CRITICAL , "20","244", "2");
       edrDemandRollback();
    }
  }

}

//------------------------------------------------------------------------------
// validateRapFileSequenceNumber()
//
// This function will be used to validate the Rap File Sequence number in header
//------------------------------------------------------------------------------
function validateRapFileSequenceNumber
{
  if (debug)
  {
    logStdout("validateRapFileSequenceNumber()\n");
  }

  if (edrInternalState(HEADER.RAP_FILE_SEQ_NO) != STATE_CLEARED and edrInputState(HEADER.RAP_FILE_SEQ_NO) != MISSING)
  {
      if( (edrLong(HEADER.RAP_FILE_SEQ_NO) < 1 ) or
          (edrLong(HEADER.RAP_FILE_SEQ_NO) > 99999) )
      {
        // set warning
        String offset = "-1";
        edrAddError("ERR_TAP3_RET",LOG_WARNING,"warning","20","181","3",offset,"-1",
                "Rap file sequence number out of range in BatchCtrlInfo/Notification");
        setAssociatedTapErr ("ERR_TAP3_HEADER_RAP_FILE_SEQ_NO", LOG_WARNING , "20","181", "3");
     }
  }
}


//------------------------------------------------------------------------------
// validateInternationalAccessCode()      
//
// This function will be used to validate the International Access Code
//------------------------------------------------------------------------------
function validateInternationalAccessCode
{
  if (debug)
  {
    logStdout("validateInternationalAccessCode()\n");
  }
  String ListArray[];
  Long i;
  String internationalAccessCodes = edrString(HEADER.IAC_LIST);
  Long nbElem = strSplit(ListArray, internationalAccessCodes, ",");
  for ( i = 0; i < nbElem; i=(i+1) )
  {
    String intAccessCode = strStrip( ListArray[i], STRIP_LEADING);
    Long ret = strSearchRegExpr(intAccessCode, "[^0-9]");
    if ( ret >= 0 )
    {
       // Set Fatal Error
       String offset = "-1";

       edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","126","6",offset,"-1",
                "International Access Code Syntax Error");
       setAssociatedTapErr ("ERR_TAP3_IAC_SYNTAX", LOG_CRITICAL , "10","126", "6");
       edrDemandRollback();
    }
  }
}

//------------------------------------------------------------------------------
// validateCountryCodeList()
//
// This function will be used to validate country code
//------------------------------------------------------------------------------
function validateCountryCodeList
{
  if (debug)
  {
    logStdout("validateCountryCodeList()\n");
  }
  String ListArray[];
  Long i;
  String countryCodes = edrString(HEADER.CC_LIST);

  Long nbElem = strSplit(ListArray, countryCodes, ",");

  String offset = "-1";

 for ( i = 0; i < nbElem; i=(i+1) )
 {
    String countryCode = strStrip( ListArray[i], STRIP_LEADING);
    Long countryCodeFound = 1;
    Bool countryCodePresent = false;
    Long j;

    // Validation for Syntax Error
    countryCodeFound = strSearchRegExpr(countryCode, "[^0-9]");
    if ( countryCodeFound >= 0 )
    {
        edrAddError("ERR_TAP3_RET",LOG_MAJOR,"fatal","10","77","3",offset,"-1",
                "country code syntax error");
        setAssociatedTapErr ("ERR_TAP3_COUNTRY_CODE_SYNTAX", LOG_CRITICAL , "10","77", "3");
        edrDemandRollback();
        return;
    }

    // Validation for Out of Range
    for( j = 0 ; j < numOfCountryCode and countryCodePresent == false ; j = j + 1 )
    {
      if( strToLong(countryCode) == strToLong(countryCodeArray[j]) )
      {
        countryCodePresent = true;
      }
    }
    if(countryCodePresent == false)
    {
        edrAddError("ERR_TAP3_RET",LOG_MAJOR,"fatal","20","77","3",offset,"-1",
                "Out of range country code");
        setAssociatedTapErr ("ERR_TAP3_COUNTRY_CODE_OOR", LOG_CRITICAL , "20","77", "3");
        edrDemandRollback();
        return;
    }
 }
}


//------------------------------------------------------------------------------
// validateFileTypeIndicator()
//
// This function will be used to validate file type indicator
//------------------------------------------------------------------------------
function validateFileTypeIndicator
{
  if (debug)
  {
    logStdout("validateFileTypeIndicator()\n");
  }

  String fileTypeIndicator = edrString(HEADER.DATA_TYPE_INDICATOR);

  String offset = "-1";
  if ( (fileTypeIndicator != "") and
       (strLength(fileTypeIndicator) != 1) )
  {
        // Setting the fatal Error.
        if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
        {
            edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","110","1",offset,"-1",
                    "Syntax Error File Type Indicator");
            setAssociatedTapErr ("ERR_TAP3_FILE_TYPE_IND_SYNTAX", LOG_CRITICAL , "10","110", "1");
            edrDemandRollback();
            return;
        }
        else
        {
            edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","10","110","2",offset,"-1",
                    "Syntax Error File Type Indicator");
            setAssociatedTapErr ("ERR_TAP3_FILE_TYPE_IND_SYNTAX", LOG_CRITICAL , "10","110", "2");
            edrDemandRollback();
            return;
        }
  }

  // If File Type Indicator is present, then it should be only "T".
  if ( (fileTypeIndicator != "") and 
       (fileTypeIndicator != "T") )
  {
        if (edrString(HEADER.SENDER_COUNTRY_CODE) == "NOTIFICATION")
        {
            // So, if File Type Indicator is present, i.e. Not Missing and Not Empty,
            // but not equal to "T", then raise the appropriate error.
            edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","110","1",offset,"-1",
                        "Out of range File Type Indicator");
            setAssociatedTapErr ("ERR_TAP3_FILE_TYPE_IND_OOR", LOG_CRITICAL , "20","110", "1");
            edrDemandRollback();
        }
        else
        {
           // So, if File Type Indicator is present, i.e. Not Missing and Not Empty,
           // but not equal to "T", then raise the appropriate error.
           edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","110","2",offset,"-1",
                       "Out of range File Type Indicator");
           setAssociatedTapErr ("ERR_TAP3_FILE_TYPE_IND_OOR", LOG_CRITICAL , "20","110", "2");
           edrDemandRollback();
        }
  }
}


//------------------------------------------------------------------------------
// validateTotalChargeValueList()
//
// This function will be used to validate the total charge value list
//------------------------------------------------------------------------------
function validateTotalChargeValueList
{
  if (debug)
  {
    logStdout("validateTotalChargeValueList()\n");
  }

  Long blockIndex;
  Long nextblockIndex;
  String correctChargeType; 
  String nextChargeType = "";    
  String offset = "-1";

  Long blockEntries = edrNumDatablocks(TRAILER.TOTAL_CHARGE_VALUE_LIST);
  for (blockIndex = 0 ; blockIndex < blockEntries ; blockIndex = (blockIndex + 1) )
  {
    if (edrInputState(TRAILER.TOTAL_CHARGE_VALUE_LIST.CHARGE_TYPE,
		blockIndex) == MISSING)
    {
      // Set Fatal Error
      // offset = longToStr( edrFieldTokenBytePos(TRAILER.TOTAL_CHARGE_VALUE_LIST.
      //		CHARGE_TYPE,blockIndex, 0));
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","30","222","3",offset,"-1",
			"Missing Charge Type");
      setAssociatedTapErr ("ERR_TAP3_MISSING_CHARGE_TYPE", LOG_CRITICAL , "30","222", "3");
      edrDemandRollback();
    }

    if (edrInputState(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_VALUE,
		blockIndex) == MISSING)
    {
      // Set Fatal Error
      // offset = longToStr( edrFieldTokenBytePos(TRAILER.TOTAL_CHARGE_VALUE_LIST.
      //		TOTAL_CHARGE_VALUE,blockIndex, 0));
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","31","222","3",offset,"-1",
			"Missing Charge Value");
      setAssociatedTapErr ("ERR_TAP3_MISSING_CHARGE_VALUE", LOG_CRITICAL , "31","222", "3");
      edrDemandRollback();
    }
    if ((edrInputState(TRAILER.TOTAL_CHARGE_VALUE_LIST.TOTAL_CHARGE_REFUND,
		blockIndex) == MISSING) and (hasChargeRefund == true))
    {
      // Set Fatal Error
      // offset = longToStr( edrFieldTokenBytePos(TRAILER.TOTAL_CHARGE_VALUE_LIST.
      //		TOTAL_CHARGE_REFUND,blockIndex, 0));
      edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","32","222","3",offset,"-1",
			"Missing Total Charge Refund");
      setAssociatedTapErr ("ERR_TAP3_MISSING_TOTAL_CHARGE_REFUND", LOG_CRITICAL , "32","222", "3");
      edrDemandRollback();
    }
    correctChargeType = edrString(TRAILER.TOTAL_CHARGE_VALUE_LIST.CHARGE_TYPE, blockIndex); 
    for (nextblockIndex = (blockIndex + 1); (nextblockIndex < blockEntries) and (correctChargeType != nextChargeType); 
                           nextblockIndex = (nextblockIndex + 1) )
    {
       nextChargeType = edrString(TRAILER.TOTAL_CHARGE_VALUE_LIST.CHARGE_TYPE, nextblockIndex);
       if ( correctChargeType == nextChargeType )
       {
          // Set Fatal Error
          edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","35","15","2",offset,"-1",
                "Duplicate Entries of Charge Type"); 
          setAssociatedTapErr ("ERR_TAP3_DUPLICATE_CHARGE_TYPE", LOG_CRITICAL , "35","15", "2");
          edrDemandRollback();
       }
     }
  }
}

//------------------------------------------------------------------------------
// validateTotalTaxValue()
//
// This function will be used to validate the total tax value
//------------------------------------------------------------------------------
function validateTotalTaxValue
{
  if (debug)
  {
    logStdout("validateTotalTaxValue()\n");
  }

  String offset = "-1";
  // offset = longToStr( edrFieldTokenBytePos(TRAILER.TAP_TOTAL_TAX_VALUE));

  if (edrInputState(TRAILER.TAP_TOTAL_TAX_VALUE) == MISSING)
  {
    // Set Fatal Error
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","31","15","2",offset,"-1",
		"Missing Total Tax Value");
    setAssociatedTapErr ("ERR_TAP3_MISSING_TOTAL_TAX_VALUE", LOG_CRITICAL , "31","15", "2");
    edrDemandRollback();
  }
  // Total Tax Value should not be a negative value.
  else if (edrDecimal(TRAILER.TAP_TOTAL_TAX_VALUE) < 0.0)
  {
    // Total Tax Value is negative, Set Fatal Error
    edrAddError("ERR_TAP3_RET",LOG_CRITICAL,"fatal","20","226","3",offset,"-1",
                "Out of Range Total Tax Value");
    setAssociatedTapErr ("ERR_TAP3_TOTAL_TAX_VALUE_OOR", LOG_CRITICAL , "20","226", "3");
    edrDemandRollback();
  }
}


