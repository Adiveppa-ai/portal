//-----------------------------------------------------------------------------
// validateHasServiceUsageBlock
//
// This function will be used to validate if this Location block has any
// ServiceUsage blocks.
//-----------------------------------------------------------------------------
function validateHasServiceUsageBlock
{
  if (debug)
  {
    logStdout("validateHasServiceUsageBlock()\n");
  }

  const String severe     = "severe";
  const String tag        = "297";
  const String arrayIndex = "-1";
  const String depth      = "3";
  const String offset     = "-1";

  if ((edrString(DETAIL.RECORD_TYPE) == type_LOCN) and
      (edrNumDatablocks(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE, 0) == 0))
  {
    const String ruleID     = "Missing ServiceUsage Block";

    // offset = longToStr(edrFieldTokenBytePos(
    //			DETAIL.ASS_LOCN_EXT.SERVICE_USAGE));
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "31", tag, depth,
		offset, arrayIndex, ruleID);
    setAssociatedTapErr("ERR_TAP3_MISSING_SERVICE_USAGE_BLOCK", LOG_MAJOR ,"31" ,tag ,depth);	
  }
  
  if ( (edrNumDatablocks(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO, 0) == 0) 
		 and (edrNumDatablocks(DETAIL.ASS_LOCN_EXT.LCSSP_INFO, 0) == 0) )
  {
    const String ruleID     = "Neither of groups Tracking Customer Information or LCS SP Information present within group";

    // offset = longToStr(edrFieldTokenBytePos(
    //                  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE));
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "30", tag, depth,
                offset, arrayIndex, ruleID);
    setAssociatedTapErr("ERR_TAP3_MISSING_TRACKING_CUSTOMER_AND_LCSSP_INFO_GROUP", LOG_MAJOR ,"30" ,tag ,depth);
  }
}


