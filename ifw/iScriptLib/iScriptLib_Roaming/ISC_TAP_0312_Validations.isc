  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CallTypeLevel2. It will raise error code 20 for CallTypeLevel2.
 ******************************************************************************************************************************/
 
function validateCallTypeLevel2 ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",255";
  
  if (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true)
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "10", "Syntax error"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error");
      edrSetIsValidDetail(false);
  }

  if ( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "0", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true)
  {
    if ( ((validateOOR(edrStringEx(myContext, indices, nParentIndices), "7", "2", "INTEGER_TYPE") == true) and edrLongEx( myContext, indices, nParentIndices ) != 0 ) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.gprsCall") == true)
  {
    if ( ((validateOOR(edrStringEx(myContext, indices, nParentIndices), "15", "10", "INTEGER_TYPE") == true) and edrLongEx( myContext, indices, nParentIndices ) != 0 ) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.messagingEvent") == true)
  {
    if ( ((validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "2", "INTEGER_TYPE") == true) and edrLongEx( myContext, indices, nParentIndices ) != 0 ) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.mobileSession") == true) and mobileSessionServiceType == 1)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "0", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.mobileSession") == true) and mobileSessionServiceType == 2)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "5", "2", "INTEGER_TYPE") == true) and edrLongEx( myContext, indices, nParentIndices ) != 0  and edrLongEx( myContext, indices, nParentIndices ) != 7 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel2 ", "255", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");  
}

/******************************************************************************************************************************
 * This function will validate CallTypeLevel1, GeographicalLocation, GprsBasicCallInformation, GPRSChargeableSubscriber,
 * GPRSDestination, GprsLocationInformation, GprsNetworkLocation, RecEntityCode. It will raise error code 20 for CallTypeLevel1,
 * error code 33 for GeographicalLocation, error code 42 for GprsBasicCallInformation, error code 30, 32, 35 for 
 * GPRSChargeableSubscriber, error code 31, 32 for GPRSDestination, error code 31 for GprsLocationInformation, error code 32, 33,
 * 34, 35, 36, 37 for GprsNetworkLocation, error code 12, 13 for RecEntityCode. 
 ******************************************************************************************************************************/
 
function validateCallTypeLevel1 ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",259";

  Bool   recEntityTypeGGSNPresent = false;
  Bool   recEntityTypeSGSNPresent = false; 
  Bool   recEntityTypeWiFiPresent = false;
  Bool   sessionZeroCallTypeAllowed = false;
  Long   callTypeLevel1;
  Long   i;
  
  if (validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true)
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "10", "Syntax error"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Syntax error");
      edrSetIsValidDetail(false);
  }

  if ( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "2", "1", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "2", "0", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.messagingEvent") == true)
  {
    if (validateOOR(edrStringEx(myContext, indices, nParentIndices), "2", "1", "INTEGER_TYPE") == true)  
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( strStartsWith(parentContext, "DETAIL.gprsCall") == true)
  {
    if ( ((validateOOR(edrStringEx(myContext, indices, nParentIndices), "12", "10", "INTEGER_TYPE") == true) and edrLongEx( myContext, indices, nParentIndices ) != 100 ) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if (edrLongEx( myContext, indices, nParentIndices ) == 0 and nonChargedPublicUserIdIsMissing == false and nonChargedPartyNumberIsMissing == true)
  {
    sessionZeroCallTypeAllowed = true;
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.mobileSession") == true) and mobileSessionServiceType == 1)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "2", "1", "INTEGER_TYPE") == true) and sessionZeroCallTypeAllowed == false)
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.mobileSession") == true) and mobileSessionServiceType == 2)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "2", "0", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.mobileSession") == true) and mobileSessionServiceType == 3)
  {
    if ( (validateOOR(edrStringEx(myContext, indices, nParentIndices), "2", "1", "INTEGER_TYPE") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeLevel1 ", "259", "20", "Value out of range"); 
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value out of range");
      edrSetIsValidDetail(false);
    }
  }
  
  if ( edrLongEx(myContext, indices, nParentIndices) == 2 )
  {
    callIndicatesInternational = true;
  }
  
  if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
  {
    callTypeLevel1 = edrLongEx(myContext, indices, nParentIndices);
    if( servingLocationDescriptionIsMissing == true and callTypeLevel1 == 100 )
    {
	  objTag = "1,3,14,117,113";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Geographical Location", "113", "33",
                                     "Item Serving Location Description not present for Wi-Fi usage");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", objTag, "0", "-1", "-1","",
                                     "Item Serving Location Description not present for Wi-Fi usage");
      edrSetIsValidDetail(false);
    }
	
    if( partialTypeIndicatorIsMissing == false and callTypeLevel1 == 100 )
    {
	  objTag = "1,3,14,114";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Basic Call Information", "114", "43",
                                     "Item Partial Type Indicator present within group for Wi-Fi usage");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "43", objTag, "0", "-1", "-1","",
                                     "Item Partial Type Indicator present within group for Wi-Fi usage");
      edrSetIsValidDetail(false);
    }
   
    if( networkInitPDPContextIsPresent == true and callTypeLevel1 == 100 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Gprs Basic Call Information", "114", "42",
                                      "Item Network Init. PDP Context present within group for Wi-Fi usage");
    }
   
    if( chargeableSubscriberIsMissing == true and callTypeLevel1 != 100 )
    {
	  objTag = "1,3,14,114,115";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Chargeable Subscriber", "115", "30",
                  "Item Chargeable Subscriber missing within group and the GPRS Call does not represent Wi-Fi usage");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", objTag, "0", "-1", "-1","",
                  "Item Chargeable Subscriber missing within group and the GPRS Call does not represent Wi-Fi usage");
      edrSetIsValidDetail(false);
    }

    if( pdpAddressIsMissing == true and callTypeLevel1 != 100 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "GPRS Chargeable Subscriber", "115", "32",
                  "Item PDP Address missing within group and GPRS Call does not represent Wi-Fi usage");
    }

    if( networkAccessIdentifierIsPresent == true and callTypeLevel1 != 100 )
    {
      objTag = "1,3,14,114,115";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "GPRS Chargeable Subscriber", "115", "35",
                  "Item Network Access Identifier present within group and the GPRS Call does not represent Wi-Fi usage");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", objTag, "0", "-1", "-1","",
                  "Item Network Access Identifier present within group and the GPRS Call does not represent Wi-Fi usage");
      edrSetIsValidDetail(false);
    }

    if( accessPointNameOIIsPresent == true and callTypeLevel1 == 100 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "GPRS Destination", "116", "32",
                                                   "Item Access Point Name OI present within group for Wi-Fi usage");
    }

    if( geographicalLocationIsMissing == true and callTypeLevel1 == 100 )
    {
      objTag = "1,3,14,117";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Location Information", "117", "31",
                                                "Group Geographical Location missing for Wi-Fi usage");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", objTag, "0", "-1", "-1","",
                                                "Group Geographical Location missing for Wi-Fi usage");
      edrSetIsValidDetail(false);
    }
	
    if( totalCallEventDurationExceeded == true and callTypeLevel1 != 100 )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "TotalCallEventDuration", "223", "200", "Total Call Event Duration exceeds limit defined by BARG in BA.12");
    }
    
    if( callTypeLevel1 != 100 )
    {
      for( i = 0; i < recEntityTypeIndx; i = i + 1 )
      {
        if ( recEntityTypeArray[i] == 3 )
        {
           recEntityTypeGGSNPresent = true;
        }
        if ( recEntityTypeArray[i] == 4 )
        {
          recEntityTypeSGSNPresent = true;
        }
      }
      if( recEntityTypeGGSNPresent == false ) 
      {
        objTag = "1,3,14,117,118";
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Network Location", "118", "32",
                                      "No Recording Entity Code of type GGSN and no Recording Entity Code of type P-GW present within group and not Wi-Fi usage");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", objTag, "0", "-1", "-1","",
                                      "No Recording Entity Code of type GGSN and no Recording Entity Code of type P-GW present within group and not Wi-Fi usage");
        edrSetIsValidDetail(false);
      }
      if( recEntityTypeSGSNPresent == false )
      {
        objTag = "1,3,14,117,118";
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Network Location", "118", "33",
                                       "No Recording Entity Code of type SGSN and no Recording Entity Code of type S-GW present within group and not Wi-Fi usage");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", objTag, "0", "-1", "-1","",
                                       "No Recording Entity Code of type SGSN and no Recording Entity Code of type S-GW present within group and not Wi-Fi usage");
        edrSetIsValidDetail(false);
      }
      if( accessPointNameOIIsPresent == false and strStartsWith(parentContext, "DETAIL.gprsCall.gprsBasicCallInformation") == true )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "GPRS Destination", "116", "31",
                                                     "Item Access Point Name OI missing within group");
      }
    }
    if( callTypeLevel1 == 100 )
    {
      WiFiNetworkUsage = true;
      for( i = 0; i < recEntityTypeIndx; i = i + 1 )
      { 
        if( recEntityTypeArray[i] == 6 )
        {
          recEntityTypeWiFiPresent = true;
        }
	else if (recEntityTypeArray[i] != 7 and recEntityTypeArray[i] != 8 )
        {
          objTag = "1,3,14,117,118,185,184";
          edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RecEntityCode", "184", "13", "Value out of range for a GPRS call (only for Wi-Fi usage), i.e. the Recording Entity Code refers to a recording entity of a type other than Wi-Fi billing information recording entity");
          edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "13", objTag, "0", "-1", "-1", "","Value out of range for a GPRS call (only for Wi-Fi usage), i.e. the Recording Entity Code refers to a recording entity of a type other than Wi-Fi billing information recording entity");
          edrSetIsValidDetail(false);
        }
      }
      if ( recEntityTypeWiFiPresent == false )
      {
        objTag = "1,3,14,117,118";
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Network Location", "118", "34",
        "For Wi-Fi usage, no Recording Entity Code of type Wi-Fi billing information recording entity present within group");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", objTag, "0", "-1", "-1","",
        "For Wi-Fi usage, no Recording Entity Code of type Wi-Fi billing information recording entity present within group");
        edrSetIsValidDetail(false);
      }
      if( recEntityTypeIndx > 1 )
      {
        objTag = "1,3,14,117,118";
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Gprs Network Location", "118", "35",
                                       "For Wi-Fi usage, more than one Recording Entity Code present within group");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", objTag, "0", "-1", "-1","",
                                       "For Wi-Fi usage, more than one Recording Entity Code present within group");
        edrSetIsValidDetail(false);
      }
      if( locationAreaIsPresent == true )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Gprs Network Location", "118", "36",
                                        "For Wi-Fi usage, item Location Area Code present within group");
      }
      if( cellIdIsPresent == true )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Gprs Network Location", "118", "37",
                                        "For Wi-Fi usage,item Cell Identity present within group");
      }
    }
    else
    {
      for( i = 0; i < recEntityTypeIndx; i = i + 1 )
      {
        if( recEntityTypeArray[i] != 3 and recEntityTypeArray[i] != 4  and recEntityTypeArray[i] != 7 and recEntityTypeArray[i] !=8 )
        {
          objTag = "1,3,14,117,118,185,184";
          edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "RecEntityCode", "184", "12", "Value out of range for a GPRS call (except for Wi-Fi usage), i.e. the Recording Entity Code refers to a recording entity of a type other than GGSN, SGSN, P-GW or S-GW");
          edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "12", objTag, "0", "-1", "-1","", "Value out of range for a GPRS call (except for Wi-Fi usage), i.e. the Recording Entity Code refers to a recording entity of a type other than GGSN, SGSN, P-GW or S-GW");
          edrSetIsValidDetail(false);
        }
      }
    }
      
  } 
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CallTypeGroup and ChargeInformation. It will raise error code 30, 31, 32 for CallTypeGroup and
 * error code 42 for ChargeInformation.
 ******************************************************************************************************************************/
 
function validateCallTypeGroup ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",258";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "callTypeLevel1";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallTypeLevel1 ( myContext, nMyIndices, "callTypeLevel1", 0, errorContext );
  }
  else       
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeGroup", "258", "30", "Missing Call Type Level 1");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Missing Call Type Level 1");
    edrSetIsValidDetail(false);
  } 
  childContext = myContext + "." + "callTypeLevel2";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallTypeLevel2 ( myContext, nMyIndices, "callTypeLevel2", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeGroup", "258", "31", "Missing Call Type Level 2");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "","Missing Call Type Level 2");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "callTypeLevel3";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallTypeLevel3 ( myContext, nMyIndices, "callTypeLevel3", 0, errorContext );
  }
  else    
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "CallTypeGroup", "258", "32", "Missing Call Type Level 3");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1", "","Missing Call Type Level 3");
    edrSetIsValidDetail(false);
  }

  if( (strStartsWith(parentContext, "DETAIL.gprsCall.gprsServiceUsed.chargeInformationList.ChargeInformation") != true) and
      (strStartsWith(parentContext, "DETAIL.mobileTerminatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList.ChargeInformation") != true) and   
      (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList.ChargeInformation") != true) and 
      (strStartsWith(parentContext, "DETAIL.mobileSession") != true) and 
      (strStartsWith(parentContext, "DETAIL.messagingEvent") != true) ) 
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Charge Information", "69", "42", 
                "Call Type Group present within group and the call event is not a MOC, MTC or GPRS Call");
  }

  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ExchangeRateCode. It will raise error code 20, 101 for ExchangeRateCode.
 ******************************************************************************************************************************/
 
function validateExchangeRateCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",105";

  Long tmpExchangeRateCode;

  if( strStartsWith(parentContext, "HEADER") == true )
  {
    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "99", "0", "INTEGER_TYPE") == true)
    {
      rollbackReason   = "AccountingInfo," +  errorContext + ",20" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "Exchange Rate Code", "105", "20", "Out Of Range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "105", "0", "-1", "-1","", "Out Of Range");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
      edrLongEx( myContext, indices, nParentIndices ) = -1; 
      return;
    }
    hasDupExchangeRateCodeEntries = false;
    lastCode             = edrLongEx(myContext, indices, nParentIndices);
    tmpExchangeRateCode = edrLongEx(myContext, indices, nParentIndices);
    if( exchangeRateCode[lastCode] == tmpExchangeRateCode )
    {
      hasDupExchangeRateCodeEntries = true;
    }
    if (hasDupExchangeRateCodeEntries == false)
    {
      exchangeRateCode[lastCode] = lastCode;
    }
  }
  else
  {
    if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "99", "0", "INTEGER_TYPE") == true)
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Exchange Rate Code", "105", "11", "Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", "105", "0", "-1", "-1", "","Syntax Error");
      edrSetIsValidDetail(false);
      return;
    }
    tmpExchangeRateCode = edrLongEx(myContext, indices, nParentIndices); 
    if( tmpExchangeRateCode != exchangeRateCode[tmpExchangeRateCode] )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Exchange Rate Code", "105", "101",
                                                "Specified Exchange Rate Code not defined in group Currency Conversion");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1","",
                                                "Specified Exchange Rate Code not defined in group Currency Conversion");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate ChargedItem. It will raise error code 10, 20 for ChargedItem.
 ******************************************************************************************************************************/
 
function validateChargedItem ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",66";

  lastChargedItem = edrStringEx( myContext, indices, nParentIndices );
  
  if( (validateSyntax(lastChargedItem, "CHECK_ALPHA_UPPER") == true) or (strLength(lastChargedItem) != 1) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Item", "66", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error");
    edrSetIsValidDetail(false);
  }
    
  if ( ((strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true) or
       ( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true) or
	   ( strStartsWith(parentContext, "DETAIL.mobileSession") == true) ) and
	   lastChargedItem != "A" and lastChargedItem != "F" and lastChargedItem != "D" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Item", "66", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.gprsCall") == true) and 
        lastChargedItem != "A" and lastChargedItem != "F" and lastChargedItem != "D" and 
		lastChargedItem != "L" and lastChargedItem != "V" and lastChargedItem != "W" and lastChargedItem != "X" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Item", "66", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.contentTransaction") == true) and 
        lastChargedItem != "C" and lastChargedItem != "F" and lastChargedItem != "D" and 
		lastChargedItem != "L" and lastChargedItem != "V" and lastChargedItem != "W" and lastChargedItem != "X" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Item", "66", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  if ( (strStartsWith(parentContext, "DETAIL.locationService") == true) and 
        lastChargedItem != "D" and lastChargedItem != "F" and lastChargedItem != "E" and lastChargedItem != "L" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Item", "66", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  
  if ( ((strStartsWith(parentContext, "DETAIL.messagingEvent") == true) or
       (strStartsWith(parentContext, "DETAIL.serviceCentreUsage") == true) or
       (strStartsWith(parentContext, "DETAIL.supplServiceEvent") == true)) and
		lastChargedItem != "E" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charged Item", "66", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  } 
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate ChargeInformation. It will raise error code 30, 31, 32, 33 for ChargeInformation.
 ******************************************************************************************************************************/
 
function validateChargeInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",69";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  lastChargedItem         = "";
  exchangeRateCodeIsMissing = false;
 
  childContext = myContext + "." + "chargedItem";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateChargedItem ( myContext, nMyIndices, "chargedItem", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Information", "69", "30", "Item Charged Item missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Item Charged Item missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "exchangeRateCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateExchangeRateCode ( myContext, nMyIndices, "exchangeRateCode", 0, errorContext );
  }
  else
  {
    exchangeRateCodeIsMissing = true;
  }
 
  childContext = myContext + "." + "callTypeGroup";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateCallTypeGroup ( myContext, nMyIndices, "callTypeGroup", 0, errorContext );
  }
  else
  {
    if( (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall.basicServiceUsedList.BasicServiceUsed.chargeInformationList") ==  true) or (strStartsWith(parentContext, "DETAIL.gprsCall.gprsServiceUsed.chargeInformationList") == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Information", "69", "32", 
      "Item Call Type Group missing within group where the Charge Information relates to Basic Service Used or GPRS Service Used");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", errorContext, "0", "-1", "-1","",
      "Item Call Type Group missing within group where the Charge Information relates to Basic Service Used or GPRS Service Used");
      edrSetIsValidDetail(false);
    }
  }
  childContext = myContext + "." + "chargeDetailList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeDetailList ( myContext, nMyIndices, "chargeDetailList", 0, errorContext );
    if( (exchangeRateCodeIsMissing == true) and (chargeGreaterThanZero == true) )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Information", "69", "31", 
     "Item Exchange Rate Code missing within group and one or more Charge within an associated Charge Detail is greater than zero");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1", "",
     "Item Exchange Rate Code missing within group and one or more Charge within an associated Charge Detail is greater than zero");
      edrSetIsValidDetail(false);
    }
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Charge Information", "69", "33", "Group Charge Detail missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1", "","Group Charge Detail missing within group");
    edrSetIsValidDetail(false);
  } 
 
  childContext = myContext + "." + "taxInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateTaxInformationList ( myContext, nMyIndices, "taxInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "discountInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateDiscountInformation ( myContext, nMyIndices, "discountInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateChargeInformation for each element of Charge Information List. 
 ******************************************************************************************************************************/
 
function validateChargeInformationList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",70";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "ChargeInformation";
  Long ChargeInformationListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < ChargeInformationListEntries; i = i + 1 )
  {
    validateChargeInformation ( myContext, nMyIndices, "ChargeInformation", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate ChargingTimeStamp and CallEventStartTimestamp. It will raise error code 30, 100, 101 for 
 * ChargingTimeStamp and error code 101 for CallEventStartTimestamp.
 ******************************************************************************************************************************/
 
function validateChargingTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",74";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );

    Long callEventStartUtcTimeOffset_Hr = 0;
    Long callEventStartUtcTimeOffset_Mn = 0;
    Long chargingUtcOffset_Hr = 0;
    Long chargingUtcOffset_Mn = 0;
    if(strSubstr(callEventStartUtcTimeOffset,0,1) == "+")
    {
      callEventStartUtcTimeOffset_Hr = - (strToLong(strSubstr(callEventStartUtcTimeOffset,1,2)));
      callEventStartUtcTimeOffset_Mn = - (strToLong(strSubstr(callEventStartUtcTimeOffset,3,2)));
    }
    else
    {
      callEventStartUtcTimeOffset_Hr = strToLong(strSubstr(callEventStartUtcTimeOffset,1,2));
      callEventStartUtcTimeOffset_Mn = strToLong(strSubstr(callEventStartUtcTimeOffset,3,2));
    }
    if(strSubstr(chargingUtcTimeOffset,0,1) == "+")
    {
      chargingUtcOffset_Hr = - (strToLong(strSubstr(chargingUtcTimeOffset,1,2)));
      chargingUtcOffset_Mn = - (strToLong(strSubstr(chargingUtcTimeOffset,3,2)));
    }
    else
    {
      chargingUtcOffset_Hr = strToLong(strSubstr(chargingUtcTimeOffset,1,2));
      chargingUtcOffset_Mn = strToLong(strSubstr(chargingUtcTimeOffset,3,2));
    }

    if( (dateDiff( dateAdd(strToDate(lastChargingTimeStamp), 0, 0, 0, chargingUtcOffset_Hr, chargingUtcOffset_Mn, 0),
         dateAdd(strToDate(lastCallEventStartTimeStamp), 0, 0, 0, callEventStartUtcTimeOffset_Hr, callEventStartUtcTimeOffset_Mn, 
         0) ) < 0) and (lastChargingTimeStamp != "") and (lastCallEventStartTimeStamp != "") and
        (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or strStartsWith(parentContext, 
         "DETAIL.mobileTerminatedCall") == true ) )
    {
      if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
      {
        objTag = "1,3,9,147,44";
      }
      else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
      {
        objTag = "1,3,10,153,44";
      }
      else if( strStartsWith(parentContext, "DETAIL.gprsCall") == true )
      {
        objTag = "1,3,14,114,44";
      }
         // Error Setting
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Call Event Start Timestamp", "44", "101",
                                                "Call event start timestamp after charging timestamp");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", objTag, "0", "-1", "-1","",
                                                "Call event start timestamp after charging timestamp");
      edrSetIsValidDetail(false);
    } 
    
    if( (dateDiff( strToDate(lastChargingTimeStamp), dateAdd(strToDate(lastCallEventStartTimeStamp), 0, 0, 0, 0, 0, 
         lastTotalCallEventDuration) ) > 0) and (lastChargingTimeStamp != "") and (lastCallEventStartTimeStamp != "") and
        (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true or strStartsWith(parentContext, 
                                      "DETAIL.mobileTerminatedCall") == true) )
    {
         // Error Setting
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargingTimeStamp", "74", "100",
                                                "Charging Timestamp is later than end of call");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", errorContext, "0", "-1", "-1","",
                                                "Charging Timestamp is later than end of call");
      edrSetIsValidDetail(false);
    } 
    if( (dateDiff( strToDate(lastChargingTimeStamp), dateAdd(strToDate(lastLcsRequestTimestamp), 0, 0, 0, 0, 0, lastResponseTime) ) 
         > 0) and (lastChargingTimeStamp != "") and (lastLcsRequestTimestamp != "") and
                                                    (strStartsWith(parentContext, "DETAIL.locationService") == true) )
    {
         // Error Setting
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargingTimeStamp", "74", "101",
                                                "Charging Timestamp is later than LCS Request Timestamp plus Response Time");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", errorContext, "0", "-1", "-1","",
                                                "Charging Timestamp is later than LCS Request Timestamp plus Response Time");
      edrSetIsValidDetail(false);
    }
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ChargingTimeStamp", "74", "30", 
		"Mandatory associated item UTC Time Offset Code missing");  
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "",
		"Mandatory associated item UTC Time Offset Code missing");  
    edrSetIsValidDetail(false);
  }
  endLocalTimeStamp = addUTCToLocalTimestamp( endLocalTimeStamp, endUTCTimeOffset);
 
  //logContext( myContext, nMyIndices );
}

