function mapMobileOriginatedCall ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( createNewDetail(record_MOC, type_MOC) == false )
  {
  }
                                                                                                             
  childContext = myContext + "." + "basicCallInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMoBasicCallInformation ( myContext, nMyIndices, "basicCallInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "locationInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLocationInformation ( myContext, nMyIndices, "locationInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "equipmentIdentifier";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapImeiOrEsn ( myContext, nMyIndices, "equipmentIdentifier", 0 );                               
  }                                                                                                          
                                                                                                             
  initializeChargeInfoTempFields();
  childContext = myContext + "." + "basicServiceUsedList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapBasicServiceUsedList ( myContext, nMyIndices, "basicServiceUsedList", 0 );                               
  }                                                                                                          
  if (successiveBasicServiceUsed > 1)
  {
    edrString(DETAIL.ASS_GSMW_EXT.BS_PACKET.LONG_DURATION_INDICATOR, 0, bsPacketIdx ) = "L";
  }
                                                                                                             
  childContext = myContext + "." + "supplServiceCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSupplServiceCode ( myContext, nMyIndices, "supplServiceCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "thirdPartyInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapThirdPartyInformation ( myContext, nMyIndices, "thirdPartyInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "camelServiceUsed";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapCamelServiceUsed ( myContext, nMyIndices, "camelServiceUsed", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0 );                               
  }                                                                                                          

  if (successiveBasicServiceUsed > 1)
  {
    edrString(DETAIL.LONG_DURATION_INDICATOR) = "L";
  }
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapCallEventDetail ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "mobileOriginatedCall";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMobileOriginatedCall ( myContext, nMyIndices, "mobileOriginatedCall", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "mobileTerminatedCall";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapMobileTerminatedCall ( myContext, nMyIndices, "mobileTerminatedCall", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "supplServiceEvent";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapSupplServiceEvent ( myContext, nMyIndices, "supplServiceEvent", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "serviceCentreUsage";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapServiceCentreUsage ( myContext, nMyIndices, "serviceCentreUsage", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "gprsCall";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapGprsCall ( myContext, nMyIndices, "gprsCall", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "contentTransaction";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapContentTransaction ( myContext, nMyIndices, "contentTransaction", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "locationService";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLocationService ( myContext, nMyIndices, "locationService", 0 );                               
  }                                                                                                          
                                                                                                               
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapCallEventDetailList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "CallEventDetail";                                            
  Long CallEventDetailListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < CallEventDetailListEntries; i = i + 1 )                                                      
  {                                                                                                          
    mapCallEventDetail ( myContext, nMyIndices, "CallEventDetail", i );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
