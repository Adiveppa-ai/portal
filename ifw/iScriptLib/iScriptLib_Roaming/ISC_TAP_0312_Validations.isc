/******************************************************************************************************************************
 * This function will validate LCSSPInformation. It will raise error code 30 for LCSSPInformation.
 ******************************************************************************************************************************/
 
function validateLCSSPInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",373";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "lCSSPIdentificationList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLCSSPIdentificationList ( myContext, nMyIndices, "lCSSPIdentificationList", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LCSSPInformation", "373", "30", "Mandatory group LCS SP Identification missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group LCS SP Identification missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "iSPList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateISPList ( myContext, nMyIndices, "iSPList", 0, errorContext );
  }
 
  childContext = myContext + "." + "networkList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateNetworkList ( myContext, nMyIndices, "networkList", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

