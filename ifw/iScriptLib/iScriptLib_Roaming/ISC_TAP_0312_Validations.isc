/**************************************************************************************************************************
 * This function will validate AdvisedChargeCurrency. It will raise error code 10, 11, 20, 21 for AdvisedChargeCurrency.
 **************************************************************************************************************************/
 
function validateAdvisedChargeCurrency ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",348";

  Bool currencyPresent  = false;
  Bool advCurrencyPresent = false;
  Long i;
  lastAdvisedChargeCurrency = edrStringEx( myContext, indices, nParentIndices );

  if (  strStartsWith(parentContext, "DETAIL") == true )
  {
    if ( hasChargeRefund == false )
    {
      for( i = 0; i < advCurrencyEntries and advCurrencyPresent == false; i = i + 1 )
      {
        if( advChargeCurrency_Arr[i] == lastAdvisedChargeCurrency )
        {
          advCurrencyIndex = i;
          advCurrencyPresent = true;
        }
      }
      if ( advCurrencyPresent == false )
      {
        advChargeCurrency_Arr[advCurrencyEntries] = lastAdvisedChargeCurrency;
        advCurrencyIndex = advCurrencyEntries;
        advCurrencyEntries = advCurrencyEntries + 1;
      }
    }
    else
    {
      for( i = 0; i < advCurrencyEntriesRefund and advCurrencyPresent == false; i = i + 1 )
      {
        if( advChargeCurrencyRefund_Arr[i] == lastAdvisedChargeCurrency )
        {
          advCurrencyRefundIndex = i;
          advCurrencyPresent = true;
        }
      }
      if ( advCurrencyPresent == false )
      {
        advChargeCurrencyRefund_Arr[advCurrencyEntriesRefund] = lastAdvisedChargeCurrency;
        advCurrencyRefundIndex = advCurrencyEntriesRefund;
        advCurrencyEntriesRefund = advCurrencyEntriesRefund + 1;
      }
    }
  }

  if (  strStartsWith(parentContext, "TRAILER") == true )
  {
    for( i = 0; i <= advCurrencyEntriesRefund and advCurrencyPresent == false; i = i + 1 )
    {
      if( advChargeCurrencyRefund_Arr[i] == lastAdvisedChargeCurrency )
      {
        advChargeCurrencyIndex = i;
        advCurrencyPresent = true;
      }
    }
    for( i = 0; i <= advCurrencyEntries and advCurrencyPresent == false; i = i + 1 )
    {
      if( advChargeCurrency_Arr[i] == lastAdvisedChargeCurrency )
      {
        advChargeCurrencyIndex = i;
        advCurrencyPresent = true;
      }
    }
  }

  for( i = 0 ; i < numOfCurrencyCode and currencyPresent == false ; i = i + 1 )
  {
    if( lastAdvisedChargeCurrency == currencyCode[i])
    {
      currencyPresent = true;
    }
  }
  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHA_UPPER") == true ) 
  {
    if( strStartsWith(parentContext, "TRAILER.auditControlInfo") == true )
    {
      rollbackReason = "AuditControlInfo," + errorContext + ",10" + ":" + AuditControlInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AdvisedChargeCurrency", "348", "10", "Advised Charge Currency Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "348", "0", "-1", "-1", "","Advised Charge Currency Syntax Error");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "AdvisedChargeCurrency", "348", "11", "Advised Charge Currency Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", errorContext, "0", "-1", "-1", "","Advised Charge Currency Syntax Error");
      edrSetIsValidDetail(false);
    }
  }
  else if(currencyPresent == false)
  {
    if( strStartsWith(parentContext, "TRAILER.auditControlInfo") == true )
    {
      rollbackReason = "AuditControlInfo," + errorContext + ",20" + ":" + AuditControlInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AdvisedChargeCurrency", "348", "20", "Advised Charge Currency Out Of Range");    
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "348", "0", "-1", "-1", "","Advised Charge Currency Out Of Range");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "AdvisedChargeCurrency", "348", "21", "Advised Charge Currency Out Of Range");  
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", errorContext, "0", "-1", "-1","", "Advised Charge Currency Out Of Range");
      edrSetIsValidDetail(false);
    }
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TotalAdvisedChargeValue. It will raise error code 30, 100, 101, 102 for TotalAdvisedChargeValue.
 ******************************************************************************************************************************/

function validateTotalAdvisedChargeValue ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",360";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  advChargeCurrencyIndex  = -1;
 
  childContext = myContext + "." + "advisedChargeCurrency";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateAdvisedChargeCurrency ( myContext, nMyIndices, "advisedChargeCurrency", 0, errorContext );
  }
  else
  {
    lastAdvisedChargeCurrency = "NO_CURRENCY";
  }
 
  childContext = myContext + "." + "totalAdvisedCharge";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalAdvisedCharge ( myContext, nMyIndices, "totalAdvisedCharge", 0, errorContext );
  }
  else
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",30" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalAdvisedChargeValue", "360", "30", "Mandatory item Total Advised Charge missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "360", "0", "-1", "-1", "","Mandatory item Total Advised Charge missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "totalAdvisedChargeRefund";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalAdvisedChargeRefund ( myContext, nMyIndices, "totalAdvisedChargeRefund", 0, errorContext );
  }
  else if( totalCalcAdvisdchrgRefund_Arr[advChargeCurrencyIndex] > 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",102" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalAdvisedChargeValue", "360", "102", "Item Total Advised Charge Refund expected and not present");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "102", "360", "0", "-1", "-1","", "Item Total Advised Charge Refund expected and not present");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

  childContext = myContext + "." + "totalCommission";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalCommission ( myContext, nMyIndices, "totalCommission", 0, errorContext );
  }
  else if( totalCalcCommission_Arr[advChargeCurrencyIndex] > 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",100" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalAdvisedChargeValue", "360", "100", "Item Total Commission expected and not present");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "100", "360", "0", "-1", "-1", "","Item Total Commission expected and not present");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "totalCommissionRefund";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTotalCommissionRefund ( myContext, nMyIndices, "totalCommissionRefund", 0, errorContext );
  }
  else if( totalCalcCommissionRefund_Arr[advChargeCurrencyIndex] > 0 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",101" + ":" + AuditControlInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TotalAdvisedChargeValue", "360", "101", "Item Total Commission Refund expected and not present");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "101", "360", "0", "-1", "-1", "","Item Total Commission Refund expected and not present");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}


/******************************************************************************************************************************
 * This function will validate AuditControlInfo. It will raise error code 39 for AuditControlInfo.
 ******************************************************************************************************************************/
 
function validateTotalAdvisedChargeValueList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",361";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "TotalAdvisedChargeValue";
  Long TotalAdvisedChargeValueListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < TotalAdvisedChargeValueListEntries; i = i + 1 )
  {
    validateTotalAdvisedChargeValue ( myContext, nMyIndices, "TotalAdvisedChargeValue", i, errorContext );
  }

  if( TotalAdvisedChargeValueListEntries == 0 and advisedChargeInfoCount >= 1 )
  {
    rollbackReason = "AuditControlInfo," + errorContext + ",39" + ":" + AuditControlInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "AuditControlInfo", "15", "39",
    "TotalAdvisedChargeValue missing and one or more occurrences of ContentTransaction present containing Advised Charge Info");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "39", "15", "0", "-1", "-1","",
    "TotalAdvisedChargeValue missing and one or more occurrences of ContentTransaction present containing Advised Charge Info");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

