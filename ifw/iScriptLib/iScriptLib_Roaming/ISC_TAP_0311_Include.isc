function mapBasicService ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "serviceCode";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapBasicServiceCode ( myContext, nMyIndices, "serviceCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transparencyIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTransparencyIndicator ( myContext, nMyIndices, "transparencyIndicator", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fnur";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFnur ( myContext, nMyIndices, "fnur", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "userProtocolIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapUserProtocolIndicator ( myContext, nMyIndices, "userProtocolIndicator", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "guaranteedBitRate";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapGuaranteedBitRate ( myContext, nMyIndices, "guaranteedBitRate", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "maximumBitRate";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapMaximumBitRate ( myContext, nMyIndices, "maximumBitRate", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapBasicServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  newBasicServiceBlock();
  service_Type = service_Basic;
  lastBasicService = "011";
                                                                                                             
  childContext = myContext + "." + "basicService";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapBasicService ( myContext, nMyIndices, "basicService", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "chargingTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargingTimeStamp ( myContext, nMyIndices, "chargingTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "chargeInformationList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0 );                               
  }                                                                                                          

  storeChargeInfoTempFields();
                                                                                                             
  childContext = myContext + "." + "hSCSDIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapHSCSDIndicator ( myContext, nMyIndices, "hSCSDIndicator", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapBasicServiceUsedList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
                                                                                                             
  String childContext     = myContext + "." + "BasicServiceUsed";                                            
  Long BasicServiceUsedListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < BasicServiceUsedListEntries; i = i + 1 )                                                      
  {                                                                                                          
    mapBasicServiceUsed ( myContext, nMyIndices, "BasicServiceUsed", i );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
