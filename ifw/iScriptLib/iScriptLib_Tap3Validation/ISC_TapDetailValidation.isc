//-----------------------------------------------------------------------------
// validateRecEntityCode()
//
// This function will be used to validate if this Network Location block has any
// missing value.
//-----------------------------------------------------------------------------
function validateRecEntityCode
{
  if (debug)
  {
    logStdout("validateRecEntityCode()\n");
  }

  //Long blockEntries;
  Long blockIndex = 0;
  if (((edrString(DETAIL.RECORD_TYPE) == type_MOC) and
  edrInputState(DETAIL.ASS_GSMW_EXT.ORIGINATING_SWITCH_IDENTIFICATION, 0) == MISSING)
  or ((edrString(DETAIL.RECORD_TYPE) == type_MTC) and
  edrInputState(DETAIL.ASS_GSMW_EXT.TERMINATING_SWITCH_IDENTIFICATION, 0) == MISSING))

  {
    const String ruleID     = "Mandatory item Recording Entity Code missing within group";
    const String severe     = "severe";
    const String tag        = "156";
    const String arrayIndex = "-1";
    const String depth      = "5";
    const String offset     = "0";

    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, severe, "30", tag, depth,
    offset, arrayIndex, ruleID);
    setAssociatedTapErr("ERR_TAP3_MISSING_REC_ENTITY_CODE", LOG_MAJOR ,"30" ,tag ,depth);
  }
}

//------------------------------------------------------------------------------
// validateBasicCallInformation()
//
// This function will be used to validate the Basic Call Information for
// MOC, MTC and GPRS.
//------------------------------------------------------------------------------
function validateBasicCallInformation
{
  if (debug)
  {
    logStdout("validateBasicCallInformation()\n");
  }

  String offset;
  String recordType = edrString(DETAIL.RECORD_TYPE);
  String depth = "5";
  String errorCode;
  String objTag;

  // Check the record type and set the object tag to appropriate value.
  if (recordType == type_MOC) //Mobile Originated Call
  {
    objTag = "147";
  }
  else if (recordType == type_MTC) //Mobile Terminated Call
  {
    objTag = "153";
  }
  else // if ( (recordType == type_GPRS_SG) or (recordType == type_GPRS_SG) ) // GPRS Call
  {
    objTag = "114";
  }


  // Check for the missing condition of Call Event Start Timestamp.
  if ( edrInputState(DETAIL.CHARGING_START_TIMESTAMP) == MISSING )
  {
    // If missing, raise appropriate error message.
    offset = "-1";
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);

    // Check the record type and set the error code appropriately
    if ( (recordType == type_MOC) or (recordType == type_MTC) )
    {
      // For MOC and MTC, the error code is 31
      errorCode = "31";
    }
    else // if ( (recordType == type_GPRS_SG) or (recordType == type_GPRS_SG) )
    {
      // For GRPS, the error code is 33
      errorCode = "33";
    }
    
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", errorCode, objTag, depth,
              offset, "-1", "Missing Call Event Start Timestamp");
    setAssociatedTapErr ("ERR_TAP3_MISSING_CALL_EVENT_START_TIMESTAMP", LOG_MAJOR, errorCode,
                              objTag, depth);
  }

  // Check for the missing condition of Total Call Event Duration.
  if ( (edrInputState(DETAIL.TOTAL_CALL_EVENT_DURATION)) == MISSING )
  {
    // If missing, raise appropriate error message.
    offset = "-1";
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);

    // Check the record type and set the error code appropriately
    if ( (recordType == type_MOC) or (recordType == type_MTC) )
    {
      // For MOC and MTC, the error code is 32
      errorCode = "32";
    }
    else // if ( (recordType == type_GPRS_SG) or (recordType == type_GPRS_SG) )
    {
      // For GPRS, the error code is 34
      errorCode = "34";
    }
    
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", errorCode, objTag, depth,
              offset, "-1", "Missing Total Call Event Duration");
    setAssociatedTapErr ("ERR_TAP3_MISSING_TOTAL_CALL_EVENT_DURATION", LOG_MAJOR, errorCode,
                              objTag, depth);
  }
  
}

//------------------------------------------------------------------------------
// validateUserProtocolIndicator()
//
// This function will be used to validate User Protocol Indicator
//------------------------------------------------------------------------------
function validateUserProtocolIndicator
{
  if (debug)
  {
    logStdout("validateUserProtocolIndicator()\n");
  }

  String offset;
  Long blockEntries;
  Long blockIndex;

  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {

    Long UserProtocolIndicator = edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.USER_PROTOCOL_INDICATOR, 0, blockIndex);
    if ( UserProtocolIndicator < 0 or UserProtocolIndicator > 5 )
    {
	  offset = "-1";
	  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "280", "6",
			offset, "-1", "User Protocol Indicator Value Out of Range ");
	  setAssociatedTapErr("ERR_TAP3_USER_PROTOCOL_INDICATOR_OOR", LOG_MAJOR ,"20" ,"280" ,"6");	
    }

  }

}

//-----------------------------------------------------------------------------
// validateCallTypeLevel
//
// This function is used to validate if call type levels are missing in call 
// type group block.
//-----------------------------------------------------------------------------
function validateCallTypeLevel
{
  if (debug)
  {
    logStdout("validateCallTypeLevel()\n");
  }

  const String severe     = "severe";
  const String arrayIndex = "-1";
  const String offset     = "-1";

  // Flag to check whether Call Type Level 2 is missing
  Bool isCallTypeLevel2Missing = false;

  // Since Call Type Level 1 and 2 both uses the same
  // container field DETAIL.CONNECT_TYPE, we will use
  // the Input state and string length of the
  // DETAIL.CONNECT_TYPE to find which fields are missing.
 
  // If DETAIL.CONNECT_TYPE is missing then clearly
  // Call Type Level 1 is missing.
  if ((edrInputState(DETAIL.CONNECT_TYPE)) == MISSING)
  {
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);

    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "258", "5",
    offset, arrayIndex, "Missing Call Type Level 1");

    setAssociatedTapErr ("ERR_TAP3_MISSING_CALL_TYPE_LEVEL_1", LOG_MAJOR, "30",
                              "258", "5");

    // If Call Type Level 1 is missing and the string length of
    // the DETAIL.CONNECT_TYPE is 0, then Call Type Level 2 is
    // also missing.
    if (strLength(edrString(DETAIL.CONNECT_TYPE)) == 0)
    {
      isCallTypeLevel2Missing = true;
    }
  }
  // Call Type Level 1 is present. Check the string length of
  // DETAIL.CONNECT_TYPE. If it is 1, then Call Type Level 2
  // is missing.
  else if (strLength(edrString(DETAIL.CONNECT_TYPE)) == 1)
  {
    isCallTypeLevel2Missing = true;
  }

  // If Call Type Level 2 is missing then raise the error.
  if (isCallTypeLevel2Missing == true)
  {
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);

    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "258", "5",
    offset, arrayIndex, "Missing Call Type Level 2");

    setAssociatedTapErr ("ERR_TAP3_MISSING_CALL_TYPE_LEVEL_2", LOG_MAJOR, "31",
                              "258", "5");
  }

  // If Call Type Level 3 is missing then raise the error.
  if (edrInputState(DETAIL.CONNECT_SUB_TYPE) == MISSING)
  {
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);

    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "32", "258", "5",
    offset, arrayIndex, "Missing Call Type Level 3");

    setAssociatedTapErr ("ERR_TAP3_MISSING_CALL_TYPE_LEVEL_3", LOG_MAJOR, "32",
                              "258", "5");
  }
  // If Called Country Code is missing and call is international then raise the error. 
  String level1           = strSubstr (edrString(DETAIL.CONNECT_TYPE),0,1);
  if ((edrInputState(DETAIL.CALLED_COUNTRY_CODE) == MISSING) and  level1 == "2")
  {
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", "258", "5",
    offset, arrayIndex, "Missing Called Country Code but Call is international");

    setAssociatedTapErr ("ERR_TAP3_MISSING_CALLED_COUNTRY_CODE", LOG_MAJOR, "33",
                              "258", "5");
  }
}

//-----------------------------------------------------------------------------
// validateCamelServiceUsed 
//
// This function is used to validate camel service used.
//-----------------------------------------------------------------------------
function validateCamelServiceUsed
{
  if (debug)
  {
    logStdout("validateCamelServiceUsed()\n");
  }
  String ListArray[];
  Long i;
  Bool isNumberModified = false;
  String camelModList  = edrString(DETAIL.ASS_CAMEL_EXT.CAMEL_MODIFICATION_LIST, 0);
  Long nbElem = strSplit(ListArray, camelModList, ",");
  for ( i = 0; ((i < nbElem) and (isNumberModified != true)); i=(i+1) )
  {
    String camelModification = strStrip( ListArray[i], STRIP_LEADING);
    if( camelModification == "1")
    {
      isNumberModified = true;
    }
  }
  if((edrInputState(DETAIL.ASS_CAMEL_EXT.DEST_GSMW_NUMBER_ORIGINAL, 0) == MISSING) and
      (isNumberModified == true))
  {
    edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "57", "4", "-1", "-1",
                "Camel Destination Number missing within group");
    setAssociatedTapErr("ERR_TAP3_MISSING_CAMEL_DESTINATION", 3,"31" ,"57" ,"4");
  }
}

//-----------------------------------------------------------------------------
// validateCamelDestinationNumber
//
// This function is used to validate camel Destination Number.
//-----------------------------------------------------------------------------
function validateCamelDestinationNumber
{
  if (debug)
  {
    logStdout("validateCamelDestinationNumber()\n");
  }
  String camelDestNo = edrString(DETAIL.ASS_CAMEL_EXT.DEST_GSMW_NUMBER_ORIGINAL, 0);
  Long j;
  Bool countryCodeFound = false;
  for( j = 0 ; j < numOfCountryCode and countryCodeFound == false ; j = j + 1 )
  {
    if (strStartsWith(camelDestNo, countryCodeArray[j]))
    {
      countryCodeFound = true;
    }
  }  
  if ( edrInternalState(DETAIL.ASS_CAMEL_EXT.DEST_GSMW_NUMBER_ORIGINAL, 0) != STATE_CLEARED
        and edrInputState(DETAIL.ASS_CAMEL_EXT.DEST_GSMW_NUMBER_ORIGINAL, 0) != MISSING
        and ( ( strSearchRegExpr(camelDestNo, "[^0-9A-E]") >= 0 ) or countryCodeFound == false ) 
        and ((strLength(camelDestNo) > 7 or strSearchRegExpr(strSubstr(camelDestNo, 0, 1),  "[^0-9A-E]") >= 0)) )
  {
    edrString( DETAIL.ERROR_REJECT_TYPE ) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "33", "4", "-1", "-1",
                "Camel Destination Number not short code and not represented in International format.");
    setAssociatedTapErr("ERR_TAP3_CAMEL_DESTINATION_NUMBER_NOT_CORRECT", 3,"20" ,"33" ,"4");
  }
}

//-----------------------------------------------------------------------------
// validateAiurRequested
//
// This function is used to validate Air Interface User Rate Requested field.
//-----------------------------------------------------------------------------
function validateAiurRequested
{
  if (debug)
  {
    logStdout("validateAiurRequested()\n");
  }

  Long blockIndex;
  Long blockEntries;

  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);

  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    // Check whether AIUR Requested field is not missing
    // This check has been performed to avoid edrLong
    // returning a 0 value when AIUR Requested field is missing.
    if (edrInternalState(DETAIL.ASS_GSMW_EXT.BS_PACKET.AIUR_REQUESTED,
                                                0, blockIndex) != STATE_CLEARED and (edrInputState(DETAIL.ASS_GSMW_EXT.BS_PACKET.AIUR_REQUESTED,
                                                0, blockIndex)) != MISSING)
    {
      Long aiurRequested = strToLong(edrString(DETAIL.ASS_GSMW_EXT.BS_PACKET.AIUR_REQUESTED,
                                                0, blockIndex)); 
      
      // aiurRequested should be in the range of 1 to 3 and 5 to 12.
      if ( (aiurRequested < 1) or (aiurRequested > 3 and aiurRequested < 5) or (aiurRequested > 12) )
      {
        // If not in range, raise Out Of Range error.
        String offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);

        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "34", "5",
                offset, longToStr(blockIndex), "Out Of Range Air Interface User Rate Requested");
        setAssociatedTapErr ("ERR_TAP3_AIUR_REQUESTED_OOR", LOG_MAJOR, "20", "34", "5");
      } 
    }
  }
}


//------------------------------------------------------------------------------
// validateMessageType()
//
// This function will be used to validate the Message Type
//------------------------------------------------------------------------------
function validateMessageType
{
  if (debug)
  {
    logStdout("validateMessageType()\n");
  }

  String offset;
  Long messageType = strToLong(edrString(DETAIL.QOS_USED));

  // Check whether Message Type value is either 0, 1 or 2
  if ( (messageType < 0) or (messageType > 2) )
  {
    // If not 0, 1 or 2, raise appropriate error
    offset = "-1";
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", "145", "5",
              offset, "-1", "Out Of Range Message Type");
    setAssociatedTapErr("ERR_TAP3_OOR_MESSAGE_TYPE", LOG_MAJOR ,"20" ,"145" ,"5");
  }
}


//------------------------------------------------------------------------------
// validateDistanceChargeBandCode() 
//
// This function will be used to validate the Distance Charge Band Code
//------------------------------------------------------------------------------
function validateDistanceChargeBandCode
{
  if (debug)
  {
    logStdout("validateDistanceChargeBandCode()\n");
  }

  String offset;
  if((edrInternalState(DETAIL.ZONE_DESCRIPTION) != STATE_CLEARED and edrInputState(DETAIL.ZONE_DESCRIPTION) != EDR_INPUT_MISSING) AND (strLength(edrString(DETAIL.ZONE_DESCRIPTION)) != 1))
  {
    offset = "-1";
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", "98", "5",
              offset, "-1", "Distance Charge Band Code Syntax Error");
    setAssociatedTapErr("ERR_TAP3_ZONE_DESCRIPTION_SYNTAX", LOG_MAJOR ,"10" ,"98" ,"5");
  }
}


//------------------------------------------------------------------------------
// validateDepositTimeStamp()
//
// This function will be used to validate the Deposit TimeStamp
//------------------------------------------------------------------------------
function validateDepositTimeStamp
{
  if (debug)
  {
    logStdout("validateDepositTimeStamp()\n");
  }
  String offset;
  if( edrInputState(DETAIL.CHARGING_START_TIMESTAMP) != EDR_INPUT_MISSING AND
      edrInternalState(DETAIL.CHARGING_START_TIMESTAMP) != STATE_CLEARED AND 
      (dateIsValid(edrDate(DETAIL.CHARGING_START_TIMESTAMP)) == false) AND (edrString(DETAIL.CHARGING_POINT) == "D") )
  {
    offset = "-1";
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", "88", "6",
              offset, "-1", "Deposit TimeStamp Syntax Error");
    setAssociatedTapErr("ERR_TAP3_DEPOSIT_TIMESTAMP_SYNTAX", LOG_MAJOR ,"11" ,"88" ,"6");
  }
  if( edrInputState(DETAIL.CHARGING_START_TIMESTAMP) != EDR_INPUT_MISSING AND
      edrInternalState(DETAIL.CHARGING_START_TIMESTAMP) != STATE_CLEARED AND 
      (dateIsValid(edrDate(DETAIL.CHARGING_START_TIMESTAMP)) == false) AND (edrString(DETAIL.CHARGING_POINT) == "C") ) 
  {
    edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "10", "88", "6",
              "-1", "-1", "Deposit TimeStamp Syntax Error");
    setAssociatedTapErr("ERR_TAP3_DEPOSIT_TIMESTAMP_SYNTAX", LOG_WARNING ,"10" ,"88" ,"6");
  } 
}


//------------------------------------------------------------------------------
// validateCompletionTimeStamp()
//
// This function will be used to validate the Completion TimeStamp
//------------------------------------------------------------------------------
function validateCompletionTimeStamp
{
  if (debug)
  {
    logStdout("validateCompletionTimeStamp()\n");
  }
  String offset;
  if( edrInputState(DETAIL.CHARGING_END_TIMESTAMP) != EDR_INPUT_MISSING AND
      edrInternalState(DETAIL.CHARGING_END_TIMESTAMP) != STATE_CLEARED AND
      (dateIsValid(edrDate(DETAIL.CHARGING_END_TIMESTAMP) ) == false) AND (edrString(DETAIL.CHARGING_POINT) == "C") ) 
  {
    offset = "-1";
    edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
    edrSetIsValidDetail(false);
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "11", "76", "6",
              offset, "-1", "Completion TimeStamp Syntax Error");
    setAssociatedTapErr("ERR_TAP3_COMPLETION_TIMESTAMP_SYNTAX", LOG_MAJOR ,"11" ,"76" ,"6");
  }
  if( edrInputState(DETAIL.CHARGING_END_TIMESTAMP) != EDR_INPUT_MISSING AND
      edrInternalState(DETAIL.CHARGING_END_TIMESTAMP) != STATE_CLEARED AND
      (dateIsValid(edrDate(DETAIL.CHARGING_END_TIMESTAMP) ) == false) AND (edrString(DETAIL.CHARGING_POINT) == "D") ) 
  {
    edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "10", "76", "6",
              "-1", "-1", "Completion TimeStamp Syntax Error");
    setAssociatedTapErr("ERR_TAP3_COMPLETION_TIMESTAMP_SYNTAX", LOG_WARNING ,"10" ,"76" ,"6");
  }
}  


//-----------------------------------------------------------------------------
// validateMin()
//
// This function will be used to validate Mobile Identification Number 
//-----------------------------------------------------------------------------
function validateMin
{
  if (debug)
  {
    logStdout("validateMin()\n");
  }

  String Min = edrString(DETAIL.ASS_ROAMING_EXT.MOBILE_ID_NUMBER,0);
  Long Min_charSearch = strSearchRegExpr(Min, "[^0-9]");

  if(Min_charSearch >= 0)  
  {
    const String ruleID     = "Min Syntax Error";
    const String tag        = "146";
    const String arrayIndex = "-1";
    const String depth      = "5";
    const String offset     = "-1";

    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", tag, depth,
    offset, arrayIndex, ruleID);
    setAssociatedTapErr("ERR_TAP3_MIN_SYNTAX_ERROR", LOG_MAJOR,"10" ,tag ,depth);
    edrDemandRollback();
  }

}

//-----------------------------------------------------------------------------
// validateCurrencyDetails
//
// This function will be used to validate the localCurrency block
//-----------------------------------------------------------------------------
function validateCurrencyDetails
{
  if (debug)
  {
    logStdout("validateCurrencyDetails()\n");
  }

  if ((edrInputState(DETAIL.WHOLESALE_CHARGED_AMOUNT_CURRENCY)) == MISSING)
  {
    const String ruleID     = "Missing Local Currency";
    const String tag        = "5";
    const String arrayIndex = "-1";
    const String depth      = "5";
    const String offset     = "-1";

    edrAddError("ERR_TAP3_RET", LOG_CRITICAL, "fatal", "32", tag, depth,
    offset, arrayIndex, ruleID);
    setAssociatedTapErr("ERR_TAP3_MISSING_LOCAL_CURRENCY", LOG_CRITICAL ,"32" ,tag ,depth);
    edrDemandRollback();
  }

}

//------------------------------------------------------------------------------
// validateDetailRecord()
//
// This function will be used to validate the detail record
//------------------------------------------------------------------------------
function validateDetailRecord
{
  if (debug)
  {
    logStdout("validateDetailRecord()\n");
  }

  switch (edrString(DETAIL.RECORD_TYPE))
  {
    case type_MOC:		// Mobile Originated Call
    {
      validateCallTypeLevel();
      validateCamelServiceUsed();
    }
    case type_MTC:		// Mobile Terminated Call
    {
      validateBasicHSCSDParameters();
      validateHSCSDParameterModification();
      validateSupplServiceUsed();
      validateBasicServiceCode();
      validateBasicCallInformation();
      validateChargeableSubscriber();
      validateCallEventStartTime();
      validateChargingTimeStamp();
      validateHasBSBlock();
      validateRecEntityCode();
      validateGeographicalLocation();
      validateSIMToolkitIndicator();
      validateBasicServiceUsed();
      validateDualServiceRequested();
      validateUserProtocolIndicator();
      validateAiurRequested();
      validateCamelDestinationNumber();
    }
    break;

    case type_MSS:		// Supplementary Service Event
    {
      validateSupplServiceUsedMSS();
      validateChargeableSubscriber();
      validateHasSSBlock();
      validateGeographicalLocation();
      validateSIMToolkitIndicator();
    }
    break;

    case type_SCU:		// Service Centre Usage
    {
      validateNonChargedNumber();
      validateCLIRIndicatorforSCU();
      validateMessageType();
      validateDistanceChargeBandCode();
      validateDepositTimeStamp();
      validateCompletionTimeStamp();
    }
    break;

    case type_VAS:		// Value Added Service
    {
      validateHasVASBlock();
    }
    break;

    case type_GPRS_SG:		// GPRS Call
    case type_GPRS_GG:
    {
      validateGprsServiceUsage();
      validateBasicCallInformation();
      validateGprsChargeableSubscriber();
      validateCallEventStartTime();
      validateGprsChargingTimeStamp();
      validateCauseForTermination();
      validateGprsCallEventDuration();
      validateHasServiceUsedBlock();
      validateGeographicalLocation();
      validateGprsServUsedChargingTimeStamp();
      validatePDPContextStartTimeStamp();
      validateTypeOfControllingNode();
      validateUMTSQoSRequestedAndUsed();
    }
    break;

    case type_CONT:		// Content Transaction
    {
      validateAdvisedCharge();
      validateChargedParty();
      validateChargedPartyHomeIdentification();
      validateChargedPartyLocation();
      validateProviderTypeandId(70);
      validateContentServiceUsed();
      validateNetworkType(70);
      validateIspInfoType(70);
      validateServiceUsedListTransactionDescriptionSupp();
      validateServiceUsedListTotalDataVolume();
      validateServiceUsedListPaymentMethod();
      validateServiceUsedListPaidIndicator();
      validateServiceUsedListObjectType();
      validateServiceUsedListDataVolumeOutgoing();
      validateServiceUsedListDataVolumeIncoming();
      validateServiceUsedListCommission();
      validateServiceUsedListChargeRefundIndicator();
      validateHasChargedPartyInfoBlock();
      validateHasServingPartiesInfoBlock();
      validateHasServiceUsedListBlock();
      validateChargedPartyIdentifier();
      validateContHomeIdentifier();
      validateContentTransactionBasicInfo();
    }
    break;

    case type_LOCN:		// Location Service
    {
      validateNetworkType(80);
      validateIspInfoType(80);
      validateProviderTypeandId(80);
      validateTrackedHomeIdentification();
      validateTrackingHomeIdentification();
      validateTrackingCustomerIdentification();
      validateTrackedCustomerIdentification();
      validateTrackedCustomerLocation();
      validateTrackingCustomerLocation();
      validateHasServiceUsageBlock();
      validateHasLCSSPInfoBlock();
      validateHasTrackingCustomerInfoBlock();
      validateHasTrackedCustomerInfoBlock();
      validateContentProviderIdentifier(); 
      validateCustomerIdentifier();
      validateHomeIdentifier();
      validateIspIdentifier();
      validateLcsChargingTimeStamp();
    }
    break;
  }

  validateChargeDetail();
  validateTaxDetail();
  validateHasCBDBlock();
  validateCurrencyDetails();
  validateMin();
  validateChargeInformation();

  return;
}

//------------------------------------------------------------------------------
// tempEDRFieldsAccess()
//
// This function will be used to access EDR fields which are not accessed. 
// This is done so that it gets validated for its type since the pipeline 
// framework supports lazy type checking.
//------------------------------------------------------------------------------
function tempEDRFieldsAccess
{
   Date temp_DETAIL_CHARGING_START_TIMESTAMP;
   Date temp_DETAIL_CHARGING_END_TIMESTAMP;
   Date temp_DETAIL_ASS_CONT_EXT_ACTUAL_DELIVERY_TIMESTAMP;
   Date temp_DETAIL_ASS_CONT_EXT_ORDER_PLACED_TIMESTAMP;
   Date temp_DETAIL_ASS_CONT_EXT_REQUESTED_DELIVERY_TIMESTAMP;
   Long temp_DETAIL_ASS_CONT_EXT_SERVICE_USED_LIST_CONTENT_CHARGING_POINT;
   Date temp_DETAIL_ASS_GPRS_EXT_GS_PACKET_CHARGING_END_TIMESTAMP;
   Date temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_CHARGING_END_TIMESTAMP;
   Long temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_HSCSD_INFO_PACKET_PM_LIST_AIUR;
   Long temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_HSCSD_INFO_PACKET_PM_LIST_MAX_NUMBER_OF_CHANNELS;
   Long temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_TRANSPARENCY_INDICATOR;
   Long temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_USER_PROTOCOL_INDICATOR;
   Date temp_DETAIL_ASS_GSMW_EXT_SS_PACKET_CHARGING_END_TIMESTAMP;
   Date temp_DETAIL_ASS_GSMW_EXT_SS_PACKET_CHARGING_START_TIMESTAMP;
   Long temp_DETAIL_ASS_GSMW_EXT_SS_PACKET_CLIR_INDICATOR;
   Long temp_DETAIL_ASS_LOCN_EXT_REC_ENTITY_CODE;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_DEL_TRACKING_FREQUENCY;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_DEL_TRACKING_PERIOD;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_H_ACCURACY_DELIVERED ;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_H_ACCURACY_REQUESTED ;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_REQ_TRACKING_FREQUENCY;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_TRACKING_PERIOD;       
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_V_ACCURACY_DELIVERED;
   Long temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_V_ACCURACY_REQUESTED;
   Date temp_DETAIL_ASS_VAS_EXT_CHARGING_END_TIMESTAMP;
   Date temp_DETAIL_ASS_VAS_EXT_CHARGING_START_TIMESTAMP;
 
 
   Long indexOne;
   Long indexTwo;
   Long indexThree;
 
   Long forIndexOne;    
   Long forIndexTwo;
   Long forIndexThree;
 
   temp_DETAIL_CHARGING_START_TIMESTAMP=edrDate(DETAIL.CHARGING_START_TIMESTAMP);
   temp_DETAIL_CHARGING_END_TIMESTAMP=edrDate(DETAIL.CHARGING_END_TIMESTAMP);

     // For Field  DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP  of type Date         
     temp_DETAIL_ASS_CONT_EXT_ACTUAL_DELIVERY_TIMESTAMP = edrDate(DETAIL.ASS_CONT_EXT.ACTUAL_DELIVERY_TIMESTAMP,0) ;
   
     // For Field  DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP of type Date             
     temp_DETAIL_ASS_CONT_EXT_ORDER_PLACED_TIMESTAMP = edrDate(DETAIL.ASS_CONT_EXT.ORDER_PLACED_TIMESTAMP,0) ;
 
     // For Field  DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP of type  Date
     temp_DETAIL_ASS_CONT_EXT_REQUESTED_DELIVERY_TIMESTAMP = edrDate(DETAIL.ASS_CONT_EXT.REQUESTED_DELIVERY_TIMESTAMP,0) ;
 
     // Loop through DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST  
     indexOne = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST, 0);
     for(forIndexOne = 0; forIndexOne < indexOne; forIndexOne = forIndexOne + 1 )
     {
       // For Field  DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_CHARGING_POINT of type Integer
       temp_DETAIL_ASS_CONT_EXT_SERVICE_USED_LIST_CONTENT_CHARGING_POINT = 
               edrLong(DETAIL.ASS_CONT_EXT.SERVICE_USED_LIST.CONTENT_CHARGING_POINT,0,forIndexOne);
       
     }
    
     //Loop through DETAIL.ASS_GSMW_EXT.BS_PACKET
     indexOne = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
     for(forIndexOne = 0; forIndexOne < indexOne; forIndexOne = forIndexOne + 1 )
     {
       // For Field  DETAIL.ASS_GSMW_EXT.BS_PACKET.USER_PROTOCOL_INDICATOR of type Integer
       temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_USER_PROTOCOL_INDICATOR = 
         edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.USER_PROTOCOL_INDICATOR,0, forIndexOne);
       
       // For Field  DETAIL.ASS_GSMW_EXT.BS_PACKET.TRANSPARENCY_INDICATOR of type Integer
       temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_TRANSPARENCY_INDICATOR = 
         edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.TRANSPARENCY_INDICATOR,0, forIndexOne);
 
       // For Field  DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_END_TIMESTAMP of type Date
       temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_CHARGING_END_TIMESTAMP = 
         edrDate(DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_END_TIMESTAMP,0, forIndexOne);
 
       //Loop through DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET
       indexTwo = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET, 0, forIndexOne);
       for(forIndexTwo = 0 ; forIndexTwo < indexTwo; forIndexTwo = forIndexTwo + 1 )
       {
         //Loop through DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST
         indexThree = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST, 0, forIndexOne, forIndexTwo);
         for(forIndexThree = 0 ; forIndexThree < indexThree; forIndexThree = forIndexThree + 1)
         {
           // For Field  DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.AIUR of type Integer
           temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_HSCSD_INFO_PACKET_PM_LIST_AIUR =
             edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.AIUR,
                     0, forIndexOne, forIndexTwo, forIndexThree);
           
           // For Field  DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.MAX_NUMBER_OF_CHANNELS of type Integer
           temp_DETAIL_ASS_GSMW_EXT_BS_PACKET_HSCSD_INFO_PACKET_PM_LIST_MAX_NUMBER_OF_CHANNELS =
             edrLong(DETAIL.ASS_GSMW_EXT.BS_PACKET.HSCSD_INFO_PACKET.PM_LIST.MAX_NUMBER_OF_CHANNELS,
                     0, forIndexOne, forIndexTwo, forIndexThree);
         }
      
       }
     }
 
     //Loop through DETAIL.ASS_GSMW_EXT.SS_PACKET
     indexOne = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.SS_PACKET, 0);
     for(forIndexOne = 0; forIndexOne < indexOne; forIndexOne = forIndexOne + 1 )
     {
       // For Field  DETAIL.ASS_GSMW_EXT.SS_PACKET.CHARGING_END_TIMESTAMP of type Date
       temp_DETAIL_ASS_GSMW_EXT_SS_PACKET_CHARGING_END_TIMESTAMP = 
         edrDate(DETAIL.ASS_GSMW_EXT.SS_PACKET.CHARGING_END_TIMESTAMP,0, forIndexOne);
 
       // For Field  DETAIL.ASS_GSMW_EXT.SS_PACKET.CHARGING_START_TIMESTAMP of type Date
       temp_DETAIL_ASS_GSMW_EXT_SS_PACKET_CHARGING_START_TIMESTAMP = 
         edrDate(DETAIL.ASS_GSMW_EXT.SS_PACKET.CHARGING_START_TIMESTAMP,0, forIndexOne);
 
       // For Field  DETAIL.ASS_GSMW_EXT.SS_PACKET.CLIR_INDICATOR of type Integer
       temp_DETAIL_ASS_GSMW_EXT_SS_PACKET_CLIR_INDICATOR = 
         edrLong(DETAIL.ASS_GSMW_EXT.SS_PACKET.CLIR_INDICATOR,0, forIndexOne);
     }
 
 
     // For Field  DETAIL.ASS_LOCN_EXT.REC_ENTITY_CODE of type Integer
     temp_DETAIL_ASS_LOCN_EXT_REC_ENTITY_CODE = 
       edrLong(DETAIL.ASS_LOCN_EXT.REC_ENTITY_CODE,0);
     
     //Loop through DETAIL.ASS_LOCN_EXT.SERVICE_USAGE
     indexOne = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE, 0);
     for(forIndexOne = 0; forIndexOne < indexOne; forIndexOne = forIndexOne + 1 )
     {
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.DEL_TRACKING_FREQUENCY of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_DEL_TRACKING_FREQUENCY = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.DEL_TRACKING_FREQUENCY,0, forIndexOne);
 
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.DEL_TRACKING_PERIOD of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_DEL_TRACKING_PERIOD = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.DEL_TRACKING_PERIOD,0, forIndexOne);
       
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.H_ACCURACY_DELIVERED  of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_H_ACCURACY_DELIVERED = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.H_ACCURACY_DELIVERED,0, forIndexOne);
 
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.H_ACCURACY_REQUESTED  of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_H_ACCURACY_REQUESTED = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.H_ACCURACY_REQUESTED,0, forIndexOne);
 
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.REQ_TRACKING_FREQUENCY of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_REQ_TRACKING_FREQUENCY = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.REQ_TRACKING_FREQUENCY,0, forIndexOne);
 
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.TRACKING_PERIOD of type Integer       
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_TRACKING_PERIOD = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.TRACKING_PERIOD,0, forIndexOne);
 
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.V_ACCURACY_DELIVERED of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_V_ACCURACY_DELIVERED = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.V_ACCURACY_DELIVERED,0, forIndexOne);
 
       // For Field  DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.V_ACCURACY_REQUESTED of type Integer
       temp_DETAIL_ASS_LOCN_EXT_SERVICE_USAGE_V_ACCURACY_REQUESTED = 
         edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.V_ACCURACY_REQUESTED,0, forIndexOne);
     }
 
     //Loop through DETAIL.ASS_GPRS_EXT.GS_PACKET
     indexOne = edrNumDatablocks(DETAIL.ASS_GPRS_EXT.GS_PACKET, 0);
     for(forIndexOne = 0; forIndexOne < indexOne; forIndexOne = forIndexOne + 1 )
     {
       // For Field  DETAIL.ASS_GPRS_EXT.GS_PACKET.CHARGING_END_TIMESTAMP of type Date
       temp_DETAIL_ASS_GPRS_EXT_GS_PACKET_CHARGING_END_TIMESTAMP = 
         edrDate(DETAIL.ASS_GPRS_EXT.GS_PACKET.CHARGING_END_TIMESTAMP,0, forIndexOne);
     }
 
     // For Field  DETAIL.ASS_VAS_EXT.CHARGING_START_TIMESTAMP of type Date
     temp_DETAIL_ASS_VAS_EXT_CHARGING_START_TIMESTAMP = 
             edrDate(DETAIL.ASS_VAS_EXT.CHARGING_START_TIMESTAMP,0) ;
 
     // For Field  DETAIL.ASS_VAS_EXT.CHARGING_END_TIMESTAMP of type Date
     temp_DETAIL_ASS_VAS_EXT_CHARGING_END_TIMESTAMP = 
             edrDate(DETAIL.ASS_VAS_EXT.CHARGING_END_TIMESTAMP,0) ;
         
} //End of tempEDRFieldsAccess

//----------------------------------------------------------------------------
// This function checks for EDR error and set the EDR to be invalid
//----------------------------------------------------------------------------
function checkEdrErrors
{
 
  if (debug)
  {
    logStdout("checkEdrErrors \n");
  }

  Long i = 0;
  for ( i = 0; i < edrNumErrors() ; i = i+1 )
  {
    if (edrGetError(i) == "ERR_TAP3_RET" and edrGetErrorSeverity(i) >= LOG_MINOR)
    {
        edrSetIsValidDetail(false);
    }
  }
}


function onHeaderEdr
{

  theAbsoluteAmountMultilier = 1.0;

  if( edrInternalState(HEADER.TAP_DECIMAL_PLACES) != STATE_CLEARED and edrInputState(HEADER.TAP_DECIMAL_PLACES) != MISSING )
  {
     Long tapDecimal = edrLong(HEADER.TAP_DECIMAL_PLACES);
     Long i;
     if( tapDecimal >= 0 and tapDecimal <= 6 )
     {
       for (i=0 ; i < tapDecimal ; i=i+1)
       {
         theAbsoluteAmountMultilier = theAbsoluteAmountMultilier * 10.0;
       }
     }
  }
  else
  {
    theAbsoluteAmountMultilier = 1.0;
  }

} // end onHeaderEdr

//==============================================================================
// Process Detail EDR record
//==============================================================================
function onDetailEdr
{
  //----------------------------------------------------------------------------
  // initialize global variables
  //----------------------------------------------------------------------------
  init();

  //----------------------------------------------------------------------------
  // Validate the Detail record.
  //----------------------------------------------------------------------------
  validateDetailRecord();

  //----------------------------------------------------------------------------
  // Access the fields that were not accessed earlier to validate their data 
  // type as pipeline framework does lazy validation.
  //----------------------------------------------------------------------------
  tempEDRFieldsAccess();

  //----------------------------------------------------------------------------
  // Check the Detail record errors and set the EDR to be invalid.
  //----------------------------------------------------------------------------
  if ( edrIsValidDetail() == true ) 
  { 
    checkEdrErrors();
  }
	
} // end onDetailEdr

function onInvalidDetailEdr
{
  //----------------------------------------------------------------------------
  // initialize global variables
  //----------------------------------------------------------------------------
  init();

  //----------------------------------------------------------------------------
  // Validate the Detail record.
  //----------------------------------------------------------------------------
  validateDetailRecord();

  //----------------------------------------------------------------------------
  // Access the fields that were not accessed earlier to validate their data 
  // type as pipeline framework does lazy validation.
  //----------------------------------------------------------------------------
  tempEDRFieldsAccess();
	
} // end onInvalidDetailEdr
