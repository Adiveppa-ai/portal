        setAssociatedTapErr("ERR_TAP3_OOR_QOS_USED_DELAY", LOG_MAJOR ,"20" ,"171" ,"8");	
      }
    }

    if ((edrInputState(
		DETAIL.ASS_GPRS_EXT.GS_PACKET.QOS_REQUESTED_MEAN_THROUGHPUT,
