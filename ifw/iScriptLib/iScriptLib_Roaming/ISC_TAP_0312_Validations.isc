/******************************************************************************************************************************
 * This function will validate NetworkInfo. It will raise error code 30, 33 for NetworkInfo.
 ******************************************************************************************************************************/
 
function validateNetworkInfo ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",6";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "utcTimeOffsetInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateUtcTimeOffsetInfoList ( myContext, nMyIndices, "utcTimeOffsetInfo", 0, errorContext );
  }
  else
  {
    rollbackReason = "TransferBatch," + errorContext + ",30";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "NetworkInfo", "6", "30", "Mandatory group UTC Time Offset Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "6", "0", "-1", "-1", "","Mandatory group UTC Time Offset Information missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }    
 
  childContext = myContext + "." + "recEntityInfo";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateRecEntityInfoList ( myContext, nMyIndices, "recEntityInfo", 0, errorContext );
  }
  else
  {
    
    rollbackReason = "TransferBatch," + errorContext + ",33";
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "NetworkInfo", "6", "33", "Group Recording Entity Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "6", "0", "-1", "-1", "","Group Recording Entity Information missing within group");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate TapDecimalPlaces. It will raise error code 20 for TapDecimalPlaces.
 ******************************************************************************************************************************/
 
function validateTapDecimalPlaces ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",244";

  if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"6" , "0", "INTEGER_TYPE") == true )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",10" + ":" + AccountingInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TapDecimalPlaces", "244", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "244", "0", "-1", "-1","", "Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
    edrLongEx( myContext, indices, nParentIndices ) = -1;
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function is used to store the exchange rate value into exchangeRate array.
 ******************************************************************************************************************************/
 
function validateExchangeRate ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",104";

  tmpExchangeRate = edrLongEx(myContext, indices, nParentIndices);
  if( hasDupExchangeRateCodeEntries == false )
  {
    exchangeRate[lastCode] = tmpExchangeRate;
  }
  
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate NumberOfDecimalPlaces. It will raise error code 20 for NumberOfDecimalPlaces.
 ******************************************************************************************************************************/
 
function validateNumberOfDecimalPlaces ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",159";

  if( edrLongEx(myContext, indices, nParentIndices) < 0 )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",20" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "NumberOfDecimalPlaces", "159", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "159", "0", "-1", "-1","", "Value Out Of Range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  
  if( edrLongEx(myContext, indices, nParentIndices) > 26 )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",10" + ":" + AccountingInfoStr;
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "NumberOfDecimalPlaces", "159", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "159", "0", "-1", "-1", "","Syntax Error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
    edrLongEx(myContext, indices, nParentIndices) = -1;
    return;
  }
  
  tmpNumberOfDecimalPlaces = edrLongEx(myContext, indices, nParentIndices);
  if ( hasDupExchangeRateCodeEntries == false )
  {
    numberOfDecimalPlaces[lastCode] = tmpNumberOfDecimalPlaces;
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate CurrencyConversion. It will raise error code 30, 31, 32, 33, 34 for CurrencyConversion.
 ******************************************************************************************************************************/
 
function validateCurrencyConversion ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",106";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

 
  childContext = myContext + "." + "exchangeRateCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateExchangeRateCode ( myContext, nMyIndices, "exchangeRateCode", 0, errorContext );
  }
  else    
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",30" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CurrencyConversion", "106", "30", "Missing Exchange Rate Code"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "30", "106", "0", "-1", "-1", "","Missing Exchange Rate Code");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "numberOfDecimalPlaces";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateNumberOfDecimalPlaces ( myContext, nMyIndices, "numberOfDecimalPlaces", 0, errorContext );
  }
  else    
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",31" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CurrencyConversion", "106", "31", "Missing Number Of Decimal Places"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "31", "106", "0", "-1", "-1","", "Missing Number Of Decimal Places");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

 
  childContext = myContext + "." + "exchangeRate";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateExchangeRate ( myContext, nMyIndices, "exchangeRate", 0, errorContext );
  }
  else    
  {
    rollbackReason   = "AccountingInfo," +  errorContext + ",32" + ":" + AccountingInfoStr;

    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CurrencyConversion", "106", "32", "Missing Exchange Rate"); 
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "32", "106", "0", "-1", "-1", "","Missing Exchange Rate");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  
  if( hasDupExchangeRateCodeEntries == true ) 
  {
    if( numberOfDecimalPlaces[lastCode] == tmpNumberOfDecimalPlaces and exchangeRate[lastCode] == tmpExchangeRate )
    {
      rollbackReason   = "AccountingInfo," +  errorContext + ",34" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CurrencyConversion", "106", "34", "duplicate Currency Conversion table entry");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "34", "106", "0", "-1", "-1","", "duplicate Currency Conversion table entry");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
    else
    {
      rollbackReason   = "AccountingInfo," +  errorContext + ",34" + ":" + AccountingInfoStr;

      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "CurrencyConversion", "106", "33",
     "More than one occurrence of group with same ExchangeRateCode where NumOfDecimal Places and/or ExchangeRate are not the same");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "33", "106", "0", "-1", "-1","",
     "More than one occurrence of group with same ExchangeRateCode where NumOfDecimal Places and/or ExchangeRate are not the same");
      edrDemandRollback(rollbackReason);
      edrSetIsValidDetail(false);
    }
  }

  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateCurrencyConversion for each element of Currency Conversion List.
 ******************************************************************************************************************************/
 
function validateCurrencyConversionList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",80";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "CurrencyConversion";
  Long CurrencyConversionListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < CurrencyConversionListEntries; i = i + 1 )
  {
    validateCurrencyConversion ( myContext, nMyIndices, "CurrencyConversion", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate TapCurrency. It will raise error code 10, 20 for TapCurrency.
 ******************************************************************************************************************************/
 
function validateTapCurrency ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",210";
  Long   i;
  Bool   currencyPresent = false;
  
  for( i = 0 ; i < numOfCurrencyCode and currencyPresent == false ; i = i + 1 )
  {
    if( edrStringEx(myContext, indices, nParentIndices) == currencyCode[i] )
    {
      currencyPresent = true;
    }
  }
  
  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_ALPHA_UPPER") == true or 
        strLength(edrStringEx(myContext, indices, nParentIndices)) != 3)
  {
    rollbackReason = "AccountingInfo," + errorContext + ",10" + ":" + AccountingInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TapCurrency", "210", "10", "Syntax error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "10", "210", "0", "-1", "-1", "","Syntax error");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }
  else if( currencyPresent == false )
  {
    rollbackReason = "AccountingInfo," + errorContext + ",20" + ":" + AccountingInfoStr; 
    edrAddError("ERR_TAP3_FATAL", LOG_MAJOR, "TapCurrency", "210", "20", "Value out of range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "fatal", "20", "210", "0", "-1", "-1","", "Value out of range");
    edrDemandRollback(rollbackReason);
    edrSetIsValidDetail(false);
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

