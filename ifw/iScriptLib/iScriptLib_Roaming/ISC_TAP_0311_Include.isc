function mapCellId ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  String strVal = longToStr(edrLongEx( myContext, indices, nParentIndices ));
  String nullFiller = buildNullFiller(5, strLength(strVal));
  if ( strStartsWith ( parentContext, "DETAIL.gprsCall" ) == true )
  {
    if (nullFiller != "")
    {
      edrString(DETAIL.ASS_GPRS_EXT.CELL_ID, 0) = strReplace(strVal, 0, 0, nullFiller);
    }
    else
    {
      edrString(DETAIL.ASS_GPRS_EXT.CELL_ID, 0) = strVal;
    }
  }
  else
  {
    if (nullFiller != "")
    {
      edrString(DETAIL.ASS_GSMW_EXT.CELL_ID, 0) = strReplace(strVal, 0, 0, nullFiller);
    }
    else
    {
      edrString(DETAIL.ASS_GSMW_EXT.CELL_ID, 0) = strVal;
    }
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
