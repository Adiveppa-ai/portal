//------------------------------------------------------------------------------
// validateProviderTypeandId()
//
// This function will be used to validate the content provider type and ID
//------------------------------------------------------------------------------
function validateProviderTypeandId(Long recordType)
{
  if (debug)
  {
    logStdout("validateProviderTypeandId\n");
  }

  Long typeID;
  Long blockIndex;
  Long blockEntries;
  String offset;

  if (recordType == 70)
  {
    blockEntries = edrNumDatablocks(DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST, 0, 0);
  }
  else
  {
    blockEntries = edrNumDatablocks(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST, 0, 0);
  }

  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    if (recordType == 70)
    {
      if ((edrInputState(DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST.TYPE,
					0, 0, blockIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST.TYPE,
	//	0, 0, blockIndex));
	offset = "-1";
	edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "30", "327", "5",
		offset, longToStr(blockIndex), "Missing Content Provider Type");
        setAssociatedTapErr("ERR_TAP3_MISSING_CONTENT_PROVIDER_TYPE", LOG_WARNING ,"30" ,"327" ,"5");	
      }
      else
      {
	typeID = edrLong(DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST.TYPE,
						0, 0, blockIndex);
	if ((typeID < 1) or (typeID > 5))
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST.TYPE,
	  //	0, 0, blockIndex));
	  offset = "-1";
	  edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "20", "291", "6",
		offset, longToStr(blockIndex), "Out Of Range Content Provider Type");
          setAssociatedTapErr("ERR_TAP3_OOR_CONTENT_PROVIDER_TYPE", LOG_WARNING ,"20" ,"291" ,"6");	
	}
      }

      if ((edrInputState(DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST.IDENTIFIER,
					0, 0, blockIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_CONT_EXT.SERVING_PARTIES_INFO.PROVIDER_LIST.IDENTIFIER,
	//	0, 0, blockIndex));
	offset = "-1";
	edrAddError("ERR_TAP3_RET", LOG_WARNING, "warning", "31", "327", "5",
		offset, longToStr(blockIndex), "Missing Content Provider Identifier");
        setAssociatedTapErr("ERR_TAP3_MISSING_CONTENT_PROVIDER_ID", LOG_WARNING ,"31" ,"327" ,"5");	
      }
    }
    else if (recordType == 80)
    {
      if ((edrInputState(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.TYPE,
					0, 0, blockIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.TYPE,
	//	0, 0, blockIndex));
	offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", "375", "5",
		offset, longToStr(blockIndex), "Missing LCS Content Provider Type");
        setAssociatedTapErr("ERR_TAP3_MISSING_LSC_CONTENT_PROVIDER_TYPE", LOG_MAJOR ,"30" ,"375" ,"5");	
      }
      else
      {
	typeID = edrLong(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.TYPE,
						0, 0, blockIndex);
	if ((typeID < 1) or (typeID > 5))
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //	DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.TYPE,
	  //	0, 0, blockIndex));
	  offset = "-1";
	  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "21", "291", "6",
		offset, longToStr(blockIndex), "Out Of Range LCS Content Provider Type");
          setAssociatedTapErr("ERR_TAP3_OOR_LSC_CONTENT_PROVIDER_TYPE", LOG_MAJOR ,"21" ,"291" ,"6");	
	}
      }

      if ((edrInputState(DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.IDENTIFIER,
					0, 0, blockIndex)) == MISSING)
      {
	// offset = longToStr(edrFieldTokenBytePos(
	//	DETAIL.ASS_LOCN_EXT.LCSSP_INFO.ID_LIST.IDENTIFIER,
	//	0, 0, blockIndex));
	offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
	edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", "375", "5",
		offset, longToStr(blockIndex), "Missing LCS Content Provider Identifier");
        setAssociatedTapErr("ERR_TAP3_MISSING_LSC_CONTENT_PROVIDER_ID", LOG_MAJOR ,"31" ,"375" ,"5");	
      }
    }
  }
}


