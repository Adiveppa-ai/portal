/******************************************************************************************************************************
 * This function will validate GeographicalLocation. It will raise error code 30 for GeographicalLocation.
 ******************************************************************************************************************************/
 
function validateGeographicalLocation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",113";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
  Bool servingBidIsPresent = false;
  servingLocationDescriptionIsMissing = false;
 
  childContext = myContext + "." + "servingNetwork";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateServingNetwork ( myContext, nMyIndices, "servingNetwork", 0, errorContext );
  }
 
  childContext = myContext + "." + "servingBid";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    servingBidIsPresent = true;
    validateServingBid ( myContext, nMyIndices, "servingBid", 0, errorContext );
  }
 
  childContext = myContext + "." + "servingLocationDescription";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateServingLocationDescription ( myContext, nMyIndices, "servingLocationDescription", 0, errorContext );
  }
  else
  {
    if( servingBidIsPresent == true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Geographical Location", "113", "30",
                                      "Item Serving Location Description is not present and Serving BID is present within group");
    }

    servingLocationDescriptionIsMissing = true;
  }
  //logContext( myContext, nMyIndices );
}
 
