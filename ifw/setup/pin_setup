use functions;
#open the logfile#
functions::createlog();
#load the config parameters#
functions::configinit(%Configvar);
functions::LoadSteps();
my $zeroprog="pin_setup"; #make it simple for now
$masterdir= functions::returnval("MasterDir");
my $fullargs=join(" ",@ARGV); #save for posterity
my $dotee=1;
my $userdie=0;
if(functions::ostype ne "Windows") {
  chomp( $ENV{"CFGpipeline_hostname"} = `/bin/hostname 2>/dev/null` ) unless exists $ENV{"CFGpipeline_hostname"};
}
else
{
  chomp( $ENV{"CFGpipeline_hostname"} = `hostname` ) unless exists $ENV{"CFGpipeline_hostname"};
}
my @timedate=localtime();
my $dts;
#($sec,$min,$hour,$mday,$mon,$year,$wday,$yday,$isdst)
$ENV{'CFGpipeline_dts'}=$dts=sprintf("%02d%02d%02d%02d%02d%02d",
  $timedate[5] % 100, #two year date
  1+$timedate[4], #month
  $timedate[3], #day of month
  $timedate[2],$timedate[1],$timedate[0], #HMS
  );


################################################################################################

my $pipelineos=${{ "hpux" => "HPUX", "solaris" => "Solaris", "aix" => "aix", "windows" => "Windows", }}{$^O};
$pipelineos="Solaris" if $ifwos eq ""; #darn demos! well, actually, this lets me do printouts on linux...

$ENV{'CFGpipeline_OSLIBEXT'}=${{ "hpux" => "sl", "solaris" => "so", "aix" => "so", "windows" => "dll", }}{$^O};
while( @ARGV ){
# IFW install args
   my $clarg=shift;
    if($clarg eq "-recover_last")
      {$recover_last=1;next;}
    if( $clarg eq "-runone" ){
    $runone=1;
    $RunStep=shift;
    next;
    }
    #general
  if( $clarg eq "-notee" ){
    $dotee=0;
    next;
    }

  #default & drop-out.
  print "$zeroprog:  bad argument \"$clarg\"\n" unless $clarg eq "--help" || $clarg eq "-h";
############# HELP ########## HELP ########## HELP ########## HELP #############
  print <<FEOF;

syntax:  $INT_HOME/setup/$zeroprog  [OPTIONS]
version: $version

general options:
  -h   --help                     : show this help
  -notee                          : do not display running log to screen

install modes:
  -recover_last                   : restart pipeline setup at last point
  -runone STEPNAME                : execute a single step or file

FEOF
  
  print <<FEOF;


FEOF
############# END  ########## END  ########## END  ########## END  #############
  exit 33;
}


