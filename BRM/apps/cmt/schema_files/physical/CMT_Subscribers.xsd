			<xs:element name="VldTo" type="dateTime-or-zero" minOccurs="0" maxOccurs="1"/> 
                        <xs:element name="Status" type="xs:string" minOccurs="0" maxOccurs="1"/>
		</xs:sequence>
	 	<xs:attribute name="id" type="xs:string" use="required"/>
