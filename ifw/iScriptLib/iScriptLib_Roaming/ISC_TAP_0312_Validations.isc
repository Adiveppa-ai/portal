/******************************************************************************************************************************
 * This function calls the validation functions validateLocalTimeStamp and validateUtcTimeOffsetCode.
 ******************************************************************************************************************************/

function validateActualDeliveryTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",302";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else    
  { 
    actualDeliveryUtcTimeOffsetCodeIsMissing = true;
  }
  endLocalTimeStamp = addUTCToLocalTimestamp( endLocalTimeStamp, endUTCTimeOffset);

  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation functions validateLocalTimeStamp and validateUtcTimeOffsetCode.
 ******************************************************************************************************************************/

function validateRequestedDeliveryTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",301";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else
  {
    requestedDeliveryUtcTimeOffsetCodeIsMissing = true;
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation functions validateLocalTimeStamp and validateUtcTimeOffsetCode.
 ******************************************************************************************************************************/
 
function validateOrderPlacedTimeStamp ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",300";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "localTimeStamp";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocalTimeStamp ( myContext, nMyIndices, "localTimeStamp", 0, errorContext );
  }
 
  childContext = myContext + "." + "utcTimeOffsetCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateUtcTimeOffsetCode ( myContext, nMyIndices, "utcTimeOffsetCode", 0, errorContext );
  }
  else
