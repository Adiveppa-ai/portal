  {
    validateScuBasicInformation ( myContext, nMyIndices, "basicInformation", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ServiceCentreUsage", "12", "30", "Mandatory group SCU Basic Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory group SCU Basic Information missing within group");
    edrSetIsValidDetail(false);
