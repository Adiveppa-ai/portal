function mapRapFileSequenceNumber ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( parentContext == "HEADER.acknowledgement" or
       parentContext == "HEADER.rapBatchControlInfoRap" )
  {
    edrLong(HEADER.SEQUENCE_NUMBER) = strToLong(edrStringEx( myContext, indices, nParentIndices ));
    headerRapFileSeqNo = edrLong(HEADER.SEQUENCE_NUMBER);
  }
  else if ( processingMode == RAPIN )
  {
    edrString(DETAIL.RAP_FILE_SEQ_NO) = edrStringEx( myContext, indices, nParentIndices );
  }
  else
  {
    if ( strStartsWith ( parentContext, "DETAIL" ) == true )
    {
      edrLong(DETAIL.ASS_ROAMING_EXT.RAP_FILE_SEQ_NO, 0) = strToLong(edrStringEx( myContext, indices, nParentIndices ));
    }
    else if ( strStartsWith ( parentContext, "HEADER" ) == true )
    {
      edrString(HEADER.RAP_FILE_SEQ_NO) = edrStringEx( myContext, indices, nParentIndices );
      theRapFileSeqNum = strToLong(edrString(HEADER.RAP_FILE_SEQ_NO));
    }
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapFileSequenceNumber ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
                                                                                                             
  if ( myContext == "HEADER.notification.fileSequenceNumber" or
       myContext == "HEADER.batchControlInfo.fileSequenceNumber" )
  {
    theFileSeqNum     = strToLong( edrStringEx( myContext, indices, nParentIndices ));
    theOrigFileSeqNum = theFileSeqNum;
    edrLong(HEADER.SEQUENCE_NUMBER)        = theFileSeqNum;
    edrLong(HEADER.ORIGIN_SEQUENCE_NUMBER) = theOrigFileSeqNum;
    toReturn_TapSeqNum = longToStr(theFileSeqNum); // was there only for batchControlInfo
  }
  else if ( strEndsWith (parentContext, "severeReturn") == true )
  {
    theFileSeqNum = strToLong( edrStringEx( myContext, indices, nParentIndices ));
    edrLong(DETAIL.ASS_ROAMING_EXT.TAP_FILE_SEQ_NO, 0) = theFileSeqNum;

    reg_TapHeaderInfoFilePath = reg_TapIOModule + ".TapHeaderInfoFilePath";
    reg_TapHeaderInfoFilePrefix = reg_TapIOModule + ".TapHeaderInfoFilePrefix";
    reg_TapHeaderInfoFileSuffix = reg_TapIOModule + ".TapHeaderInfoFileSuffix";
    reg_TapHeaderInfoFieldSep   = reg_TapIOModule + ".TapHeaderInfoFieldSep";

    strTapHeaderInfoFilePath = regString(reg_TapHeaderInfoFilePath);
    strTapHeaderInfoFilePrefix = regString(reg_TapHeaderInfoFilePrefix);
    strTapHeaderInfoFileSuffix = regString(reg_TapHeaderInfoFileSuffix);
    strTapHeaderInfoFieldSep   = regString(reg_TapHeaderInfoFieldSep);

    if ( strTapHeaderInfoFilePath != "" )
    {
      loadRejectedTAPHeaderInfo();
    }
  }
  else if ( strEndsWith (parentContext, "fatalReturn") == true )
  {
    theFileSeqNum = strToLong( edrStringEx( myContext, indices, nParentIndices ));
    edrLong(DETAIL.ASS_ROAMING_EXT.TAP_FILE_SEQ_NO, 0) = theFileSeqNum;
  }

  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapRecipient ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          
                                                                                                             
  if ( myContext == "HEADER.notification.recipient" or
       myContext == "HEADER.batchControlInfo.recipient" )
  {
    theRecipient = edrStringEx ( myContext, indices, nParentIndices );
    edrString(HEADER.RECIPIENT) = theRecipient;
  }
  else if ( myContext == "HEADER.acknowledgement.recipient" or
            myContext == "HEADER.rapBatchControlInfoRap.recipient" )
  {
    edrString(HEADER.RECIPIENT) = edrStringEx ( myContext, indices, nParentIndices );
    headerRecipient = edrString(HEADER.RECIPIENT);
  }

  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapSender ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( myContext == "HEADER.notification.sender" or
       myContext == "HEADER.batchControlInfo.sender" )
  {
    theSender = edrStringEx ( myContext, indices, nParentIndices );
    edrString(HEADER.SENDER) = theSender;

    if (strCheckSequencer != "")
    {
      edrString(HEADER.SEQ_CHECK_KEY) = theSender;
    }

    if (strToUpper(strUseSenderAsSeqGenKey) == "TRUE")
    {
      edrString(HEADER.SEQ_GEN_KEY) = theSender;
    }
  }
  else if ( myContext == "HEADER.acknowledgement.sender" or
            myContext == "HEADER.rapBatchControlInfoRap.sender" )
  {
    edrString(HEADER.SENDER) = edrStringEx ( myContext, indices, nParentIndices );
    headerSender = edrString(HEADER.SENDER);
  }

                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapNotification ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( myContext != "HEADER.notification" )
  {
    return;
  }
                                                                                                             
  childContext = myContext + "." + "sender";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSender ( myContext, nMyIndices, "sender", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "recipient";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRecipient ( myContext, nMyIndices, "recipient", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFileSequenceNumber ( myContext, nMyIndices, "fileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "rapFileSequenceNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileCreationTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapFileCreationTimeStamp ( myContext, nMyIndices, "fileCreationTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileAvailableTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapFileAvailableTimeStamp ( myContext, nMyIndices, "fileAvailableTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "transferCutOffTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTransferCutOffTimeStamp ( myContext, nMyIndices, "transferCutOffTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "specificationVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapSpecificationVersionNumber ( myContext, nMyIndices, "specificationVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "releaseVersionNumber";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapReleaseVersionNumber ( myContext, nMyIndices, "releaseVersionNumber", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "fileTypeIndicator";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapFileTypeIndicator ( myContext, nMyIndices, "fileTypeIndicator", 0 );                               
  }                                                                                                          
  else
  {
    theFileTypeIndicator = "";
  }
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
