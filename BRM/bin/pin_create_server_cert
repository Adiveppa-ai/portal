#!/bin/sh
#
# $Header: common_vob/common_platform/pcm_pcp/ssl_wallets/server/pin_create_server_cert.sh /cgbubrm_mainbrm.portalbase/1 2017/10/06 05:23:27 anirbisw Exp $
