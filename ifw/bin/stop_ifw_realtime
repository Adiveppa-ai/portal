#!/bin/sh

INT_HOME=$IFW_HOME
IFW_EVENTHANDLER_PORT=$IFWRT_EVENTHANDLER_PORT
export IFW_EVENTHANDLER_PORT
for aa in \
        conf/wirelessRealtime.reg  \
        ; do
  if [ -r "$INT_HOME/$aa" ] ; then
    IFW_REGFILE="$aa"
    break
  fi
done
export IFW_REGFILE
IFW_SEMFILE="$INT_HOME/semaphore/semaphoreRT.reg"
export IFW_SEMFILE

$INT_HOME/bin/stop_ifw

