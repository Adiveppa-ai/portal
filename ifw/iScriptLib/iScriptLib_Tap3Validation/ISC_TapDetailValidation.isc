//------------------------------------------------------------------------------
// validateCallEventStartTime()
//
// This function will be used to validate the call event start time
//------------------------------------------------------------------------------
function validateCallEventStartTime
{
  if (debug)
  {
    logStdout("validateCallEventStartTime()\n");
  }

  Long blockIndex;
  Long packetIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_CBD);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Long packetEntries= edrNumDatablocks(DETAIL.ASS_CBD.CP, blockIndex);

    for (packetIndex = 0; packetIndex < packetEntries; packetIndex = packetIndex + 1)
    {
      Date chargeDate = edrDate(DETAIL.ASS_CBD.CP.CHARGING_START_TIMESTAMP,
				blockIndex, packetIndex);
      if (dateIsValid(chargeDate))
      {
	if (dateDiff(chargeDate, edrDate(DETAIL.CHARGING_START_TIMESTAMP)) < 0)
	{
	  // offset = longToStr(edrFieldTokenBytePos(
	  //		DETAIL.CHARGING_START_TIMESTAMP));
	  offset = "-1";
	  edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
	  edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "44", "5",
		offset, "-1", "Call event start time after charge detail start time ");
          setAssociatedTapErr("ERR_TAP3_CALL_EVENT_TIME_MISMATCH", LOG_MAJOR ,"100" ,"44" ,"5");	
        }
      }
    }
  }
}

function validateLcsChargingTimeStamp
{
  if (edrNumDatablocks(DETAIL.ASS_LOCN_EXT) > 0 and
      edrNumDatablocks(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE, 0) > 0)
  {
    if (dateIsValid(edrDate(DETAIL.CHARGING_START_TIMESTAMP)) == true and
        edrInputState(DETAIL.CHARGING_START_TIMESTAMP) != EDR_INPUT_MISSING and
        edrInternalState(DETAIL.CHARGING_START_TIMESTAMP) != STATE_CLEARED)
    {
      if (edrInputState(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0) != EDR_INPUT_MISSING and
          edrInternalState(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0) != STATE_CLEARED)
      {
        Date tmpDate = edrDate(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQUEST_TIMESTAMP, 0, 0);

        if (edrInputState(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.RESPONSE_TIME, 0, 0) != EDR_INPUT_MISSING and
            edrInternalState(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.RESPONSE_TIME, 0, 0) != STATE_CLEARED)
        {
          dateAdd(tmpDate, 0, 0, 0, 0, 0, edrLong(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.RESPONSE_TIME, 0, 0));
        }

        if (dateDiff(tmpDate, edrDate(DETAIL.CHARGING_START_TIMESTAMP)) < 0)
        {
          edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
          edrSetIsValidDetail(false);
          edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", "74", "5",
                      "-1", "-1", "Charging timestamp greater than LCSRequestTimeStamp plus ResponseTime.");
          setAssociatedTapErr("ERR_TAP3_CHARGING_TIMESTAMP_GT_LCSREQUEST_TIMESTAMP", LOG_MAJOR ,"101" ,"74" ,"5");	
        }
      }
    }
  }
} 


//------------------------------------------------------------------------------
// validateChargingTimeStamp()
//
// This function will be used to validate the charging timestamp
//------------------------------------------------------------------------------
function validateChargingTimeStamp
{
  if (debug)
  {
    logStdout("validateChargingTimeStamp()\n");
  }

  Long blockIndex;
  Long blockEntries;
  String offset;

  blockEntries = edrNumDatablocks(DETAIL.ASS_GSMW_EXT.BS_PACKET, 0);
  for (blockIndex = 0; blockIndex < blockEntries; blockIndex = (blockIndex + 1))
  {
    Date chargeDate = edrDate(
	DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_START_TIMESTAMP, 0, blockIndex);
    if (dateIsValid(chargeDate))
    {
      if (dateDiff(chargeDate, edrDate(DETAIL.CHARGING_START_TIMESTAMP)) < 0)
      {
        // offset = longToStr(edrFieldTokenBytePos(
        //	DETAIL.CHARGING_START_TIMESTAMP));
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "101", "44", "5",
		offset, "-1", "Call event start time after charging timestamp ");
        setAssociatedTapErr("ERR_TAP3_CALL_EVENT_TIMESTAMP_MISMATCH", LOG_MAJOR ,"101" ,"44" ,"5");	
      }

      Long diff_Date = dateDiff(chargeDate, edrDate(DETAIL.CHARGING_START_TIMESTAMP));
      Long callDuration = edrLong(DETAIL.TOTAL_CALL_EVENT_DURATION);
      if (diff_Date > callDuration)
      {
        // offset = longToStr(edrFieldTokenBytePos(
        //	DETAIL.ASS_GSMW_EXT.BS_PACKET.CHARGING_START_TIMESTAMP,
        //	0, blockIndex));
        offset = "-1";
        edrString(DETAIL.ERROR_REJECT_TYPE) = "ERR_TAP3_RET";
        edrSetIsValidDetail(false);
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", "74", "5",
		offset, "-1", "Charging timestamp greater than call event end time ");
        setAssociatedTapErr("ERR_TAP3_CHARGING_TIMESTAMP_GT_CALL_EVENT_END_TIME", LOG_MAJOR ,"100" ,"74" ,"5");	

      }
    }
  }
}


