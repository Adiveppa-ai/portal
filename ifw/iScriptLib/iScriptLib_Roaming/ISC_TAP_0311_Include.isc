function mapLCSQosRequested ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "lCSRequestTimestamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLCSRequestTimestamp ( myContext, nMyIndices, "lCSRequestTimestamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "horizontalAccuracyRequested";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapHorizontalAccuracyRequested ( myContext, nMyIndices, "horizontalAccuracyRequested", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "verticalAccuracyRequested";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapVerticalAccuracyRequested ( myContext, nMyIndices, "verticalAccuracyRequested", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "responseTimeCategory";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapResponseTimeCategory ( myContext, nMyIndices, "responseTimeCategory", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "trackingPeriod";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTrackingPeriod ( myContext, nMyIndices, "trackingPeriod", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "trackingFrequency";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTrackingFrequency ( myContext, nMyIndices, "trackingFrequency", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapLocationServiceUsage ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( edrAddDatablock( DETAIL.ASS_LOCN_EXT.SERVICE_USAGE ) == false )
  {
  }
                                                                                                             
  childContext = myContext + "." + "lCSQosRequested";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLCSQosRequested ( myContext, nMyIndices, "lCSQosRequested", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "lCSQosDelivered";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLCSQosDelivered ( myContext, nMyIndices, "lCSQosDelivered", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "chargingTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargingTimeStamp ( myContext, nMyIndices, "chargingTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             

  initializeChargeInfoTempFields();                                                                                                             
  childContext = myContext + "." + "chargeInformationList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapChargeInformationList ( myContext, nMyIndices, "chargeInformationList", 0 );                               
  }                                                                                                          

  storeChargeInfoTempFields();
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapEquipmentId ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith( parentContext, "DETAIL.contentTransaction" ) == true )
  {
    edrString(DETAIL.ASS_CONT_EXT.CHARGED_PARTY_INFO.EQUIPMENT.IDENTIFIER, 0, 0, 0) = edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith( parentContext, "DETAIL.locationService.trackedCustomerInformation" ) == true )
  {
    edrString(DETAIL.ASS_LOCN_EXT.TRACKED_CUST_INFO.EQUIPMENT.IDENTIFIER, 0, 0, 0) = edrStringEx( myContext, indices, nParentIndices );
  }
  else if ( strStartsWith( parentContext, "DETAIL.locationService.trackingCustomerInformation" ) == true )
  {
    edrString(DETAIL.ASS_LOCN_EXT.TRACKING_CUST_INFO.EQUIPMENT.IDENTIFIER, 0, 0, 0) = edrStringEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");                     
}                                                                                                            
                                                                                                             
function mapEquipmentIdType ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith( parentContext, "DETAIL.contentTransaction" ) == true )
  {
