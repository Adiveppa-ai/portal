    validateRecEntityCode ( myContext, nMyIndices, "recEntityCode", 0, errorContext );
  }  
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ServiceCentreUsage", "12", "33", "Mandatory item Recording Entity Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1", "","Mandatory item Recording Entity Code missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "chargeInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeInformation ( myContext, nMyIndices, "chargeInformation", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ServiceCentreUsage", "12", "34", "Mandatory group Charge Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "34", errorContext, "0", "-1", "-1","", "Mandatory group Charge Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "scuChargeType";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateScuChargeType ( myContext, nMyIndices, "scuChargeType", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ServiceCentreUsage", "12", "35", "Mandatory group SCU Charge Type missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", errorContext, "0", "-1", "-1","", "Mandatory group SCU Charge Type missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "scuTimeStamps";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateScuTimeStamps ( myContext, nMyIndices, "scuTimeStamps", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "ServiceCentreUsage", "12", "36", "Mandatory group SCU Timestamps missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "36", errorContext, "0", "-1", "-1","", "Mandatory group SCU Timestamps missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate BearerServiceCode. It will raise error code 10, 11, 20, 21 for BearerServiceCode.
 ******************************************************************************************************************************/
 
function validateBearerServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",40";

  Bool   bearerServiceCodePresent = false;
  String lastBearerServiceCode = edrStringEx(myContext, indices, nParentIndices);
  Long   i;

  if( (validateHexValue(edrStringEx(myContext, indices, nParentIndices)) == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 2) )
  {
    if( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") != true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Bearer Service Code", "40", "10", "Syntax Error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error");
      edrSetIsValidDetail(false);
    }
    else
    {
       edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Bearer Service Code", "40", "11", "Syntax Error");
    }
  }
  else
  {
    for( i = 0 ; i < numOfBearerServiceCode and bearerServiceCodePresent == false ; i = i + 1 )
    {
      if( lastBearerServiceCode == bearerServiceCodeArray[i])
      {
        bearerServiceCodePresent = true;
      }
    }
    if(bearerServiceCodePresent == false)
    {
      if( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") != true )
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Bearer Service Code", "40", "20", "Value Out Of Range");
        edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range");
        edrSetIsValidDetail(false);
      }
      else
      {
        // FieldName, AppId, ErrorCode,ErrorDescription
        edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Bearer Service Code", "40", "21", "Value Out Of Range");
      }
    }
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate TeleServiceCode, MoBasicCallInformation, CalledNumber, Destination and TotalCallEventDuration. 
 * It will raise error code 10, 11, 20, 21 for TeleServiceCode, error code 35 for MoBasicCallInformation, error code 10, 11 for
 * CalledNumber, error code 39, 42 for Destination and error code 100 for TotalCallEventDuration.
 ******************************************************************************************************************************/
 
function validateTeleServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",218";

  Bool codePresent = false;
  Long i;
  String lastTeleServiceCode = edrStringEx(myContext, indices, nParentIndices);

  for( i = 0 ; i < numTeleServiceCode and codePresent == false ; i = i + 1 )
  {
    if( edrStringEx( myContext, indices, nParentIndices ) == TeleServiceCodeArr[i])
    {
      codePresent = true;
    }
  }  
  
  if( (validateHexValue(edrStringEx(myContext, indices, nParentIndices)) == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 2) )
  {
    if ( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") != true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TeleServiceCode", "218", "10", "Syntax error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error"); 
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "TeleServiceCode", "218", "11", "Syntax error");
    }    
  }
  else if ( codePresent == false ) 
  {
    if ( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") != true )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TeleServiceCode", "218", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "TeleServiceCode", "218", "21", "Value out of range");
    }    
  }  
  
  // If Destination field is missing when the call is not an emergency call.
  if( destinationIsMissing == true and lastTeleServiceCode != "12" and
      strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
  {
    objTag = "1,3,9,147";
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MoBasicCallInformation", "147", "35", "Group Destination missing and call is not for use of emergency service");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "35", objTag, "0", "-1", "-1", "","Group Destination missing and call is not for use of emergency service");
    edrSetIsValidDetail(false);
  }
  

  if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true and 
                    calledNumberIsMissing == false )
  {
    if( (validateSyntax(lastCalledNumber, "CHECK_NUM") == true) and lastTeleServiceCode != "12" )
    {
      objTag = "1,3,9,147,89,407";
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Called Number", "407", "10",
                                                "Syntax error and call does not represent an emergency call");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", objTag, "0", "-1", "-1", "",
                                                "Syntax error and call does not represent an emergency call");
      edrSetIsValidDetail(false);
    }
    else if( (validateSyntax(lastCalledNumber, "CHECK_NUM") == true) and lastTeleServiceCode == "12" )
    {
      // FieldName, AppId, ErrorCode,ErrorDescription
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Called Number", "407", "11",
                                                   "Syntax error and call represents emergency call");
    }
  }
  
  if( calledNumberIsMissing == true and dialledDigitsIsMissing == true and lastTeleServiceCode != "12" and
      strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
  {
    objTag = "1,3,9,147,89";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Destination", "89", "39",
                "Neither item Called Number nor Dialled Digits present within call and call does not represent an emergency call");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "39", objTag, "0", "-1", "-1","",
                "Neither item Called Number nor Dialled Digits present within call and call does not represent an emergency call");
    edrSetIsValidDetail(false);
  }
  
  if( (calledNumberIsMissing == true) and (lastTeleServiceCode == "20" or lastTeleServiceCode == "21" or lastTeleServiceCode == "22" ) and (strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true) )
  {
    objTag = "1,3,9,147,89";
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Destination", "89", "42", 
                                              "Called Number not present and call represents SMS usage");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "42", objTag, "0", "-1", "-1","",
                                              "Called Number not present and call represents SMS usage");
    edrSetIsValidDetail(false);
  }  
  
  if( (lastTotalCallEventDuration > 0) and 
      (lastTeleServiceCode == "20" or lastTeleServiceCode == "21" or lastTeleServiceCode == "22") )
  {
    if( strStartsWith(parentContext, "DETAIL.mobileOriginatedCall") == true )
    {
      objTag = "1,3,9,147,223";
    }
    else if( strStartsWith(parentContext, "DETAIL.mobileTerminatedCall") == true )
    {
      objTag = "1,3,9,153,223";
    }
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "TotalCallEventDuration", "223", "100", "Total Call Event Duration is greater than 0 (zero) for SMS call");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "100", objTag, "0", "-1", "-1", "","Total Call Event Duration is greater than 0 (zero) for SMS call");
    edrSetIsValidDetail(false);
  }

  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function calls the validation functions validateTeleServiceCode and validateBearerServiceCode.
 ******************************************************************************************************************************/

function validateBasicServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",426";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "teleServiceCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateTeleServiceCode ( myContext, nMyIndices, "teleServiceCode", 0, errorContext );
  }
 
  childContext = myContext + "." + "bearerServiceCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateBearerServiceCode ( myContext, nMyIndices, "bearerServiceCode", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function calls the validation function validateBasicServiceCode for each element of Basic Service Code List.
 ******************************************************************************************************************************/
 
function validateBasicServiceCodeList ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",37";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
 
  String childContext     = myContext + "." + "BasicServiceCode";
  Long BasicServiceCodeListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );
  Long i;
  for( i = 0; i < BasicServiceCodeListEntries; i = i + 1 )
  {
    validateBasicServiceCode ( myContext, nMyIndices, "BasicServiceCode", i, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}
 
function validateSsParameters ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",204";
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate SupplServiceActionCode. It will raise error code 20 , 22 for SupplServiceActionCode.
 ******************************************************************************************************************************/
 
function validateSupplServiceActionCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",208";
  lastSupplServiceActionCode = edrLongEx( myContext, indices, nParentIndices );

  if ( (lastSupplServiceCode != "FF") and (lastSupplServiceActionCode < 0 or lastSupplServiceActionCode > 6) )   
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Suppl Service Action Code", "208", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  else if ( (lastSupplServiceCode == "FF") and (lastSupplServiceActionCode != 7) )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Suppl Service Action Code", "208", "22", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "22", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");
}

/******************************************************************************************************************************
 * This function will validate SupplServiceCode. It will raise error code 10, 11, 20, 21, 22 for SupplServiceCode.
 ******************************************************************************************************************************/
 
function validateSupplServiceCode ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",209";

  Bool codePresent = false;
  Long i;
  lastSupplServiceCode = edrStringEx( myContext, indices, nParentIndices );
  
  for( i = 0 ; i < numSupplServiceCode and codePresent == false ; i = i + 1 )
  {
    if( edrStringEx( myContext, indices, nParentIndices ) == SupplServiceCodeArr[i])
    {
      codePresent = true;
    }
  }
  
  if( (validateHexValue(edrStringEx(myContext, indices, nParentIndices)) == true) or
      (strLength(edrStringEx(myContext, indices, nParentIndices)) != 2) )
  {
    if( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceCode", "209", "10", "Syntax error");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error");
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "SupplServiceCode", "209", "11", "Syntax error");
    }    
  }
  else if ( codePresent == false )
  {
  
    if ( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") == true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceCode", "209", "20", "Value out of range");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
      edrSetIsValidDetail(false);
    }
    else
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "SupplServiceCode", "209", "21", "Value out of range");
    } 
  }
  else if( edrStringEx(myContext, indices, nParentIndices) == "FF" )
  { 
    if ( strStartsWith(parentContext, "DETAIL.supplServiceEvent.supplServiceUsed") != true )
    {
      edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceCode", "209", "22", "Value 'FF' ");
      edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "22", errorContext, "0", "-1", "-1", "","Value 'FF' ");
      edrSetIsValidDetail(false);
    }
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate SupplServiceUsed. It will raise error code 30, 31, 32, 33, 36 for SupplServiceUsed. 
 ******************************************************************************************************************************/
 
function validateSupplServiceUsed ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",206";
  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;

  lastSupplServiceCode = "";
  lastSupplServiceActionCode = -1;
  
  childContext = myContext + "." + "supplServiceCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSupplServiceCode ( myContext, nMyIndices, "supplServiceCode", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceUsed", "206", "30", "Mandatory item Supplementary Service Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Mandatory item Supplementary Service Code missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "supplServiceActionCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateSupplServiceActionCode ( myContext, nMyIndices, "supplServiceActionCode", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceUsed", "206", "31", "Mandatory item Action Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "31", errorContext, "0", "-1", "-1","", "Mandatory item Action Code missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "ssParameters";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    if ( ( ( lastSupplServiceCode != "21" and lastSupplServiceCode != "20" and 
               lastSupplServiceCode != "28" and lastSupplServiceCode != "29" and
                 lastSupplServiceCode != "2A" and lastSupplServiceCode != "2B") and lastSupplServiceActionCode != 0 ) and
                   lastSupplServiceCode != "FF" )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Supplementary Service Used", "206", "32", "Item Supplementary Service Parameters present when Supplementary Service is not for call forward registration or does not represent USSD usage");
    }    
    validateSsParameters ( myContext, nMyIndices, "ssParameters", 0, errorContext );
  }
  else
  {
    if ( ( lastSupplServiceCode == "21" or lastSupplServiceCode == "20" or 
             lastSupplServiceCode == "28" or lastSupplServiceCode == "29" or
               lastSupplServiceCode == "2A" or lastSupplServiceCode == "2B") and 
               ( lastSupplServiceActionCode == 0  or  lastSupplServiceActionCode == 5 ) )
    {
      edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "Supplementary Service Used", "206", "33", "Item Supplementary Service Parameters not present when Supplementary Service is for call forward registration or invocation usage");
    }
  }
 
  childContext = myContext + "." + "chargingTimeStamp";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargingTimeStamp ( myContext, nMyIndices, "chargingTimeStamp", 0, errorContext );
  }
  else
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceUsed", "206", "36", "Item Charging Timestamp missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "36", errorContext, "0", "-1", "-1", "","Item Charging Timestamp missing within group"); 
    edrSetIsValidDetail(false);
  }
 
 
  childContext = myContext + "." + "chargeInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeInformation ( myContext, nMyIndices, "chargeInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "basicServiceCodeList";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateBasicServiceCodeList ( myContext, nMyIndices, "basicServiceCodeList", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate NetworkLocation. It will raise error code 30 for NetworkLocation.
 ******************************************************************************************************************************/
 
function validateNetworkLocation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",156";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "recEntityCode";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRecEntityCode ( myContext, nMyIndices, "recEntityCode", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "NetworkLocation", "156", "30", "Mandatory item Recording Entity Code missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory item Recording Entity Code missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "callReference";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCallReference ( myContext, nMyIndices, "callReference", 0, errorContext );
  }
 
  childContext = myContext + "." + "locationArea";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateLocationArea ( myContext, nMyIndices, "locationArea", 0, errorContext );
  }
 
  childContext = myContext + "." + "cellId";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateCellId ( myContext, nMyIndices, "cellId", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate LocationInformation. It will raise error code 30 for LocationInformation.
 ******************************************************************************************************************************/
 
function validateLocationInformation ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",138";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "networkLocation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateNetworkLocation ( myContext, nMyIndices, "networkLocation", 0, errorContext );
  }
  else if( strStartsWith(parentContext, "DETAIL.gprsCall") == false )
  {  
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "LocationInformation", "138", "30", "Mandatory item Network Location missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1", "","Mandatory item Network Location missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "homeLocationInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateHomeLocationInformation ( myContext, nMyIndices, "homeLocationInformation", 0, errorContext );
  }
 
  childContext = myContext + "." + "geographicalLocation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateGeographicalLocation ( myContext, nMyIndices, "geographicalLocation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate SupplServiceEvent. It will raise error code 30, 33, 34, 36 for SupplServiceEvent.
 ******************************************************************************************************************************/
 
function validateSupplServiceEvent ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext        = parentContext + "." + child;
  errorContext = errorContext + ",11";

  indices[nParentIndices] = childIndex;
  Long nMyIndices         = nParentIndices + 1;
  String childContext;
 
  childContext = myContext + "." + "chargeableSubscriber";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateChargeableSubscriber ( myContext, nMyIndices, "chargeableSubscriber", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceEvent", "11", "30", "Mandatory group Chargeable Subscriber missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "30", errorContext, "0", "-1", "-1","", "Mandatory group Chargeable Subscriber missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "rapFileSequenceNumber";
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )
  {
    validateRapFileSequenceNumber ( myContext, nMyIndices, "rapFileSequenceNumber", 0, errorContext );
  }
 
  childContext = myContext + "." + "locationInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateLocationInformation ( myContext, nMyIndices, "locationInformation", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceEvent", "11", "33", "Mandatory group Location Information missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "33", errorContext, "0", "-1", "-1", "","Mandatory group Location Information missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "equipmentIdentifier";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateImeiOrEsn ( myContext, nMyIndices, "equipmentIdentifier", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_WARNING", LOG_WARNING, "SupplServiceEvent", "11", "34", "Mandatory item Equipment Identifier missing within group");
  }
 
  childContext = myContext + "." + "supplServiceUsed";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateSupplServiceUsed ( myContext, nMyIndices, "supplServiceUsed", 0, errorContext );
  }
  else
  {
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "SupplServiceEvent", "11", "36", "Mandatory group Supplementary Service Used missing within group");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "36", errorContext, "0", "-1", "-1","", "Mandatory group Supplementary Service Used missing within group");
    edrSetIsValidDetail(false);
  }
 
  childContext = myContext + "." + "operatorSpecInformation";
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )
  {
    validateOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0, errorContext );
  }
 
  //logContext( myContext, nMyIndices );
}

/******************************************************************************************************************************
 * This function will validate HSCSDIndicator. It will raise error code 10, 20 for HSCSDIndicator.
 ******************************************************************************************************************************/
 
function validateHSCSDIndicator ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",424";

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true or
      strLength(edrStringEx(myContext, indices, nParentIndices)) != 1 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "HSCSD Indicator", "424", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error");
    edrSetIsValidDetail(false);
  }
  else if( edrStringEx(myContext, indices, nParentIndices) != "1" )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "HSCSD Indicator", "424", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate MaximumBitRate. It will raise error code 10, 20 for MaximumBitRate.
 ******************************************************************************************************************************/
 
function validateMaximumBitRate ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",421";

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true or
      strLength(edrStringEx(myContext, indices, nParentIndices)) != 1  )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MaximumBitRate", "421", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax error"); 
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx( myContext, indices, nParentIndices) ,"7" , "1", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "MaximumBitRate", "421", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1", "","Value Out Of Range"); 
    edrSetIsValidDetail(false);
  }  
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

/******************************************************************************************************************************
 * This function will validate GuaranteedBitRate. It will raise error code 10, 20 for GuaranteedBitRate.
 ******************************************************************************************************************************/
 
function validateGuaranteedBitRate ( String parentContext, Long nParentIndices, String child, Long childIndex, String errorContext )
{
  String myContext = parentContext + "." + child;
  errorContext = errorContext + ",420";

  if( validateSyntax(edrStringEx(myContext, indices, nParentIndices), "CHECK_NUM") == true or
      strLength(edrStringEx(myContext, indices, nParentIndices)) != 1 )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Guaranteed Bit Rate", "420", "10", "Syntax Error");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "10", errorContext, "0", "-1", "-1", "","Syntax Error");
    edrSetIsValidDetail(false);
  }
  else if( validateOOR(edrStringEx(myContext, indices, nParentIndices), "7", "1", "INTEGER_TYPE") == true )
  {
    // FieldName, AppId, ErrorCode,ErrorDescription
    edrAddError("ERR_TAP3_SEVERE", LOG_MAJOR, "Guaranteed Bit Rate", "420", "20", "Value Out Of Range");
    edrAddError("ERR_TAP3_RET", LOG_MAJOR, "severe", "20", errorContext, "0", "-1", "-1","", "Value Out Of Range");
    edrSetIsValidDetail(false);
  }
 
  //logContext( myContext, nParentIndices );
  //logStdout( "Value: " + edrStringEx( myContext, indices, nParentIndices ) + "\n");
}

