create or replace
PACKAGE RARating AS
TYPE refcursor IS REF CURSOR;
TYPE QUERY_TYPE is table of VARCHAR2(30000) index by binary_integer;

FUNCTION RARatingSummary(
              	pStartDate 		IN VARCHAR2,
		pEndDate 		IN VARCHAR2,
		pTransStartDate 	IN VARCHAR2,
		pTransEndDate 	        IN VARCHAR2,
              	pFlowType 		IN VARCHAR2,
              	pControlPoint 	        IN VARCHAR2,
              	pServiceType 	        IN VARCHAR2,
              	pBatchTypeStart 	IN NUMBER,
              	pBatchTypeEnd 	        IN NUMBER
                         ) RETURN RARating.refcursor;

FUNCTION RARatingDetail(
              	pStartDate 		IN VARCHAR2,
		pEndDate 		IN VARCHAR2,
		pTransStartDate 	IN VARCHAR2,
		pTransEndDate 	        IN VARCHAR2,
              	pFlowType 		IN VARCHAR2,
              	pControlPoint 	        IN VARCHAR2,
              	pServiceType 	        IN VARCHAR2,
              	pBatchID 		IN VARCHAR2,
                pReportType     	IN VARCHAR2,
              	pSuccess 		IN VARCHAR2,
              	pSuspense 		IN VARCHAR2,
              	pWrittenOff 	        IN VARCHAR2,
                pRaScope                 IN VARCHAR2) RETURN RARating.refcursor;

FUNCTION CreateDynamicQuery(
            pstartdate        IN VARCHAR2,   
            penddate          IN VARCHAR2,   
            ptransstartdate   IN VARCHAR2,   
            ptransenddate     IN VARCHAR2,   
            pflowtype         IN VARCHAR2,   
            pcontrolpoint     IN VARCHAR2,   
            pservicetype      IN VARCHAR2,   
            pbatchid          IN VARCHAR2,   
            pdetailstablename IN VARCHAR2,   
            pRaScope           IN VARCHAR2) RETURN VARCHAR2;

FUNCTION ref_cur(dquery IN VARCHAR2) RETURN rarating.refcursor;

END;
/

create or replace
PACKAGE BODY RARating AS

FUNCTION RARatingSummary(
              	pStartDate 	IN VARCHAR2,
		pEndDate 	IN VARCHAR2,
		pTransStartDate IN VARCHAR2,
		pTransEndDate 	IN VARCHAR2,
              	pFlowType 	IN VARCHAR2,
              	pControlPoint 	IN VARCHAR2,
              	pServiceType 	IN VARCHAR2,
              	pBatchTypeStart IN NUMBER,
              	pBatchTypeEnd 	IN NUMBER
                         ) RETURN RARating.refcursor IS
                      l_cursor RARating.refcursor;

      FlowType1               VARCHAR(200):=NULL;	
      FlowType                VARCHAR(200):=NULL;
      ServiceType1            VARCHAR(200):=NULL;
      ServiceType             VARCHAR(200):=NULL;
      ControlPoint1           VARCHAR(200):=NULL;
      ControlPoint            VARCHAR(200):=NULL;
      MyQuery                 QUERY_TYPE;
      
      myquery10 varchar2(6000):=null;
      INVALID_ARGUMENT        EXCEPTION;
      INVALID_SERVICE_TYPE    EXCEPTION;
      INVALID_FLOW_TYPE       EXCEPTION;
      INVALID_CONTROL_POINT   EXCEPTION;
      INVALID_RANGE           EXCEPTION;
      
      
  BEGIN

  IF ( pBatchTypeStart > pBatchTypeEnd ) THEN
         RAISE INVALID_RANGE;
  END IF;
  IF (pFlowType is NULL) THEN
         RAISE INVALID_FLOW_TYPE;
  END IF;
  IF (pControlPoint is NULL) THEN
         RAISE INVALID_CONTROL_POINT;
  END IF;
--  IF (pServiceType = 'NULL') THEN
--         RAISE INVALID_SERVICE_TYPE;
--  END IF;

  IF (UPPER(pControlPoint) = 'ALL' ) THEN
      ControlPoint := ' like ''%''  ';
  ELSIF instr(pControlPoint, ':') <> 0 THEN
      ControlPoint1 := replace(pControlPoint,':',''',''');
      ControlPoint := ' in ( '''||ControlPoint1||''' ) ' ; 	
  ELSE
      ControlPoint := ' in ( ''' || pControlPoint || ''' ) ' ;
  END IF;

  IF (pServiceType = 'NULL' ) THEN
      ServiceType := ' = NULL  ';
  ELSIF ( instr(pServiceType, ':') <> 0 ) THEN
      ServiceType1 := replace(pServiceType,':',''',''');
      ServiceType := ' in ( '''||ServiceType1||''' ) ' ; 	
  ELSE
      ServiceType := ' in ( ''' || pServiceType || ''' ) ' ;
  END IF;

  IF ( pFlowType IS NULL ) THEN
      FlowType := ' = NULL ';
  ELSIF ( instr(pFlowType, ':') <> 0 ) THEN
      FlowType1 := replace(pFlowType,':',''',''');
      FlowType := ' in ( '''||FlowType1||''' ) ' ; 	
  ELSE
      FlowType := ' in ( ''' || pFlowType || ''' ) ' ;
  END IF;
-- This query corresponds to RA_11 scenario where the grouping is based on
-- outputstream and object type is /process_audit/batchstat/outputstream
MyQuery(1) := 'SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   NULL                                     EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   OUTPUT_STREAM                            OUTPUT_STREAM,
   NULL                                     REVENUE_STREAM,
   NULL                                     SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   UPPER(OUTPUT_STREAM)                     UOUTPUT_STREAM,
   NULL                                     UREVENUE_STREAM,
   NULL                                     USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   1                                        POID_VAL
FROM((("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0")
INNER JOIN "GDTLS_OSTRM_T" "GDTLS_OSTRM_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_OSTRM_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"  ' || FlowType || '
 AND "PROC_AUD_T"."PROCESS_NAME"  ' || ControlPoint || '
 AND("PROC_AUD_BSTAT_T"."BATCH_TYPE" >=  ' || pBatchTypeStart || '
 AND "PROC_AUD_BSTAT_T"."BATCH_TYPE" <=  ' || pBatchTypeEnd || ' )
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet( ''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
			bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
			bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND("GDTLS_OSTRM_T"."USAGE_START_T" >= bipext.infStrToTimet( ''' || pTransStartDate || ''', 2)
 AND "GDTLS_OSTRM_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
			bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
			bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)))
 AND bipext.infCheckDates(''' || pStartDate || ''', ''' || pEndDate || ''') = 1
 AND bipext.infCheckDates(''' || pTransStartDate || ''', ''' || pTransEndDate || ''') = 1
 AND "PROC_AUD_T"."VERSION_ID" = 4 ';

-- This query corresponds to RA_03 scenario where the grouping is based on
-- Service Type and object type is /process_audit/batchstat/svctype
MyQuery(2) := ' SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   NULL                                     EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   NULL                                     OUTPUT_STREAM,
   NULL                                     REVENUE_STREAM,
   SERVICE_TYPE                             SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   NULL                                     UOUTPUT_STREAM,
   NULL                                     UREVENUE_STREAM,
   UPPER(SERVICE_TYPE)                      USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   2                                        POID_VAL
FROM((("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0")
INNER JOIN "GDTLS_STYPE_T" "GDTLS_STYPE_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_STYPE_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"  ' || FlowType || '
 AND "PROC_AUD_T"."PROCESS_NAME"  ' || ControlPoint || '
 AND("PROC_AUD_BSTAT_T"."BATCH_TYPE" >=  ' || pBatchTypeStart || '
 AND "PROC_AUD_BSTAT_T"."BATCH_TYPE" <=  ' || pBatchTypeEnd || ' )
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet( ''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND("GDTLS_STYPE_T"."USAGE_START_T" >= bipext.infStrToTimet( ''' || pTransStartDate || ''', 2)
 AND "GDTLS_STYPE_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)))
 AND "GDTLS_STYPE_T"."SERVICE_TYPE"  ' || ServiceType || '
 AND bipext.infCheckDates(''' || pStartDate || ''', ''' || pEndDate || ''') = 1
 AND bipext.infCheckDates(''' || pTransStartDate || ''', ''' || pTransEndDate || ''') = 1
 AND "PROC_AUD_T"."VERSION_ID" = 4 ';

-- This query corresponds to RA_06 scenario where the grouping is based on
-- Revenue stream and EDR Status and object type is /process_audit/batchstat/revstream_status
 MyQuery(3) := ' SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   EDR_STATUS                               EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   NULL                                     OUTPUT_STREAM,
   REVENUE_STREAM                           REVENUE_STREAM,
   NULL                                     SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   NULL                                     UOUTPUT_STREAM,
   UPPER(REVENUE_STREAM)                    UREVENUE_STREAM,
   NULL                                     USERVICE_TYPE,
   UPPER(EDR_STATUS)                        UEDR_STATUS,
   3                                        POID_VAL
FROM("GDTLS_RSTRM_STS_T" "GDTLS_RSTRM_STS_T"
INNER JOIN(("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE")) ON "GDTLS_RSTRM_STS_T"."OBJ_ID0" = "PROC_AUD_T"."POID_ID0")
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"  ' || FlowType || '
 AND "PROC_AUD_T"."PROCESS_NAME"  ' || ControlPoint || '
 AND("PROC_AUD_BSTAT_T"."BATCH_TYPE" >=  ' || pBatchTypeStart || '
 AND "PROC_AUD_BSTAT_T"."BATCH_TYPE" <=  ' || pBatchTypeEnd || ' )
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet( ''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND("GDTLS_RSTRM_STS_T"."USAGE_START_T" >= bipext.infStrToTimet( ''' || pTransStartDate || ''', 2)
 AND "GDTLS_RSTRM_STS_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)))
 AND bipext.infCheckDates(''' || pStartDate || ''', ''' || pEndDate || ''') = 1
 AND bipext.infCheckDates(''' || pTransStartDate || ''', ''' || pTransEndDate || ''') = 1
 AND "PROC_AUD_T"."VERSION_ID" = 4 ';

-- This query corresponds to RA_08 scenario where the grouping is based on Revenue stream,
-- Service Type and EDR Status and object type is /process_audit/batchstat/revstream_svctype_status
MyQuery(4) := ' SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   EDR_STATUS                               EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   NULL                                     OUTPUT_STREAM,
   REVENUE_STREAM                           REVENUE_STREAM,
   SERVICE_TYPE                             SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   NULL                                     UOUTPUT_STREAM,
   UPPER(REVENUE_STREAM)                    UREVENUE_STREAM,
   UPPER(SERVICE_TYPE)                      USERVICE_TYPE,
   UPPER(EDR_STATUS)                        UEDR_STATUS,
   4                                        POID_VAL
FROM((("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0")
INNER JOIN "GDTLS_RSTRM_STYPE_STS_T" "GDTLS_RSTRM_STYPE_STS_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_RSTRM_STYPE_STS_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"  ' || FlowType || '
 AND "PROC_AUD_T"."PROCESS_NAME"  ' || ControlPoint || '
 AND("PROC_AUD_BSTAT_T"."BATCH_TYPE" >=  ' || pBatchTypeStart || '
 AND "PROC_AUD_BSTAT_T"."BATCH_TYPE" <=  ' || pBatchTypeEnd || ' )
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet( ''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''',2)))
 AND("GDTLS_RSTRM_STYPE_STS_T"."USAGE_START_T" >= bipext.infStrToTimet( ''' || pTransStartDate || ''', 2)
 AND "GDTLS_RSTRM_STYPE_STS_T"."USAGE_START_T" <= DECODE((instr( ''' || pTransEndDate || ''' , '':'', 1, 2)), 0, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''' , 2)-1, 
        	bipext.INFSTRTOTIMET(''' || pTransEndDate || ''',2)))
 AND bipext.infCheckDates(''' || pStartDate || ''', ''' || pEndDate || ''') = 1
 AND bipext.infCheckDates(''' || pTransStartDate || ''', ''' || pTransEndDate || ''') = 1
 AND "GDTLS_RSTRM_STYPE_STS_T"."SERVICE_TYPE"  ' || ServiceType || '
 AND "PROC_AUD_T"."VERSION_ID" = 4 ';

-- This query corresponds to RA_07 scenario where the grouping is based on
-- Revenue stream and Service Type and object type is /process_audit/batchstat/revstream_svctype
MyQuery(5) := ' SELECT
  "PROC_AUD_T"."CREATED_T"                  CREATED_T,
  "CONFIG_RA_FLOWS_T"."FLOW_NAME"           FLOW_NAME,
   OLD_DISCOUNT_VALUE      		    OLD_DISCOUNT_VALUE,
   OLD_RETAIL_AMOUNT                        OLD_RETAIL_AMOUNT,
   ORIGINAL_BATCH_ID                        ORIGINAL_BATCH_ID,
  "PROC_AUD_T"."POID_TYPE"                  POID_TYPE,
  "PROC_AUD_T"."PROCESS_NAME"               PROCESS_NAME,
   TOTAL_COUNT                              TOTAL_COUNT,
   TOTAL_DISCOUNT_VALUE                     TOTAL_DISCOUNT_VALUE,
   TOTAL_DURATION                           TOTAL_DURATION,
   TOTAL_RETAIL_AMOUNT                      TOTAL_RETAIL_AMOUNT,
   TOTAL_VOLUME_RECEIVED                    TOTAL_VOLUME_RECEIVED,
   TOTAL_VOLUME_SENT                        TOTAL_VOLUME_SENT,
   TOTAL_WHOLESALE_AMOUNT                   TOTAL_WHOLESALE_AMOUNT,
   USAGE_START_T                            USAGE_START_T,
  "PROC_AUD_T"."VERSION_ID"                  VERSION_ID,
   NULL                                     EDR_STATUS,
   NULL		                            GDTLS_REL_T_OBJ_ID0,
   NULL                                     GDTLS_REL_T_TOTAL_VALUE,
   NULL                                     GDTLS_REL_T_EVENT_COUNT,
   NULL                                     OUTPUT_STREAM,
   REVENUE_STREAM                           REVENUE_STREAM,
   SERVICE_TYPE                             SERVICE_TYPE,
   NULL                                     SUSPENSE_CODE,
   UPPER("CONFIG_RA_FLOWS_T"."FLOW_NAME")   UFLOW_NAME,
   UPPER("PROC_AUD_T"."PROCESS_NAME")       UPROCESS_NAME,
   NULL                                     UOUTPUT_STREAM,
   UPPER(REVENUE_STREAM)                    UREVENUE_STREAM,
   UPPER(SERVICE_TYPE)                      USERVICE_TYPE,
   NULL                                     UEDR_STATUS,
   5                                        POID_VAL
FROM((("CONFIG_RA_CTRL_PT_T" "CONFIG_RA_CTRL_PT_T"
INNER JOIN "CONFIG_RA_FLOWS_T" "CONFIG_RA_FLOWS_T" ON("CONFIG_RA_CTRL_PT_T"."OBJ_ID0" = "CONFIG_RA_FLOWS_T"."OBJ_ID0")
 AND("CONFIG_RA_CTRL_PT_T"."REC_ID2" = "CONFIG_RA_FLOWS_T"."REC_ID"))
INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "PROC_AUD_BSTAT_T" "PROC_AUD_BSTAT_T" ON "PROC_AUD_T"."POID_ID0" = "PROC_AUD_BSTAT_T"."OBJ_ID0")
INNER JOIN "GDTLS_RSTRM_STYPE_T" "GDTLS_RSTRM_STYPE_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_RSTRM_STYPE_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"  ' || FlowType || '
 AND "PROC_AUD_T"."PROCESS_NAME"  ' || ControlPoint || '
 AND("PROC_AUD_BSTAT_T"."BATCH_TYPE" >=  ' || pBatchTypeStart || '
 AND "PROC_AUD_BSTAT_T"."BATCH_TYPE" <=  ' || pBatchTypeEnd || ' )
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet( ''' || pStartDate || ''', 2)
