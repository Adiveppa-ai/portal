function mapAuditControlInfo ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  if ( myContext != "TRAILER.auditControlInfo" )
  {
    return;
  }
  
  childContext = myContext + "." + "earliestCallTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapEarliestCallTimeStamp ( myContext, nMyIndices, "earliestCallTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "latestCallTimeStamp";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapLatestCallTimeStamp ( myContext, nMyIndices, "latestCallTimeStamp", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalCharge";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalCharge ( myContext, nMyIndices, "totalCharge", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalChargeRefund";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalChargeRefund ( myContext, nMyIndices, "totalChargeRefund", 0 );                               
  }                                                                                                          

  edrDecimal(TRAILER.TOTAL_RETAIL_CHARGED_VALUE)     = 0.0;
  edrDecimal(TRAILER.TOTAL_WHOLESALE_CHARGED_VALUE)  = sumChargedAmountValueFile;
  if (theTotalChargedValue_00 != 0.0 )
  {
    edrDecimal(TRAILER.TAP_TOTAL_CHARGE_VALUE)  = theTotalChargedValue_00 / theAbsoluteAmountDivider;
  }
  else
  {
    edrDecimal(TRAILER.TAP_TOTAL_CHARGE_VALUE)  = theTotalChargedValue / theAbsoluteAmountDivider;
  }
                                                                                                             
  childContext = myContext + "." + "totalTaxRefund";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalTaxRefund ( myContext, nMyIndices, "totalTaxRefund", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalTaxValue";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalTaxValue ( myContext, nMyIndices, "totalTaxValue", 0 );                               
  }                                                                                                          
  edrDecimal(TRAILER.TOTAL_TAX_VALUE) = sumTaxChargeFile;

                                                                                                             
  childContext = myContext + "." + "totalDiscountValue";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalDiscountValue ( myContext, nMyIndices, "totalDiscountValue", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalDiscountRefund";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTotalDiscountRefund ( myContext, nMyIndices, "totalDiscountRefund", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "totalAdvisedChargeValueList";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapTotalAdvisedChargeValueList ( myContext, nMyIndices, "totalAdvisedChargeValueList", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "callEventDetailsCount";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapCallEventDetailsCount ( myContext, nMyIndices, "callEventDetailsCount", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "operatorSpecInformation";                                                       
  if ( edrNumDatablocksEx( childContext, indices, nMyIndices ) > 0 )                                         
  {                                                                                                          
    mapOperatorSpecInfoList ( myContext, nMyIndices, "operatorSpecInformation", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapDiscountableAmount ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  edrDecimal(DETAIL.ASS_ROAMING_EXT.DISCOUNTABLE_AMOUNT, 0) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapDiscount ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  edrDecimal(DETAIL.ASS_CBD.CP.GRANTED_DISCOUNT_AMOUNT_VALUE, ACBidx, CPidx) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
  lastDiscountValue = (longToDecimal(edrLongEx( myContext, indices, nParentIndices )) / theAbsoluteAmountDivider);
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapDiscountCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "HEADER" ) == true )
  {
    lastCode = edrLongEx( myContext, indices, nParentIndices );
  }
  else
  {
    lastDiscountCode = edrLongEx( myContext, indices, nParentIndices );

    if (getDiscountAppliedType(lastDiscountCode) == discountApplied_fixedDiscountValue)
    {
      lastDiscountValue = (longToDecimal(getDiscountApplied(lastDiscountCode)) / theAbsoluteAmountDivider);
      edrDecimal(DETAIL.ASS_CBD.CP.GRANTED_DISCOUNT_AMOUNT_VALUE, ACBidx, CPidx) = lastDiscountValue;
    }
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapDiscountInformation ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       
                                                                                                             
  childContext = myContext + "." + "discountCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapDiscountCode ( myContext, nMyIndices, "discountCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "discount";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapDiscount ( myContext, nMyIndices, "discount", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "discountableAmount";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapDiscountableAmount ( myContext, nMyIndices, "discountableAmount", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapTaxableAmount ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  edrDecimal(DETAIL.ASS_CBD.TP.TAXABLE_AMOUNT, ACBidx, TPidx) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
  Decimal taxAmount = (longToDecimal(edrLongEx( myContext, indices, nParentIndices )) / theAbsoluteAmountDivider) * lastExchangeRateFactor;
  sumTaxAmountCI = sumTaxAmountCI + taxAmount;

  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapTaxValue ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  edrDecimal(DETAIL.WHOLESALE_CHARGED_TAX_VALUE) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
  edrDecimal(DETAIL.ASS_CBD.TP.TAX_VALUE, ACBidx, TPidx) = longToDecimal(edrLongEx( myContext, indices, nParentIndices ));
  lastTaxCharge = (longToDecimal(edrLongEx( myContext, indices, nParentIndices )) / theAbsoluteAmountDivider) * lastExchangeRateFactor;
  sumTaxChargeCI = sumTaxChargeCI + lastTaxCharge;
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapTaxCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  if ( strStartsWith ( parentContext, "HEADER" ) == true )
  {
    lastCode = edrLongEx( myContext, indices, nParentIndices );
  }
  else
  {
    edrString(DETAIL.ASS_CBD.TP.TAX_CODE, ACBidx, TPidx) = longToStr(edrLongEx( myContext, indices, nParentIndices ));

    String taxRateStr    = getTaxRate( edrLongEx( myContext, indices, nParentIndices ) );
    String taxTypeStr    = getTaxType( edrLongEx( myContext, indices, nParentIndices ) );
    String chargeTypeStr   = getChargeType  ( edrLongEx( myContext, indices, nParentIndices ) );
    String taxIndicatorStr = getTaxIndicator( edrLongEx( myContext, indices, nParentIndices ) );
    edrString(DETAIL.ASS_CBD.TP.TAX_RATE, ACBidx, TPidx) = taxRateStr;
    edrString(DETAIL.ASS_CBD.TP.TAX_TYPE, ACBidx, TPidx) = taxTypeStr;
    if (chargeTypeStr != "")
    {
      edrString(DETAIL.ASS_CBD.TP.CHARGE_TYPE, ACBidx, TPidx) = chargeTypeStr;
    }
    if (taxIndicatorStr != "")
    {
      edrString(DETAIL.ASS_CBD.TP.TAX_INDICATOR, ACBidx, TPidx) = taxIndicatorStr;
    }

    Long taxRateStrlen = strLength (taxRateStr);
    if (taxRateStrlen > 3)
    {
      lastTaxRate = strToLong (strSubstr (taxRateStr, 0, (taxRateStrlen - 3)));
    }
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
function mapTaxInformation ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              
  String childContext;                                                                                       

  successiveTaxDetail = successiveTaxDetail + 1;
  if ( edrAddDatablock( DETAIL.ASS_CBD.TP ) == false )
  {
  }
  TPidx = successiveTaxPacket;
  successiveTaxPacket   = successiveTaxPacket + 1;
  records = records + 1;

  edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) = edrLong(DETAIL.NUMBER_ASSOCIATED_RECORDS) + 1;
  edrString(DETAIL.ASS_CBD.TP.RECORD_TYPE, ACBidx, TPidx) = extension_TP;
  edrLong(DETAIL.ASS_CBD.TP.RECORD_NUMBER, ACBidx, TPidx) = records;
  edrLong(DETAIL.ASS_CBD.TP.RELATED_RECORD_NUMBER, ACBidx, TPidx) = related_record;
  edrLong(DETAIL.ASS_CBD.TP.RELATED_CHARGE_INFO_ID, ACBidx, TPidx) = related_info_id;
                                                                                                             
  childContext = myContext + "." + "taxCode";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxCode ( myContext, nMyIndices, "taxCode", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "taxValue";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxValue ( myContext, nMyIndices, "taxValue", 0 );                               
  }                                                                                                          
                                                                                                             
  childContext = myContext + "." + "taxableAmount";                                                       
  if ( edrInternalStateEx( childContext, indices, nMyIndices ) != STATE_CLEARED )                            
  {                                                                                                          
    mapTaxableAmount ( myContext, nMyIndices, "taxableAmount", 0 );                               
  }                                                                                                          
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapTaxInformationList ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext        = parentContext + "." + child;                                                   
  indices[nParentIndices] = childIndex;                                                                      
  Long nMyIndices         = nParentIndices + 1;                                                              

  lastTaxCharge  = 0.0;
                                                                                                             
  String childContext     = myContext + "." + "TaxInformation";                                            
  Long TaxInformationListEntries = edrNumDatablocksEx( childContext, indices, nMyIndices );                   
  Long i;                                                                                                    
  for( i = 0; i < TaxInformationListEntries; i = i + 1 )                                                      
  {                                                                                                          
    mapTaxInformation ( myContext, nMyIndices, "TaxInformation", i );                               
  }                                                                                                          

  lastTaxCharge  = 0.0;
                                                                                                             
  //logContext( myContext, nMyIndices );                                                                       
}                                                                                                            
                                                                                                             
function mapUtcTimeOffsetCode ( String parentContext, Long nParentIndices, String child, Long childIndex )   
{                                                                                                            
  String myContext = parentContext + "." + child;                                                          

  lastUtcTimeOffset  = getUtcTimeOffset(edrLongEx( myContext, indices, nParentIndices ));

  if (strEndsWith(parentContext, "chargingTimeStamp") == true)
  {
    if ( (record_Type == record_MSS) or (record_Type == record_SCU) or (record_Type == record_VAS))
    {
      edrString(DETAIL.UTC_TIME_OFFSET) = lastUtcTimeOffset;
    }

    if ( service_Type == service_Basic )
    {
      edrString(DETAIL.ASS_GSMW_EXT.BS_PACKET.UTC_TIME_OFFSET, 0, bsPacketIdx) = lastUtcTimeOffset;
    }

    if ( service_Type == service_Suppl )
    {
      edrString(DETAIL.ASS_GSMW_EXT.SS_PACKET.UTC_TIME_OFFSET, 0, ssPacketIdx) = lastUtcTimeOffset;
    }
  }
  else if (strEndsWith(parentContext, "chargeDetailTimeStamp") == true)
  {
  }
  else if (strEndsWith(parentContext, "callEventStartTimeStamp") == true)
  {
    edrString(DETAIL.UTC_TIME_OFFSET) = lastUtcTimeOffset;
    lastValidUtcTimeOffset = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "orderPlacedTimeStamp") == true)
  {
    edrString(DETAIL.ASS_CONT_EXT.ORDER_PLACED_UTC_TIME_OFFSET, 0) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "requestedDeliveryTimeStamp") == true)
  {
    edrString(DETAIL.ASS_CONT_EXT.REQ_DELIVERY_UTC_TIME_OFFSET, 0) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "actualDeliveryTimeStamp") == true)
  {
    edrString(DETAIL.ASS_CONT_EXT.ACT_DELIVERY_UTC_TIME_OFFSET, 0) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "depositTimeStamp") == true)
  {
    lastValidUtcTimeOffset = lastUtcTimeOffset;
    edrString(DETAIL.UTC_TIME_OFFSET) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "completionTimeStamp") == true)
  {
  }
  else if (strEndsWith(parentContext, "lCSRequestTimestamp") == true)
  {
    edrString(DETAIL.ASS_LOCN_EXT.SERVICE_USAGE.LCS_REQ_UTC_OFFSET, 0, 0) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "pDPContextStartTimestamp") == true)
  {
    edrString(DETAIL.ASS_GPRS_EXT.PDP_UTC_TIME_OFFSET, 0) = lastUtcTimeOffset;
  }
  else if (strEndsWith(parentContext, "UtcTimeOffsetInfo") == true)
  {
    lastCode = edrLongEx( myContext, indices, nParentIndices );
  }
                                                                                                             
  //logContext( myContext, nParentIndices );                                                                   
  //logStdout( "Value: " + longToStr(edrLongEx( myContext, indices, nParentIndices )) + "\n");            
}                                                                                                            
                                                                                                             
