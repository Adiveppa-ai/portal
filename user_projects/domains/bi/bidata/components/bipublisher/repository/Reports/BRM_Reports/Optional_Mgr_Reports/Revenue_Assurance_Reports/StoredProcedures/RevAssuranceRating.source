INNER JOIN "PROC_AUD_T" "PROC_AUD_T" ON("CONFIG_RA_CTRL_PT_T"."CP_NAME" = "PROC_AUD_T"."PROCESS_NAME")
 AND("CONFIG_RA_CTRL_PT_T"."OBJ_TYPE" = "PROC_AUD_T"."POID_TYPE"))
INNER JOIN "GDTLS_RSTRM_STYPE_STS_T" "GDTLS_RSTRM_STYPE_STS_T" ON "PROC_AUD_T"."POID_ID0" = "GDTLS_RSTRM_STYPE_STS_T"."OBJ_ID0"
WHERE "CONFIG_RA_FLOWS_T"."FLOW_NAME"= ''' || pFlowType  || '''
 AND "PROC_AUD_T"."PROCESS_NAME"= ''' || pControlPoint || '''
 AND "GDTLS_RSTRM_STYPE_STS_T"."ORIGINAL_BATCH_ID" = ''' || pBatchID || '''
 AND("PROC_AUD_T"."CREATED_T" >= bipext.infStrToTimet(''' || pStartDate || ''', 2)
 AND "PROC_AUD_T"."CREATED_T" <= DECODE((instr( ''' || pEndDate || ''' , '':'', 1, 2)), 0, 
        bipext.INFSTRTOTIMET(''' || pEndDate || ''' , 2)-1, 
