-- all indexes on event tables are local partitioned, there are prefixed and non-prefixed 
--       local indexes
-- global indexes would be too slow in partition maintenance operations

-- when defining a unique index where partitioning key (here it is obj_id0)
-- 	 is not a subset of the index key, one needs to tag obj_id0 to the 
--	 index key to make local partition possible (Oracle8i does not support
--       unique local index that partitioning key is not a subset of 
--	 the index key)

-- /event
-- NOTE: subtables do NOT have rec_id, experience says it is slower.
create unique index i_event__id on event_t ( poid_id0 )
        $PIN_CONF_TBLSPACEX15
        $PIN_CONF_STORAGE_LARGE_INS
        $PIN_CONF_PARTITION_IND ;

create index i_event_bal_impacts__id on event_bal_impacts_t ( obj_id0 )
        $PIN_CONF_TBLSPACEX14
        $PIN_CONF_STORAGE_LARGE_INS
        $PIN_CONF_PARTITION_IND ;

create index i_event_bi_account_obj__id on event_bal_impacts_t
        ( account_obj_id0 )
        $PIN_CONF_TBLSPACEX6
        $PIN_CONF_STORAGE_LARGE_INS
        $PIN_CONF_PARTITION_IND ;

create index i_event_bi_item_obj__id on event_bal_impacts_t
        ( item_obj_id0 )
        $PIN_CONF_TBLSPACEX6
        $PIN_CONF_STORAGE_LARGE_INS
        $PIN_CONF_PARTITION_IND ;

create index i_event_bi_bal_grp__id on event_bal_impacts_t
        ( bal_grp_obj_id0 )
        $PIN_CONF_TBLSPACEX6
        $PIN_CONF_STORAGE_LARGE_INS
        $PIN_CONF_PARTITION_IND ;

-- /event.PIN_FLD_SUB_BAL_IMPACTS
create index i_event_sub_bal_imp__id on event_sub_bal_imp_t ( obj_id0 )
        $PIN_CONF_TBLSPACEX13
        $PIN_CONF_STORAGE_MED_INS
        $PIN_CONF_PARTITION_IND ;

